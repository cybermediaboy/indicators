// --- HELPER FUNCTIONS ---
// V19: f_get_mc_family_from_context() removed - use SetupsLib.f_classify_market_state() instead

f_calculate_te_score(array<float> primary_arr, array<float> ticker_arr, int window, int bins) =>
    CausalityLib.f_calculate_te_score_v2(primary_arr, ticker_arr, window, bins, 1)

f_pack_signed(float value, float scale, int offset, int max_val) =>
    int scaled = int(math.round(value * scale))
    int shifted = scaled + offset
    math.max(0, math.min(shifted, max_val))

// Pseudo-random number generator (0.0 to 1.0)
// FIX Bug #11 (Phase 3): Removed local f_prng - now using MCLib.f_prng(seed1, seed2)
// Deterministic PRNG with no time dependency → reproducible backtests across chart reloads

f_z_and_corr(src_base, src_ext, len) =>
    z_ext = TAUtilityLib.f_zscore(src_ext, len)
    // Use returns-level beta instead of price-level correlation (captures leverage)
    float ret_base = ta.roc(src_base, 1)
    float ret_ext = ta.roc(src_ext, 1)
    // Modern Quant Practice: Numerically stable two-pass covariance calculation
    // Avoids catastrophic cancellation from E[XY] - E[X]E[Y] on small returns
    float mean_base = ta.sma(ret_base, len)
    float mean_ext = ta.sma(ret_ext, len)
    // Two-pass: calculate deviations from means, then covariance
    float dev_base = ret_base - mean_base
    float dev_ext = ret_ext - mean_ext
    float cov_br = ta.sma(dev_base * dev_ext, len)  // Numerically stable covariance
    float var_ext = ta.variance(ret_ext, len)
    float beta_ret = var_ext > 1e-12 ? cov_br / var_ext : 0.0
    beta_ret := math.max(-3.0, math.min(beta_ret, 3.0))  // Soft clamp for stability
    z_ext * beta_ret

var array<float> basis_price_scratch = array.new_float(0)
var array<float> basis_dev_scratch = array.new_float(0)

f_basis_mode_calc(string mode, float src, int len, float vol) =>
    float out_ma = ta.sma(src, len)
    float out_dev = ta.stdev(src, len)
    float out_z = out_dev > 0 ? (src - out_ma) / out_dev : 0.0
    
    if mode == "Median+MAD"
        array.clear(basis_price_scratch)
        for i = 0 to len - 1
            array.push(basis_price_scratch, src[i])
        array.sort(basis_price_scratch, order.ascending)
        int med_idx = int(array.size(basis_price_scratch) / 2)
        out_ma := array.size(basis_price_scratch) > 0 ? array.get(basis_price_scratch, med_idx) : src
        array.clear(basis_dev_scratch)
        for i = 0 to len - 1
            array.push(basis_dev_scratch, math.abs(src[i] - out_ma))
        array.sort(basis_dev_scratch, order.ascending)
        float mad = array.size(basis_dev_scratch) > 0 ? array.get(basis_dev_scratch, med_idx) : 0.0
        out_dev := mad * 1.4826
        out_z := out_dev > 0 ? (src - out_ma) / out_dev : 0.0
    else if mode == "VWMA+VWStDev"
        float vwma = ta.sma(src * vol, len) / ta.sma(vol, len)
        out_ma := vwma
        float vw_variance = ta.sma(vol * math.pow(src - vwma, 2), len) / ta.sma(vol, len)
        out_dev := math.sqrt(math.max(vw_variance, 0.0))
        out_z := out_dev > 0 ? (src - out_ma) / out_dev : 0.0
    
    [out_ma, out_dev, out_z]

f_update_feature_buffers(array<float> h1, array<float> h2, array<float> h3, array<float> h4, array<float> h5, array<float> h6, array<float> h7, float v1, float v2, float v3, float v4, float v5, float v6, float v7, int max_size) =>
    if array.size(h1) >= max_size
        array.shift(h1)
    array.push(h1, v1)
    if array.size(h2) >= max_size
        array.shift(h2)
    array.push(h2, v2)
    if array.size(h3) >= max_size
        array.shift(h3)
    array.push(h3, v3)
    if array.size(h4) >= max_size
        array.shift(h4)
    array.push(h4, v4)
    if array.size(h5) >= max_size
        array.shift(h5)
    array.push(h5, v5)
    if array.size(h6) >= max_size
        array.shift(h6)
    array.push(h6, v6)
    if array.size(h7) >= max_size
        array.shift(h7)
    array.push(h7, v7)

f_cld(float corr_osc, float price, float z_score, float slope_thresh) =>
    float best_signal = 0.0
    float best_confidence = 0.0
    int best_bars = 0
    if cld_enable and bar_index > cld_max_bars * 2 + 10
        for half_len = cld_min_bars to cld_max_bars
            float sum_x1 = 0.0, sum_y1 = 0.0, sum_xy1 = 0.0, sum_x21 = 0.0
            int n1 = half_len
            for i = 0 to half_len - 1
                int bar_back = half_len + (half_len - 1 - i)
                float x = float(i), y = nz(corr_osc[bar_back])
                sum_x1 += x, sum_y1 += y, sum_xy1 += x * y, sum_x21 += x * x
            float denom1 = n1 * sum_x21 - sum_x1 * sum_x1
            float slope1 = denom1 != 0 ? (n1 * sum_xy1 - sum_x1 * sum_y1) / denom1 : 0.0
            float sum_x2 = 0.0, sum_y2 = 0.0, sum_xy2 = 0.0, sum_x22 = 0.0
            int n2 = half_len
            for i = 0 to half_len - 1
                int bar_back = half_len - 1 - i
                float x = float(i), y = nz(corr_osc[bar_back])
                sum_x2 += x, sum_y2 += y, sum_xy2 += x * y, sum_x22 += x * x
            float denom2 = n2 * sum_x22 - sum_x2 * sum_x2
            float slope2 = denom2 != 0 ? (n2 * sum_xy2 - sum_x2 * sum_y2) / denom2 : 0.0
            float price_start = nz(price[2 * half_len - 1]), price_end = price
            float total_move = price_end - price_start
            int agreeing = 0
            int total_bars_check = 2 * half_len - 1
            for i = 0 to total_bars_check - 1
                float bar_move = nz(price[total_bars_check - 1 - i]) - nz(price[total_bars_check - i])
                agreeing += (math.sign(bar_move) == math.sign(total_move)) ? 1 : 0
            float consistency = total_bars_check > 0 ? float(agreeing) / float(total_bars_check) : 0.0
            bool has_direction = consistency >= (cld_price_consist * 0.7) and math.abs(total_move) > 0
            bool has_z_stretch = math.abs(z_score) >= (cld_z_min * 0.5)
            float this_signal = 0.0
            if has_direction and has_z_stretch
                if slope1 < -slope_thresh and slope2 > slope_thresh
                    this_signal := 1.0
                else if slope1 > slope_thresh and slope2 < -slope_thresh
                    this_signal := -1.0
            if this_signal != 0
                float slope_strength = (math.abs(slope1) + math.abs(slope2)) / 2.0
                float slope_conf = math.min(slope_strength / 0.25, 1.0)
                float z_conf = math.min(math.abs(z_score) / 2.0, 1.0)
                float consist_conf = math.max(0, (consistency - cld_price_consist) / (0.85 - cld_price_consist))
                float conf = (slope_conf * 0.35 + z_conf * 0.30 + consist_conf * 0.35)
                if conf > best_confidence
                    best_signal := this_signal, best_confidence := conf, best_bars := 2 * half_len
    [best_signal, best_confidence, best_bars]

