// ═══════════════════════════════════════════════════════════════════════════
// kNN+MC DIAGNOSTIC PLOTS
// ═══════════════════════════════════════════════════════════════════════════

// ═══════════════════════════════════════════════════════════════════════════
// kNN+MC DIAGNOSTIC PLOTS (Moved to global scope, bitencoded)
// ═══════════════════════════════════════════════════════════════════════════

// Bitencode kNN diagnostics into a single data-window plot (no extra plot calls):
// NEW 41-bit layout: confidence(7b) | corr_damping(3b) | family(3b) | packed_vec(28b)
// Formula: (confidence << 34) | (corr_damping_q << 31) | (family << 28) | packed_vec
// Decode: confidence=floor(x/17179869184), damping_q=floor(x%17179869184/2147483648),
//         family=floor(x%2147483648/268435456), packed_vec=x%268435456
// corr_damping quantization: 0→0.00, 1→0.14, 2→0.29, 3→0.43, 4→0.57, 5→0.71, 6→0.86, 7→1.00
bool show_knn_diag_pack = enable_knn
int corr_damping_q = int(math.round(nz(corr_damping, 0.0) * 7.0))  // 3-bit quantized [0-7]
float knn_diag_superpack = show_knn_diag_pack ? (math.round(nz(mc_knn_confidence)) * 17179869184.0) + (corr_damping_q * 2147483648.0) + (mc_family * 268435456.0) + packed_vec : na
//plot(knn_diag_superpack, "kNN Superpack (Conf|Damp|Fam|Vec)", color=color.new(color.yellow, 0), linewidth=1, display=display.data_window)

// ═══════════════════════════════════════════════════════════════════════════
// DIAGNOSTIC LABEL - setupsDB integration debug
// ═══════════════════════════════════════════════════════════════════════════
if barstate.islast
    int bt_size = array.size(bt_setups)
    int triggered_size = array.size(triggered_setups)
    int label_count = array.size(setup_labels)
    int cache_size = array.size(setupsdb_cache)
    
    // Check if any setups were triggered on this bar
    string last_triggered_ids = ""
    if triggered_size > 0
        for i = 0 to math.min(triggered_size - 1, 2)
            SetupsDB.SetupConfig c = array.get(triggered_setups, i)
            last_triggered_ids += c.id + (i < math.min(triggered_size - 1, 2) ? "," : "")
    
    // Diagnostic label (inside barstate.islast to access local variables)
    if show_setupsdb_diag
        // Show current entry context (must match thresholds at line 3236)
        int current_entry_ctx = z0 < -0.5 ? 1000 : z0 > 0.5 ? 1200 : 1100
        
        string diag_text = "setupsDB Diagnostic:\n" + 
                           "triggered: " + str.tostring(triggered_size) + " | cache: " + str.tostring(cache_size) + "\n" +
                           "bt_setups.size: " + str.tostring(bt_size) + " | labels: " + str.tostring(label_count) + "\n" +
                           "IDs: " + (triggered_size > 0 ? last_triggered_ids : "none") + "\n" +
                           "entryCtx: " + str.tostring(current_entry_ctx) + " (z0=" + str.tostring(z0, "#.##") + ")\n" +
                           "basket_latched: " + str.tostring(basket_latched) + " | peers: " + str.tostring(peer_count_active, "#") + " | stable: " + str.tostring(basket_stable) + "\n" +
                           "basket_vec_z: " + str.tostring(basket_vec_z, "#.##") + " | basket_fit: " + str.tostring(basket_fit, "#.#") + "\n" +
                           "te_osc: " + str.tostring(te_osc, "#.##") + " | mr: " + str.tostring(mr_for_setups, "#.##") + "\n" +
                           "f7_burst: " + str.tostring(f7_burst_raw, "#.##") + " | allow_s/l: " + str.tostring(allow_short) + "/" + str.tostring(allow_long) + "\n" +
                           "lastShort: " + str.tostring(last_pred_short_bar) + " | lastLong: " + str.tostring(last_pred_long_bar) + " | lastTrig: " + str.tostring(last_setup_trigger_bar)
        label.new(bar_index, high * 1.02, diag_text, color=color.new(color.blue, 80), 
                  textcolor=color.black, style=label.style_label_down, size=size.normal)

