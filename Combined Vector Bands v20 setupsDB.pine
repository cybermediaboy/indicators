if basket_preset == "Auto Scan"
    [s1, s2, s3, s4, s5_unused, use_sym5_unused, sc1, sc2, sc3, sc4, idx1, idx2, idx3, idx4, mode_lbl, new_latched] = BasketLib.f_process_auto_scan(scan_scores, scan_symbols, basket_scan_ready, basket_latched, basket_rescan_due, fallback_sym1, fallback_sym2, fallback_sym3, fallback_sym4, "", false, scan_idx_1, scan_idx_2, scan_idx_3, scan_idx_4)
    sym1 := s1
    sym2 := s2
    sym3 := s3
    sym4 := s4
    auto_score_1 := sc1
    auto_score_2 := sc2
    auto_score_3 := sc3
    auto_score_4 := sc4
    scan_idx_1 := idx1
    scan_idx_2 := idx2
    scan_idx_3 := idx3
    scan_idx_4 := idx4
    basket_mode_label := mode_lbl
    basket_latched := new_latched

if basket_preset == "Auto Scan" and basket_rescan_due
    basket_last_rescan_bar := bar_index

// Integer index routing function (compile-time safe)
f_route_scan_idx(int idx) =>
    idx == 0 ? sc01 : idx == 1 ? sc02 : idx == 2 ? sc03 : idx == 3 ? sc04 : idx == 4 ? sc05 : idx == 5 ? sc06 : idx == 6 ? sc07 : idx == 7 ? sc08 : idx == 8 ? sc09 : idx == 9 ? sc10 : na

c1 = basket_preset == "Auto Scan" ? f_route_scan_idx(scan_idx_1) : request.security(sym1, timeframe.period, close)
c2 = basket_preset == "Auto Scan" ? f_route_scan_idx(scan_idx_2) : request.security(sym2, timeframe.period, close)
c3 = basket_preset == "Auto Scan" ? f_route_scan_idx(scan_idx_3) : request.security(sym3, timeframe.period, close)
c4 = basket_preset == "Auto Scan" ? f_route_scan_idx(scan_idx_4) : request.security(sym4, timeframe.period, close)
// REMOVED: c5 (5th asset not needed)

// Define Returns
r0_raw = ta.roc(c0, 1)
r1_raw = ta.roc(c1, 1)
r2_raw = ta.roc(c2, 1)
r3_raw = ta.roc(c3, 1)
r4_raw = ta.roc(c4, 1)
// REMOVED: r5_raw

// Standardize returns for entropy discretization
int te_z_len = 50
r0 = r0_raw / math.max(ta.stdev(r0_raw, te_z_len), syminfo.mintick)
r1 = r1_raw / math.max(ta.stdev(r1_raw, te_z_len), syminfo.mintick)
r2 = r2_raw / math.max(ta.stdev(r2_raw, te_z_len), syminfo.mintick)
r3 = r3_raw / math.max(ta.stdev(r3_raw, te_z_len), syminfo.mintick)
r4 = r4_raw / math.max(ta.stdev(r4_raw, te_z_len), syminfo.mintick)
// REMOVED: r5

int te_max_size = te_window + 20
var te_primary_returns = array.new_float()
var te_basket_returns_1 = array.new_float()
var te_basket_returns_2 = array.new_float()
var te_basket_returns_3 = array.new_float()
var te_basket_returns_4 = array.new_float()
var te_basket_returns_5 = array.new_float()

// --- CALCULATIONS ---

// 1. Base Asset Stats
float ma0 = ta.sma(c0, basis_len)
float dev0 = ta.stdev(c0, basis_len)
float z0 = TAUtilityLib.f_zscore(c0, basis_len)
float vert_dev0 = dev0
float denom0 = 1.0

// Per-bar volatility for MC simulation (true single-bar price change StDev)
float per_bar_vol = ta.stdev(close - close[1], basis_len)

// Advanced Basis Modes
if basis_mode != "SMA+StDev"
    [ma0_calc, dev0_calc, z0_calc] = f_basis_mode_calc(basis_mode, c0, basis_len, volume)
    ma0 := ma0_calc
    dev0 := dev0_calc
    z0 := z0_calc
    vert_dev0 := dev0
    denom0 := 1.0

// 2. External Asset Vectors (PVB-style)
v1 = f_z_and_corr(c0, c1, len_z)
v2 = f_z_and_corr(c0, c2, len_z)
v3 = f_z_and_corr(c0, c3, len_z)
v4 = f_z_and_corr(c0, c4, len_z)
// REMOVED: v5

bool is_self1 = str.contains(str.upper(sym1), str.upper(current_base))
bool is_self2 = str.contains(str.upper(sym2), str.upper(current_base))
bool is_self3 = str.contains(str.upper(sym3), str.upper(current_base))
bool is_self4 = str.contains(str.upper(sym4), str.upper(current_base))
// REMOVED: is_self5

// Simple average basket vector (PVB uses 3 assets, we use 4-5)
// Exclude self-references from the average
float v_sum = (is_self1 ? 0.0 : v1) + (is_self2 ? 0.0 : v2) + (is_self3 ? 0.0 : v3) + (is_self4 ? 0.0 : v4)
float peer_count_active = (is_self1 ? 0.0 : 1.0) + (is_self2 ? 0.0 : 1.0) + (is_self3 ? 0.0 : 1.0) + (is_self4 ? 0.0 : 1.0)
basket_vec_z_raw = peer_count_active > 0 ? v_sum / peer_count_active : 0.0

// Peer z-scores — wrapped in function (saves 8 vars: ma1-4, dev1-4)
f_calc_peer_zscores(float _c1, float _c2, float _c3, float _c4, int _len) =>
    float _m1 = ta.sma(_c1, _len), float _d1 = ta.stdev(_c1, _len)
    float _m2 = ta.sma(_c2, _len), float _d2 = ta.stdev(_c2, _len)
    float _m3 = ta.sma(_c3, _len), float _d3 = ta.stdev(_c3, _len)
    float _m4 = ta.sma(_c4, _len), float _d4 = ta.stdev(_c4, _len)
    [_d1 == 0 ? 0.0 : (_c1 - _m1) / _d1, _d2 == 0 ? 0.0 : (_c2 - _m2) / _d2,
     _d3 == 0 ? 0.0 : (_c3 - _m3) / _d3, _d4 == 0 ? 0.0 : (_c4 - _m4) / _d4]

[z1_raw, z2_raw, z3_raw, z4_raw] = f_calc_peer_zscores(c1, c2, c3, c4, len_z)

TAUtilityLib.f_push_limited(te_primary_returns, r0, te_max_size)
TAUtilityLib.f_push_limited(te_basket_returns_1, r1, te_max_size)
TAUtilityLib.f_push_limited(te_basket_returns_2, r2, te_max_size)
TAUtilityLib.f_push_limited(te_basket_returns_3, r3, te_max_size)
TAUtilityLib.f_push_limited(te_basket_returns_4, r4, te_max_size)
// REMOVED: te_basket_returns_5 push

// ══════════════════════════════════════════════════════════════
// TRANSFER ENTROPY — OPTIMIZED EXECUTION
// ══════════════════════════════════════════════════════════════

// Schedule logic
int bars_from_end = last_bar_index - bar_index
bool is_hard_zone = bars_from_end < max_heavy_bars
bool te_warmed_up = bar_index > te_window + 5

// TE calculation via CausalityLib wrapper (saves ~20 vars through library scope)
[te_osc, te_strength_smoothed, te_direction_smoothed] = CausalityLib.f_compute_te_wrapper(te_primary_returns, te_basket_returns_1, te_basket_returns_2, te_basket_returns_3, te_basket_returns_4, te_window, te_bins, te_force_smoothing, is_self1, is_self2, is_self3, is_self4, is_hard_zone, bar_index)

// @function Build TE debug diagnostic string (moved to function to reduce #main bytecode)
// @param te_dbg Raw TE score
// @param te_dbg_dir TE direction
// @param te_osc Smoothed TE oscillator
// @param te_strength_smoothed TE strength
// @param te_direction_smoothed TE direction smoothed
// @returns Formatted debug string
f_build_te_debug_string(float te_dbg, float te_dbg_dir, float te_osc_val, float te_strength, float te_direction, int te_dbg_win, int te_dbg_valid, float te_dbg_min_x, float te_dbg_max_x, float te_dbg_min_y, float te_dbg_max_y, float te_dbg_b0, float te_dbg_b1, float te_dbg_b2, float te_dbg_b3, float te_dbg_b4, float te_dbg_b5, float te_dbg_b6, float te_dbg_b7) =>
    string result = "TE Debug (lag=1)\n"
    result += "te_osc=" + str.tostring(te_dbg, "#.###") + " dir=" + str.tostring(te_dbg_dir, "#.###") + "\n"
    result += "ensemble_final=" + str.tostring(te_osc_val, "#.###") + " strength=" + str.tostring(te_strength, "#.###") + " direction=" + str.tostring(te_direction, "#.###") + "\n"
    result += "arr_primary=" + str.tostring(array.size(te_primary_returns)) + " arr_basket1=" + str.tostring(array.size(te_basket_returns_1)) + "\n"
    result += "te_warmed_up=" + str.tostring(te_warmed_up) + " is_hard_zone=" + str.tostring(is_hard_zone) + "\n"
    result += "win_size=" + str.tostring(te_dbg_win) + " valid_count=" + str.tostring(te_dbg_valid) + " required=" + str.tostring(te_window + 5) + "\n"
    result += "r0=" + str.tostring(r0, "#.###") + " r1=" + str.tostring(r1, "#.###") + " r2=" + str.tostring(r2, "#.###") + " r3=" + str.tostring(r3, "#.###") + " r4=" + str.tostring(r4, "#.###") + "\n"
    result += "x[min,max]=" + str.tostring(te_dbg_min_x, "#.####") + "," + str.tostring(te_dbg_max_x, "#.####") + "\n"
    result += "y[min,max]=" + str.tostring(te_dbg_min_y, "#.####") + "," + str.tostring(te_dbg_max_y, "#.####") + "\n"
    result += "bins=" + str.tostring(te_dbg_b0, "#.##") + "," + str.tostring(te_dbg_b1, "#.##") + "," + str.tostring(te_dbg_b2, "#.##") + "," + str.tostring(te_dbg_b3, "#.##") + "," + str.tostring(te_dbg_b4, "#.##") + "," + str.tostring(te_dbg_b5, "#.##") + "," + str.tostring(te_dbg_b6, "#.##") + "," + str.tostring(te_dbg_b7, "#.##")
    result

// Debug: TE diagnostics on last bar (only when debug enabled)
// Note: Uses raw barstate check because execution context flags defined later
if barstate.islast and show_te_debug
    [te_dbg, te_dbg_dir, te_dbg_win, te_dbg_valid, te_dbg_min_x, te_dbg_max_x, te_dbg_min_y, te_dbg_max_y, te_dbg_b0, te_dbg_b1, te_dbg_b2, te_dbg_b3, te_dbg_b4, te_dbg_b5, te_dbg_b6, te_dbg_b7] = CausalityLib.f_calculate_te_score_debug(te_primary_returns, te_basket_returns_1, te_window, te_bins, 1)
    string te_dbg_text = f_build_te_debug_string(te_dbg, te_dbg_dir, te_osc, te_strength_smoothed, te_direction_smoothed, te_dbg_win, te_dbg_valid, te_dbg_min_x, te_dbg_max_x, te_dbg_min_y, te_dbg_max_y, te_dbg_b0, te_dbg_b1, te_dbg_b2, te_dbg_b3, te_dbg_b4, te_dbg_b5, te_dbg_b6, te_dbg_b7)
    label.new(bar_index, high, te_dbg_text, color=color.new(color.yellow, 0), textcolor=color.black, style=label.style_label_down, size=size.small, force_overlay=true)

// Calculate Simple Validation Basket (Linear Average of Peers)
// Used strictly for Correlation Filter to avoid "Double Weighting"
// Exclude self-references from the average

// Declare basket variables
var float simple_basket_z = na
var float simple_basket_return = na
var float simple_basket_avg = na

// Calculate per-peer correlations for weighting (nz-protected for warmup)
float rho1 = is_self1 ? 0.0 : nz(ta.correlation(r0, r1, 50), 0.0)
float rho2 = is_self2 ? 0.0 : nz(ta.correlation(r0, r2, 50), 0.0)
float rho3 = is_self3 ? 0.0 : nz(ta.correlation(r0, r3, 50), 0.0)
float rho4 = is_self4 ? 0.0 : nz(ta.correlation(r0, r4, 50), 0.0)

// Modern Quant Practice: Continuous correlation weighting instead of violent sign flipping
// As rho → 0, assets naturally phase out without ±1 derivative shock
float z_sum = (is_self1 ? 0.0 : rho1 * z1_raw) + (is_self2 ? 0.0 : rho2 * z2_raw) + (is_self3 ? 0.0 : rho3 * z3_raw) + (is_self4 ? 0.0 : rho4 * z4_raw)
float r_sum = (is_self1 ? 0.0 : rho1 * r1) + (is_self2 ? 0.0 : rho2 * r2) + (is_self3 ? 0.0 : rho3 * r3) + (is_self4 ? 0.0 : rho4 * r4)
simple_basket_z := peer_count_active > 0 ? z_sum / peer_count_active : na
simple_basket_return := peer_count_active > 0 ? r_sum / peer_count_active : na

// Create simple_basket_avg for compatibility with existing code
simple_basket_avg := simple_basket_return

// Endogenous foam suppression — wrapped in function (saves 12 vars from global scope)
f_calc_clean_dev(float _r0, float _bret, float _vdev0, int _len) =>
    float _brm = ta.sma(_bret, 50)
    float _r0m = ta.sma(_r0, 50)
    float _var = ta.variance(_bret, 50)
    float _beta = _var > 1e-10 ? ta.sma((_r0 - _r0m) * (_bret - _brm), 50) / _var : 0.0
    float _res = _r0 - _beta * _bret
    float _std = ta.stdev(_res, 100)
    float _z   = _std > 1e-10 ? _res / _std : 0.0
    float _exc = math.abs(_z) > 1.5 ? math.sign(_z) * (math.abs(_z) - 1.5) * _std : 0.0
    math.max(math.min(_vdev0, ta.stdev(_r0 - _exc, _len)), syminfo.mintick)

float vert_dev0_clean = f_calc_clean_dev(r0, simple_basket_return, vert_dev0, basis_len)

// ══════════════════════════════════════════════════════════════
// V13: 3-LEVEL MR ORTHOGONALIZATION
// Removes double-counting from correlated basket peers
// ══════════════════════════════════════════════════════════════

// LEVEL 1+2: Pairwise spread inlined into EMA accumulators (saves sp1-4 + lam = 5 vars)
var float a1 = 0.0, var float a2 = 0.0
var float a3 = 0.0, var float a4 = 0.0
a1 := a1 * 0.80 + nz((z0 - rho1 * z1_raw) * math.abs(rho1), 0.0) * 0.20
a2 := a2 * 0.80 + nz((z0 - rho2 * z2_raw) * math.abs(rho2), 0.0) * 0.20
a3 := a3 * 0.80 + nz((z0 - rho3 * z3_raw) * math.abs(rho3), 0.0) * 0.20
a4 := a4 * 0.80 + nz((z0 - rho4 * z4_raw) * math.abs(rho4), 0.0) * 0.20

// LEVEL 3: Gram-Schmidt Orthogonalization — wrapped in function (saves 34 vars from global scope)
f_gram_schmidt_orth(float _a1, float _a2, float _a3, float _a4, bool _s1, bool _s2, bool _s3, bool _s4) =>
    float _m1  = ta.sma(_a1, 50)
    float _v1  = ta.variance(_a1, 50)
    float _m2  = ta.sma(_a2, 50)
    float _b12 = _v1 > 1e-10 ? ta.sma((_a1 - _m1) * (_a2 - _m2), 50) / _v1 : 0.0
    float _m3  = ta.sma(_a3, 50)
    float _b13 = _v1 > 1e-10 ? ta.sma((_a1 - _m1) * (_a3 - _m3), 50) / _v1 : 0.0
    float _m4  = ta.sma(_a4, 50)
    float _b14 = _v1 > 1e-10 ? ta.sma((_a1 - _m1) * (_a4 - _m4), 50) / _v1 : 0.0
    float _a2r = _a2 - _b12 * _a1
    float _a3r = _a3 - _b13 * _a1
    float _a4r = _a4 - _b14 * _a1
    float _m2r = ta.sma(_a2r, 50)
    float _v2r = ta.variance(_a2r, 50)
    float _m3r = ta.sma(_a3r, 50)
    float _b23 = _v2r > 1e-10 ? ta.sma((_a2r - _m2r) * (_a3r - _m3r), 50) / _v2r : 0.0
    float _m4r = ta.sma(_a4r, 50)
    float _b24 = _v2r > 1e-10 ? ta.sma((_a2r - _m2r) * (_a4r - _m4r), 50) / _v2r : 0.0
    float _a3r2 = _a3r - _b23 * _a2r
    float _a4r2 = _a4r - _b24 * _a2r
    float _v3r  = ta.variance(_a3r2, 50)
    float _m3r2 = ta.sma(_a3r2, 50)
    float _m4r2 = ta.sma(_a4r2, 50)
    float _b34  = _v3r > 1e-10 ? ta.sma((_a3r2 - _m3r2) * (_a4r2 - _m4r2), 50) / _v3r : 0.0
    float _o4   = _a4r2 - _b34 * _a3r2
    float _o1c  = math.max(-3.0, math.min(_a1,   3.0))
    float _o2c  = math.max(-3.0, math.min(_a2r,  3.0))
    float _o3c  = math.max(-3.0, math.min(_a3r2, 3.0))
    float _o4c  = math.max(-3.0, math.min(_o4,   3.0))
    float _ap   = (_s1 ? 0.0 : 1.0) + (_s2 ? 0.0 : 1.0) + (_s3 ? 0.0 : 1.0) + (_s4 ? 0.0 : 1.0)
    _ap > 0.0 ? (_o1c + _o2c + _o3c + _o4c) / _ap : 0.0

float PhiTotal_orth = f_gram_schmidt_orth(a1, a2, a3, a4, is_self1, is_self2, is_self3, is_self4)

// LEVEL 4: Raw Aggregate (no correlation normalization for stronger amplitude)
// Use raw sum instead of weighted average for maximum MR signal strength

// --- CORRELATION FILTER (DECOUPLING) ---
// V8 IMPROVEMENT: Use proper State-Space Kalman Beta tracking (modern quant practice)
// Z-Score correlation measures structural cointegration (regime shifts)
// HTF Kalman Beta tracker (replaces flawed single-bar covariance)
var float htf_kalman_beta = 1.0
var float htf_kalman_p = 1.0
float htf_q = 0.01    // process noise — how fast beta can change
float htf_r = 0.1     // measurement noise — observation equation uncertainty

// Calculate returns for State-Space model
float asset_return = ta.change(math.log(close))
float basket_return = ta.change(math.log(simple_basket_avg))

// Declare rho outside conditional blocks
float rho = na

// Skip if basket return is too small (division by zero protection)
if math.abs(basket_return) > 1e-8
    // Kalman predict step
    float beta_pred = htf_kalman_beta
    float p_pred = htf_kalman_p + htf_q
    
    // Observation equation: y_t = beta * x_t + epsilon
    // Measurement innovation: asset_return - beta_pred * basket_return
    float innov = asset_return - beta_pred * basket_return
    
    // Kalman update equations
    float S = p_pred * basket_return * basket_return + htf_r  // Innovation covariance
    float K = p_pred * basket_return / S                     // Kalman gain
    
    // Update state and covariance
    htf_kalman_beta := beta_pred + K * innov
    htf_kalman_p := (1.0 - K * basket_return) * p_pred
    
    // Convert Beta to Correlation: ρ = β * (σ_x / σ_y)
    // Use recent volatilities as proxy for sigma ratio
    float sigma_x = math.max(ta.stdev(basket_return, 50), 1e-8)
    float sigma_y = math.max(ta.stdev(asset_return, 50), 1e-8)
    rho := math.max(-1.0, math.min(htf_kalman_beta * (sigma_x / sigma_y), 1.0))
else
    rho := htf_kalman_beta  // Use previous estimate if basket_return too small

float rho_returns = na  // Raw returns correlation for velocity coupling
float rho_z = rho        // Z-score correlation for regime detection

// For backward compatibility, calculate traditional correlations when needed
if use_corr_filter and not na(simple_basket_z)
    if corr_source_type == "Z-Score"
        rho_z := ta.correlation(z0, simple_basket_z, corr_len)
    else if corr_source_type == "Returns"
        // V8: Use RAW log returns (no EMA smoothing) for lag-free coupling detection
        rho_returns := ta.correlation(r0, simple_basket_return, corr_len)
    else // Price
        // Correlation of Price vs Z-score basket is tricky, defaulting to Z-space for robustness
        rho_z := ta.correlation(z0, simple_basket_z, corr_len)
    
    // Always calculate both for regime shift detection
    if na(rho_returns)
        rho_returns := ta.correlation(r0, simple_basket_return, corr_len)
    if na(rho_z)
        rho_z := ta.correlation(z0, simple_basket_z, corr_len)

// --- CORRELATION FILTER (SOFT DAMPENING) ---
float corr_damping = 1.0
if use_corr_filter and not na(rho)
    // Modern Quant Practice: Apply Fisher transform to rho before sigmoid
    // Fisher transform: z = 0.5 * ln((1+ρ)/(1-ρ)) normalizes correlation distribution
    float rho_clamped = math.max(-0.99, math.min(rho, 0.99))  // Avoid log(0)
    float fisher_rho = 0.5 * math.log((1.0 + rho_clamped) / (1.0 - rho_clamped))
    // Apply sigmoid to Fisher-transformed correlation for better statistical properties
    corr_damping := TAUtilityLib.f_sigmoid_norm(math.abs(fisher_rho) - corr_thresh, 5.0)
else if use_corr_filter and na(rho)
    corr_damping := 0.5  // Unknown -> Half trust

// Apply Soft Dampening
basket_vec_z = basket_vec_z_raw * corr_damping

// Percentile-based Decoupling Detection
// Track correlation damping history for percentile calculation
var corr_damp_history = array.new<float>()
var array<float> corr_damp_sorted = array.new<float>(0)
var int corr_damp_recalc_counter = 0
var float corr_damp_p20 = 0.2  // 20th percentile (decoupled threshold)
var float corr_damp_p80 = 0.8  // 80th percentile (attached threshold)

// Store current corr_damping value
array.push(corr_damp_history, corr_damping)
if array.size(corr_damp_history) > 1000
    array.shift(corr_damp_history)

// Recalculate percentiles every 100 bars
corr_damp_recalc_counter := corr_damp_recalc_counter + 1
if corr_damp_recalc_counter >= 100 or na(corr_damp_p20)
    corr_damp_recalc_counter := 0
    if array.size(corr_damp_history) >= 100
        array.clear(corr_damp_sorted)
        for i = 0 to array.size(corr_damp_history) - 1
            array.push(corr_damp_sorted, array.get(corr_damp_history, i))
        array.sort(corr_damp_sorted, order.ascending)
        int damp_size = array.size(corr_damp_sorted)
        int p20_idx = math.round(damp_size * 0.20)
        int p80_idx = math.round(damp_size * 0.80)
        corr_damp_p20 := array.get(corr_damp_sorted, math.max(0, math.min(p20_idx, damp_size - 1)))
        corr_damp_p80 := array.get(corr_damp_sorted, math.max(0, math.min(p80_idx, damp_size - 1)))

// Status for Visualization (percentile-based)
bool is_decoupled = corr_damping < corr_damp_p20
bool is_partial = corr_damping >= corr_damp_p20 and corr_damping < corr_damp_p80
bool is_attached = corr_damping >= corr_damp_p80

// --- LTF CORRELATION TRACKING (ZG MAGNET STYLE) ---
string ltf_timeframe = ltf_manual_tf
if ltf_mode == "Auto (1/3 to 1/8 of Chart TF)"
    int chart_tf_mins = timeframe.in_seconds() / 60
    int target_ltf_mins = math.max(1, math.round(chart_tf_mins / 5.0))
    if target_ltf_mins <= 1
        ltf_timeframe := "1"
    else if target_ltf_mins <= 3
        ltf_timeframe := "3"
    else if target_ltf_mins <= 5
        ltf_timeframe := "5"
    else if target_ltf_mins <= 15
        ltf_timeframe := "15"
    else if target_ltf_mins <= 30
        ltf_timeframe := "30"
    else
        ltf_timeframe := "60"

bool ltf_calc_active = ltf_enabled

array<float> ltf_pri_close  = ltf_calc_active ? request.security_lower_tf(syminfo.tickerid, ltf_timeframe, close)  : array.new<float>(0)
array<float> ltf_pri_volume = ltf_calc_active ? request.security_lower_tf(syminfo.tickerid, ltf_timeframe, volume) : array.new<float>(0)
array<float> ltf_sym1_close = ltf_calc_active ? request.security_lower_tf(sym1, ltf_timeframe, close) : array.new<float>(0)
array<float> ltf_sym2_close = ltf_calc_active ? request.security_lower_tf(sym2, ltf_timeframe, close) : array.new<float>(0)
array<float> ltf_sym3_close = ltf_calc_active ? request.security_lower_tf(sym3, ltf_timeframe, close) : array.new<float>(0)
array<float> ltf_sym4_close = ltf_calc_active ? request.security_lower_tf(sym4, ltf_timeframe, close) : array.new<float>(0)

array<float> ltf_bas_close = array.new<float>(0)
if ltf_calc_active and array.size(ltf_sym1_close) > 0 and array.size(ltf_sym2_close) > 0 and array.size(ltf_sym3_close) > 0 and array.size(ltf_sym4_close) > 0
    int basket_size = math.min(array.size(ltf_sym1_close), math.min(array.size(ltf_sym2_close), math.min(array.size(ltf_sym3_close), array.size(ltf_sym4_close))))
    ltf_bas_close := array.new<float>(basket_size)
    for i = 0 to basket_size - 1
        array.set(ltf_bas_close, i, (array.get(ltf_sym1_close, i) + array.get(ltf_sym2_close, i) + array.get(ltf_sym3_close, i) + array.get(ltf_sym4_close, i)) / 4.0)

float current_intrabar_vwap = na
if ltf_calc_active and array.size(ltf_pri_close) > 0 and array.size(ltf_pri_volume) > 0
    float sum_cv = 0.0
    float sum_v  = 0.0
    int vwap_n = math.min(array.size(ltf_pri_close), array.size(ltf_pri_volume))
    for i = 0 to vwap_n - 1
        sum_cv += array.get(ltf_pri_close, i) * array.get(ltf_pri_volume, i)
        sum_v  += array.get(ltf_pri_volume, i)
    if sum_v > 0
        current_intrabar_vwap := sum_cv / sum_v

var vwap_history = array.new<float>()
if barstate.isnew
    array.push(vwap_history, current_intrabar_vwap)
    if array.size(vwap_history) > kb_pivot_len + 20
        array.shift(vwap_history)

// ===== LTF KALMAN CORRELATION TRACKER =====
// FIX 1: init beta to 0.0 (correlation domain [-1,+1], not beta domain)
// FIX 2: measurement uses properly normalised Pearson rho on LTF return pairs
// FIX 3: ltf_ema_smooth is now applied
var float ltf_kalman_beta = 0.0   // FIX 1: was 1.0 → mismatched domain caused ~200-bar drag
var float ltf_kalman_P    = 1.0
var float ltf_prev_pri    = na
var float ltf_prev_bas    = na
float ltf_kalman_Q = 0.015
float ltf_kalman_R = 0.15
var int ltf_kalman_bar_count = 0

if ltf_calc_active
    ltf_kalman_bar_count := ltf_kalman_bar_count + 1

float ltf_corr_raw = na
if ltf_calc_active and array.size(ltf_pri_close) > 1 and array.size(ltf_bas_close) > 1
    int pri_last = array.size(ltf_pri_close) - 1
    int bas_last = array.size(ltf_bas_close) - 1
    float pri_price = array.get(ltf_pri_close, pri_last)
    float bas_price = array.get(ltf_bas_close, bas_last)

    if not na(ltf_prev_pri) and not na(ltf_prev_bas) and ltf_prev_pri > 0 and ltf_prev_bas > 0
        float y_t = math.log(pri_price / ltf_prev_pri)
        float x_t = math.log(bas_price / ltf_prev_bas)

        if math.abs(x_t) > 1e-8
            // FIX 2: compute proper Pearson rho from recent LTF return pairs
            // Normalize by rolling stdev product — not an arbitrary constant
            int corr_win = math.min(20, math.min(pri_last, bas_last))
            float measurement = ltf_kalman_beta  // fallback

            if ltf_kalman_bar_count > 10 and corr_win >= 3
                float sum_xy = 0.0, float sum_xx = 0.0, float sum_yy = 0.0
                int valid = 0
                for i = 1 to corr_win - 1
                    if pri_last >= i and bas_last >= i
                        float ry = math.log(array.get(ltf_pri_close, pri_last - i + 1) / array.get(ltf_pri_close, pri_last - i))
                        float rx = math.log(array.get(ltf_bas_close, bas_last - i + 1) / array.get(ltf_bas_close, bas_last - i))
                        if math.abs(ry) > 1e-10 and math.abs(rx) > 1e-10
                            sum_xy += ry * rx
                            sum_xx += rx * rx
                            sum_yy += ry * ry
                            valid  += 1
                if valid >= 3
                    float denom_rho = math.sqrt(sum_xx * sum_yy)
                    measurement := denom_rho > 1e-10 ? math.max(-1.0, math.min(sum_xy / denom_rho, 1.0)) : ltf_kalman_beta

            // Kalman update
            float P_pred  = ltf_kalman_P + ltf_kalman_Q
            float innov   = measurement - ltf_kalman_beta
            float S       = P_pred + ltf_kalman_R
            float K       = P_pred / S
            ltf_kalman_beta := math.max(-1.0, math.min(ltf_kalman_beta + K * innov, 1.0))
            ltf_kalman_P    := (1.0 - K) * P_pred
            ltf_corr_raw    := ltf_kalman_beta
        else
            ltf_corr_raw := ltf_kalman_beta
    ltf_prev_pri := pri_price
    ltf_prev_bas := bas_price

// FIX 3: apply ltf_ema_smooth (was hardwired bypass)
var float ltf_corr_ema = na
if not na(ltf_corr_raw)
    ltf_corr_ema := na(ltf_corr_ema) ? ltf_corr_raw : ltf_corr_ema + (2.0 / (ltf_ema_smooth + 1)) * (ltf_corr_raw - ltf_corr_ema)

// FIX 6: parenthesise ternary to avoid operator-precedence ambiguity
int _ltf_z_len = 2 * ltf_corr_len
var int ltf_z_warmup = 0
if not na(ltf_corr_ema)
    ltf_z_warmup := ltf_z_warmup + 1
float ltf_rho_mean  = ta.sma(ltf_corr_ema, _ltf_z_len)
float ltf_rho_stdev = ta.stdev(ltf_corr_ema, _ltf_z_len)
float ltf_rho_z = (ltf_z_warmup >= _ltf_z_len and ltf_rho_stdev > 1e-6) ? (ltf_corr_ema - ltf_rho_mean) / ltf_rho_stdev : 0.0

// LTF Decoupling/Recoupling Detection
var bool ltf_is_decoupled = false
var int ltf_last_decouple_bar = 0
var int ltf_last_recouple_bar = 0

bool ltf_decouple_event = false
bool ltf_recouple_event = false

if ltf_enabled and not na(ltf_corr_ema)
    // Detect decoupling (absolute correlation drops below threshold)
    // Use absolute value to handle inverse peers properly
    if not ltf_is_decoupled and math.abs(ltf_corr_ema) < ltf_decouple_thresh
        ltf_is_decoupled := true
        ltf_decouple_event := true
        ltf_last_decouple_bar := bar_index
    
    // Detect recoupling (absolute correlation rises above threshold)
    if ltf_is_decoupled and math.abs(ltf_corr_ema) > ltf_recouple_thresh
        ltf_is_decoupled := false
        ltf_recouple_event := true
        ltf_last_recouple_bar := bar_index

// --- BASKET FIT (RETURN CORRELATION) ---
float fit_rho = not na(simple_basket_return) ? ta.correlation(r0, simple_basket_return, fit_eval_len) : na
float basket_fit = nz(fit_rho, 0.0) * 100.0

string fit_label = math.abs(basket_fit) > 40 ? "Strong" :(math.abs(basket_fit) > 25 ? "Moderate" :(math.abs(basket_fit) > 10 ? "Weak" : "None"))
color fit_color = basket_fit > 40 ? color.lime :(basket_fit > 25 ? color.green :(basket_fit > 10 ? color.yellow : color.red))

// Basket Fit Percentile Tracking (for FV line opacity normalization)
// Calculate percentiles ONCE based on 3000 bars of history
var basket_fit_history = array.new<float>()
var array<float> basket_fit_sorted = array.new<float>(0)
var float basket_fit_p20 = 10.0  // 20th percentile (weak coupling)
var float basket_fit_p80 = 40.0  // 80th percentile (strong coupling)
var bool percentiles_calculated = false

// Store current basket_fit value if we haven't calculated percentiles yet
// Collect up to 3000 bars of history
if not percentiles_calculated and not na(basket_fit)
    array.push(basket_fit_history, basket_fit)
    
    // Once we hit 3000 bars (or on the last historical bar if less than 3000), calculate and freeze
    // Note: Uses raw barstate check because execution context flags defined later
    if array.size(basket_fit_history) >= 3000 or barstate.islastconfirmedhistory
        array.clear(basket_fit_sorted)
        for i = 0 to array.size(basket_fit_history) - 1
            array.push(basket_fit_sorted, array.get(basket_fit_history, i))
        array.sort(basket_fit_sorted, order.ascending)
        int fit_size = array.size(basket_fit_sorted)
        
        if fit_size > 0
            int p20_idx = math.round(fit_size * 0.20)
            int p80_idx = math.round(fit_size * 0.80)
            basket_fit_p20 := array.get(basket_fit_sorted, math.max(0, math.min(p20_idx, fit_size - 1)))
            basket_fit_p80 := array.get(basket_fit_sorted, math.max(0, math.min(p80_idx, fit_size - 1)))
        
        percentiles_calculated := true

// Normalize current basket_fit to 0-1 range using the frozen percentiles
// This accounts for different baseline correlation levels across asset-basket combinations
float basket_fit_normalized = 0.5  // Default fallback
if basket_fit_p80 > basket_fit_p20 and not na(basket_fit)
    basket_fit_normalized := (basket_fit - basket_fit_p20) / (basket_fit_p80 - basket_fit_p20)
    basket_fit_normalized := math.max(0.0, math.min(basket_fit_normalized, 1.0))

// Coupling quality from running mean returns correlation
float avg_rho = ta.sma(nz(rho_returns, 0.0), 30)
// DEBUG: Clamp to valid correlation range to prevent Fisher transform display
avg_rho := math.max(-1.0, math.min(avg_rho, 1.0))
float coupling_r2 = math.max(0.0, math.min(100.0, avg_rho * avg_rho * 100.0))
string coupling_q_label = math.abs(avg_rho) > 0.50 ? "Strong" : math.abs(avg_rho) > 0.30 ? "Mod" : math.abs(avg_rho) > 0.16 ? "Weak" : "None"
color coupling_q_color = avg_rho > 0.50 ? color.lime : avg_rho > 0.30 ? color.green : avg_rho > 0.16 ? color.yellow : color.red

// --- CORRELATION LIFECYCLE DETECTOR (CLD) ---
float cld_corr_input = math.abs(nz(rho))  // FIXED: Use |rho| to detect correlation strength regardless of sign

// Calculate adaptive slope threshold
float rho_std_50 = ta.stdev(cld_corr_input, 50)
float cld_slope_thresh_adaptive = math.max(0.008, nz(rho_std_50, 0.04) * 0.30)
float current_cld_slope_thresh = cld_auto_slope ? cld_slope_thresh_adaptive : cld_slope_thresh_manual

[cld_signal, cld_conf, cld_bars] = f_cld(cld_corr_input, c0, z0, current_cld_slope_thresh)

// Derived flags
bool cld_continuation = cld_signal > 0.5 and cld_conf > 0.3
bool cld_exhaustion = cld_signal < -0.5 and cld_conf > 0.3

// Direction of the underlying price move
bool cld_move_up = c0 > nz(c0[cld_bars], c0)
bool cld_move_down = c0 < nz(c0[cld_bars], c0)

// High-conviction composites
bool cld_strong_continuation = cld_continuation and cld_conf > 0.6
bool cld_strong_exhaustion = cld_exhaustion and cld_conf > 0.5 and math.abs(z0) > 1.2
var bool cld_div_armed = false
var bool cld_div_up = false
var float cld_div_price_ref = na
var float cld_div_z0_ref = na
var float cld_div_bco_ref = na
var float cld_div_te_ref = na
var int cld_div_arm_bar = na
bool cld_exhaust_edge = cld_exhaustion and not cld_exhaustion[1]
if cld_exhaust_edge
    cld_div_armed := true
    cld_div_up := cld_move_up
    cld_div_price_ref := c0
    cld_div_z0_ref := z0
    cld_div_bco_ref := cld_corr_input
    cld_div_te_ref := te_osc
    cld_div_arm_bar := bar_index
bool cld_div_stale = cld_div_armed and bar_index - nz(cld_div_arm_bar, bar_index) >= 3
bool cld_div_not_expired = cld_div_armed and bar_index - nz(cld_div_arm_bar, bar_index) <= 20
bool cld_div_new_extreme = cld_div_armed and ((cld_div_up and high > nz(cld_div_price_ref, high)) or (not cld_div_up and low < nz(cld_div_price_ref, low)))
bool cld_div_z_weaker = cld_div_armed and math.abs(z0) < math.abs(nz(cld_div_z0_ref, z0))
bool cld_div_bco_weaker = cld_div_armed and cld_corr_input < nz(cld_div_bco_ref, cld_corr_input)
bool cld_div_te_weaker = cld_div_armed and te_osc < nz(cld_div_te_ref, te_osc)
bool cld_div_any = cld_div_z_weaker or cld_div_bco_weaker or cld_div_te_weaker
bool cld_div_exhaust = cld_div_not_expired and cld_div_stale and cld_div_new_extreme and cld_div_any
if cld_div_exhaust or (cld_div_armed and not cld_div_not_expired)
    cld_div_armed := false
    cld_div_up := false
    cld_div_price_ref := na
    cld_div_z0_ref := na
    cld_div_bco_ref := na
    cld_div_te_ref := na
    cld_div_arm_bar := na

// --- KIRSCHENBAUM SELF-TUNING (SGD) ---
var float vector_sens_opt = vector_sens
var int sgd_updates = 0
var float vwap_rejection_target_z = 0.5
// REMOVED: vwap_sgd_updates (unused after Innovation KB Learning removal)

// Detect Pivots
ph = show_kirschenbaum ? ta.pivothigh(high, kb_pivot_len, kb_pivot_len) : na
pl = show_kirschenbaum ? ta.pivotlow(low, kb_pivot_len, kb_pivot_len) : na

if enable_adaptive and show_kirschenbaum
    // 1. Handle High Pivots
    if not na(ph)
        hist_vec_z = nz(basket_vec_z[kb_pivot_len])
        hist_ma = nz(ma0[kb_pivot_len])
        hist_dev = nz(vert_dev0[kb_pivot_len])
        
        if hist_dev > 0
            // Calculate Predicted Band with Current Sensitivity
            hist_shift = hist_vec_z * vector_sens_opt
            [pred_up, _] = BandsLib.f_calc_survival_bands(hist_ma, hist_dev, hist_shift, survival_p3, 0.0)
            
            // Proximity Filter (TKBY5 Logic)
            dist_to_ma = ph - hist_ma
            band_width = pred_up - hist_ma
            proximity = band_width > 0 ? dist_to_ma / band_width : 0.0
            
            // Only learn if pivot is in the outer zone (e.g. > 70% of band width)
            if sgd_proximity_pct >= 1.0 or (proximity >= (1.0 - sgd_proximity_pct))
                // Error in Z-space (Normalized)
                pred_z = (pred_up - hist_ma) / hist_dev
                actual_z = (ph - hist_ma) / hist_dev
                error = pred_z - actual_z
                
                // Update
                step = learning_rate * error * hist_vec_z
                vector_sens_opt := math.max(vector_sens_min, math.min(vector_sens_max, vector_sens_opt - step))
                sgd_updates += 1

    // 2. Handle Low Pivots
    if not na(pl)
        hist_vec_z = nz(basket_vec_z[kb_pivot_len])
        hist_ma = nz(ma0[kb_pivot_len])
        hist_dev = nz(vert_dev0[kb_pivot_len])
        
        if hist_dev > 0
            // Calculate Predicted Band
            hist_shift = hist_vec_z * vector_sens_opt
            [_, pred_dn] = BandsLib.f_calc_survival_bands(hist_ma, hist_dev, hist_shift, survival_p3, 0.0)
            
            // Proximity Filter
            dist_to_ma = hist_ma - pl
            band_width = hist_ma - pred_dn
            proximity = band_width > 0 ? dist_to_ma / band_width : 0.0
            
            if sgd_proximity_pct >= 1.0 or (proximity >= (1.0 - sgd_proximity_pct))
                // Error in Z-space (distance from MA)
                pred_z = (hist_ma - pred_dn) / hist_dev
                actual_z = (hist_ma - pl) / hist_dev
                error = pred_z - actual_z
                
                // Update (Note: For lower band, vec_z polarity is complex.
                // If vec_z is negative (bearish), pred_z increases (wider band).
                // If pred_z > actual_z (too wide), error > 0.
                // We want to reduce sensitivity magnitude.
                // We need to invert the step for the lower band side?
                // Let's check f_calc_survival_bands logic:
                // prob_lower = prob * exp(tanh(shift)*0.693).
                // If shift < 0 (bearish), prob_lower < prob. Z_lower increases. Band expands.
                // So Shift magnitude increases -> Z increases.
                // If error > 0 (Predicted > Actual), we want Z to decrease.
                // So we want Shift magnitude to decrease.
                // If Vec_Z < 0, we want Sens to decrease.
                // Step = lr * pos_error * neg_vec_z = negative.
                // Sens -= Step => Sens increases. WRONG.
                // We need to invert the sign for lower band updates when using signed shift logic?
                // Actually, let's treat Z as purely distance.
                // d(Z)/d(Sens) is positive for bearish vector (wider band).
                // So gradient is positive w.r.t deviation?
                // Actually, simpler: Use absolute vector z for magnitude?
                // No, vector direction matters.
                // Correct update: vector_sens_opt -= learning_rate * error * hist_vec_z * -1.0
                step = learning_rate * error * hist_vec_z * -1.0
                vector_sens_opt := math.max(vector_sens_min, math.min(vector_sens_max, vector_sens_opt - step))
                sgd_updates += 1

// Select Sensitivity
sens_final = enable_adaptive ? vector_sens_opt : vector_sens

// 4. Cyclic Target Z (Fair Value)
float target_z_cyclic = na
if hyp_mode == "Catch-up"
    // Catch-up: Target is the weighted average of peers
    target_z_cyclic := basket_vec_z
else
    // Gravity Reversion: Basket pulls us back
    // Target = Current Z + (Reversion Vector)
    // Reversion Vector = Average of (-Z_peer * Weight)
    // This simplifies to: z0 - basket_vec_z
    target_z_cyclic := z0 - basket_vec_z

// --- PREDICTIVE MA & BANDS ---

// 1. Shadow Price (Vector-Adjusted)
// We shift the price by the vector pressure * volatility * sensitivity
price_offset = basket_vec_z * vert_dev0_clean * sens_final

// Auto-scaling coefficient to fit FV overlay within band amplitude
// Use typical band amplitude based on stabilized volatility (vert_dev0_clean * typical z-score range)
// Typical survival band at ~10% probability uses z ≈ ±1.65, so full amplitude ≈ 3.3 * vert_dev0_clean
int band_amplitude_lookback = 50
var float fv_scale_coeff = 1.0

// Estimate typical band amplitude from volatility (without needing actual band values)
float typical_band_amp = ta.sma(vert_dev0_clean * 3.3, band_amplitude_lookback)
float historical_offset_range = ta.sma(math.abs(price_offset), band_amplitude_lookback)

// Calculate scaling coefficient: ratio of band amplitude to offset range
// Target: offset should be ~50% of band amplitude for visual clarity
if historical_offset_range > 0
    fv_scale_coeff := (typical_band_amp * 0.5) / historical_offset_range
    // Clamp scaling to reasonable range to avoid extreme values
    fv_scale_coeff := math.max(0.1, math.min(fv_scale_coeff, 3.0))

// Apply scaling to price offset
float price_offset_scaled = price_offset * fv_scale_coeff
shadow_price = c0 + price_offset_scaled

// 2. Predictive MA (Smoothed Shadow Price)
pred_ma = ta.hma(shadow_price, len_smooth)

// --- MEAN REVERSION (FV) LOGIC ---
// Cyclic Fair Value (calculate before survival bands for MR factor)
fv_cyclic = ma0 + (target_z_cyclic * vert_dev0)

// === PHASE MR: Peer-Driven Reversion Target ===
// Fixed formula: residual = actual_z0 - expected_z0_given_peer
float phase_mr_sp1 = (z0 - nz(rho1, 0.0) * nz(z1_raw, 0.0)) * math.abs(nz(rho1, 0.0))
float phase_mr_sp2 = (z0 - nz(rho2, 0.0) * nz(z2_raw, 0.0)) * math.abs(nz(rho2, 0.0))
float phase_mr_sp3 = (z0 - nz(rho3, 0.0) * nz(z3_raw, 0.0)) * math.abs(nz(rho3, 0.0))
float phase_mr_sp4 = (z0 - nz(rho4, 0.0) * nz(z4_raw, 0.0)) * math.abs(nz(rho4, 0.0))

float phase_mr_lam = 0.80
var float phase_mr_a1 = 0.0
var float phase_mr_a2 = 0.0
var float phase_mr_a3 = 0.0
var float phase_mr_a4 = 0.0
phase_mr_a1 := phase_mr_a1 * phase_mr_lam + nz(phase_mr_sp1, 0.0) * (1.0 - phase_mr_lam)
phase_mr_a2 := phase_mr_a2 * phase_mr_lam + nz(phase_mr_sp2, 0.0) * (1.0 - phase_mr_lam)
phase_mr_a3 := phase_mr_a3 * phase_mr_lam + nz(phase_mr_sp3, 0.0) * (1.0 - phase_mr_lam)
phase_mr_a4 := phase_mr_a4 * phase_mr_lam + nz(phase_mr_sp4, 0.0) * (1.0 - phase_mr_lam)

float phase_mr_w1 = math.abs(nz(rho1, 0.0))
float phase_mr_w2 = math.abs(nz(rho2, 0.0))
float phase_mr_w3 = math.abs(nz(rho3, 0.0))
float phase_mr_w4 = math.abs(nz(rho4, 0.0))
float phase_mr_wsum = phase_mr_w1 + phase_mr_w2 + phase_mr_w3 + phase_mr_w4
float PhiTotalorthPhase = phase_mr_wsum > 0.01 ? (phase_mr_a1 * phase_mr_w1 + phase_mr_a2 * phase_mr_w2 + phase_mr_a3 * phase_mr_w3 + phase_mr_a4 * phase_mr_w4) / phase_mr_wsum : 0.0

// === STRUCTURAL MR LATCH ===
// Detect synchronous collapse: peer spreads carry no cross-sectional info (sp1-sp4 inlined)
float spread_rms = math.sqrt(((z0 - rho1 * z1_raw) * math.abs(rho1) * (z0 - rho1 * z1_raw) * math.abs(rho1) + (z0 - rho2 * z2_raw) * math.abs(rho2) * (z0 - rho2 * z2_raw) * math.abs(rho2) + (z0 - rho3 * z3_raw) * math.abs(rho3) * (z0 - rho3 * z3_raw) * math.abs(rho3) + (z0 - rho4 * z4_raw) * math.abs(rho4) * (z0 - rho4 * z4_raw) * math.abs(rho4)) / 4.0)
float spread_rms_avg = ta.ema(spread_rms, 100)
bool phi_informative = spread_rms > spread_rms_avg * 0.4

var float PhiLatch = 0.0
if phi_informative
    PhiLatch := PhiTotalorthPhase
else
    PhiLatch := PhiLatch * 0.999

float mr_target_orth = ma0 + PhiTotal_orth * vert_dev0 * 3.0
float mr_target_latch = ma0 + PhiLatch * vert_dev0 * 3.0
float mr_target_price = mr_target_orth

// Kalman-smoothed Cyclic FV for innovation bands
var float fv_kalman_x = na  // State estimate
var float fv_kalman_p = 1.0  // Error covariance
if na(fv_kalman_x)
    fv_kalman_x := fv_cyclic
    fv_kalman_p := 1.0
else
    // Prediction step (assume constant model: x_pred = x_prev)
    float x_pred = fv_kalman_x
    float p_pred = fv_kalman_p + innov_kalman_q
    
    // Update step with basket vector as control input
    float innovation = fv_cyclic - x_pred
    float s = p_pred + innov_kalman_r
    float k = p_pred / s
    
    fv_kalman_x := x_pred + k * innovation
    fv_kalman_p := (1.0 - k) * p_pred

float fv_cyclic_kalman = fv_kalman_x

// Mean Reversion Oscillator (normalized distance from independent peer-driven target)
float mr_raw = (c0 - mr_target_orth) / math.max(vert_dev0, syminfo.mintick)
float mr_osc_base = nz(TAUtilityLib.f_kalman(mr_raw, 0.3), 0.0)

// V13: MR oscillator now uses independent peer-driven target (no circular dependency)
float mr_osc = mr_osc_base

// Normalized MR for is_falling_knife detection (needed by regime detector)
float mr_norm_knife = vert_dev0 > 0 ? -TAUtilityLib.f_tanh(mr_osc) : 0.0
bool is_falling_knife = mr_norm_knife > 0.95

// --- V8: HIGH VECTOR CONTEXT INTERPRETATION ---
// Guideline 1: High Vector doesn't always mean long - depends on MR state
// Based on 561 historical events analysis:
// - High Vector + MR Overbought (>+1.0) = Macro Exhaustion → DUMP
// - High Vector + MR Cooled (<0.0) = Continuation → PUMP
// - Correlation state modulates the interpretation

bool high_vector = basket_vec_z > 1.0
bool mr_overbought = mr_osc > 1.0
bool mr_cooled = mr_osc < 0.0
bool coupled = not na(rho) and math.abs(rho) > 0.5
bool decoupled = not na(rho) and math.abs(rho) < 0.3

// High Vector Context States
bool macro_exhaustion = high_vector and mr_overbought  // Asset + Basket both tired
bool continuation_setup = high_vector and mr_cooled    // Asset has room to run
bool coupled_mirror = high_vector and coupled          // Asset will mirror basket
bool idiosyncratic_flow = high_vector and decoupled    // Token-specific flows dominate

// Regime Shift Detection: Z-score correlation breakdown
bool regime_shift = not na(rho_z) and math.abs(rho_z) < 0.3  // Structural detachment

// --- SURVIVAL BANDS ---
// Calculate 3 zones based on vector pressure shift + optional MR factor
shift_z = basket_vec_z * sens_final
float mr_shift = use_mr_factor ? mr_osc * mr_weight : 0.0

// All 3 zones: static probability (user-defined)
[z1_up, z1_dn] = BandsLib.f_calc_survival_bands(ma0, vert_dev0, shift_z, survival_p1, mr_shift)
[z2_up, z2_dn] = BandsLib.f_calc_survival_bands(ma0, vert_dev0, shift_z, survival_p2, mr_shift)
[z3_up, z3_dn] = BandsLib.f_calc_survival_bands(ma0, vert_dev0, shift_z, survival_p3, mr_shift)

// --- 3-STATE KALMAN FUSION (BASELINE COLOR) ---
// 1. Slope State (of Baseline MA)
slope_raw = ma0 - ma0[1]
[slope_avg, slope_z, slope_dev] = TAUtilityLib.f_zscore_standard(slope_raw, len_z)

// 2. Momentum State (Price Momentum)
mom_len = 10
mom_raw = c0 - c0[mom_len]
[mom_avg, mom_z, mom_dev] = TAUtilityLib.f_zscore_standard(mom_raw, len_z)

// 3. Vector State (already calculated as basket_vec_z)

// Fusion: Kalman Control Model (Prediction vs Measurement)
// State = Trend Intensity
// Measurement (z) = Internal Price Dynamics (Slope + Momentum)
// Control Input (u) = External Vector Force (Basket Pressure)
internal_dynamics = (nz(slope_z) + nz(mom_z)) / 2.0
external_force = nz(basket_vec_z) * nz(denom0, 1.0)

// We use the Vector Force to PREDICT the next Trend State
// And use Internal Dynamics to UPDATE (Correct) the estimate
// Reactivity 0.2 means 1 unit of Vector Z drives 0.2 units of Trend Z per bar
est_trend = nz(TAUtilityLib.f_kalman_control(internal_dynamics, external_force, 0.2), 0.0)

// --- CONFLUENCE DETECTOR ---
if show_confluence and not simple_mode and bar_index > 100
    BandsLib.f_detect_confluence(ma0, fv_cyclic, vert_dev0, conf_tol, conf_min_lines)

// --- SHANNON ENTROPY (for background coloring only) ---
int entropy_max_size = math.max(entropy_window + 20, 200)
var ent_arr_returns = array.new<float>()

TAUtilityLib.f_push_limited(ent_arr_returns, r0, entropy_max_size)

float price_entropy = 0.0
if array.size(ent_arr_returns) >= entropy_window
    array<float> win_returns = TAUtilityLib.f_tail(ent_arr_returns, entropy_window)
    price_entropy := CausalityLib.f_shannon_entropy_v2(win_returns, entropy_bins)

// Entropy collapse detection (low entropy = structured/trending, high = chaotic)
float entropy_ema = ta.ema(price_entropy, 14)
bool entropy_collapse = price_entropy < 2.0 and entropy_ema < 2.2  // Major trend change
bool entropy_high = price_entropy > 2.8  // High chaos/volatility event

// === REGIME EVENT DETECTOR ===
// Per-bar. No windows. No discretization. Uses existing state variables.

// Component 1: Kalman Innovation Monitor
float kf_predicted = nz(est_trend[1]) + nz(basket_vec_z[1]) * 0.2
float kf_measured = (nz(slope_z) + nz(mom_z)) / 2.0
float kf_innovation = kf_measured - kf_predicted

float innov_smooth = ta.ema(kf_innovation, regime_innov_len)
float innov_abs_dev = ta.ema(math.abs(kf_innovation - innov_smooth), regime_innov_len * 2)
float innov_z_score = innov_abs_dev > 0 ? innov_smooth / math.max(innov_abs_dev, 0.001) : 0.0

var float cusum_pos = 0.0
var float cusum_neg = 0.0
float cusum_thresh = 0.5
cusum_pos := math.max(0.0, cusum_pos + kf_innovation - cusum_thresh * innov_abs_dev)
cusum_neg := math.max(0.0, cusum_neg - kf_innovation - cusum_thresh * innov_abs_dev)

// Component 2: Return Surprisal
float r0_pct_rank = 0.5
int surp_lookback = 50
float surp_count = 0.0
for i = 1 to surp_lookback
    if math.abs(r0) >= math.abs(nz(r0[i]))
        surp_count += 1.0
r0_pct_rank := surp_count / surp_lookback
float surprisal = r0_pct_rank > 0.01 ? -math.log(1.0 - r0_pct_rank + 0.01) / math.log(2) : 0.0

// State Variables
float position = nz(z0)
float velocity = nz(est_trend)
float pressure = nz(basket_vec_z)
float coupling = nz(corr_damping)
float mr_state = nz(mr_osc)

// EVENT 1: TREND CONTINUATION BOUNCE
// Bounce event — wrapped in function (saves 6 vars: near_ma, trend_alive, dir_aligned, was_stretched, resuming, is_bounce)
f_detect_bounce(float _pos, float _vel, float _pres, float _coup, float _z0, int _hist, float _thresh) =>
    bool _b = math.abs(_pos) < _thresh and math.abs(_vel) > 0.12 and (math.sign(_vel) == math.sign(_pres) and _coup > 0.5) and math.abs(nz(_z0[_hist])) > _thresh * 1.5 and ((_vel > 0 and close > nz(close[1])) or (_vel < 0 and close < nz(close[1])))
    _b and not _b[1] and not _b[2]

bool bounce_event = f_detect_bounce(position, velocity, pressure, coupling, z0, regime_bounce_hist, regime_bounce_z)

// EVENT 2: MEAN REVERSION SETUP
// V8 STRATEGY HF: Innovation Decel + MR Turn (97.1% precision, 79.6% recall, 87.4% F1)
// Replaces surprisal + static mr_state threshold + coupling gate

// Gate 1: At extreme (lowered from 1.5 to 1.0 to recover 42-65% of missed reversals)
bool at_extreme = math.abs(position) > 1.0

// Gate 2: Multi-Scale Innovation Deceleration (L6 - replaces surprisal > 2.0)
// Checks 4 timescales: 1-bar (V-shapes), 2-bar, 3-bar, 5-bar (U-shapes)
// 93.2% recall - catches both fast snap reversals and slow grinds
float innov_chg_1 = innov_z_score - nz(innov_z_score[1])
float innov_chg_2 = innov_z_score - nz(innov_z_score[2])
float innov_chg_3 = innov_z_score - nz(innov_z_score[3])
float innov_chg_5 = innov_z_score - nz(innov_z_score[5])

// Multi-scale detection: V-shapes trigger on fast scales, U-shapes on slow scales
// Lower z-threshold (-0.8) for fast scales, higher (-1.0) for slow scales
bool multi_scale_decel_long = (position < -0.8 and innov_chg_1 > 0.15) or (position < -0.8 and innov_chg_2 > 0.12) or (position < -1.0 and innov_chg_3 > 0.10) or (position < -1.0 and innov_chg_5 > 0.08)

bool multi_scale_decel_short = (position > 0.8 and innov_chg_1 < -0.15) or (position > 0.8 and innov_chg_2 < -0.12) or (position > 1.0 and innov_chg_3 < -0.10) or (position > 1.0 and innov_chg_5 < -0.08)

bool innov_decel = multi_scale_decel_long or multi_scale_decel_short

// Gate 3: MR Turning Point (replaces static |mr_state| > 0.5)
// Detects inflection instead of level - works universally across all assets
bool mr_turning_down = mr_osc > 0.3 and mr_osc < nz(mr_osc[1])
bool mr_turning_up = mr_osc < -0.3 and mr_osc > nz(mr_osc[1])
bool mr_turning = mr_turning_down or mr_turning_up

// Gate 4: Price returning (single-bar check)
bool price_returning = (position > 0 and r0 < 0) or (position < 0 and r0 > 0)

// Coupling gate REMOVED - high-beta alts decouple during climax moves (100% of AERO misses)
// Falling knife gate kept for safety
// L6: Multi-scale innovation decel OR MR turning - maximum coverage (93.2% recall)
bool is_mr_raw = at_extreme and (innov_decel or mr_turning) and price_returning and not is_falling_knife

// Edge detection + 15-bar cooldown (prevents repeated signals)
var int last_mr_bar = 0
bool is_mr = is_mr_raw and not is_mr_raw[1] and not is_mr_raw[2] and (bar_index - last_mr_bar > 15)
bool mr_event = is_mr
if mr_event
    last_mr_bar := bar_index

// EVENT 3: TREND CHANGE
bool cusum_triggered = cusum_pos > 3.0 * innov_abs_dev or cusum_neg > 3.0 * innov_abs_dev
bool innov_biased = math.abs(innov_z_score) > 2.0
bool velocity_flip = ta.cross(velocity, 0.0)
bool major_surprise = surprisal > 2.5 and math.abs(r0) > 2.0 * ta.stdev(r0, 20)
bool is_transition = (cusum_triggered or innov_biased) and velocity_flip
bool transition_event = is_transition and not is_transition[1]
bool model_failing = cusum_triggered or innov_biased
bool is_trend_change = model_failing and (velocity_flip or major_surprise)

var int last_tc_bar = 0
bool tc_event = is_trend_change and (bar_index - last_tc_bar > 10)
if tc_event
    last_tc_bar := bar_index

if cusum_triggered
    cusum_pos := 0.0
    cusum_neg := 0.0

// Legacy compatibility (for existing code that references these)
bool bounce_signal = bounce_event
bool mr_signal = mr_event

// --- SQUEEZE/BOTTLENECK BREAKOUT DETECTION (legacy — kept for backward compat) ---
[squeeze_bull, squeeze_bear, final_squeeze_signal, bw_pct] = BandsLib.f_detect_squeeze(z3_up, z3_dn, c0, corr_damping)

// ═══════════════════════════════════════════════════════════════════════════
// SQUEEZE THROAT DETECTOR (TAUtilityLib: Hurst RS + composite state machine)
// ═══════════════════════════════════════════════════════════════════════════
// Global persistent state (Pine v6: arrays/vars must live in caller scope)
int hurst_len = 64  // Minimum R/S window (32+ for stable Hurst)
var array<float> sqz_hurst_buf = array.new_float(0)
var bool  sqz_armed        = false
var int   sqz_arm_bar      = 0
var int   sqz_cooldown_bar = 0
var int   sqz_low_counter  = 0

// Placeholder (will be computed after innov_band definition)
TAUtilityLib.SqzState sqz_raw = na

// Hurst inputs
int sqz_bwv_len    = 3   // velocity lookback
int sqz_bwz_len    = 100 // bw z-score history
float sqz_bwv_sq   = 0.03 // squeeze velocity threshold
float sqz_bwv_ex   = 0.02 // expansion velocity threshold
float sqz_arm_thresh = 0.55 // score to arm
int sqz_cooldown   = 8  // bars between fires

// Push log-return buffer for Hurst
float log_ret = math.log(close / nz(close[1], close))
if array.size(sqz_hurst_buf) >= hurst_len
    array.shift(sqz_hurst_buf)
array.push(sqz_hurst_buf, log_ret)

float hurst_exp = is_hard_zone ? TAUtilityLib.f_hurst_rs(sqz_hurst_buf) : 0.5

// Reactive confirms (used later in f_squeeze_state after innov_band definition)
bool ltf_at_extreme = ltf_is_decoupled or (not na(ltf_corr_ema) and math.abs(ltf_corr_ema) > 0.6)
// burst_for_sqz computed after path_A/f7_burst_raw definition (see F7 section)

// --- VECTOR & CORRELATION OSCILLATORS (needed for Synergic Density) ---
// PVB-style vector oscillator calculation
float vector_mean = ta.sma(basket_vec_z_raw, len_z)
float vector_stdev = ta.stdev(basket_vec_z_raw, len_z)
float vector_osc_z = vector_stdev > 0 ? (basket_vec_z_raw - vector_mean) / vector_stdev : 0.0
// Note: vector_osc (the -6+tanh*3 version) deleted — use registered VEC osc instead

// V8 REFINEMENT: Use 2*corr_len for more stable reference distribution
float rho_mean = ta.sma(nz(rho, 0.0), 2 * corr_len)
float rho_stdev = ta.stdev(nz(rho, 0.0), 2 * corr_len)
float rho_z_score = rho_stdev > 0 ? (nz(rho, 0.0) - rho_mean) / rho_stdev : 0.0
// Note: basket_corr_osc (the -6+tanh*3 version) deleted — use registered CORR osc instead

// ═══════════════════════════════════════════════════════════════════════════
// kNN+MC ENGINE: 6 ORTHOGONAL FEATURES
// ═══════════════════════════════════════════════════════════════════════════

// --- Feature History Buffers (max_heavy_bars ring buffer) ---
var f1_history = array.new_float(0)  // VectorOsc
var f2_history = array.new_float(0)  // BasketCorr
var f3_history = array.new_float(0)  // InnovZ
var f4_history = array.new_float(0)  // TE_Osc
var f5_history = array.new_float(0)  // OrthoZcvb
var f6_history = array.new_float(0)  // PhiDiv
var f7_history = array.new_float(0)  // BurstScore

// --- v16: Additional History Arrays for Path Resampling ---
var arr_close = array.new_float(0)         // Close prices
var arr_high = array.new_float(0)          // High prices for TP detection
var arr_low = array.new_float(0)           // Low prices for SL detection
var arr_ATR = array.new_float(0)           // ATR(14) for noise scaling
var arr_predma = array.new_float(0)        // FIX 4: Predictive MA for trailing SL / predflip / BE exits
var arr_setup_id = array.new_int(0)        // Setup code (0 if no setup)
var arr_setup_family = array.new_int(0)    // MC Family 0-4
var arr_packed_vec = array.new_int(0)      // 24-bit TurboQuant for Hamming
var bt_setups = array.new<HistoricalSetup>(0)

// Final kNN results (after decluster)
var final_knn_ids = array.new_int(0)
var final_distances = array.new_float(0)
var final_weights = array.new_float(0)

// ═══════════════════════════════════════════════════════════════════════════
// STABLE PERCENTILE-RANK NORMALIZATION (Bug 1 Fix C)
// ═══════════════════════════════════════════════════════════════════════════
// Wrapper for TAUtilityLib.f_percentile_rank_fisher()
// Replaces rolling z-score normalization to eliminate temporal drift
f_norm_stable(float raw, int window) =>
    TAUtilityLib.f_percentile_rank_fisher(raw, window)

// --- F1: VectorOsc (already computed as vector_osc_z) ---
float f1_vec_raw = vector_osc_z

// --- F2: BasketCorr (raw correlation, will be Fisher-normalized) ---
float f2_corr_raw = nz(rho, 0.0)

// --- F3: InnovZ (already computed as innov_z_score) ---
float f3_innov_raw = innov_z_score

// --- F4: TE_Osc (will be normalized after TE calculation) ---
float f4_te_raw = te_osc

// --- F5: OrthoZcvb (z0 - β·VectorOsc) ---
// Compute beta as rolling correlation between z0 and vector_osc_z
int beta_window = 100
float beta_orth = ta.correlation(z0, vector_osc_z, beta_window)
float f5_orth_raw = z0 - (nz(beta_orth, 0.0) * vector_osc_z)

// --- F6: PhiDiv (PhiLatch - PhiTotal_orth) ---
float f6_phi_raw = PhiLatch - PhiTotal_orth

// Phi divergence score for squeeze throat detector
[phi_div_score, phi_onset, phi_spread, phi_div_accel] = TAUtilityLib.f_phi_divergence_score(PhiLatch, PhiTotal_orth, 5, 3)

// Z-normalize PhiDiv — inline mean/std (saves 2 vars)
float phi_div_z = (f6_phi_raw - ta.sma(f6_phi_raw, 200)) / math.max(ta.stdev(f6_phi_raw, 200), 0.01)

// --- F7: BurstScore — wrapped in function (saves 14 vars from global scope) ---
f_calc_burst_score(float _mr_osc, float _pred_ma, float _vdev0, float _z3u, float _z3d, float _vec_z, float _fv_kalman, float _phi_accel, float _bw_pct, string _mode) =>
    float _atr_f = ta.atr(14)
    float _isq   = math.max(0.0, 1.0 - _atr_f / math.max(ta.sma(_atr_f, 50), syminfo.mintick))
    float _mrt   = math.max(0.0, math.abs(_mr_osc) - 1.0)
    float _pmd   = _pred_ma - nz(_pred_ma[1], _pred_ma)
    float _pma   = math.abs(_pmd - nz(_pmd[1], _pmd)) / math.max(_vdev0, syminfo.mintick)
    float _bw    = _z3u - _z3d
    float _bcv   = _bw - nz(_bw[1])
    float _vv    = math.abs(_vec_z - nz(_vec_z[1]))
    float _psr   = math.abs(_pred_ma - _fv_kalman)
    float _psc   = math.max(0.0, _psr - nz(_psr[1], _psr))
    float _pA    = _isq * _isq * _phi_accel
    float _pB    = _pma * _mrt
    float _pC    = math.max(0.0, -_bcv) * _vv * _psc / math.max(_vdev0, syminfo.mintick)
    float _raw   = _pA * (1.0 + _pB + _pC) * (1.0 + _isq)
    float _eff   = _raw * (_bw_pct < 0.25 ? 1.0 : 0.0)
    float _bsqz  = _mode == "pathA" ? _pA : _raw
    bool  _high  = math.min(1.0, math.max(0.0, (_bsqz + 3.0) / 6.0)) > 0.80
    [_pA, _raw, _eff, _high]

[path_A, f7_burst_raw, f7_burst_effective, burst_pct_high] = f_calc_burst_score(mr_osc, pred_ma, vert_dev0, z3_up, z3_dn, vector_osc_z, fv_cyclic_kalman, phi_div_accel, bw_pct, burst_osc_mode)

// --- BurstScore Oscillator Display Value (placeholder, actual source selected after squeeze computation) ---
float burst_osc_raw = 0.0  // Will be reassigned after squeeze_score is available
float burst_osc_z = 0.0    // Will be calculated after burst_osc_raw is set with selected source

// --- Normalize Features (Bug 1 Fix C: Percentile-Rank + Fisher Transform) ---
// Replaces rolling z-score normalization with time-invariant percentile ranking
int norm_win = knn_norm_len  // Same 200-bar window
float f1_vec_norm = enable_knn ? f_norm_stable(f1_vec_raw, norm_win) : 0.0
float f2_corr_norm = enable_knn ? f_norm_stable(f2_corr_raw, norm_win) : 0.0
float f3_innov_norm = enable_knn ? f_norm_stable(f3_innov_raw, norm_win) : 0.0
float f4_te_norm = enable_knn ? f_norm_stable(f4_te_raw, norm_win) : 0.0
float f5_orth_norm = enable_knn ? f_norm_stable(f5_orth_raw, norm_win) : 0.0
float f6_phi_norm = enable_knn ? f_norm_stable(f6_phi_raw, norm_win) : 0.0
float f7_burst_norm = enable_knn ? f_norm_stable(f7_burst_effective, norm_win) : 0.0

// ═══════════════════════════════════════════════════════════════════════════
// FEATURE VALIDATION GATE (prevents garbage TE data in ring buffer)
// ═══════════════════════════════════════════════════════════════════════════
// Problem: TE is only valid in heavy zone after warmup (~105 bars)
// Solution: Only push to ring buffer when ALL features are valid
// Impact: Ring buffer starts at bar ~17425 instead of 0, size ~2895 instead of 3000
bool basket_stable = basket_latched and bar_index >= 400
bool te_valid = is_hard_zone and te_warmed_up
bool all_features_valid = basket_stable and te_valid

// Safe F4: push 0.0 (neutral z-score) when TE not valid to prevent normalization poisoning
float f4_te_norm_safe = (is_hard_zone and te_warmed_up) ? f4_te_norm : 0.0

// --- Update History Buffers (ring buffer with max size) ---
if enable_knn and all_features_valid and is_hard_zone
    f_update_feature_buffers(f1_history, f2_history, f3_history, f4_history, f5_history, f6_history, f7_history, f1_vec_norm, f2_corr_norm, f3_innov_norm, f4_te_norm_safe, f5_orth_norm, f6_phi_norm, f7_burst_norm, max_heavy_bars)

// --- Lloyd-Max TurboQuant Encoding (24-bit packed vector) ---
int packed_vec = 0
int mc_family = 4  // Default: Uncertain
float knn_confidence = 0.0

if enable_knn and all_features_valid and is_hard_zone
    // Bug 1 Fix C: Clamp to Fisher transform range [-2.65, +2.65] for optimal TurboQuant
    // This matches percentile-rank output and improves Hamming discrimination
    float f1_clamped = TAUtilityLib.f_clamp(f1_vec_norm, -2.65, 2.65)
    float f2_clamped = TAUtilityLib.f_clamp(f2_corr_norm, -2.65, 2.65)
    float f3_clamped = TAUtilityLib.f_clamp(f3_innov_norm, -2.65, 2.65)
    float f4_clamped = TAUtilityLib.f_clamp(f4_te_norm_safe, -2.65, 2.65)
    float f5_clamped = TAUtilityLib.f_clamp(f5_orth_norm, -2.65, 2.65)
    float f6_clamped = TAUtilityLib.f_clamp(f6_phi_norm, -2.65, 2.65)
    float f7_clamped = TAUtilityLib.f_clamp(f7_burst_norm, -2.65, 2.65)
    
    // Lloyd-Max quantization: O(48) instead of O(6000)
    [i1, r1] = kNNLib.f_turboquant(f1_clamped)
    [i2, r2] = kNNLib.f_turboquant(f2_clamped)
    [i3, r3] = kNNLib.f_turboquant(f3_clamped)
    [i4, r4] = kNNLib.f_turboquant(f4_clamped)
    [i5, r5] = kNNLib.f_turboquant(f5_clamped)
    [i6, r6] = kNNLib.f_turboquant(f6_clamped)
    [i7, r7] = kNNLib.f_turboquant(f7_clamped)
    
    // Pack into 24-bit vector
    packed_vec := kNNLib.f_pack_vector_7(i1, r1, i2, r2, i3, r3, i4, r4, i5, r5, i6, r6, i7, r7)
    
    // Store packed_vec in arr_packed_vec (for Hamming screening)
    if array.size(arr_packed_vec) >= max_heavy_bars
        array.shift(arr_packed_vec)
    array.push(arr_packed_vec, packed_vec)
    
    // MC Family classification (moved from MCLib to SetupsLib - domain logic separation)
    mc_family := SetupsLib.f_get_mc_family(f1_vec_norm, f2_corr_norm, f3_innov_norm, f4_te_norm_safe, f5_orth_norm, f6_phi_norm)
    
    // v16: Store additional history for Path Resampling
    if array.size(arr_close) >= max_heavy_bars
        array.shift(arr_close)
    array.push(arr_close, close)
    
    if array.size(arr_high) >= max_heavy_bars
        array.shift(arr_high)
    array.push(arr_high, high)
    
    if array.size(arr_low) >= max_heavy_bars
        array.shift(arr_low)
    array.push(arr_low, low)
    
    if array.size(arr_ATR) >= max_heavy_bars
        array.shift(arr_ATR)
    array.push(arr_ATR, ta.atr(14))

    // FIX 4: Push pred_ma for BT exit simulation (trailing SL, predflip, breakeven)
    if array.size(arr_predma) >= max_heavy_bars
        array.shift(arr_predma)
    array.push(arr_predma, pred_ma)

    // FIX 7: Per-bar placeholder for setup code (overwritten in f_fire_setup_byid on first fire)
    if array.size(arr_setup_id) >= max_heavy_bars
        array.shift(arr_setup_id)
    array.push(arr_setup_id, 0)

    if array.size(arr_setup_family) >= max_heavy_bars
        array.shift(arr_setup_family)
    array.push(arr_setup_family, mc_family)

// ═══════════════════════════════════════════════════════════════════════════
// MC VISUALIZATION (lines and fills for cone display)
// ═══════════════════════════════════════════════════════════════════════════
bool is_right_edge = barstate.islast and not barstate.isrealtime
bool is_live_new_bar = barstate.isnew and barstate.isrealtime
bool is_live_intrabar = not barstate.isnew and barstate.isrealtime
bool is_history_edge = barstate.islastconfirmedhistory
bool is_replay_mode = barstate.islast and not barstate.isrealtime and not is_history_edge
bool bt_allowed = bt_enable and not is_replay_mode
bool trigger_new_cycle = is_history_edge or is_live_new_bar or is_right_edge
bool is_fast_path = is_history_edge or is_right_edge or is_live_new_bar
bool allow_chunking = is_live_new_bar or is_live_intrabar
bool allow_bt_chunk = allow_chunking or is_history_edge or is_right_edge
bool allow_bt_init = is_history_edge and bt_allowed

var int mc_oracle_direction = 0
var float mc_oracle_pct_up = na
var float mc_knn_confidence = na
var mc_p10_lines = array.new_line(0)
var mc_p50_lines = array.new_line(0)
var mc_p90_lines = array.new_line(0)
var mc_cone_fills = array.new_linefill(0, na)
var array<int> pathsUpAtH = array.new_int(0)
varip int bt_total_setups = 0
varip int bt_validated_setups = 0
varip int bt_confirmed_setups = 0
varip float bt_avg_agree = na
varip bool bt_table_ready = false
varip int bt_first_bar = na  // First validated setup bar_idx
varip int bt_last_bar = na   // Last validated setup bar_idx
var table bt_summary_tbl = table.new(position.top_right, 4, 21, border_width=1)

// ═══════════════════════════════════════════════════════════════════════════
// --- EXECUTION CONTEXT NORMALIZATION (Stage 7) ---
// Note: This block replaces scattered raw barstate.* checks in the kNN/MC flow.
// It is intentionally defined once to avoid duplicate local identifiers.

bool should_start_knn = enable_knn and enable_mc and enable_chunked_mc and array.size(f1_history) >= math.max(knn_k * 3, 300)

// Normalized execution context: downstream logic uses these booleans only
bool trigger_new_bar = trigger_new_cycle
bool phase_idle = (mc_phase == 0 or mc_phase == 4)  // Only start new cycle if idle or done

// ── PHASE 0: kNN Tournament (one tick on new bar) ──
if should_start_knn and trigger_new_bar and phase_idle
    mc_phase := 1
    mc_chunk_done := 0
    mc_oracle_direction := 0
    mc_oracle_pct_up := na
    mc_knn_confidence := na
    // Clean up progress label from previous bar
    if not na(mc_progress_lbl)
        label.delete(mc_progress_lbl)
        mc_progress_lbl := na
    
    // Snapshot current state
    float s_f1 = nz(f1_vec_norm)
    float s_f2 = nz(f2_corr_norm)
    float s_f3 = nz(f3_innov_norm)
    float s_f4 = nz(f4_te_norm)
    float s_f5 = nz(f5_orth_norm)
    float s_f6 = nz(f6_phi_norm)
    float s_f7 = nz(f7_burst_norm)
    int s_packed = packed_vec
    int s_family = mc_family
    int current_setup_code = array.size(arr_setup_id) > 0 ? array.get(arr_setup_id, array.size(arr_setup_id) - 1) : 0
    
    // Run kNN tournament (~50ms)
    // C4 FIX: hamming_thresh=3 (was 4) for ~50% rejection, pool_max=200 (was 50) for T4=1200
    // Phase 2: kNNLib now uses domain-agnostic category parameters
    [final_knn_ids, final_distances, final_weights, iter_result, hamming_result, na_result, cands_result] = kNNLib.f_hierarchical_tournament_live(s_packed, s_f1, s_f2, s_f3, s_f4, s_f5, s_f6, s_f7, s_family, f1_history, f2_history, f3_history, f4_history, f5_history, f6_history, f7_history, arr_packed_vec, arr_setup_id, arr_setup_family, current_setup_code, knn_oracle_horizon, mc_horizon, knn_k, 3, knn_decluster_gap, 200)
    
    // Persist debug results for table display
    dbg_total_iter := iter_result
    dbg_hamming_skip := hamming_result
    dbg_na_skip := na_result
    dbg_cands := cands_result
    
    // Store kNN results persistently
    array.clear(var_knn_ids)
    array.clear(var_knn_weights)
    array.clear(var_cumw)
    
    if array.size(final_knn_ids) > 0
        // Snapshot kNN IDs for table display
        array.clear(final_knn_ids_display)
        for i = 0 to array.size(final_knn_ids) - 1
            array.push(final_knn_ids_display, array.get(final_knn_ids, i))
        
        // Normalize weights
        float wsum_sync = 0.0
        int ksync = array.size(final_weights)
        for i = 0 to ksync - 1
            wsum_sync += array.get(final_weights, i)
        if wsum_sync > 0
            for i = 0 to ksync - 1
                array.push(var_knn_weights, array.get(final_weights, i) / wsum_sync)
        
        // Copy IDs
        for i = 0 to array.size(final_knn_ids) - 1
            array.push(var_knn_ids, array.get(final_knn_ids, i))
        
        // Build cumulative weights
        float running = 0.0
        for i = 0 to array.size(var_knn_weights) - 1
            running += array.get(var_knn_weights, i)
            array.push(var_cumw, running)
        
        // Initialize Welford accumulators
        array.clear(var_wMean)
        array.clear(var_wM2)
        array.clear(var_wCount)
        array.clear(var_pathsUp)
        for h = 0 to mc_horizon - 1
            array.push(var_wMean, 0.0)
            array.push(var_wM2, 0.0)
            array.push(var_wCount, 0)
            array.push(var_pathsUp, 0)
        var_total_paths := 0
        
        // Calculate kNN confidence
        float avg_dist_sync = 0.0
        int final_cnt = array.size(final_distances)
        if final_cnt > 0
            for i = 0 to final_cnt - 1
                avg_dist_sync += array.get(final_distances, i)
            avg_dist_sync := avg_dist_sync / final_cnt
            dbg_avg_dist := avg_dist_sync
            // Bug 1 Fix C: Distance ceiling updated for Fisher transform range [-2.65, +2.65]
            // Max distance per dimension = 5.3, for 7 features: sqrt(7) * 5.3 ≈ 14.0
            float dist_ceiling = math.sqrt(7.0) * 5.3
            mc_knn_confidence := math.max(0.0, math.min(100.0, (1.0 - math.min(avg_dist_sync / dist_ceiling, 1.0)) * 100.0))
        
        mc_phase := 2  // → next tick starts MC chunking
    else
        mc_phase := 0  // No neighbors found, abort

// ── PHASE 2: MC Bootstrap Chunks (many ticks) ──
if mc_phase == 2 and (allow_chunking or is_fast_path) and array.size(var_knn_ids) > 0
    // Fast-path: run all MC on first tick of new bar OR history edge (prevents cone disappearing)
    // Chunking fallback: if interrupted mid-cycle, process mc_chunk_size per tick
    bool first_tick_of_bar = is_fast_path
    int runs_this_tick = first_tick_of_bar ? (mc_target_runs - mc_chunk_done) : math.min(mc_chunk_size, mc_target_runs - mc_chunk_done)

    // Run MC chunk
    int paths_executed = MCLib.f_welford_knn_chunk(var_knn_ids, var_cumw, arr_close, arr_ATR, mc_horizon, runs_this_tick, mc_noise_scale, close, var_wMean, var_wM2, var_wCount, var_pathsUp, mc_chunk_done, bar_index)
    
    mc_chunk_done += runs_this_tick
    var_total_paths += paths_executed
    
    // Update live progress label on current bar
    if barstate.isrealtime
        if not na(mc_progress_lbl)
            label.delete(mc_progress_lbl)
        int current_chunk = int(math.ceil(mc_chunk_done / mc_chunk_size))
        int total_chunks = int(math.ceil(mc_target_runs / mc_chunk_size))
        int bt_size = array.size(bt_setups)
        string chunk_text = "CHUNK: " + str.tostring(current_chunk) + "/" + str.tostring(total_chunks) + 
                           " | MC: " + str.tostring(mc_chunk_done) + "/" + str.tostring(mc_target_runs) + 
                           " | setups: " + str.tostring(bt_size)
        mc_progress_lbl := label.new(bar_index, high * 1.005, chunk_text, 
                                     color=color.new(color.blue, 70), textcolor=color.white, 
                                     style=label.style_label_down, size=size.small)
    
    if mc_chunk_done >= mc_target_runs
        mc_phase := 3  // → next tick computes percentiles
        // Delete progress label when done
        if not na(mc_progress_lbl)
            label.delete(mc_progress_lbl)
            mc_progress_lbl := na

// ── PHASE 3: Percentiles + Oracle Direction (one tick) ──
if mc_phase == 3 and (allow_chunking or is_fast_path)
    // Compute percentiles from Welford stats
    array.clear(mc_progressive_p10)
    array.clear(mc_progressive_p50)
    array.clear(mc_progressive_p90)
    for h = 0 to mc_horizon - 1
        float mu = array.get(var_wMean, h)
        int cnt = array.get(var_wCount, h)
        float sig = cnt > 1 ? math.sqrt(array.get(var_wM2, h) / cnt) : 0.0
        array.push(mc_progressive_p10, mu - 1.282 * sig)
        array.push(mc_progressive_p50, mu)
        array.push(mc_progressive_p90, mu + 1.282 * sig)
    
    // Adaptive horizon selection
    int optHorizon = mc_horizon
    float optScore = 0.0
    string optDir = ""
    float optDirPct = na
    if mcearlydirected and var_total_paths > 0
        float bestScore = 0.0
        int bestH = mc_horizon
        for h = math.max(0, mcminhorizon - 1) to mc_horizon - 1
            float mu_h = array.get(var_wMean, h)
            int count_h = array.get(var_wCount, h)
            float sigma_h = count_h > 1 ? math.sqrt(array.get(var_wM2, h) / count_h) : 0.0
            float upPct_h = float(array.get(var_pathsUp, h)) / var_total_paths
            float dnPct_h = 1.0 - upPct_h
            bool bullH = upPct_h >= dnPct_h
            float dirPct_h = bullH ? upPct_h : dnPct_h
            if dirPct_h < mcedgedirpct
                continue
            float mfe_h = bullH ? (mu_h - close) : (close - mu_h)
            float mae_h = 1.282 * sigma_h
            float rr_h = mfe_h / math.max(mae_h, syminfo.mintick)
            float score_h = dirPct_h * math.max(0.0, rr_h)
            if score_h > bestScore
                bestScore := score_h
                bestH := h + 1
                optScore := score_h
                optDir := bullH ? "BULL" : "BEAR"
                optDirPct := dirPct_h
        if bestScore >= mcedgeminscore
            optHorizon := bestH
    
    optHorizon := math.max(mcminhorizon, math.min(optHorizon, mc_horizon))
    mc_opt_horizon := optHorizon
    mc_opt_score := optScore
    mc_opt_dir := optDir
    mc_opt_dir_pct := optDirPct
    
    // Oracle direction from final horizon
    float final_mu = array.get(var_wMean, optHorizon - 1)
    int final_n = array.get(var_wCount, optHorizon - 1)
    float final_sig = final_n > 1 ? math.sqrt(array.get(var_wM2, optHorizon - 1) / final_n) : 0.0
    
    if final_sig > 0
        float z_final = (close - final_mu) / final_sig
        mc_oracle_pct_up := 100.0 / (1.0 + math.exp(1.7 * z_final))
    else
        mc_oracle_pct_up := final_mu > close ? 100.0 : 0.0
    
    mc_oracle_direction := mc_oracle_pct_up > 50.0 ? 1 : -1
    mc_result_bar := bar_index  // Track freshness
    mc_has_results := true
    mc_phase := 4  // DONE

// ── PHASE 4: Idle (wait for new bar) ──
// Stage 7 (DR-4): MC state machine resets independently of backtest
if mc_phase == 4 and trigger_new_bar
    mc_phase := 0  // Reset for next bar
    // Clean up progress label from previous bar
    if not na(mc_progress_lbl)
        label.delete(mc_progress_lbl)
        mc_progress_lbl := na

// Calculate ma_trend (needed for Synergic Density)
float ma_slope = pred_ma - nz(pred_ma[3], pred_ma)
float ma_trend = vert_dev0 > 0 ? TAUtilityLib.f_tanh(ma_slope / (vert_dev0 * 0.1)) : 0.0

// Pred MA Rounding Detection (for entry/exit filters)
float ma_accel = ma_slope - nz(ma_slope[1], ma_slope)
bool slope_near_zero = math.abs(ma_slope) < vert_dev0 * 0.05
bool accel_opposite = (ma_slope > 0 and ma_accel < 0) or (ma_slope < 0 and ma_accel > 0)
bool pred_rounded = slope_near_zero or accel_opposite

// ═══════════════════════════════════════════════════════════════════════════
// REGIME-SWITCHED NORMALIZATION SYSTEM (5 Layers)
// ═══════════════════════════════════════════════════════════════════════════
// Solves: Fixed thresholds fail on low-coupling assets (JCT: Basket Fit 13.4%)
// Solution: Adaptive thresholds based on coupling regime + IQR normalization
// Performance: Percentile scan every N bars instead of per-bar (cached)
// ═══════════════════════════════════════════════════════════════════════════

// --- Percentile Cache Infrastructure ---
var float te_p25_cached = na
var float te_p75_cached = na
var float mr_p25_cached = na
var float mr_p75_cached = na
var float mr_p02_cached = na
var float mr_p98_cached = na
var float vec_p25_cached = na
var float vec_p75_cached = na
var float corr_p25_cached = na
var float corr_p75_cached = na
var float ltf_p20_cached = na
var float ltf_p50_cached = na
var int last_percentile_scan_bar = 0

// Recalc trigger: every percentile_scan_interval bars OR first bar OR realtime
bool should_recalc_percentiles = enable_normalization and (bar_index - last_percentile_scan_bar >= percentile_scan_interval or bar_index == 0 or allow_chunking)

if should_recalc_percentiles
    // Layer 2: IQR Normalization - calculate percentiles for oscillators
    te_p25_cached := ta.percentile_linear_interpolation(te_osc, norm_percentile_window, 25)
    te_p75_cached := ta.percentile_linear_interpolation(te_osc, norm_percentile_window, 75)
    mr_p25_cached := ta.percentile_linear_interpolation(mr_osc, norm_percentile_window, 25)
    mr_p75_cached := ta.percentile_linear_interpolation(mr_osc, norm_percentile_window, 75)
    mr_p02_cached := ta.percentile_linear_interpolation(mr_osc, norm_percentile_window, 2)
    mr_p98_cached := ta.percentile_linear_interpolation(mr_osc, norm_percentile_window, 98)
    vec_p25_cached := ta.percentile_linear_interpolation(vector_osc_z, norm_percentile_window, 25)
    vec_p75_cached := ta.percentile_linear_interpolation(vector_osc_z, norm_percentile_window, 75)
    corr_p25_cached := ta.percentile_linear_interpolation(rho_z_score, norm_percentile_window, 25)
    corr_p75_cached := ta.percentile_linear_interpolation(rho_z_score, norm_percentile_window, 75)
    
    // LTF Corr percentiles for adaptive decouple/recouple thresholds
    if ltf_enabled and not na(ltf_corr_ema)
        ltf_p20_cached := ta.percentile_linear_interpolation(ltf_corr_ema, norm_percentile_window, 20)
        ltf_p50_cached := ta.percentile_linear_interpolation(ltf_corr_ema, norm_percentile_window, 50)
    
    last_percentile_scan_bar := bar_index

// 5-Layer Normalization System via TAUtilityLib (saves ~15 vars through library scope)
[coupling_regime, te_norm, mr_norm, vec_norm, corr_norm, te_effective, ltf_decouple_adaptive, ltf_recouple_adaptive, mr_vol_adj] = TAUtilityLib.f_norm_system(enable_normalization, te_osc, mr_osc, vector_osc_z, rho_z_score, te_p25_cached, te_p75_cached, mr_p25_cached, mr_p75_cached, vec_p25_cached, vec_p75_cached, corr_p25_cached, corr_p75_cached, ltf_p20_cached, ltf_p50_cached, coupling_strong_thresh, coupling_weak_thresh, ltf_decouple_thresh, ltf_recouple_thresh, ltf_enabled, mr_vol_lookback)

// --- Layer 5: Regime-Switched Signal Routing ---
// (MC variables declared earlier, before Innovation section)

// --- SETUP COOLDOWN HELPER (used by setupsDB integration) ---
int setup_min_gap = 5  // Minimum 5 bars between same setup fires

f_setup_cooldown_ok(string setup_id, string dir, int last_bar) =>
    int min_gap = setup_min_gap
    bar_index - last_bar >= min_gap

// Regime Event Detection Calculator
// Detects innovation states, pivot confirmations, trend states, and breakout events
// Returns tuple of all regime event flags (all intermediate vars stay in function scope)
f_calc_regime_events(float innov_z, float c_now, float c_10bars, float mr_val, float low_val,
                    float est_trend_val, float z3_upper, float z3_lower, bool is_decoup, bool is_part) =>
    // Price direction over 10 bars
    float price_dir_10 = c_now > nz(c_10bars) and nz(c_10bars) > 0 ? (c_now - nz(c_10bars)) / nz(c_10bars) : 0.0
    bool price_up_10 = price_dir_10 > 0
    bool price_dn_10 = price_dir_10 < 0
    
    // 4 distinct innovation states (RAW)
    bool iz_top_exhaust_raw = innov_z < -1.5 and price_up_10
    bool iz_bot_recovery_raw = innov_z > 1.5 and price_dn_10
    bool iz_bull_mom = innov_z > 1.5 and price_up_10
    bool iz_bear_mom = innov_z < -1.5 and price_dn_10
    
    // TOP EXHAUST: IZ pivotHigh(2,1)
    float iz_abs = math.abs(innov_z)
    float iz_piv_hi = ta.pivothigh(iz_abs, 2, 1)
    bool iz_piv_recent = not na(iz_piv_hi) or not na(iz_piv_hi[1]) or not na(iz_piv_hi[2]) or not na(iz_piv_hi[3])
    bool iz_top_exhaust = iz_top_exhaust_raw and iz_piv_recent
    
    // BOT RECOVERY: MR pivotLow(2,2) ∩ Price pivotLow(2,1)
    float mr_piv_lo = ta.pivotlow(mr_val, 2, 2)
    float price_piv_lo = ta.pivotlow(low_val, 2, 1)
    bool mr_piv_recent = not na(mr_piv_lo) or not na(mr_piv_lo[1]) or not na(mr_piv_lo[2])
    bool price_piv_recent = not na(price_piv_lo) or not na(price_piv_lo[1]) or not na(price_piv_lo[2])
    bool iz_bot_recovery = iz_bot_recovery_raw and mr_piv_recent and price_piv_recent
    
    // TREND STATE
    bool trend_bull = est_trend_val > 0.05
    bool trend_bear = est_trend_val < -0.05
    
    // BREAKOUT DETECTION & VOLATILITY TERM STRUCTURE
    float bw = z3_upper - z3_lower
    float bw_roc = bw - nz(bw[1])
    float bw_roc_z = bw_roc / math.max(ta.stdev(bw_roc, 20), 0.001)
    bool expand_by_bw = bw_roc_z > 1.5
    float vol_short = ta.stdev(close, 10)
    float vol_long = ta.stdev(close, 50)
    float vol_ratio = vol_short / math.max(vol_long, syminfo.mintick)
    bool expand_by_vol = ta.crossover(vol_ratio, 0.80) and nz(vol_ratio[3]) < 0.65
    bool expansion_confirmed = expand_by_bw or expand_by_vol
    
    // Align with Kalman Projected Trend
    bool expansion_up = ta.crossover(c_now, z3_upper) and trend_bull
    bool expansion_dn = ta.crossunder(c_now, z3_lower) and trend_bear
    
    // Color Logic (Kalman Trend Only)
    color col_base = est_trend_val > 0.05 ? color.from_gradient(est_trend_val, 0.05, 0.8, color.gray, color.lime) : (est_trend_val < -0.05 ? color.from_gradient(est_trend_val, -0.8, -0.05, color.red, color.gray) : color.gray)
    
    [iz_top_exhaust_raw, iz_bot_recovery_raw, iz_bull_mom, iz_bear_mom, iz_top_exhaust, iz_bot_recovery, trend_bull, trend_bear, expansion_confirmed, expansion_up, expansion_dn, col_base]

// Calculate regime events via function (saves ~40 global variables)
[iz_top_exhaust_raw, iz_bot_recovery_raw, iz_bull_mom, iz_bear_mom, iz_top_exhaust, iz_bot_recovery,trend_bull, trend_bear, expansion_confirmed, expansion_up, expansion_dn, col_base] = f_calc_regime_events(innov_z_score, c0, c0[10], mr_osc, low, est_trend, z3_up, z3_dn, is_decoupled, is_partial)

// ============================================================================
// V9: EMPIRICAL SETUP DETECTION & LABEL MANAGEMENT
// ============================================================================

f_log_price_code(float price_val) =>
    na(price_val) ? 0 : math.max(0, math.min(65535, math.round((math.log(math.max(price_val, syminfo.mintick)) + 10.0) * 1000.0)))

f_pct_offset_code(float target_price, float entry_price) =>
    na(target_price) or na(entry_price) or entry_price == 0 ? 0 : math.max(0, math.min(255, math.round(math.abs(target_price - entry_price) / entry_price * 5000.0)))

// f_calc_tpsl moved to SetupsLib - use SetupsLib.f_calc_tpsl(dir, ep, tp_pct, sl_pct, z2_up, z2_dn, z3_up, z3_dn, tpsl_use_zones)

f_seed_validation(string next_setup_id, string next_setup_direction, label next_label, string next_tooltip) =>
    [next_setup_id, bar_index, close, next_setup_direction, next_label, next_tooltip, 1]

f_start_or_queue_validation(bool validator_idle, string curr_pending_setup_id, int curr_pending_trigger_bar, float curr_pending_entry_price, string curr_pending_direction, label curr_pending_label, string curr_pending_tooltip, int curr_pending_phase, string next_setup_id, int next_trigger_bar, float next_entry_price, string next_direction, label next_label, string next_tooltip, int next_phase) =>
    string out_validating_setup_id = na
    int out_setup_trigger_bar = na
    float out_setup_entry_price = na
    string out_setup_direction = na
    label out_validating_label = na
    string out_validating_tooltip = na
    int out_validation_phase = 0
    string out_pending_setup_id = curr_pending_setup_id
    int out_pending_trigger_bar = curr_pending_trigger_bar
    float out_pending_entry_price = curr_pending_entry_price
    string out_pending_direction = curr_pending_direction
    label out_pending_label = curr_pending_label
    string out_pending_tooltip = curr_pending_tooltip
    int out_pending_phase = curr_pending_phase
    if validator_idle
        out_validating_setup_id := next_setup_id
        out_setup_trigger_bar := next_trigger_bar
        out_setup_entry_price := next_entry_price
        out_setup_direction := next_direction
        out_validating_label := next_label
        out_validating_tooltip := next_tooltip
        out_validation_phase := next_phase
    else
        out_pending_setup_id := next_setup_id
        out_pending_trigger_bar := next_trigger_bar
        out_pending_entry_price := next_entry_price
        out_pending_direction := next_direction
        out_pending_label := next_label
        out_pending_tooltip := next_tooltip
        out_pending_phase := next_phase
    [out_validating_setup_id, out_setup_trigger_bar, out_setup_entry_price, out_setup_direction, out_validating_label, out_validating_tooltip, out_validation_phase, out_pending_setup_id, out_pending_trigger_bar, out_pending_entry_price, out_pending_direction, out_pending_label, out_pending_tooltip, out_pending_phase]

f_open_position(string setup_id, string dir, string fire_dir, float wr, float tp_pct, float sl_pct, string size_info) =>
    ActivePosition next_pos = ActivePosition.new("", "", 0, na, na, na, na, na, na, na, false, na, "", -1, 0, -1)
    float ep = close
    [tp1_tmp, tp2_tmp, tp3_tmp, sl_tmp] = SetupsLib.f_calc_tpsl(dir, ep, tp_pct, sl_pct, z2_up, z2_dn, z3_up, z3_dn, tpsl_use_zones)
    float rrr = math.abs(tp1_tmp - ep) / math.max(math.abs(sl_tmp - ep), syminfo.mintick)
    
    // Draw TP/SL lines via SetupsLib (freeze on sweep/expire, don't delete)
    bool bad_rrr = rrr < tpsl_min_rrr
    color tp_col = bad_rrr ? color.new(color.green, 60) : color.green
    color sl_col = bad_rrr ? color.new(color.red, 60) : color.red
    
    [lvl_idx, lvl_cnt] = SetupsLib.f_create_tpsl_levels(level_trackers, dir, tp1_tmp, tp2_tmp, sl_tmp, bar_index, tpsl_max_hold, tpsl_level_scan, tp_col, sl_col)
    
    next_pos := ActivePosition.new(setup_id, dir, bar_index, ep, tp1_tmp, tp2_tmp, sl_tmp, na, na, rrr, true, na, "", lvl_idx, lvl_cnt, -1)

    // Entry context debug packing (data window only)
    int setup_code = 0
    for _ci = 0 to array.size(setupsdb_cache) - 1
        SetupsDB.SetupConfig _cc = array.get(setupsdb_cache, _ci)
        if _cc.id == setup_id
            setup_code := _cc.code
            break
    int dir_code = dir == "LONG" ? 1 : 0
    // V19: Use SetupsLib.f_classify_market_state() with Family table
    SetupsLib.Family current_family = SetupsLib.f_classify_market_state(families, nz(z0), nz(est_trend), nz(basket_vec_z), nz(corr_damping), nz(mr_osc))
    int family_code = current_family.id
    int oracle_flipped = fire_dir != dir ? 1 : 0
    int z0_code = f_pack_signed(z0, 10.0, 32, 63)
    int trend_code = f_pack_signed(est_trend, 100.0, 32, 63)
    int vec_code = f_pack_signed(basket_vec_z, 100.0, 32, 63)
    int damp_code = int(math.round(math.max(0.0, math.min(corr_damping, 1.0)) * 63.0))
    int mr_code = f_pack_signed(mr_osc, 32.0, 32, 63)
    int te_code = f_pack_signed(te_osc, 32.0, 32, 63)
    int rr_code = int(math.round(math.max(0.0, math.min(rrr, 6.3)) * 10.0))
    float entry_ctx = setup_code + oracle_flipped * 32.0 + family_code * 64.0 + z0_code * 512.0 + trend_code * 32768.0 + vec_code * 2097152.0 + damp_code * 134217728.0 + mr_code * 8589934592.0 + te_code * 549755813888.0 + rr_code * 35184372088832.0
    [next_pos, entry_ctx]

// Determine duration category based on setup ID
f_get_duration_category(string setup_id) =>
    int avg_bars = 12
    for _ci = 0 to array.size(setupsdb_cache) - 1
        SetupsDB.SetupConfig _cc = array.get(setupsdb_cache, _ci)
        if _cc.id == setup_id
            avg_bars := _cc.hold_bars
            break
    avg_bars <= 7 ? 1 : avg_bars <= 12 ? 2 : 3

f_add_setup_label(string setup_id, string setup_name, string dir, float wr, float sharpe, float tp_pct, float sl_pct, string tooltip_text) =>
    // Guard against disabled setup labels
    if not show_setup_labels
        [na, tooltip_text]
    
    // Manage setup label array (max 500). Keep confirmed labels, evict oldest unconfirmed.
    if array.size(setup_labels) >= 500
        int idx_to_remove = -1
        label lbl_to_remove = na
        // Find the oldest unconfirmed label
        for i = 0 to array.size(setup_labels) - 1
            label test_lbl = array.get(setup_labels, i)
            bool is_confirmed = false
            for j = 0 to array.size(bt_setups) - 1
                HistoricalSetup rec = array.get(bt_setups, j)
                if rec.setup_label == test_lbl
                    if rec.mc_confirmed
                        is_confirmed := true
                    break
            if not is_confirmed
                idx_to_remove := i
                lbl_to_remove := test_lbl
                break
        
        if idx_to_remove >= 0
            array.remove(setup_labels, idx_to_remove)
            label.delete(lbl_to_remove)
        else
            // If all 500 are confirmed, we have to drop the oldest one anyway to make room
            old_lbl = array.shift(setup_labels)
            label.delete(old_lbl)
    
    string meta_name = setup_name
    string meta_dir = dir
    float meta_wr = wr
    float meta_sharpe = sharpe
    float meta_tp = tp_pct
    float meta_sl = sl_pct
    int meta_avg_bars = 12
    string meta_thesis = tooltip_text
    for _ci = 0 to array.size(setupsdb_cache) - 1
        SetupsDB.SetupConfig _cc = array.get(setupsdb_cache, _ci)
        if _cc.id == setup_id
            meta_name := _cc.name
            meta_dir := _cc.dir
            meta_wr := _cc.wr
            meta_sharpe := _cc.sharpe
            meta_tp := _cc.tp_pct
            meta_sl := _cc.sl_pct
            meta_avg_bars := _cc.hold_bars
            meta_thesis := _cc.thesis
            break
    string duration_text = "Typical hold: " + str.tostring(meta_avg_bars) + " bars"
    string full_tooltip = "Setup | " + setup_id + "\n" +"Name  | " + meta_name + "\n" +"Dir   | " + meta_dir + "\n" +"WR    | " + str.tostring(meta_wr, "#.##") + "%\n" +"Sharpe| " + str.tostring(meta_sharpe, "#.##") + "\n" +"TP    | " + str.tostring(meta_tp, "#.##") + "%\n" +"SL    | " + str.tostring(meta_sl, "#.##") + "%\n" +"Hold  | " + duration_text + "\n" +"Entry | " + str.tostring(close, "#.####") + "\n" +"Bar   | " + str.tostring(bar_index) + "\n" +"Meta  | " + meta_thesis

    color lbl_color = dir == "LONG" ? color.new(color.lime, 80) : color.new(color.red, 80)
    
    // Position at next bar's open price (use close of current bar as proxy for next open)
    float label_y = close
    
    // Add spaces to widen label based on duration category
    int duration_cat = f_get_duration_category(setup_id)
    string padding = duration_cat == 1 ? "" : (duration_cat == 2 ? "  " : "    ")
    string label_text = setup_id + padding
    
    label new_lbl = label.new(bar_index, label_y, label_text, yloc=yloc.price, color=lbl_color, textcolor=color.black, style=label.style_label_right, size=size.tiny, tooltip=full_tooltip, force_overlay=true)
    array.push(setup_labels, new_lbl)
    [new_lbl, full_tooltip]  // Return [label, tooltip] for MC validation

f_fire_setup(string fire_setup_id, string fire_setup_name, string setup_dir, string fire_dir, float fire_wr, float fire_sharpe, float fire_tp_pct, float fire_sl_pct, string fire_tooltip, string fire_size_info, int setup_code) =>
    ActivePosition out_pos = pos
    float out_mae = na
    float out_mfe = na
    float out_entry_ctx = na
    
    // FIX Bug #4: Cleanup active position before overwrite (prevent orphaned labels/levels)
    if pos.is_active
        // Freeze TP/SL levels
        if pos.levels_idx >= 0
            SetupsLib.f_freeze_levels(level_trackers, pos.levels_idx, pos.levels_cnt)
        // Mark label with tilde (position interrupted, not properly exited)
        if not na(pos.setup_label)
            label.set_text(pos.setup_label, pos.setup_id + " ~")
            label.set_textcolor(pos.setup_label, color.gray)
    
    // 1. Add Label and Open Position
    [entry_label, full_tooltip] = f_add_setup_label(fire_setup_id, fire_setup_name, setup_dir, fire_wr, fire_sharpe, fire_tp_pct, fire_sl_pct, fire_tooltip)
    [temp_pos, temp_ctx] = f_open_position(fire_setup_id, setup_dir, fire_dir, fire_wr, fire_tp_pct, fire_sl_pct, fire_size_info)
    out_pos := temp_pos
    out_pos.setup_label := entry_label
    out_pos.tooltip := full_tooltip  // Save tooltip for exit info append
    out_entry_ctx := temp_ctx

    if enable_mc and enable_knn
        HistoricalSetup rec = HistoricalSetup.new()
        rec.bar_idx := bar_index
        rec.setup_id := fire_setup_id
        rec.direction := fire_dir
        rec.entry_price := close
        rec.tp_pct := fire_tp_pct
        rec.sl_pct := fire_sl_pct
        rec.max_hold := tpsl_max_hold
        rec.f1_snap := nz(f1_vec_norm)
        rec.f2_snap := nz(f2_corr_norm)
        rec.f3_snap := nz(f3_innov_norm)
        rec.f4_snap := nz(f4_te_norm)
        rec.f5_snap := nz(f5_orth_norm)
        rec.f6_snap := nz(f6_phi_norm)
        rec.f7_snap := nz(f7_burst_norm)
        rec.packed_snap := packed_vec
        // V19: Assign Family UDT from families table using mc_family ID
        rec.family_snap := array.get(families, mc_family)
        rec.hist_avail := array.size(f1_history)
        rec.coupling_regime_snap := coupling_regime
        rec.basket_fit_norm_snap := nz(basket_fit_normalized, 0.5)
        rec.rho_snap := nz(rho, 0.0)
        // FIX: Use setup_code passed from f_fire_setup_by_id (cfg.code) instead of searching cleared cache
        rec.setup_code := setup_code
        rec.entry_ctx := temp_ctx  // Store packed context bitfield for ML export
        rec.mc_oracle_dir := "NONE"  // Will be set during MC validation
        rec.actual_pnl := na
        rec.actual_mae := na
        rec.actual_mfe := na
        rec.exit_reason := "OPEN"
        rec.mc_pct_agree := na
        rec.mc_confirmed := false
        rec.mc_confidence := na
        rec.knn_cands := na
        rec.setup_label := entry_label
        array.push(bt_setups, rec)
        // Instant MC validation disabled (token-saving placeholder)

    [out_pos, out_mae, out_mfe, out_entry_ctx]

// ── BT PHASE 0→1 INIT: Prepare backtest validation on history edge only ──
// Stage 7 (DR-4): Dual State Machine — Option B Hybrid Approach
// bt_phase runs independently so backtest never blocks live cone
// Hybrid guard: only bootstrap when the cone pipeline is idle or already committed
bool mc_idle_or_done = mc_phase == 0 or mc_phase == 4
if bt_allowed and enable_knn and enable_mc and allow_bt_init and bt_phase == 0 and mc_idle_or_done
    bt_total_setups := array.size(bt_setups)
    
    // FIX Bug 3: Guard against empty bt_setups - stay in phase 0 for retry
    if bt_total_setups > 0
        bt_validated_setups := 0
        bt_confirmed_setups := 0
        bt_chunk_idx := 0
        bt_table_ready := false
        // Reset persistent accumulators
        bt_raw_wins := 0
        bt_raw_total := 0
        bt_raw_pnl_sum := 0.0
        bt_filt_wins := 0
        bt_filt_total := 0
        bt_filt_pnl_sum := 0.0
        bt_agree_sum := 0.0
        bt_raw_mae_sum := 0.0
        bt_raw_mfe_sum := 0.0
        bt_filt_mae_sum := 0.0
        bt_filt_mfe_sum := 0.0
        bt_raw_mean := 0.0
        bt_raw_m2 := 0.0
        bt_filt_mean := 0.0
        bt_filt_m2 := 0.0
        bt_phase := 1  // → bt_phase 1: chunked backtest validation

// --- BT PHASE 1: Budget-based chunking with kNN filtering ---
    // AGGRESSIVE LABEL CLEANUP: Clear old labels to prevent overflow
    // FIX Bug #5: Don't delete labels referenced by bt_setups
    // NOTE: Increased from 250 to 450 to preserve BT annotations for more setups
    // FIX: Skip cleanup during entire backtest (Phase 1-4) until rendering is complete
    bool bt_in_progress = bt_phase > 0 and bt_phase < 4
    bool phase3_painting = bt_phase == 3 and bt_phase3_idx < array.size(bt_setups)
    bool bt_done = bt_phase == 4
    if array.size(setup_labels) > 450 and bt_done and not bt_in_progress and not phase3_painting
        for i = 0 to math.min(50, array.size(setup_labels) - 450)
            old_lbl = array.shift(setup_labels)
            if not na(old_lbl)
                // Check if label is referenced by any BT setup
                bool is_referenced = false
                for j = 0 to array.size(bt_setups) - 1
                    HistoricalSetup rec = array.get(bt_setups, j)
                    if rec.setup_label == old_lbl
                        is_referenced := true
                        break
                // Only delete if not referenced
                if not is_referenced
                    label.delete(old_lbl)
    
    // Process setups in chunks to stay within heavy calculation limits
    // NOTE Bug #9: BT only runs when mc_phase == 0 or 4 (idle/done). If setups fire frequently,
    // MC cycles 0→1→2→3→4→0 continuously, starving BT execution windows. BT Progress stays "...".
    // Trade-off: prevents heavy calc overflow, but can stall BT on active charts.
varip int bt_last_seen_attempt = -1
bool mc_finished = mc_phase == 0 or mc_phase == 4
if bt_phase == 1 and allow_bt_chunk and mc_finished
    int heavy_budget = bt_heavy_budget  // User-configurable: max validations per tick
    int valid_this_chunk = 0
    int s = bt_chunk_idx
    int max_scan = bt_total_setups
    
    int csize_bt = array.size(arr_close)
    for _i = 0 to max_scan - 1
        if s >= bt_total_setups
            break
        if heavy_budget <= 0
            break
        
        bt_last_seen_attempt := s
        HistoricalSetup rec = array.get(bt_setups, s)
        int hist_avail = rec.hist_avail
        s += 1
        
        if hist_avail < bt_min_history
            continue  // Skip is FREE - doesn't count against budget

        valid_this_chunk += 1

        int offset = rec.bar_idx - (bar_index - csize_bt + 1)
        if offset < 0 or offset >= csize_bt
            continue  // Skip is FREE

        float ep = rec.entry_price
        bool is_long = rec.direction == "LONG"
        int hold_limit = tpsl_enable_maxhold_tp ? math.min(rec.max_hold > 0 ? rec.max_hold : tpsl_max_hold, csize_bt - offset - 1) : csize_bt - offset - 1

        // Unified BT simulation via SetupsLib (FIX Bug #3: pass arr_high, arr_low for correct TP/SL detection)
        [exit_pnl, worst, best, exit_rsn] = SetupsLib.f_simulate_bt_position(rec.direction, ep, rec.tp_pct, hold_limit, arr_close, arr_high, arr_low, arr_predma, offset, csize_bt)
        
        rec.actual_pnl := exit_pnl - fee_pct  // Subtract round-trip trading fees
        rec.actual_mae := worst
        rec.actual_mfe := best
        rec.exit_reason := exit_rsn

        // P1: Force knnlimit = offset - mchorizon - 1 to eliminate path walk past setup bar
        int knn_limit = math.min(offset - mc_horizon - 1, array.size(arr_packed_vec))
        int setup_code = rec.setup_code
        int family_id = rec.family_snap.id
        
        // FIX Bug 2: Create quantized F1 history for BT kNN (expects array<int>, not packed vectors)
        // BT kNN signature: f1history is array<int> with quantized values (0-15), not packed 28-bit vectors
        array<int> f1_history_quant = array.new<int>(0)
        int f1_size = array.size(f1_history)
        for i = 0 to math.min(f1_size, knn_limit) - 1
            float f1_val = array.get(f1_history, i)
            // Quantize to 4-bit (0-15) matching kNN signal-aware filter expectations
            int quant_val = int(math.round(math.max(0.0, math.min(15.0, (f1_val + 1.0) * 7.5))))
            array.push(f1_history_quant, quant_val)
        
        // Phase 2: kNNLib now uses domain-agnostic category parameters
        [chosen_ids, chosen_dists, chosen_w, dbg_iter, dbg_hskip, dbg_nskip, final_count] = kNNLib.f_hierarchical_tournament_backtest_signaware(rec.packed_snap, rec.f1_snap, rec.f2_snap, rec.f3_snap, rec.f4_snap, rec.f5_snap, rec.f6_snap, rec.f7_snap, family_id, setup_code, f1_history_quant, f2_history, f3_history, f4_history, f5_history, f6_history, f7_history, arr_setup_id, arr_setup_family, arr_packed_vec, knn_limit, knn_k, 4, knn_decluster_gap, 50)
        
        rec.knn_cands := final_count

        // P0: Forward bias check - log offset, knnlimit, and chosen_ids range
        // FIX Bug #7: Skip setup if forward bias detected (prevents future contamination)
        if array.size(chosen_ids) > 0
            int min_id = array.get(chosen_ids, 0)
            int max_id = array.get(chosen_ids, array.size(chosen_ids) - 1)
            bool forward_bias_detected = max_id >= offset
            if forward_bias_detected
                rec.mc_confirmed := false
                rec.mc_pct_agree := na
                rec.mc_confidence := na
                rec.knn_cands := final_count
                array.set(bt_setups, s - 1, rec)  // s already incremented at line 2458
                heavy_budget -= 1
                continue

        if array.size(chosen_ids) == 0
            rec.mc_confirmed := false
            rec.mc_pct_agree := na
            rec.mc_confidence := na
            rec.knn_cands := 0
            array.set(bt_setups, s - 1, rec)  // s already incremented at line 2458
            heavy_budget -= 1  // Count against budget even if kNN fails
            continue

        int chosen_w_size = array.size(chosen_w)
        float wsum = 0.0
        for i = 0 to chosen_w_size - 1
            wsum += array.get(chosen_w, i)
        if wsum > 0 and chosen_w_size > 0
            for i = 0 to chosen_w_size - 1
                array.set(chosen_w, i, array.get(chosen_w, i) / wsum)

        array.clear(bt_cw)
        float cw_run = 0.0
        for i = 0 to chosen_w_size - 1
            cw_run += array.get(chosen_w, i)
            array.push(bt_cw, cw_run)

        int paths_agree = 0
        int total_paths = 0
        int dir_agree = 0  // NEW: Simple directional agreement metric
        int mc_hz = tpsl_enable_maxhold_tp ? math.min(mc_horizon, math.min(rec.max_hold > 0 ? rec.max_hold : 20, 20)) : mc_horizon
        int ksz = array.size(chosen_ids)
        int fallback_idx = ksz - 1
        
        // P3: Validator direction mode logic
        bool use_setup_direction = mc_validator_direction_mode == "Setup Direction"
        
        for run = 0 to bt_mc_runs - 1
            float rw = MCLib.f_prng(rec.bar_idx + run + 1, run + 1)
            int chosen_idx = array.get(chosen_ids, fallback_idx)
            for n = 0 to ksz - 1
                if rw <= array.get(bt_cw, n)
                    chosen_idx := array.get(chosen_ids, n)
                    break
            if chosen_idx + mc_hz >= csize_bt
                continue
            float priceA = rec.entry_price
            float priceB = rec.entry_price
            float nATR = nz(array.get(arr_ATR, chosen_idx))
            float nClose = array.get(arr_close, chosen_idx)
            float ns = nClose > 0 ? nATR * mc_noise_scale / nClose : 0.0
            for h = 0 to mc_hz - 1
                int fb = chosen_idx + h + 1
                if fb >= csize_bt
                    break
                float cur = array.get(arr_close, fb)
                float prev = array.get(arr_close, fb - 1)
                float hr = not na(cur) and not na(prev) and prev > 0 ? math.log(cur / prev) : 0.0
                float u1 = math.max(1e-10, MCLib.f_prng(rec.bar_idx + run * 997 + h * 61, 11))
                float u2 = MCLib.f_prng(rec.bar_idx + run * 991 + h * 67, 17)
                float z = math.sqrt(-2.0 * math.log(u1)) * math.cos(6.2831853 * u2)
                priceA *= math.exp(hr + z * ns)
                priceB *= math.exp(hr - z * ns)
            
            if use_setup_direction
                // TRUE-TRAJECTORY VALIDATION: Check actual TP/SL levels with path tracking
                float target_px = rec.entry_price * (1.0 + (rec.tp_pct / 100.0) * (is_long ? 1.0 : -1.0))
                float stop_px = rec.entry_price * (1.0 - (math.abs(rec.sl_pct) / 100.0) * (is_long ? 1.0 : -1.0))
                
                // Track path high/low inside the simulation loop
                float pathHighA = priceA
                float pathLowA = priceA
                float pathHighB = priceB
                float pathLowB = priceB
                
                for h = 0 to mc_hz - 1
                    int fb = offset + h + 1  // FIX: use offset (array index) not rec.bar_idx (absolute bar)
                    if fb >= csize_bt
                        break
                    float cur = array.get(arr_close, fb)
                    float prev = array.get(arr_close, fb - 1)
                    float hr = not na(cur) and not na(prev) and prev > 0 ? math.log(cur / prev) : 0.0
                    float u1 = math.max(1e-10, MCLib.f_prng(rec.bar_idx + run * 997 + h * 61, 11))
                    float u2 = MCLib.f_prng(rec.bar_idx + run * 991 + h * 67, 17)
                    float z = math.sqrt(-2.0 * math.log(u1)) * math.cos(6.2831853 * u2)
                    float ns = nClose > 0 ? nATR * mc_noise_scale / nClose : 0.0
                    priceA *= math.exp(hr + z * ns)
                    priceB *= math.exp(hr - z * ns)
                    
                    // Update path high/low tracking
                    pathHighA := math.max(pathHighA, priceA)
                    pathLowA := math.min(pathLowA, priceA)
                    pathHighB := math.max(pathHighB, priceB)
                    pathLowB := math.min(pathLowB, priceB)
                
                // Check if path reached target before stop (using high/low tracking)
                bool is_win_A = is_long ? (pathHighA >= target_px) : (pathLowA <= target_px)
                bool is_loss_A = is_long ? (pathLowA <= stop_px) : (pathHighA >= stop_px)
                bool is_win_B = is_long ? (pathHighB >= target_px) : (pathLowB <= target_px)
                bool is_loss_B = is_long ? (pathLowB <= stop_px) : (pathHighB >= stop_px)
                
                // Only count paths that actually reached the profit target
                paths_agree += (is_win_A and not is_loss_A) ? 1 : 0
                paths_agree += (is_win_B and not is_loss_B) ? 1 : 0
                
                // NEW: Simple directional agreement (comparable to live MC oracle)
                dir_agree += is_long ? (priceA > rec.entry_price ? 1 : 0) : (priceA < rec.entry_price ? 1 : 0)
                dir_agree += is_long ? (priceB > rec.entry_price ? 1 : 0) : (priceB < rec.entry_price ? 1 : 0)
            else
                // P3: Best MC Direction mode - score both directions and use the stronger one
                int long_agree = (priceA > rec.entry_price ? 1 : 0) + (priceB > rec.entry_price ? 1 : 0)
                int short_agree = (priceA < rec.entry_price ? 1 : 0) + (priceB < rec.entry_price ? 1 : 0)
                // FIXED: Require higher threshold to overcome 50/50 random bias
                paths_agree += (math.max(long_agree, short_agree) >= 2) ? 2 : math.max(long_agree, short_agree)
                
                // NEW: Direction agreement for Best MC Direction mode
                dir_agree += math.max(long_agree, short_agree)
            total_paths += 2

        rec.mc_pct_agree := total_paths > 0 ? paths_agree * 100.0 / total_paths : na
        
        // NEW: Direction agreement percentage for concordance filter
        rec.mc_dir_pct := total_paths > 0 ? dir_agree * 100.0 / total_paths : na
        
        // CONCORDANCE FILTER: Use directional agreement for gate, TP/SL for RR quality
        bool strength_ok = not na(rec.mc_dir_pct) and rec.mc_dir_pct >= bt_agree_pct
        bool direction_match = false
        
        // Track long/short agreement separately for mc_oracle_dir (needed outside if/else)
        int long_agree_total = 0
        int short_agree_total = 0
        
        if use_setup_direction
            // In Setup Direction mode, direction is inherently matched by validation logic
            direction_match := true
        else
            // In Best MC Direction mode, check if MC direction matches setup direction
            
            for run = 0 to bt_mc_runs - 1
                float rw = MCLib.f_prng(rec.bar_idx + run + 1, run + 1)
                float priceA = rec.entry_price
                float priceB = rec.entry_price
                
                // Use same ATR-normalized noise as main MC loop (not 0.1 multiplier)
                int concIdx = math.max(0, math.min(rec.bar_idx - (bar_index - csize_bt + 1), csize_bt - 1))
                float concATR = nz(array.get(arr_ATR, concIdx))
                float concClose = array.get(arr_close, concIdx)
                float ns = concClose > 0 ? concATR * mc_noise_scale / concClose : 0.0
                
                // Simulate paths (simplified version for direction checking)
                for h = 0 to mc_hz - 1
                    int baseOffset = rec.bar_idx - (bar_index - csize_bt + 1)
                    int fb = baseOffset + h + 1
                    if fb >= csize_bt
                        break
                    float cur = array.get(arr_close, fb)
                    float prev = array.get(arr_close, fb - 1)
                    float hr = not na(cur) and not na(prev) and prev > 0 ? math.log(cur / prev) : 0.0
                    float u1 = math.max(1e-10, MCLib.f_prng(rec.bar_idx + run * 997 + h * 61, 11))
                    float u2 = MCLib.f_prng(rec.bar_idx + run * 991 + h * 67, 17)
                    float z = math.sqrt(-2.0 * math.log(u1)) * math.cos(6.2831853 * u2)
                    priceA *= math.exp(hr + z * ns)
                    priceB *= math.exp(hr - z * ns)
                
                // Count direction agreement
                long_agree_total += (priceA > rec.entry_price ? 1 : 0) + (priceB > rec.entry_price ? 1 : 0)
                short_agree_total += (priceA < rec.entry_price ? 1 : 0) + (priceB < rec.entry_price ? 1 : 0)
            
            // Check if MC direction matches setup direction
            direction_match := is_long ? (long_agree_total > short_agree_total) : (short_agree_total > long_agree_total)
        
        // Set Oracle direction based on MC agreement
        rec.mc_oracle_dir := long_agree_total > short_agree_total ? "BULL" : "BEAR"
        rec.mc_confirmed := strength_ok  // Use directional agreement for gate
        rec.mc_confidence := math.min(100.0, float(array.size(chosen_ids)) / knn_k * 100.0)
        
        // P2: CSV export logging per setup for scatter plot analysis
        if not na(rec.mc_pct_agree) and not na(rec.actual_pnl)
            // FIX Bug #1: Remove format truncation for scatter plot precision
            string csv_line = rec.setup_id + "," + rec.direction + "," + str.tostring(rec.mc_pct_agree) + "," + str.tostring(rec.actual_pnl)
            // CSV: " + csv_line
        
        array.set(bt_setups, s - 1, rec)  // s already incremented at line 2458

        bt_validated_setups += 1
        bt_agree_sum += nz(rec.mc_pct_agree, 0.0)
        
        // Track scan range (first and last validated bar)
        if na(bt_first_bar)
            bt_first_bar := rec.bar_idx
        bt_last_bar := rec.bar_idx
        if not na(rec.actual_pnl)
            bt_raw_total += 1
            bt_raw_pnl_sum += rec.actual_pnl
            if rec.actual_pnl > 0
                bt_raw_wins += 1
            bt_raw_mae_sum += math.abs(nz(rec.actual_mae, 0.0))
            bt_raw_mfe_sum += nz(rec.actual_mfe, 0.0)
            float delta = rec.actual_pnl - bt_raw_mean
            bt_raw_mean := bt_raw_mean + delta / bt_raw_total
            float delta2 = rec.actual_pnl - bt_raw_mean
            bt_raw_m2 := bt_raw_m2 + delta * delta2
        if rec.mc_confirmed
            bt_confirmed_setups += 1
            if not na(rec.actual_pnl)
                bt_filt_total += 1
                bt_filt_pnl_sum += rec.actual_pnl
                if rec.actual_pnl > 0
                    bt_filt_wins += 1
                bt_filt_mae_sum += math.abs(nz(rec.actual_mae, 0.0))
                bt_filt_mfe_sum += nz(rec.actual_mfe, 0.0)
                float delta_f = rec.actual_pnl - bt_filt_mean
                bt_filt_mean := bt_filt_mean + delta_f / bt_filt_total
                float delta2_f = rec.actual_pnl - bt_filt_mean
                bt_filt_m2 := bt_filt_m2 + delta_f * delta2_f
        
        heavy_budget -= 1  // Count this heavy validation
    
    bt_chunk_idx := s
    if bt_chunk_idx >= bt_total_setups
        bt_phase := 2
        // ── MC AGREE LOG DUMP (paste into Pine Logs, copy-paste to CSV) ──
        // FIX 6: Added mc_dir_mode and vel_fix columns for cross-file comparison
        // Format: BAR_IDX | SETUP_ID | DIR | ENTRY | MC_AGREE% | DIR_PCT% | CONFIRMED | CONFIDENCE | PNL% | MAE% | MFE% | EXIT | DIR_MODE | VEL_FIX
        string vel_fix_str = "true"  // ltf_corr_ema uses math.abs() from this version
        string dir_mode_str = mc_validator_direction_mode == "Setup Direction" ? "setup" : "best"
        log.info("MC_LOG_HEADER: bar_idx|setup_id|direction|entry_price|mc_pct_agree|mc_dir_pct|mc_confirmed|mc_confidence|actual_pnl|actual_mae|actual_mfe|exit_reason|mc_dir_mode|vel_recouple_abs_fix")
        int _log_n = array.size(bt_setups)
        if _log_n > 0
            for _li = 0 to _log_n - 1
                HistoricalSetup _ls = array.get(bt_setups, _li)
                log.info("MC_LOG:" + str.tostring(_ls.bar_idx) + "|" + _ls.setup_id + "|" + _ls.direction + "|" + str.tostring(_ls.entry_price, "#.######") + "|" + str.tostring(_ls.mc_pct_agree, "#.##") + "|" + str.tostring(_ls.mc_dir_pct, "#.##") + "|" + str.tostring(_ls.mc_confirmed) + "|" + str.tostring(_ls.mc_confidence, "#.##") + "|" + str.tostring(_ls.actual_pnl, "#.####") + "|" + str.tostring(_ls.actual_mae, "#.####") + "|" + str.tostring(_ls.actual_mfe, "#.####") + "|" + _ls.exit_reason + "|" + dir_mode_str + "|" + vel_fix_str)
    // BT progress tracked every 100 chunks
    if bt_chunk_idx % 100 == 0
        bt_last_seen_attempt := bt_chunk_idx  // Update progress marker

// ── BT PHASE 2: Backtest Summary Calculation (one tick) ──
// Stage 7 (DR-4): Backtest completes independently, never resets MC state
// Only set ready flag, actual rendering moved to main UI loop
if bt_phase == 2
    bt_avg_agree := bt_validated_setups > 0 ? bt_agree_sum / bt_validated_setups : na
    bt_table_ready := true
    int bt_rec_size = array.size(bt_setups)
    int bt_scan_range = not na(bt_first_bar) and not na(bt_last_bar) ? bt_last_bar - bt_first_bar + 1 : na
    bt_audit_log := "AUD setups=" + str.tostring(bt_rec_size) + " val=" + str.tostring(bt_validated_setups) + " raw=" + str.tostring(bt_raw_total) + " filt=" + str.tostring(bt_filt_total) + " conf=" + str.tostring(bt_confirmed_setups) + " rng=" + str.tostring(bt_scan_range)
    
    // Build Candidates Summary
    array.clear(bt_u_setups)
    array.clear(bt_u_cands)
    array.clear(bt_u_mc_conf)
    array.clear(bt_u_cnt)
    
    for _i = 0 to bt_rec_size - 1
        HistoricalSetup rec = array.get(bt_setups, _i)
        // Skip setups that were not fully processed (na knn_cands means they were skipped due to warmup or forward bias)
        if not na(rec.knn_cands)
            string sid = rec.setup_id
            int cands = rec.knn_cands
            float mcconf = nz(rec.mc_confidence)
            int idx = array.indexof(bt_u_setups, sid)
            if idx == -1
                array.push(bt_u_setups, sid)
                array.push(bt_u_cands, cands)
                array.push(bt_u_mc_conf, mcconf)
                array.push(bt_u_cnt, 1)
            else
                array.set(bt_u_cands, idx, array.get(bt_u_cands, idx) + cands)
                array.set(bt_u_mc_conf, idx, array.get(bt_u_mc_conf, idx) + mcconf)
                array.set(bt_u_cnt, idx, array.get(bt_u_cnt, idx) + 1)
            
    string cands_str = ""
    for _j = 0 to array.size(bt_u_setups) - 1
        int avg_cands = int(math.round(array.get(bt_u_cands, _j) / array.get(bt_u_cnt, _j)))
        cands_str += array.get(bt_u_setups, _j) + ":" + str.tostring(avg_cands) + " "
    bt_cands_log := cands_str

    bt_phase3_idx := bt_rec_size
    bt_phase3_overflow := false
    bt_phase := 3  // Move to render state

// ── BT PHASE 3: Continuous Label Rendering ──
// Labels must be recolored on EVERY tick after validation is done,
// otherwise Pine Script's rollback mechanic reverts them to their initial color.
// CRITICAL: Must run on every realtime tick, not just history edge
var int current_painted_labels = 0
if bt_phase >= 3 and (barstate.isrealtime or barstate.islast)
    int bt_size = array.size(bt_setups)
    int painted_cnt = 0
    
    // Render loop: process all live labels every tick
    if bt_size > 0
        for j = bt_size - 1 to 0
            HistoricalSetup rec = array.get(bt_setups, j)
            
            // Reverse repaint: prioritize freshest visible labels first
            if not na(rec.setup_label)
                painted_cnt += 1
                bool is_long_bt = rec.direction == "LONG"
                if rec.mc_confirmed
                    bool is_win_bt = not na(rec.actual_pnl) and rec.actual_pnl > 0
                    // Win: solid bright colors, Loss: dark colors (no transparency)
                    color new_col = is_long_bt ? (is_win_bt ? color.new(color.lime, 0) : color.new(color.green, 0)) : (is_win_bt ? color.new(color.red, 0) : color.new(color.maroon, 0))
                    label.set_color(rec.setup_label, new_col)
                    // Text annotations only if debug flag enabled
                    if show_setupsdb_debug
                        label.set_text(rec.setup_label, rec.setup_id + (is_win_bt ? " W" : " X"))
                else
                    label.set_color(rec.setup_label, color.new(is_long_bt ? color.lime : color.red, 80))
                    if show_setupsdb_debug
                        label.set_text(rec.setup_label, rec.setup_id + " ?")
        current_painted_labels := painted_cnt

var int last_setup_trigger_bar = 0
// Armed setup variables removed - obsolete with setupsDB architecture

// ── BT FEATURE EXPORT FOR METRIC LEARNING ──
// Fires once after BT summary completes. Paste output into CSV.
// FIX 6: Added mc_dir_mode and vel_fix columns
if bt_phase == 2 and barstate.islast
    string vel_fix_str2 = "true"
    string dir_mode_str2 = mc_validator_direction_mode == "Setup Direction" ? "setup" : "best"
    // FIX Bug #5: Add setup_code and entry_ctx to header
    log.info("ML_EXPORT_HEADER: baridx,setupid,direction,setup_code,entry_ctx,f1,f2,f3,f4,f5,f6,f7,family_id,coupling_regime,basket_fit_norm,rho,mc_oracle_dir,actualpnl,actualmae,actualmfe,exitreason,mcconfirmed,mcconfidence")
    int exportcount = array.size(bt_setups)
    // FIX CRITICAL Export Bugs: (1) Full precision, (2) No 5-row limit, (3) Add entry_ctx + setup_code
    log.info("ML_EXPORT_DEBUG: bt_setups size = " + str.tostring(exportcount))
    if exportcount > 0
        for i = 0 to exportcount - 1  // FIX Bug #2: Remove artificial 5-row limit
            HistoricalSetup s = array.get(bt_setups, i)
            bool hasoutcome = not na(s.actual_pnl)
            // Check if hist_avail field exists and is valid
            int hist_check = na(s.hist_avail) ? 0 : s.hist_avail
            if hasoutcome and hist_check > 0
                // FIX Bug #1: Remove format strings for full precision (no truncation)
                // FIX Bug #5: Add setup_code and entry_ctx for market-state awareness
                string row = "ML_EXPORT_ROW|" + str.tostring(s.bar_idx) + "," + s.setup_id + "," + s.direction + "," + str.tostring(s.setup_code) + "," + str.tostring(s.entry_ctx) + "," + str.tostring(s.f1_snap) + "," + str.tostring(s.f2_snap) + "," + str.tostring(s.f3_snap) + "," + str.tostring(s.f4_snap) + "," + str.tostring(s.f5_snap) + "," + str.tostring(s.f6_snap) + "," + str.tostring(s.f7_snap) + "," + str.tostring(s.family_snap.id) + "," + str.tostring(s.coupling_regime_snap) + "," + str.tostring(s.basket_fit_norm_snap) + "," + str.tostring(s.rho_snap) + "," + s.mc_oracle_dir + "," + str.tostring(s.actual_pnl) + "," + str.tostring(s.actual_mae) + "," + str.tostring(s.actual_mfe) + "," + s.exit_reason + "," + str.tostring(s.mc_confirmed) + "," + str.tostring(s.mc_confidence)
                log.info(row)
        log.info("ML_EXPORT_DONE: " + str.tostring(exportcount) + " rows")

f_fire_setup_by_id(string fire_setup_id, string fire_tooltip, string fire_size_info, int last_trigger_bar) =>
    int out_last_trigger_bar = last_trigger_bar
    float out_mae = na
    float out_mfe = na
    float out_entry_ctx = na
    int out_fire_code = 0
    
    // setupsDB architecture: find config in cache
    SetupsDB.SetupConfig cfg = na
    for i = 0 to array.size(setupsdb_cache) - 1
        SetupsDB.SetupConfig c = array.get(setupsdb_cache, i)
        if c.id == fire_setup_id
            cfg := c
            break
    
    if na(cfg)
        // Setup not found in cache - skip
        [pos, out_last_trigger_bar, out_mae, out_mfe, out_entry_ctx, out_fire_code]
    else
        // Freshness check: direction-aware — a LONG won't be blocked by a recent SHORT
        bool is_stale = cfg.dir == "LONG" ? (bar_index - last_pred_long_bar < 3) : (bar_index - last_pred_short_bar < 3)
        // MC Cone direction filter: suppress if cone disagrees with setup direction
        bool cone_conflict = mc_opt_score >= 0.6 and mc_opt_dir != "" and ((cfg.dir == "LONG" and mc_opt_dir == "BEAR") or (cfg.dir == "SHORT" and mc_opt_dir == "BULL"))
        if is_stale or cone_conflict
            [pos, out_last_trigger_bar, out_mae, out_mfe, out_entry_ctx, out_fire_code]
        else
            out_last_trigger_bar := bar_index
            string setup_name = cfg.name
            string setup_dir = cfg.dir
            float setup_wr = cfg.wr
            float setup_sharpe = cfg.sharpe
            float setup_tp = cfg.tp_pct
            float setup_sl = cfg.sl_pct
            
            // MC-INFORMED ADAPTIVE TP: Use mc_opt_horizon from live cone to override fixed TP
            float mc_tp = na
            if tpsl_enable_maxhold_tp and mc_opt_score > 0.3 and mc_opt_horizon < tpsl_max_hold
                // Use P50 at optimal horizon as MC-suggested target
                int opt_idx = math.max(0, mc_opt_horizon - 1)
                if array.size(mc_progressive_p50) > opt_idx
                    float mc_target_price = array.get(mc_progressive_p50, opt_idx)
                    bool is_long = setup_dir == "LONG"
                    mc_tp = is_long ? (mc_target_price - close) / close * 100.0 : (close - mc_target_price) / close * 100.0
            
            // Use the tighter of MC-TP and SetupDB-TP
            float effective_tp = not na(mc_tp) and mc_tp > 0 ? math.min(setup_tp, mc_tp) : setup_tp
            
            // cfg.code is the authoritative code — always non-zero for all SetupConfig entries
            out_fire_code := cfg.code
            
            [r_pos, r_mae, r_mfe, r_entry_ctx] = f_fire_setup(fire_setup_id, setup_name, setup_dir, setup_dir, setup_wr, setup_sharpe, effective_tp, setup_sl, fire_tooltip, fire_size_info, out_fire_code)
            out_mae := r_mae
            out_mfe := r_mfe
            out_entry_ctx := r_entry_ctx

            // FIX 7: Guard multi-fire race — only write if this bar's slot hasn't been claimed yet
            int setup_id_count = array.size(arr_setup_id)
            if setup_id_count > 0
                int last_code = array.get(arr_setup_id, setup_id_count - 1)
                int fire_setup_code = out_fire_code  // Use the hash we already calculated
                if fire_setup_code != 0 and last_code == 0
                    array.set(arr_setup_id, setup_id_count - 1, fire_setup_code)

            [r_pos, out_last_trigger_bar, out_mae, out_mfe, out_entry_ctx, out_fire_code]

f_add_signal_label(string marker_text, string tooltip_text, bool is_long, float y_price, color marker_color) =>
    // Guard against disabled setup labels - only create if enabled
    if show_setup_labels
        int overlay_label_count = array.size(overlay_labels)
        if overlay_label_count >= 100
            old_lbl = array.shift(overlay_labels)
            if not na(old_lbl)
                label.delete(old_lbl)
        label new_lbl = label.new(bar_index, y_price, marker_text, yloc=yloc.price, color=marker_color, textcolor=color.black, style=is_long ? label.style_label_up : label.style_label_down, size=size.tiny, tooltip=tooltip_text, force_overlay=true)
        array.push(overlay_labels, new_lbl)

// ═══════════════════════════════════════════════════════════════════════════
// IMPULSE CONTEXT SUPPRESSOR
// ═══════════════════════════════════════════════════════════════════════════
// Blocks counter-trend setups during vertical moves (S5/V2/73% shorting into pump)
// Uses pred slope + price velocity confirmation to avoid Kalman overshoot false positives

// Impulse detection: pred slope steep AND price confirming
float pred_slope_raw = pred_ma - nz(pred_ma[3])  // 3-bar pred delta
float pred_slope_atr = pred_slope_raw / math.max(ta.atr(14), syminfo.mintick)  // Normalized by volatility
float price_move_atr = (close - nz(close[5])) / math.max(ta.atr(14), syminfo.mintick)  // 5-bar price move

// Binary impulse flags (for hard blocking)
bool impulse_up = pred_slope_atr > 0.3 and price_move_atr > 1.0
bool impulse_down = pred_slope_atr < -0.3 and price_move_atr < -1.0

// Graded impulse strength (for soft suppression)
// Ramps from 0 (no impulse) to 1 (max impulse) between 0.15 and 0.45 ATR slope
float impulse_strength_up = math.max(0, math.min(1, (pred_slope_atr - 0.15) / 0.3))
float impulse_strength_down = math.max(0, math.min(1, (-pred_slope_atr - 0.15) / 0.3))

// Dynamic confidence requirement: 50% baseline + 20% during max impulse = 70% required
float short_conf_requirement = 50 + impulse_strength_up * 20
float long_conf_requirement = 50 + impulse_strength_down * 20

// Setup detection logic (simplified for key setups)
bool cfv_rising = fv_cyclic_kalman > nz(fv_cyclic_kalman[1]) and fv_cyclic_kalman[1] > nz(fv_cyclic_kalman[2])
float mr_for_setups = enable_normalization ? mr_vol_adj : mr_osc
// FIX 1: Reset actualfiresignal at bar start (only set when a setup passes ALL gates in f_fire_setup_byid)
actualfiresignal := 0

// FIX 4: Coupling gate — block setups in decoupled regime (WR 54.8%, Sharpe 0.2)
bool coupling_gate = not is_decoupled  // ctx >= partial (is_partial or is_attached)
bool coupling_gate_strict = is_attached  // ctx == full coupling only

// FIX 3: MR double-zone for short setups (dead zone -1.5...-0.3 excluded)
// Zone A: MR near zero (beginning of reversal) → Sharpe 45.0, WR 83.3%
// Zone B: MR deep extreme (oversold bounce) → Sharpe 51.7, WR 79.2%
bool mr_short_sweet = (mr_for_setups > -0.3 and mr_for_setups < 0.3) or (mr_for_setups < -1.5)
// Mirror for long setups
bool mr_long_sweet = (mr_for_setups > -0.3 and mr_for_setups < 0.3) or (mr_for_setups > 1.5)

// FIX 1: Stale context gate — suppress setups on the bar where coupling regime just flipped
var int _prev_coupling_regime = 0
bool coupling_just_flipped = coupling_regime != _prev_coupling_regime
_prev_coupling_regime := coupling_regime

// ═══════════════════════════════════════════════════════════════════════════
// DATA-DRIVEN SETUP ROUTING (setupsDB Architecture)
// ═══════════════════════════════════════════════════════════════════════════
// Pred round detection (used in bitfield diagnostics)
bool pred_round_long = (math.abs(ma_slope) < vert_dev0 * pred_round_pivot_range and ma_accel > 0) or (ma_slope < 0 and ma_accel > 0)
bool pred_round_short = (math.abs(ma_slope) < vert_dev0 * pred_round_pivot_range and ma_accel < 0) or (ma_slope > 0 and ma_accel < 0)
int cooldown_bars = 15  // Display value for info table

bool allow_long = not is_falling_knife
bool allow_short = not is_falling_knife

// =====================================================================
// --- ZIGZAG PERCENTILE EXHAUSTION (STRUCTURAL MACRO SHOWSTOPPER) ---
// =====================================================================
// Measures amplitude of alternating ZigZag structural legs
// 85th percentile of these amplitudes = exhaustion threshold
// Blocks late setups when price has displaced beyond this threshold

string exh_mode = input.string("Hard Gate", "Exhaustion Mode", options=["Off", "Hard Gate", "Confidence Penalty", "Penalty + Boost Opposite"], group="Exhaustion Primitive")
float exh_penalty = input.float(15.0, "Exhaustion WR Penalty %", minval=0.0, maxval=50.0, step=5.0, group="Exhaustion Primitive", tooltip="How much to reduce setup's Win Rate when exhausted")

var array<float> zz_leg_amps = array.new_float(0)
var int zz_dir = 0
var float zz_last_ph = na
var float zz_last_pl = na
var float running_ph = na
var float running_pl = na
var float exh_p85 = na
var int exh_recalc_ctr = 0

// Detect pivots with wide structural lookback (65 left, 100 right = confirmed macro pivots)
float exh_ph = ta.pivothigh(high, 65, 100)
float exh_pl = ta.pivotlow(low, 65, 100)

// Strict ZigZag Alternation & Amplitude Collection
if not na(exh_ph)
    float cur_ph = nz(high[100], high)
    if zz_dir <= 0  // Switch to UP leg
        zz_dir := 1
        if not na(zz_last_pl)
            float amp = math.abs(cur_ph - zz_last_pl)
            if amp > 0
                array.push(zz_leg_amps, amp)
                if array.size(zz_leg_amps) > 60
                    array.shift(zz_leg_amps)
        zz_last_ph := cur_ph
        running_ph := cur_ph
    else // Still in UP leg, update extreme if higher
        if cur_ph > nz(zz_last_ph, 0.0)
            zz_last_ph := cur_ph
            running_ph := math.max(nz(running_ph, 0.0), cur_ph)

if not na(exh_pl)
    float cur_pl = nz(low[100], low)
    if zz_dir >= 0  // Switch to DOWN leg
        zz_dir := -1
        if not na(zz_last_ph)
            float amp = math.abs(zz_last_ph - cur_pl)
            if amp > 0
                array.push(zz_leg_amps, amp)
                if array.size(zz_leg_amps) > 60
                    array.shift(zz_leg_amps)
        zz_last_pl := cur_pl
        running_pl := cur_pl
    else // Still in DOWN leg, update extreme if lower
        if cur_pl < nz(zz_last_pl, 9999999.0)
            zz_last_pl := cur_pl
            running_pl := math.min(nz(running_pl, 9999999.0), cur_pl)

// Update running extremes on every bar to eliminate the 100-bar blind spot
if zz_dir == 1
    running_ph := math.max(nz(running_ph, high), high)
else if zz_dir == -1
    running_pl := math.min(nz(running_pl, low), low)

// Recalculate 85th percentile every 25 bars (cheap)
exh_recalc_ctr += 1
if (exh_recalc_ctr >= 25 or na(exh_p85)) and array.size(zz_leg_amps) >= 8
    exh_recalc_ctr := 0
    var array<float> exh_sorted = array.new_float(0)
    array.clear(exh_sorted)
    for i = 0 to array.size(zz_leg_amps) - 1
        array.push(exh_sorted, array.get(zz_leg_amps, i))
    array.sort(exh_sorted, order.ascending)
    int idx85 = int(math.round(array.size(exh_sorted) * 0.85))
    exh_p85 := array.get(exh_sorted, math.max(0, math.min(idx85, array.size(exh_sorted) - 1)))

// System-wide showstopper flags based on current leg extension
float exh_dist_from_low = na
float exh_dist_from_high = na
if zz_dir == 1
    exh_dist_from_low := not na(zz_last_pl) ? close - zz_last_pl : na
    exh_dist_from_high := not na(running_ph) ? running_ph - close : na
else if zz_dir == -1
    exh_dist_from_low := not na(running_pl) ? close - running_pl : na
    exh_dist_from_high := not na(zz_last_ph) ? zz_last_ph - close : na

bool exh_block_long = not na(exh_p85) and not na(exh_dist_from_low) and exh_dist_from_low > exh_p85
bool exh_block_short = not na(exh_p85) and not na(exh_dist_from_high) and exh_dist_from_high > exh_p85

// OLD HARDCODED SETUPS REMOVED - Now using setupsDB architecture
// Note: setupsDB.evaluate_all() call and processing moved after innov_band definition (line ~3280)

// DEBUG REMOVED: setup_debug_code, setup_debug_mask
// Engine event processing moved to after setupsDB.evaluate_all() call (line ~3273)

// Per-bar level tracker update (sweep detection + line extension)
if show_setup_labels
    SetupsLib.f_update_levels(level_trackers, high, low, bar_index)

// Prune oldest TP/SL lines when limit reached (configurable 20-450, uses available line slots)
// Auto-delete oldest 10% of lines to make room for new positions
if array.size(level_trackers) > max_tpsl_lines
    int prune_count = math.max(1, int(max_tpsl_lines * 0.1))  // Delete 10% of limit
    for i = 0 to prune_count - 1
        SetupsLib.LevelTracker t = array.shift(level_trackers)
        if not na(t.ln)
            line.delete(t.ln)

// ═══════════════════════════════════════════════════════════════════════════
// PREDFLIP + BREAKEVEN EXIT STRATEGY
// ═══════════════════════════════════════════════════════════════════════════
// Strategy C from backtest: +200-333% improvement over fixed 10-bar exit
// Exit logic:
//   1. If PnL > 0 after 5 bars → hold until pred_ma color flip
//   2. If PnL ≤ 0 after 5 bars → close at breakeven (0% loss)
//   3. Hard stop -1.8% always active

if pos.is_active and bar_index > pos.entry_bar
    // Position metrics
    int bars_held = bar_index - pos.entry_bar
    float pos_pnl = pos.dir == "LONG" ? (close - pos.entry_price) / pos.entry_price * 100 : (pos.entry_price - close) / pos.entry_price * 100
    
    // Track max PnL for trailing activation
    var float max_pnl = 0.0
    if pos.is_active and bar_index == pos.entry_bar
        max_pnl := 0.0
        min_pnl := 0.0
    if pos.is_active
        max_pnl := math.max(max_pnl, pos_pnl)
        min_pnl := math.min(min_pnl, pos_pnl)
    
    // Pred MA slope detection (3-bar comparison - matches backtest)
    bool pred_rising = pred_ma > nz(pred_ma[3], pred_ma)
    bool pred_rising_1ago = nz(pred_ma[1], pred_ma) > nz(pred_ma[4], pred_ma)
    
    // Unified exit evaluation via SetupsLib
    var float trail_sl = na
    [exit_code, temp_trail_sl] = SetupsLib.f_evaluate_exit(pos.dir, pos_pnl, max_pnl, bars_held, high, low, pos.tp1, trail_sl, pred_ma, pred_rising, pred_rising_1ago)
    trail_sl := temp_trail_sl
    
    // Process exit (unified handler)
    if exit_code >= 0
        last_exit_reason_code := exit_code
        last_exit_bars_held := bars_held
        last_exit_pnl := pos_pnl
        last_exit_mae := math.min(min_pnl, 0.0)
        last_exit_mfe := max_pnl
        last_exit_basket_fit := basket_fit
        
        // Update label with exit marker and tooltip via SetupsLib
        SetupsLib.f_update_exit_label(pos.setup_label, pos.setup_id, pos.dir, exit_code, pos_pnl)
        if not na(pos.setup_label)
            string exit_info = SetupsLib.f_get_exit_info(exit_code)
            label.set_tooltip(pos.setup_label, pos.tooltip + exit_info)
        
        // Cleanup
        trail_sl := na
        max_pnl := 0.0
        min_pnl := 0.0
        if pos.levels_idx >= 0
            SetupsLib.f_freeze_levels(level_trackers, pos.levels_idx, pos.levels_cnt)
        pos := ActivePosition.new("", "", 0, na, na, na, na, na, na, na, false, na, "", -1, 0, -1)
    else if tpsl_enable_maxhold_tp and bar_index - pos.entry_bar > tpsl_max_hold
        if pos.levels_idx >= 0
            SetupsLib.f_freeze_levels(level_trackers, pos.levels_idx, pos.levels_cnt)
        pos := ActivePosition.new("", "", 0, na, na, na, na, na, na, na, false, na, "", -1, 0, -1)

// --- SIGNAL LOGIC ---
// 1. Predictive Trend (Kalman State)

// 2. Mean Reversion Potential (Price vs FV)
mr_bull = c0 < fv_cyclic
mr_bear = c0 > fv_cyclic

// --- MR CONFLUENCE LOGIC (Data-Driven) ---

// Optimal MR Sweet Spot: 0.7-0.9 (avoids falling knife > 0.95)
// Strong Bull MR: Price undervalued (0.7-0.9) + Trend not collapsing
bool is_strong_bull_mr = (mr_norm > 0.7 and mr_norm < 0.95) and (ma_trend > -0.5)

// Strong Bear MR: Price overvalued (< -0.5) + Trend not mooning
bool is_strong_bear_mr = (mr_norm < -0.5) and (ma_trend < 0.5)

// Falling Knife Warning: Extreme dump (MR > 0.95) - structural breakdown, not mean reversion
strong_bull = trend_bull and mr_bull
strong_bear = trend_bear and mr_bear

// --- PLOTTING ---

// 1. Predictive MA with MR Confluence Coloring
// Priority: Falling Knife > MR Confluence > Kalman Trend
// Decoupling now modulates color intensity instead of discrete switching
color col_ma_base = color.gray

if is_falling_knife
    col_ma_base := color.yellow  // Falling knife warning - don't catch!
else if bounce_signal
    col_ma_base := color.new(color.lime, 10)  // Bounce from median → trend continuation
else if is_strong_bull_mr
    // Strong bullish MR confluence: brighter green based on MR strength
    int opacity = int(100 * (1.0 - math.min(mr_norm, 1.0)))
    col_ma_base := color.new(color.lime, opacity)
else if is_strong_bear_mr
    // Strong bearish MR confluence: brighter red based on MR strength
    int opacity = int(100 * (1.0 - math.abs(mr_norm)))
    col_ma_base := color.new(color.red, opacity)
else
    // Default: Kalman trend gradient
    col_ma_base := est_trend > 0.05 ? color.from_gradient(est_trend, 0.05, 0.8, color.gray, color.lime) : (est_trend < -0.05 ? color.from_gradient(est_trend, -0.8, -0.05, color.red, color.gray) : color.gray)

// Pred MA transparency: self-normalized percentile rank on chosen coupling source
// corr_damping is sigmoid-compressed into [0.5,1.0] for most crypto → invert to spread range
// LTF correlation: higher |ema| = more coupled = more opaque → also invert
float _transp_raw = pred_ma_transparency_src == "LTF Correlation" ? (1.0 - math.abs(nz(ltf_corr_ema))) : (1.0 - nz(corr_damping, 0.5))
float _transp_pctile = nz(TAUtilityLib.f_percentile_rank_fisher(_transp_raw, 200), 0.5)  // Default 0.5 if na (early bars)
// FIX: Cap max transparency at 60% so pred MA line is always ≥40% opaque and visible
int transparency = int(10 + (_transp_pctile * 50))  // 10% base (coupled→10%), 60% ceiling (decoupled→60%)
col_ma = color.new(col_ma_base, transparency)
p_ma = plot(not pred_fv_color_candles ? pred_ma : na, "Predictive Vector MA", color=col_ma, linewidth=3, force_overlay=true)
barcolor(pred_fv_color_candles ? col_ma : na)

// PLOTTING PARAMETER CALCULATION FUNCTIONS
// ═══════════════════════════════════════════════════════════════════════════
// These functions calculate all intermediate variables for plotting (colors, transparency, conditions)
// and return tuples. All intermediate vars stay in function scope → don't count toward global limit.

// NOTE: f_calc_regime_events moved to line 1889 (before its call site)

// NOTE: f_calc_scan_correlation_scores moved to BasketLib for universal use
// Use BasketLib.f_calc_scan_correlation_scores() instead

// Survival Zone Colors & Fill Parameters — updated for squeeze throat detector
f_calc_survival_zone_params(bool force_low_fit, bool final_squeeze, bool squeeze_bull, bool squeeze_bear, bool sqz_armed, float sqz_score, bool strong_bull, bool strong_bear, color col_base, color col_ma_base, color innov_band_col, bool cld_cont, bool cld_exh) =>
    // Transparency boosts for low-fit regime
    int fill_boost = force_low_fit ? 5 : 0
    int fill_z1 = force_low_fit ? 96 : 90
    int fill_z2 = force_low_fit ? 92 : 85
    int fill_z2_squeeze = force_low_fit ? 88 : 80
    int fill_z3 = force_low_fit ? 90 : 85
    int fill_z3_squeeze = force_low_fit ? 86 : 75

    // Zone 3 plot color — throat active gets blue/white, armed gets dim blue
    color z3_col = final_squeeze ? (squeeze_bull ? color.new(color.blue, 40) : color.new(color.white, 40)) :
                   sqz_armed ? color.new(color.blue, 70) : color.new(color.gray, 80)

    // Zone 2 plot color — throat direction overrides, armed gets muted amber
    color z2_col = squeeze_bull ? color.new(color.rgb(0, 100, 0), fill_z2_squeeze) :
                   (squeeze_bear ? color.new(color.rgb(139, 0, 0), fill_z2_squeeze) :
                    (sqz_armed ? color.new(color.rgb(100, 50, 0), fill_z2_squeeze + 10) :
                     color.new(color.yellow, fill_z2)))

    // Zone 1 plot color
    color z1_col = final_squeeze ? (squeeze_bull ? color.new(color.rgb(0, 100, 0), fill_z1) : color.new(color.rgb(139, 0, 0), fill_z1)) : color.new(color.gray, fill_z1)

    // 3-way alignment detection
    bool ma_green = color.r(col_ma_base) < 128 and color.g(col_ma_base) > 128
    bool ma_red = color.r(col_ma_base) > 128 and color.g(col_ma_base) < 128
    bool innov_green = color.r(innov_band_col) < 128 and color.g(innov_band_col) > 128
    bool innov_red = color.r(innov_band_col) > 128 and color.g(innov_band_col) < 128
    bool cld_green = cld_cont
    bool cld_red = cld_exh
    bool all_green = ma_green and innov_green and cld_green
    bool all_red = ma_red and innov_red and cld_red

    // Zone 1 fill color — 3-way alignment only (MA + Innov + Cloud), no squeeze override
    color z1_fill = all_green ? color.new(color.lime, 50 + fill_boost) : (all_red ? color.new(color.red, 50 + fill_boost) :color.new(col_base, fill_z1))

    // Zone 2 fill color — throat direction + score overlay
    color z2_fill = squeeze_bull ? color.new(color.rgb(0, 100, 0), fill_z2_squeeze) :(squeeze_bear ? color.new(color.rgb(139, 0, 0), fill_z2_squeeze) : color.new(color.yellow, fill_z2))

    // Zone 3 fill colors with dynamic opacity — throat overrides
    int op_bull = strong_bull ? 70 : 85
    int op_bear = strong_bear ? 70 : 85
    int z3_bull_alpha = force_low_fit ? math.min(op_bull + 5, 100) : op_bull
    int z3_bear_alpha = force_low_fit ? math.min(op_bear + 5, 100) : op_bear
    int z3_sqz_alpha = int(60 + sqz_score * 25)  // 60-85 range
    color z3_upper_fill = squeeze_bull ? color.new(color.rgb(0, 100, 0), fill_z3_squeeze) :(squeeze_bear ? color.new(color.rgb(139, 0, 0), fill_z3_squeeze) :(final_squeeze ? color.new(color.blue, z3_sqz_alpha) :color.new(color.red, z3_bear_alpha)))
    color z3_lower_fill = squeeze_bull ? color.new(color.rgb(0, 100, 0), fill_z3_squeeze) :(squeeze_bear ? color.new(color.rgb(139, 0, 0), fill_z3_squeeze) :(final_squeeze ? color.new(color.blue, z3_sqz_alpha) :color.new(color.lime, z3_bull_alpha)))

    // Return tuple of all calculated parameters
    [z3_col, z2_col, z1_col, z1_fill, z2_fill, z3_upper_fill, z3_lower_fill]

// PLOTTING
// ═══════════════════════════════════════════════════════════════════════════

// 1. Baseline MA & Bands (Reference)
p_base = plot(ma0, "Baseline MA", color=col_base, linewidth=2, style=plot.style_line, force_overlay=true, display=simple_mode ? display.data_window : display.all)
// Baseline bands removed from plot to reduce clutter, as Survival Zones provide the main context

// 3. Cyclic FV (Reference) - plot Kalman-smoothed version if selected as MA source (KEEP IN SIMPLE MODE)
float fv_to_plot = innov_band_ma_source == "Kalman Cyclic FV" ? fv_cyclic_kalman : fv_cyclic
plot(fv_to_plot, "Cyclic FV", color=color.new(color.blue, 70), style=plot.style_line, linewidth=1, force_overlay=true)

// 3.1. V13: MR Target Band (Orthogonalized)
plot(mr_target_latch, "PhiLatch Target", color=color.new(color.purple, 60), style=plot.style_circles, linewidth=1, force_overlay=true)
plot(mr_target_orth, "PhiTotal Orth Target", color=color.new(color.purple, 30), linewidth=2, force_overlay=true)

// 3.5. Innovation Bands (Fast MA envelope)
// Configurable MA type and deviation method for optimal innovation detection
// Select source: Price or Kalman-smoothed Cyclic FV
float innov_source = innov_band_ma_source == "Kalman Cyclic FV" ? fv_cyclic_kalman : c0

float fast_ma = na
if innov_band_ma_type == "SMA"
    fast_ma := ta.sma(innov_source, innov_band_len)
else if innov_band_ma_type == "EMA"
    fast_ma := ta.ema(innov_source, innov_band_len)
else if innov_band_ma_type == "HMA"
    fast_ma := ta.hma(innov_source, innov_band_len)
else if innov_band_ma_type == "ALMA"
    fast_ma := ta.alma(innov_source, innov_band_len, 0.85, 6)
else if innov_band_ma_type == "Kalman"
    fast_ma := nz(TAUtilityLib.f_kalman(innov_source, 0.3), innov_source)
else if innov_band_ma_type == "KAMA"
    fast_ma := TAUtilityLib.f_kama(innov_source, innov_band_len, 2, 30)

// Calculate deviation using selected method
float fast_dev = na
if innov_band_dev_type == "StDev"
    // Standard deviation (SMA-based)
    fast_dev := ta.stdev(c0, innov_band_len)
else if innov_band_dev_type == "MAD"
    // Mean Absolute Deviation (EMA-based, more robust to spikes)
    float raw_dev = math.abs(c0 - fast_ma)
    fast_dev := ta.ema(raw_dev, innov_band_len) * 1.25  // 1.25 scales MAD to approximate StDev
else if innov_band_dev_type == "ATR"
    // Average True Range - measures actual bar-to-bar volatility including gaps
    fast_dev := ta.atr(innov_band_len)

float final_innov_mult = innov_band_mult
float innov_band_upper = fast_ma + (fast_dev * final_innov_mult)
float innov_band_lower = fast_ma - (fast_dev * final_innov_mult)

// ═══════════════════════════════════════════════════════════════════════════
// SETUP DATABASE EVALUATION (after innov_band definition)
// ═══════════════════════════════════════════════════════════════════════════
float innov_width = innov_band_upper - innov_band_lower
float innov_width_med = ta.median(innov_width, 50)

var array<SetupsDB.SetupConfig> triggered_setups = na
// Map z0 to discrete entry context codes: 1000 (LONG zone), 1100 (neutral), 1200 (SHORT zone)
// Strict thresholds: ±0.5 to properly separate mean-reversion from neutral/trend regimes
int entry_context_code = z0 < -0.5 ? 1000 : z0 > 0.5 ? 1200 : 1100

triggered_setups := SetupsDB.evaluate_all(
    entry_context_code,  // Entry context: 1000=LONG zone, 1100=neutral, 1200=SHORT zone
    nz(mr_for_setups),
    nz(basket_vec_z),     // vec: peer z-score vector
    nz(basket_fit),         // basket: 0-100 correlation score (NOT z-score)
    nz(f7_burst_raw),       // burst: raw float burst score (NOT bool)
    nz(te_osc),
    close,
    nz(fv_cyclic_kalman),
    nz(ma0),
    nz(pred_ma),
    nz(PhiTotal_orth),
    nz(innov_band_lower),
    nz(innov_band_upper),
    innov_width,
    innov_width_med,
    nz(z3_dn),
    false,  // vwap_short_rej (defined later at line ~3447)
    false,  // vwap_long_rej (defined later at line ~3447)
    squeeze_bull ? 1.0 : 0.0,  // Convert bool to float
    nz(mc_knn_confidence)
)

// LONGEVAL: dump all params when LONG zone reached (temporary debug)
if barstate.isconfirmed and entry_context_code == 1000
    int trig_cnt = na(triggered_setups) ? 0 : array.size(triggered_setups)
    float _inn_ratio = innov_width_med > 0 ? innov_width / innov_width_med : na
    log.info("LONGEVAL,bar=" + str.tostring(bar_index) +
             ",entryCtx=" + str.tostring(entry_context_code) +
             ",z0=" + str.tostring(z0, "#.###") +
             ",mr=" + str.tostring(mr_for_setups, "#.###") +
             ",vec=" + str.tostring(basket_vec_z, "#.###") +
             ",basket=" + str.tostring(basket_fit, "#.##") +
             ",burst=" + str.tostring(f7_burst_raw, "#.######") +
             ",te=" + str.tostring(te_osc, "#.###") +
             ",innW=" + str.tostring(innov_width, "#.####") +
             ",innWmed=" + str.tostring(innov_width_med, "#.####") +
             ",innRatio=" + str.tostring(_inn_ratio, "#.###") +
             ",knn=" + str.tostring(mc_knn_confidence, "#.##") +
             ",phiTotal=" + str.tostring(PhiTotal_orth, "#.###") +
             ",triggered=" + str.tostring(trig_cnt))

// Process triggered setups from setupsDB
array<SetupsLib.SetupEvent> engine_events = array.new<SetupsLib.SetupEvent>()
array.clear(setupsdb_cache)  // Clear cache for this bar

if array.size(triggered_setups) > 0
    for i = 0 to array.size(triggered_setups) - 1
        SetupsDB.SetupConfig cfg = array.get(triggered_setups, i)
        
        // Direction-based cooldown check
        int last_bar = cfg.dir == "SHORT" ? last_pred_short_bar : last_pred_long_bar
        bool is_dir_allowed = (cfg.dir == "SHORT" and allow_short) or (cfg.dir == "LONG" and allow_long)
        bool cooldown_ok = f_setup_cooldown_ok(cfg.id, cfg.dir, last_bar)
        
        bool exh_gate_ok = true
        if exh_mode == "Hard Gate"
            exh_gate_ok := (cfg.dir == "LONG" and not exh_block_long) or (cfg.dir == "SHORT" and not exh_block_short) or na(exh_p85)
            
        if is_dir_allowed and cooldown_ok and exh_gate_ok
            float final_wr = cfg.wr
            if exh_mode == "Confidence Penalty" or exh_mode == "Penalty + Boost Opposite"
                if exh_block_long and cfg.dir == "LONG"
                    final_wr -= exh_penalty
                if exh_block_short and cfg.dir == "SHORT"
                    final_wr -= exh_penalty
                
                if exh_mode == "Penalty + Boost Opposite"
                    if exh_block_long and cfg.dir == "SHORT"
                        final_wr += exh_penalty
                    if exh_block_short and cfg.dir == "LONG"
                        final_wr += exh_penalty
            
            cfg.wr := math.max(0.0, math.min(100.0, final_wr))
        // Cache config for f_fire_setup_by_id to use
        array.push(setupsdb_cache, cfg)
        // Register setup event with metadata using v2 (confidence-aware, showstopper-ready)
        SetupsLib.SetupSpec spec = SetupsLib.f_config_to_spec(
            cfg.id, cfg.name, cfg.dir, cfg.tp_pct, cfg.sl_pct, cfg.hold_bars,
            cfg.wr, cfg.sharpe, cfg.edgeratio, cfg.thesis, cfg.showstopper_mask, cfg.code, cfg.mask)
        SetupsLib.OscContext ctx = SetupsLib.OscContext.new(
            array.new<float>(6, 0.0), array.new<float>(6, 0.0), array.new<float>(6, 1.0),
            array.new<float>(6, 0.0), array.new<float>(6, 1.0))
        SetupsLib.f_register_event_v2(engine_events, true, spec, ctx, 0.0, cfg.name)

// Reset MC visualization variables at start of each bar
mae_viz_price := na
mfe_viz_price := na

// Execute registered setup events
int engine_event_count = array.size(engine_events)
if engine_event_count > 0
    for i = 0 to engine_event_count - 1
        SetupsLib.SetupEvent setup_event = array.get(engine_events, i)
        // setupsDB: size_info not used, data comes from setupsdb_cache
        [next_pos, next_last_trigger_bar, next_mae, next_mfe, next_entry_ctx, next_fire_code] = f_fire_setup_by_id(setup_event.id, setup_event.tooltip, "", last_setup_trigger_bar)
        if next_fire_code != 0
            actualfiresignal := next_fire_code
        pos := next_pos
        last_setup_trigger_bar := next_last_trigger_bar
        
        // Update global visualization variables
        if not na(next_mae)
            mae_viz_price := next_mae
        if not na(next_mfe)
            mfe_viz_price := next_mfe
        
        // Update direction-based cooldown trackers — ONLY when setup actually fired
        // Use cfg.dir lookup instead of hardcoded IDs — works for any future setup
        if next_fire_code != 0
            SetupsDB.SetupConfig fired_cfg = na
            for j = 0 to array.size(setupsdb_cache) - 1
                SetupsDB.SetupConfig jc = array.get(setupsdb_cache, j)
                if jc.id == setup_event.id
                    fired_cfg := jc
                    break
            if not na(fired_cfg)
                if fired_cfg.dir == "SHORT"
                    last_pred_short_bar := bar_index
                else
                    last_pred_long_bar := bar_index

// ═══════════════════════════════════════════════════════════════════════════
// MAHALANOBIS SQUEEZE CACHE (covariance matrix for 4D structural features)
// ═══════════════════════════════════════════════════════════════════════════
var float sqm_v1 = 1.0, var float sqm_v2 = 1.0, var float sqm_v3 = 1.0, var float sqm_v4 = 1.0
var float sqm_c12 = 0.0, var float sqm_c13 = 0.0, var float sqm_c14 = 0.0
var float sqm_c23 = 0.0, var float sqm_c24 = 0.0, var float sqm_c34 = 0.0
var float sqm_innov_bw_mean = 0.0, var float sqm_innov_bw_std = 1.0
float sqm_arm_thresh = 1.5  // Mahalanobis distance threshold for armed gate
int sqm_cov_len = knn_norm_len  // Use same 200-bar window as kNN normalization

// Recalc covariances when kNN percentiles update
bool shouldrecalcpercentiles = bar_index % 25 == 0
if shouldrecalcpercentiles
    float _ibw = innov_band_upper - innov_band_lower
    sqm_innov_bw_mean := ta.sma(_ibw, sqm_cov_len)
    sqm_innov_bw_std  := math.max(ta.stdev(_ibw, sqm_cov_len), 1e-6)
    
    // Compute 4D features for covariance estimation (use previous bar's z3_bwv)
    float _prev_z3_bwv = not na(sqz_raw) ? nz(sqz_raw.z3_bwv, 0.0) : 0.0  // from previous bar's SqzState
    [_sz1, _sz2, _sz3, _sz4] = BandsLib.f_squeeze_mahal_features(
        bw_pct, _ibw, sqm_innov_bw_mean, sqm_innov_bw_std, phi_div_score, _prev_z3_bwv)
    
    // Update variances and covariances
    sqm_v1  := math.max(ta.variance(_sz1, sqm_cov_len), 1e-6)
    sqm_v2  := math.max(ta.variance(_sz2, sqm_cov_len), 1e-6)
    sqm_v3  := math.max(ta.variance(_sz3, sqm_cov_len), 1e-6)
    sqm_v4  := math.max(ta.variance(_sz4, sqm_cov_len), 1e-6)
    sqm_c12 := BandsLib.f_covariance(_sz1, _sz2, sqm_cov_len)
    sqm_c13 := BandsLib.f_covariance(_sz1, _sz3, sqm_cov_len)
    sqm_c14 := BandsLib.f_covariance(_sz1, _sz4, sqm_cov_len)
    sqm_c23 := BandsLib.f_covariance(_sz2, _sz3, sqm_cov_len)
    sqm_c24 := BandsLib.f_covariance(_sz2, _sz4, sqm_cov_len)
    sqm_c34 := BandsLib.f_covariance(_sz3, _sz4, sqm_cov_len)

// Compute Mahalanobis distance for current bar
float _curr_z3_bwv = not na(sqz_raw) ? nz(sqz_raw.z3_bwv, 0.0) : 0.0  // from previous bar
[sz1, sz2, sz3, sz4] = BandsLib.f_squeeze_mahal_features(
    bw_pct, innov_band_upper - innov_band_lower,
    sqm_innov_bw_mean, sqm_innov_bw_std,
    phi_div_score, _curr_z3_bwv)

float sqm_dist = BandsLib.f_mahalanobis_4x4(
    sz1, sz2, sz3, sz4,
    sqm_v1, sqm_v2, sqm_v3, sqm_v4,
    sqm_c12, sqm_c13, sqm_c14,
    sqm_c23, sqm_c24, sqm_c34, 0.05)

// Update squeeze state with phi+mahal gates
[_sqz_tmp, _armed_tmp, _arm_bar_tmp, _cooldown_tmp, _low_ctr_tmp] = TAUtilityLib.f_squeeze_state(
    innov_band_upper, innov_band_lower, z3_up, z3_dn, hurst_exp,
    ltf_at_extreme, burst_pct_high,
    sqz_bwv_len, sqz_bwz_len, sqz_bwv_sq, sqz_bwv_ex,
    sqz_arm_thresh, sqz_cooldown,
    sqz_armed, sqz_arm_bar, sqz_cooldown_bar, sqz_low_counter,
    phi_div_score, phi_onset, sqm_dist, sqm_arm_thresh)
sqz_raw := _sqz_tmp
sqz_armed := _armed_tmp
sqz_arm_bar := _arm_bar_tmp
sqz_cooldown_bar := _cooldown_tmp
sqz_low_counter := _low_ctr_tmp

// Extract computed state
bool throat_active  = sqz_raw.active
float squeeze_score = sqz_raw.score
bool sqz_armed_state = sqz_raw.armed
bool sqz_expanding  = sqz_raw.sq_expanding

// BURST Oscillator Source Selection (for subpane display)
// Adaptive range normalization: map squeeze [0,1] and mahal [0,∞] to burst's [-3,+3] range
float burst_raw_prenorm = na
if burst_osc_source == "squeeze"
    // Squeeze score [0,1] → percentile normalize to [-3,+3]
    int sqz_lookback = 200
    float sqz_p10 = ta.percentile_nearest_rank(squeeze_score, sqz_lookback, 10)
    float sqz_p90 = ta.percentile_nearest_rank(squeeze_score, sqz_lookback, 90)
    float sqz_range = math.max(sqz_p90 - sqz_p10, 0.01)
    float sqz_center = (sqz_p90 + sqz_p10) / 2.0
    burst_raw_prenorm := ((squeeze_score - sqz_center) / sqz_range) * 3.0  // Scale to ±3
else if burst_osc_source == "mahalanobis"
    // Mahalanobis [0,∞] → center at threshold (1.5), scale by rolling range
    int mahal_lookback = 200
    float mahal_p10 = ta.percentile_nearest_rank(sqm_dist, mahal_lookback, 10)
    float mahal_p90 = ta.percentile_nearest_rank(sqm_dist, mahal_lookback, 90)
    float mahal_range = math.max(mahal_p90 - mahal_p10, 0.1)
    float mahal_center = sqm_arm_thresh  // Center at arm threshold (1.5)
    burst_raw_prenorm := ((sqm_dist - mahal_center) / mahal_range) * 3.0  // Scale to ±3
else
    // Burst score already in appropriate range
    burst_raw_prenorm := burst_osc_mode == "pathA" ? path_A : f7_burst_raw

burst_osc_raw := burst_raw_prenorm
[_burst_z_mean, _burst_z_temp, _burst_z_std] = TAUtilityLib.f_zscore_standard(burst_osc_raw, len_z)
burst_osc_z := _burst_z_temp

// Legacy compat: override BandsLib squeeze signals with throat state
bool pred_fv_slope_up = pred_ma > nz(pred_ma[1], pred_ma)
bool throat_squeeze_bull  = throat_active and pred_fv_slope_up
bool throat_squeeze_bear  = throat_active and not pred_fv_slope_up
bool throat_final_squeeze = throat_active

// Innovation Band Coloring: Green when correlation rises with FV up, Red when correlation rises with FV down
bool corr_rising = not na(rho) and not na(rho[1]) and math.abs(rho) > math.abs(nz(rho[1]))
bool fv_rising = pred_ma > nz(pred_ma[1], pred_ma)
bool fv_falling = pred_ma < nz(pred_ma[1], pred_ma)

color innov_band_color = color.new(color.gray, 75)  // Default gray
if corr_rising and fv_rising
    innov_band_color := color.new(color.lime, 60)  // Green when correlation rises with upward FV
else if corr_rising and fv_falling
    innov_band_color := color.new(color.red, 60)   // Red when correlation rises with downward FV

// Innovation Bands (KEEP IN SIMPLE MODE)
plot(innov_band_upper, "Innovation Band Upper", color=innov_band_color, style=plot.style_line, linewidth=1, force_overlay=true)
plot(innov_band_lower, "Innovation Band Lower", color=innov_band_color, style=plot.style_line, linewidth=1, force_overlay=true)

// 4. Survival Zones - Calculate all parameters via function (throat + legacy squeeze)
[z3_plot_col, z2_plot_col, z1_plot_col, z1_fill_col, z2_fill_col, z3_upper_fill_col, z3_lower_fill_col] = f_calc_survival_zone_params(force_low_fit_visual_regime, final_squeeze_signal or throat_final_squeeze, squeeze_bull or throat_squeeze_bull, squeeze_bear or throat_squeeze_bear, sqz_armed_state, squeeze_score, strong_bull, strong_bear, col_base, col_ma_base, innov_band_color, cld_continuation, cld_exhaustion)

bool show_zones = not simple_mode or show_survival_bands_simple
p_z3_up = plot(show_zones ? z3_up : na, "Zone 3 Upper", color=color.new(color.gray, 35), force_overlay=true)
p_z3_dn = plot(show_zones ? z3_dn : na, "Zone 3 Lower", color=color.new(color.gray, 35), force_overlay=true)
p_z2_up = plot(show_zones ? z2_up : na, "Zone 2 Upper", color=z2_plot_col, force_overlay=true)
p_z2_dn = plot(show_zones ? z2_dn : na, "Zone 2 Lower", color=z2_plot_col, force_overlay=true)
p_z1_up = plot(show_zones ? z1_up : na, "Zone 1 Upper", color=z1_plot_col, force_overlay=true)
p_z1_dn = plot(show_zones ? z1_dn : na, "Zone 1 Lower", color=z1_plot_col, force_overlay=true)

fill(p_z1_up, p_base, color=z1_fill_col, title="Zone 1 Upper")
fill(p_base, p_z1_dn, color=z1_fill_col, title="Zone 1 Lower")
fill(p_z2_up, p_z1_up, color=z2_fill_col, title="Zone 2 Upper")
fill(p_z1_dn, p_z2_dn, color=z2_fill_col, title="Zone 2 Lower")
fill(p_z3_up, p_z2_up, color=z3_upper_fill_col, title="Zone 3 Upper (Resistance)")
fill(p_z2_dn, p_z3_dn, color=z3_lower_fill_col, title="Zone 3 Lower (Support)")


// --- V8: REGIME SHIFT & VELOCITY COUPLING VISUAL INDICATORS ---

// Velocity coupling circles — wrapped in function (saves 11 vars from global scope)
f_calc_vel_coupling(bool _ltf_en, bool _ltf_dec, bool _ltf_rec, bool _ltf_is_dec, float _rho_ret, float _int_dyn, float _bvz, bool _dec_edge_in, bool _rec_edge_in, bool _fv_up, bool _fv_col, float _pred_ma) =>
    bool _dec_e = _ltf_en ? _ltf_dec : ((not na(_rho_ret) and math.abs(_rho_ret) < 0.3) and (na(_rho_ret[1]) or math.abs(_rho_ret[1]) >= 0.3))
    bool _rec_e = _ltf_en ? _ltf_rec : ((not na(_rho_ret) and math.abs(_rho_ret) > 0.7) and (na(_rho_ret[1]) or math.abs(_rho_ret[1]) <= 0.7))
    bool _sdo   = ((_int_dyn > 0.05 and _bvz > 0.15) or (_int_dyn < -0.05 and _bvz < -0.15))
    bool _dep   = _dec_e and not _sdo
    float _dec_y = _dep ? (_fv_col ? high : _pred_ma) : na
    color _dec_c = color.new(color.gray, 0)
    float _rec_y = _rec_e ? (_fv_col ? low : _pred_ma) : na
    color _rec_c = _fv_up ? color.new(color.lime, 0) : color.new(color.red, 0)
    [_dec_y, _dec_c, _rec_y, _rec_c]

[vel_dec_y, vel_dec_col, vel_rec_y, vel_rec_col] = f_calc_vel_coupling(ltf_enabled, ltf_decouple_event, ltf_recouple_event, ltf_is_decoupled, rho_returns, internal_dynamics, basket_vec_z, ltf_decouple_event, ltf_recouple_event, pred_fv_slope_up, pred_fv_color_candles, pred_ma)
plotchar(show_burst_signals and show_velocity_signals and not simple_mode ? vel_dec_y : na, "Velocity Decouple", "D", location.absolute, vel_dec_col, size=size.tiny, force_overlay=true)
plotchar(show_burst_signals and show_velocity_signals and not simple_mode ? vel_rec_y : na, "Velocity Recouple", "C", location.absolute, vel_rec_col, size=size.tiny, force_overlay=true)

// High Vector Context Markers (HIDE IN SIMPLE MODE)
if show_burst_signals and not simple_mode and macro_exhaustion and not macro_exhaustion[1]
    f_add_signal_label("⚠️", "Macro Exhaustion\nHigh vector pressure aligned with overbought MR context\nBias: SHORT exhaustion / distribution", false, high, color.new(color.red, 0))
if show_burst_signals and not simple_mode and continuation_setup and not continuation_setup[1]
    f_add_signal_label("✅", "Continuation Setup\nHigh vector pressure with cooled MR context\nBias: LONG continuation", true, low, color.new(color.lime, 0))

// --- EXTRAS ---
// Combined Probability Heatmap (moved to indicator pane)
combined_z = (z0 + basket_vec_z) / 2.0

// Breakout Markers — tiny triangle + VWAP flags computed in function (saves 13 vars from global scope)
f_calc_breakout_flags(float _c0, float _z3u, float _z3d, float _z2u, float _z2d, float _z1u, float _z1d, float _ma0, float _izs, float _trend, float _damp, bool _mr_bull, bool _mr_bear, float _vwap, float _fdev, bool _show_vwap, bool _en_vwap, float _vwap_tgt, float _ib_lo, float _ib_hi) =>
    float _bw = math.max(_z3u - _z3d, syminfo.mintick)
    float _near = math.min(math.abs(_c0 - _z3u), math.min(math.abs(_c0 - _z2u), math.min(math.abs(_c0 - _z1u), math.min(math.abs(_c0 - _ma0), math.min(math.abs(_c0 - _z1d), math.min(math.abs(_c0 - _z2d), math.abs(_c0 - _z3d)))))))
    bool _pns = _near <= _bw * 0.05
    bool _spk = not na(ta.pivothigh(_izs, 2, 2)) and ta.pivothigh(_izs, 2, 2) > 0.85
    bool _svl = not na(ta.pivotlow(_izs, 2, 2)) and ta.pivotlow(_izs, 2, 2) < -0.85
    bool _tt_bull = _pns and _svl and _trend > 0.025 and _damp > 0.20 and _mr_bull
    bool _tt_bear = _pns and _spk and _trend < -0.025 and _damp > 0.20 and _mr_bear
    float _vdz = not na(_vwap) ? (_vwap - low) / math.max(nz(_fdev, syminfo.mintick), syminfo.mintick) : na
    float _vdzs = not na(_vwap) ? (high - _vwap) / math.max(nz(_fdev, syminfo.mintick), syminfo.mintick) : na
    bool _vwl = _show_vwap and _en_vwap and not na(_vdz) and low < _ib_lo and _vdz > _vwap_tgt
    bool _vws = _show_vwap and _en_vwap and not na(_vdzs) and high > _ib_hi and _vdzs > _vwap_tgt
    [_tt_bull, _tt_bear, _vwl, _vws]

[tiny_triangle_bull, tiny_triangle_bear, is_smart_vwap_long_rejection, is_smart_vwap_short_rejection] = f_calc_breakout_flags(c0, z3_up, z3_dn, z2_up, z2_dn, z1_up, z1_dn, ma0, innov_z_score, est_trend, corr_damping, mr_bull, mr_bear, current_intrabar_vwap, fast_dev, show_vwap_rejection_signal, enable_vwap_sgd, vwap_rejection_target_z, innov_band_lower, innov_band_upper)

// Breakout markers (HIDE IN SIMPLE MODE)
if show_burst_signals and show_breakout_markers and not simple_mode and (expansion_up or tiny_triangle_bull)
    string breakout_up_tip = expansion_up ? "Breakout Up\nPrice expanded through outer structure in bullish trend context" : "Breakout Up\nTiny-triangle bullish release near structure with innovation valley confirmation"
    f_add_signal_label("▲", breakout_up_tip, true, low, color.new(color.lime, 0))
if show_burst_signals and show_breakout_markers and not simple_mode and (expansion_dn or tiny_triangle_bear)
    string breakout_dn_tip = expansion_dn ? "Breakout Down\nPrice expanded through outer structure in bearish trend context" : "Breakout Down\nTiny-triangle bearish release near structure with innovation peak confirmation"
    f_add_signal_label("▼", breakout_dn_tip, false, high, color.new(color.red, 0))

// VWAP Rejection signals as small centered plotchar points at LTF close level - MERGED
color vwap_col = is_smart_vwap_long_rejection ? color.new(color.lime, 0) : is_smart_vwap_short_rejection ? color.new(color.red, 0) : na
plotchar(show_burst_signals and show_breakout_markers and show_vwap_rejection_signal and not simple_mode and is_smart_vwap_long_rejection ? current_intrabar_vwap : na, "VWAP Rejection Long", "•", location.absolute, vwap_col, size=size.tiny, force_overlay=true)
plotchar(show_burst_signals and show_breakout_markers and show_vwap_rejection_signal and not simple_mode and is_smart_vwap_short_rejection ? current_intrabar_vwap : na, "VWAP Rejection Short", "•", location.absolute, vwap_col, size=size.tiny, force_overlay=true)

// Squeeze breakout markers (HIDE IN SIMPLE MODE)
plotshape(show_burst_signals and show_breakout_markers and not simple_mode and squeeze_bull ? c0 : na, "Squeeze Bull", shape.circle, location.absolute, color.new(color.blue, 0), size=size.auto, force_overlay=true)

// --- SQUEEZE THROAT STATE LABELS ---
bool sqz_arm_edge = sqz_armed_state and not sqz_armed_state[1]
if show_burst_signals and show_breakout_markers and not simple_mode and sqz_arm_edge
    string arm_tooltip = "Squeeze ARMED 💤\nScore: " + str.tostring(squeeze_score, "#.##") +
                         "\nPhi Div: " + str.tostring(phi_div_score, "#.##") +
                         "\nMahal: " + str.tostring(sqm_dist, "#.##") +
                         "\nWaiting for: expansion + reactive confirms"
    f_add_signal_label("💤", arm_tooltip, false, high, color.new(color.blue, 30))

// FIRE state: 🔥 when squeeze fires (armed + expanding + reactive)
bool sqz_fire_edge = throat_active and not throat_active[1]
if show_burst_signals and show_breakout_markers and sqz_fire_edge and not simple_mode
    string fire_tooltip = "Squeeze FIRING 🔥\nScore: " + str.tostring(squeeze_score, "#.##") +
                          "\nDirection: " + (throat_squeeze_bull ? "BULL ↑" : "BEAR ↓") +
                          "\nPhi Div: " + str.tostring(phi_div_score, "#.##") + (phi_onset ? " ⚡ONSET" : "") +
                          "\nMahal: " + str.tostring(sqm_dist, "#.##") + (sqz_raw.mahal_armed ? " ✓" : "") +
                          "\nBreakout in progress"
    f_add_signal_label("🔥", fire_tooltip, throat_squeeze_bull, throat_squeeze_bull ? low : high, color.new(throat_squeeze_bull ? color.lime : color.red, 0))

// --- DUAL ENTROPY REGIME MARKERS ---
// Aqua circles = MR regime entry | Lime circles = Bounce regime entry
float dist_to_z3_up = math.abs(c0 - z3_up)
float dist_to_z3_dn = math.abs(c0 - z3_dn)
bool closer_to_upper = dist_to_z3_up < dist_to_z3_dn

// Regime Event Markers (at price, not on bands)
if not simple_mode and show_regime_markers and bounce_event
    f_add_signal_label("▲", "Bounce\nTrend continuation bounce near mean with aligned velocity and pressure", true, low, color.new(color.lime, 0))
// MR Diamonds and Trend Change - MERGED
float regime_y = mr_event ? (position > 0 ? high : low) : tc_event ? (velocity > 0 ? high : low) : na
color regime_col = mr_event ? (position > 0 ? color.new(color.red, 0) : color.new(color.lime, 0)) : tc_event ? color.new(color.orange, 0) : na
plotshape((show_regime_markers and mr_event) or (not simple_mode and show_regime_markers and tc_event) ? regime_y : na, "Regime Markers", shape.diamond, location.absolute, regime_col, size=size.tiny, force_overlay=true)

// --- V8: HIGH-PROBABILITY SETUP LABELS (≥70% WR) ---
// FIXED: Proper inflection point detection, edge detection, cooldown, and multi-bar signals
float label_offset = ta.atr(14) * 0.1
if show_burst_signals and show_cld_patterns and cld_div_exhaust and cld_div_up
    string cld_div_tooltip_up = "CLD post-signal divergence exhaustion\nNew price high after CLD exhaustion, but internals weakened\nZ weaker: " + str.tostring(cld_div_z_weaker) + "\nBCO weaker: " + str.tostring(cld_div_bco_weaker) + "\nTE weaker: " + str.tostring(cld_div_te_weaker)
    label.new(bar_index, high + label_offset, "+div", yloc=yloc.price, style=label.style_label_down, color=color.new(color.red, 0), textcolor=color.black, size=size.small, tooltip=cld_div_tooltip_up, force_overlay=true)
if show_burst_signals and show_cld_patterns and cld_div_exhaust and not cld_div_up
    string cld_div_tooltip_dn = "CLD post-signal divergence exhaustion\nNew price low after CLD exhaustion, but internals weakened\nZ weaker: " + str.tostring(cld_div_z_weaker) + "\nBCO weaker: " + str.tostring(cld_div_bco_weaker) + "\nTE weaker: " + str.tostring(cld_div_te_weaker)
    label.new(bar_index, low - label_offset, "+div", yloc=yloc.price, style=label.style_label_up, color=color.new(color.red, 0), textcolor=color.black, size=size.small, tooltip=cld_div_tooltip_dn, force_overlay=true)

// --- CLD PATTERN SIGNALS (HIDE IN SIMPLE MODE) ---
// Replaced plotshapes with labels to save plot slots, using overlay label array with separate slot management
if not simple_mode and show_burst_signals and show_cld_patterns
    // Keep CLD markers isolated from setup labels so they cannot evict BT setup annotations
    int MAX_LABELS = 150
    if array.size(overlay_labels) >= MAX_LABELS
        // Delete oldest label and remove from array
        label oldest = array.shift(overlay_labels)
        label.delete(oldest)
    
    // Green Diamond: FALL-RISE continuation (97% continuation rate, don't fade)
    if cld_continuation and cld_move_up
        label lbl = label.new(bar_index, low, "◆", yloc=yloc.price, style=label.style_none, color=color.new(color.lime, 100), textcolor=color.new(color.lime, 20), size=size.small, tooltip="CLD Continue ↑\n97% continuation rate\nDon't fade this move", force_overlay=true)
        array.push(overlay_labels, lbl)
    else if cld_continuation and cld_move_down
        label lbl = label.new(bar_index, high, "◆", yloc=yloc.price, style=label.style_none, color=color.new(color.lime, 100), textcolor=color.new(color.lime, 20), size=size.small, tooltip="CLD Continue ↓\n97% continuation rate\nDon't fade this move", force_overlay=true)
        array.push(overlay_labels, lbl)
    
    // Red Cross: RISE-FALL exhaustion (76% reversal rate, expect reversal)
    if cld_exhaustion and cld_move_up
        label lbl = label.new(bar_index, high, "✕", yloc=yloc.price, style=label.style_none, color=color.new(color.red, 100), textcolor=color.new(color.red, 20), size=size.small, tooltip="CLD Exhaust ↑→↓\n76% reversal rate\nExpect reversal", force_overlay=true)
        array.push(overlay_labels, lbl)
    else if cld_exhaustion and cld_move_down
        label lbl = label.new(bar_index, low, "✕", yloc=yloc.price, style=label.style_none, color=color.new(color.red, 100), textcolor=color.new(color.red, 20), size=size.small, tooltip="CLD Exhaust ↓→↑\n76% reversal rate\nExpect reversal", force_overlay=true)
        array.push(overlay_labels, lbl)

// --- UNIFIED BACKGROUND COLORING ---
// Priority: Regime Shift > Entropy Collapse > Entropy High
color unified_bg_color = na
bool is_historical_heavy_zone = bars_from_end >= max_heavy_bars
if is_historical_heavy_zone
    unified_bg_color := color.new(color.gray, 85)  // Historical bars older than heavy-bars zone
else if regime_shift
    unified_bg_color := color.new(color.orange, 95)  // Regime shift (structural detachment)
else if show_entropy_bg
    if entropy_collapse
        unified_bg_color := color.new(color.blue, 92)  // Entropy collapse (trend change)
    else if entropy_high
        unified_bg_color := color.new(color.purple, 92)  // Entropy high (volatility event)
bgcolor(unified_bg_color, title="Background (Regime/Entropy)")

// ═══════════════════════════════════════════════════════════════════════════
// OSCILLATORS - 3-UDT ARCHITECTURE (SubPane → OscMeta → OscState)
// MOVED EARLY: Registration at ~line 1780 so f_norm_system can read states
// ═══════════════════════════════════════════════════════════════════════════

var panes = array.new<TAUtilityLib.SubPane>(0)
var oscs = array.new<TAUtilityLib.OscMeta>(0)
var states = array.new<TAUtilityLib.OscState>(0)

if bar_index == 0
    // Create SubPanes
    array.push(panes, TAUtilityLib.SubPane.new(
        0, "MAIN", 0.0, 0.0, 0.0, 0.0, false, na, na, na,
        color.new(color.gray, 85), color.new(color.gray, 70)))
    array.push(panes, TAUtilityLib.SubPane.new(
        1, "CORR", 0.0, 0.0, 0.0, 0.0, false, na, na, na,
        color.new(color.gray, 85), color.new(color.gray, 70)))
    
    // Register Oscillators
    TAUtilityLib.f_register_osc(oscs, states,
        "MR", "Mean Reversion Oscillator",
        "Peer-driven orthogonal deviation from basket fair value",
        0, -3.0, 3.0, osc_compression, 0.50, false,
        true, true, color.lime, color.red)
    
    TAUtilityLib.f_register_osc(oscs, states,
        "TE", "Transfer Entropy Oscillator",
        "Information flow from basket to asset",
        0, -1.0, 1.0, osc_compression, 10.0, false,
        true, show_te_osc and not simple_mode, color.aqua, color.orange)
    
    TAUtilityLib.f_register_osc(oscs, states,
        "VEC", "Basket Vector Oscillator",
        "Weighted z-score of correlation-adjusted basket spread",
        1, -3.0, 3.0, osc_compression, 0.75, false,
        true, true, color.lime, color.red)
    
    TAUtilityLib.f_register_osc(oscs, states,
        "CORR", "Basket Correlation Oscillator",
        "Z-scored rolling correlation regime state",
        1, -3.0, 3.0, osc_compression, 0.75, false,
        true, not simple_mode, color.yellow, color.purple)
    
    TAUtilityLib.f_register_osc(oscs, states,
        "LTF", "LTF Correlation Tracker",
        "Kalman-filtered intrabar correlation",
        1, -3.0, 3.0, osc_compression, 1.0, false,
        true, ltf_enabled and not simple_mode, color.teal, color.maroon)
    
    string burst_label = burst_osc_source == "squeeze" ? "SQUEEZE" :(burst_osc_source == "mahalanobis" ? "MAHAL" : "BURST")
    string burst_desc = burst_osc_source == "squeeze" ? "Composite squeeze score [0..1] (5 components)" :(burst_osc_source == "mahalanobis" ? "4D Mahalanobis distance (structural anomaly)" :"Volatility squeeze × PhiDiv acceleration composite")
    TAUtilityLib.f_register_osc(oscs, states,
        burst_label, burst_label + " Oscillator",
        burst_desc,
        0, -3.0, 3.0, osc_compression, 1.0, false,
        true, not simple_mode, color.orange, color.gray)
    
    // Layout + Visibility + Lines
    TAUtilityLib.f_layout_subpanes(panes, 4.0, -10.0, 0.10)
    TAUtilityLib.f_update_visibility(panes, oscs)
    TAUtilityLib.f_manage_subpane_lines(panes)

// Every bar: process oscillators (EARLY PASS — produces states[i].visualvalue for f_norm_system)
rawvals = array.from(mr_osc, te_osc, vector_osc_z, rho_z, ltf_rho_z, burst_osc_z)
TAUtilityLib.f_process_oscs(panes, oscs, states, rawvals)

if array.size(panes) > 0 and array.size(oscs) > 0 and array.size(states) > 0
    array<float> mr_ob_vals = array.from(mr_p98_cached, na, na, na, na, na)
    array<float> mr_os_vals = array.from(mr_p02_cached, na, na, na, na, na)
    TAUtilityLib.f_update_osc_ob_os_lines(panes, oscs, states, mr_ob_vals, mr_os_vals, color.new(color.red, 40), color.new(color.lime, 40))

// Last bar: update visibility + render labels
if is_right_edge or is_history_edge
    bool _dbg = show_debug_osc
    array<bool> _vis = array.from(true, (show_te_osc and not simple_mode) or _dbg, true, not simple_mode or _dbg, (ltf_enabled and not simple_mode) or _dbg, not simple_mode or _dbg)
    for _i = 0 to array.size(oscs) - 1
        TAUtilityLib.OscMeta _m = array.get(oscs, _i)
        _m.should_display := array.get(_vis, _i)
    TAUtilityLib.f_manage_labels(oscs, states, 3)

// Helper: read visual value + color from state/meta arrays
_ov(int i) => array.get(states, i).visualvalue
_oc(int i, float raw) =>
    raw >= 0 ? array.get(oscs, i).bull_color : array.get(oscs, i).bear_color

// Plots (unavoidable global scope requirement)
// MR and VEC oscillators show even in simple mode for better context
plot(_ov(0), "MR", color=_oc(0, mr_osc), linewidth=2, display=simple_mode ? display.all : display.all)
plot(_ov(1), "TE", color=_oc(1, te_osc), linewidth=2, display=simple_mode ? display.none : display.all)
plot(_ov(2), "VEC", color=_oc(2, vector_osc_z), linewidth=2, display=simple_mode ? display.all : display.all)
plot(_ov(3), "CORR", color=_oc(3, rho_z), linewidth=2, display=simple_mode ? display.none : display.all)
plot(_ov(4), "LTF", color=_oc(4, ltf_rho_z), linewidth=2, display=simple_mode ? display.none : display.all)
plot(_ov(5), "BURST", color=_oc(5, burst_osc_z), linewidth=2, display=simple_mode ? display.all : display.all)

// kNN Confidence is event-level data (computed only in State 4 on realtime bars)
// Display via Info Table or Label, not as time-series plot()

// phi_total_vis, phi_latch_vis removed (plots removed, 6 vars saved)

// TE Pit Detection — stateful state machine wrapped in function (saves 7 vars from global scope)
f_detect_te_pit(float _te_osc, int _lookback, float _drop_sigma, float _abs_floor, int _window, float _rec2, float _rec3) =>
    var bool _armed = false
    var int _start_bar = na
    var float _bottom = na
    var int _bottom_bar = na
    float _delta = not na(_te_osc) and not na(_te_osc[1]) ? _te_osc - _te_osc[1] : na
    float _dmean = ta.sma(_delta, _lookback)
    float _dstdev = ta.stdev(_delta, _lookback)
    bool _drop = not na(_delta) and ((not na(_dmean) and not na(_dstdev) and _delta < _dmean - _drop_sigma * _dstdev) or _delta < _abs_floor)
    int _sig = 0
    float _conf_rec = na
    int _conf_bars = na
    if _drop and not _armed
        _armed := true
        _start_bar := bar_index
        _bottom := _te_osc
        _bottom_bar := bar_index
    else if _armed
        if _te_osc < _bottom
            _bottom := _te_osc
            _bottom_bar := bar_index
        int _bspit = bar_index - nz(_start_bar, bar_index)
        int _bsbot = bar_index - nz(_bottom_bar, bar_index)
        float _rec = not na(_bottom) ? _te_osc - _bottom : 0.0
        if _bspit <= _window and ((_bsbot >= 2 and _rec >= _rec2) or (_bsbot >= 3 and _rec >= _rec3))
            _sig := 1
            _conf_rec := _rec
            _conf_bars := _bsbot
            _armed := false
            _start_bar := na
            _bottom := na
            _bottom_bar := na
        else if _bspit > _window
            _sig := -1
            _armed := false
            _start_bar := na
            _bottom := na
            _bottom_bar := na
    [_sig, _armed, _bottom_bar, _delta, _dmean, _dstdev, _conf_rec, _conf_bars]

[_te_pit_sig, _te_pit_armed, _te_pit_bbar, te_delta, te_delta_mean, te_delta_stdev, te_pit_confirm_recovery, te_pit_confirm_bars] = f_detect_te_pit(te_osc, te_pit_delta_lookback, te_pit_drop_sigma, te_pit_abs_floor, te_pit_window, te_pit_recovery_2, te_pit_recovery_3)
bool te_pit_recovery = _te_pit_sig == 1
bool te_pit_pending = _te_pit_armed and not te_pit_recovery
bool te_pit_at_bottom = _te_pit_armed and bar_index == _te_pit_bbar
color te_col = te_pit_pending ? color.new(color.yellow, 0) : (te_pit_recovery ? color.new(color.red, 0) : color.new(color.purple, 20))

// Remove Z-score normalization because it crushes small TE variance to 0.0
// Instead, map raw [-1, 1] TE to the visual oscillator scale [-10, 10]
// HIGH Bug #4 WARNING: te_osc_normalized is ONLY for visual display (chart pane).
// ML export, setup thresholds, and all logic use raw te_osc ([-1, 1] range).
// If visually optimizing from chart: divide visual value by 10 for code thresholds.
// Example: Visual "-5" on chart = te_osc = -0.5 in code/export.
float te_osc_normalized = na(te_osc) ? na : te_osc * 10.0

// Oscillator baselines: MR at 0, TE/Vector/Basket Corr at -6
hline(0, "Subchart1 Base", color=color.new(color.gray, 70), linestyle=hline.style_dotted)
hline(-6, "TE/Vec/Corr Base", color=color.new(color.gray, 70), linestyle=hline.style_dotted)
hline(-10, "Lower Osc -10", color=color.new(color.gray, 55), linestyle=hline.style_solid)
hline(-4, "Lower Osc -4", color=color.new(color.gray, 35), linestyle=hline.style_solid)
hline(3, "Upper Osc 3", color=color.new(color.gray, 35), linestyle=hline.style_solid)

// TE Pit Labels: Show at bottom and recovery
var label lbl_te_pit_bottom = na
var label lbl_te_pit_recovery = na

// Label at pit bottom (yellow warning)
if show_te_osc and te_pit_at_bottom and not simple_mode
    if not na(lbl_te_pit_bottom)
        label.delete(lbl_te_pit_bottom)
    string pit_tooltip = "TE Pit Detected\n" +"TE Drop: " + str.tostring(te_delta, "#.3f") + "\n" +"Current TE: " + str.tostring(te_osc, "#.3f") + "\n" +"Threshold: " + str.tostring(te_delta_mean - te_pit_drop_sigma * te_delta_stdev, "#.3f")
    lbl_te_pit_bottom := label.new(bar_index, te_osc_normalized, "⚠ PIT", color=color.new(color.yellow, 0), textcolor=color.black, style=label.style_label_down, size=size.normal, tooltip=pit_tooltip)

// Label at recovery (green confirmation)
if show_te_osc and te_pit_recovery and not simple_mode
    if not na(lbl_te_pit_recovery)
        label.delete(lbl_te_pit_recovery)
    string recovery_tooltip = "TE Pit Recovery\n" +"Recovery: +" + str.tostring(te_pit_confirm_recovery, "#.3f") + "\n" +"Bars: " + str.tostring(te_pit_confirm_bars) + "\n" +"Current TE: " + str.tostring(te_osc, "#.3f")
    lbl_te_pit_recovery := label.new(bar_index, te_osc_normalized, "✓", color=color.new(color.lime, 0), textcolor=color.black, style=label.style_label_up, size=size.small, tooltip=recovery_tooltip)

// DEBUG PLOTS REMOVED: vector_osc, basket_corr_osc

// Innovation Z Pivot Detection with Percentile Filter
var innov_history = array.new_float()
var array<float> innov_sorted = array.new_float(0)
var int recalc_counter = 0
var float high_percentile = na
var float low_percentile = na

// Push current Innovation Z to history array
if not na(innov_z_score)
    array.push(innov_history, innov_z_score)
    if array.size(innov_history) > 1000
        array.shift(innov_history)

// Recalculate percentiles every 100 bars
recalc_counter := recalc_counter + 1
if recalc_counter >= 100 or na(high_percentile)
    recalc_counter := 0
    if array.size(innov_history) >= 100
        array.clear(innov_sorted)
        for i = 0 to array.size(innov_history) - 1
            array.push(innov_sorted, array.get(innov_history, i))
        array.sort(innov_sorted, order.ascending)
        int size = array.size(innov_sorted)
        int high_idx = math.round(size * (100.0 - innov_pivot_pct) / 100.0)
        int low_idx = math.round(size * innov_pivot_pct / 100.0)
        high_percentile := array.get(innov_sorted, math.max(0, math.min(high_idx, size - 1)))
        low_percentile := array.get(innov_sorted, math.max(0, math.min(low_idx, size - 1)))

// Detect pivots (5 bars left, 2 bars right)
float pivot_high = ta.pivothigh(innov_z_score, 5, 2)
float pivot_low = ta.pivotlow(innov_z_score, 5, 2)

// Filter by percentile
bool high_pivot_valid = show_innov_pivots and not na(pivot_high) and not na(high_percentile) and pivot_high > high_percentile
bool low_pivot_valid = show_innov_pivots and not na(pivot_low) and not na(low_percentile) and pivot_low < low_percentile

// Color the Innovation Z line based on pivot detection
// Red for positive Innovation Z pivots, Green for negative Innovation Z pivots
color innov_color = high_pivot_valid ? color.new(color.red, 0) : (low_pivot_valid ? color.new(color.lime, 0) : color.new(color.gray, 30))
// DEBUG PLOT REMOVED: innov_z_score

// Note: ltf_corr_osc deleted — never consumed, ltf_rho_z used directly

// Encode basket_vec_z_raw and vector_osc_z thresholds (bits 15-18)
// Encodes all 5 synergic density dimensions + labeled signals into a single integer
// Bits 0-4: D1-D5 active (>0.15)
// Bits 5-7: Regime markers (bounce, MR, TC)
// Bits 8-9: CLD patterns (continuation, exhaustion)

// Encode all signals and thresholds into a single statement to bypass CE10296
plot((barstate.isrealtime ? 1.0 : 0.0) * 1000.0 + (bt_table_ready ? 100.0 : 0.0) + (mc_has_results ? 10.0 : 0.0), "Trade State", color=color.new(color.blue, 0), display=display.data_window)
// FIX: Cap bt_validated at 99 for encoding (actual value shown in table)
plot(mc_phase * 1000.0 + mc_chunk_done * 100.0 + math.min(bt_validated_setups, 99) * 10.0 + math.min(bt_confirmed_setups, 9), "MC Debug", color=color.new(color.orange, 0), display=display.data_window)
plot((not na(pos) ? 1000.0 : 0.0) + (pos.dir == "LONG" ? 100.0 : pos.dir == "SHORT" ? 200.0 : 0.0), "Entry Context", color=color.new(color.green, 0), display=display.data_window)
plot((not na(pos) and not pos.is_active ? 1000.0 : 0.0) + (not na(pos) ? 100.0 : 0.0), "Exit Context", color=color.new(color.red, 0), display=display.data_window)
plot(0.0, "Density Debug", color=color.new(color.purple, 0), display=display.data_window)

// Setup Context Bitfield (boolean flags for setup diagnostics)
// Bit 0: pred_rounded
// Bit 1: pred_round_long
// Bit 2: pred_round_short
// Bit 3: ltf_is_decoupled
// Bit 4: ltf_decouple_event
// Bit 5: ltf_recouple_event
// Bit 6: phi_informative
// Bit 7: bounce_event
// Bit 8: mr_event
// Bit 9: transition_event (tc_event)
// Bit 10: cld_continuation
// Bit 11: cld_exhaustion
// Bit 12: macro_exhaustion
// Bit 13: continuation_setup
// Bit 14: idiosyncratic_flow
// Bit 15: is_falling_knife
plot((pred_rounded ? 1.0 : 0.0) + (pred_round_long ? 2.0 : 0.0) + (pred_round_short ? 4.0 : 0.0) + (ltf_is_decoupled ? 8.0 : 0.0) + (ltf_decouple_event ? 16.0 : 0.0) + (ltf_recouple_event ? 32.0 : 0.0) + (phi_informative ? 64.0 : 0.0) + (bounce_event ? 128.0 : 0.0) + (mr_event ? 256.0 : 0.0) + (transition_event ? 512.0 : 0.0) + (cld_continuation ? 1024.0 : 0.0) + (cld_exhaustion ? 2048.0 : 0.0) + (macro_exhaustion ? 4096.0 : 0.0) + (continuation_setup ? 8192.0 : 0.0) + (idiosyncratic_flow ? 16384.0 : 0.0) + (is_falling_knife ? 32768.0 : 0.0), "Setup Context Flags", color=color.new(color.fuchsia, 0), display=display.data_window)

// Continuous Setup Diagnostics (non-bit-encodable values)
plot(basket_fit, "Basket Fit (0-100)", color=color.new(color.aqua, 0), display=display.data_window)
plot(te_direction_smoothed, "TE Direction", color=color.new(color.orange, 0), display=display.data_window)
// FIX: Export corr_damping as standalone CSV column for debugging transparency issues
plot(corr_damping, "Corr Damping (0-1)", color=color.new(color.purple, 0), display=display.data_window)

// Debug Combined: actualfiresignal + state bits + CLD (setup_debug_code removed — replaced by actualfiresignal)
plot(actualfiresignal + ((actualfiresignal > 0 ? 1.0 : 0.0) * 10000.0) + (barstate.isrealtime ? 20000.0 : 0.0) + ((cld_continuation ? 100.0 : 0.0) + (cld_exhaustion ? 200.0 : 0.0) + (macro_exhaustion ? 300.0 : 0.0)) * 100000.0, "Debug Combined", color=color.new(color.yellow, 0), display=display.data_window)

// MC Setup Validator - MAE/MFE Visualization (red/green micro squares) - MERGED
plotshape(not na(mae_viz_price) or not na(mfe_viz_price) ? nz(mae_viz_price, mfe_viz_price) : na, "MC Visualization", shape.square, location.absolute, not na(mae_viz_price) ? color.new(color.red, 0) : color.new(color.lime, 0), size=size.tiny, force_overlay=true)

// ═══════════════════════════════════════════════════════════════════════════
// MONTE CARLO FORWARD PATH SIMULATION
// ═══════════════════════════════════════════════════════════════════════════

// ═══════════════════════════════════════════════════════════════════════════
// TIME-SLICED SETUP VALIDATOR
// ═══════════════════════════════════════════════════════════════════════════

// MC Cone Visualization (confidence-adaptive, direction-aware)
bool cone_fresh = is_live_new_bar or is_live_intrabar or barstate.isrealtime or barstate.islast or (bar_index - mc_result_bar) <= 2  // Explicit live-bar refresh + fallback for history/replay
if enable_knn and enable_mc and show_mc_cone and mc_has_results and cone_fresh and array.size(mc_progressive_p10) > 0 and (allow_chunking or is_fast_path)
    // Clear old lines and fills
    while array.size(mc_p10_lines) > 0
        line.delete(array.shift(mc_p10_lines))
    while array.size(mc_p50_lines) > 0
        line.delete(array.shift(mc_p50_lines))
    while array.size(mc_p90_lines) > 0
        line.delete(array.shift(mc_p90_lines))
    while array.size(mc_cone_fills) > 0
        linefill.delete(array.shift(mc_cone_fills))

    // Confidence → transparency mapping
    float _confPct = math.max(0.0, math.min(nz(mc_knn_confidence), 100.0))
    float _confNorm = _confPct / 100.0

    int _boundTransp = int(88 - _confNorm * 63)
    int _medianTransp = int(78 - _confNorm * 68)
    int _fillTransp = int(97 - _confNorm * (97 - mc_cone_opacity))

    // Direction-aware coloring
    bool _bullish = mc_oracle_direction >= 0
    color _boundCol = _bullish ? color.new(color.lime, _boundTransp) : color.new(color.red, _boundTransp)
    color _medianCol = _bullish ? color.new(color.green, _medianTransp) : color.new(color.red, _medianTransp)
    color _fillCol = _bullish ? color.new(color.lime, _fillTransp) : color.new(color.red, _fillTransp)

    // Draw cone from current bar forward using the selected adaptive horizon
    int cone_size = math.min(array.size(mc_progressive_p10), math.max(2, mc_opt_horizon))

    for h = 1 to cone_size - 1
        int x1 = bar_index + (h - 1)
        int x2 = bar_index + h
        float prev_p10 = array.get(mc_progressive_p10, h - 1)
        float curr_p10 = array.get(mc_progressive_p10, h)
        float prev_p50 = array.get(mc_progressive_p50, h - 1)
        float curr_p50 = array.get(mc_progressive_p50, h)
        float prev_p90 = array.get(mc_progressive_p90, h - 1)
        float curr_p90 = array.get(mc_progressive_p90, h)

        line l_p10 = line.new(x1, prev_p10, x2, curr_p10, color=_boundCol, width=1, force_overlay=true)
        line l_p50 = line.new(x1, prev_p50, x2, curr_p50, color=_medianCol, width=2, force_overlay=true)
        line l_p90 = line.new(x1, prev_p90, x2, curr_p90, color=_boundCol, width=1, force_overlay=true)
        array.push(mc_p10_lines, l_p10)
        array.push(mc_p50_lines, l_p50)
        array.push(mc_p90_lines, l_p90)

        linefill fill_cone = linefill.new(l_p10, l_p90, _fillCol)
        array.push(mc_cone_fills, fill_cone)
        
        // Add optimal horizon label at the end of the cone
        if h == mc_opt_horizon and mc_opt_score > 0
            float opt_p50 = array.get(mc_progressive_p50, h)
            string opt_label_text = "H" + str.tostring(mc_opt_horizon) + " S" + str.tostring(mc_opt_score, "#.2")
            label.new(bar_index + h, opt_p50, opt_label_text, style=label.style_label_down, color=color.new(color.orange, 20), textcolor=color.orange, size=size.tiny, force_overlay=true)
        
        // Progress label (floating) - shows MC cone + backtest processing status
        // NOTE: Fast-path completes all MC phases (0→1→2→3→4) in a single tick,
        // so mc_phase==2 is never true at this code point. Use "just done" window instead.
        float oc_range_sma5 = ta.sma(math.abs(close - open), 5)
        float candle_height_sma25 = ta.sma(math.abs(close - open), 25)
        float progress_offset = math.max(syminfo.mintick, candle_height_sma25 * 5.0)  // 5x the sma(25) of absolute candle heights
        bool mc_in_flight = mc_phase > 0 and mc_phase < 4
        bool mc_just_done = mc_has_results and (bar_index - mc_result_bar) <= 2
        bool bt_in_flight = bt_phase > 0 and bt_phase < 3
        string mc_txt = mc_just_done ? "MC ✓" + str.tostring(mc_chunk_done) + "p" : mc_phase > 0 ? "MC " + str.tostring(mc_chunk_done) + "/" + str.tostring(mc_target_runs) + "(" + str.tostring(mc_chunk_done * 100.0 / math.max(mc_target_runs, 1), "#.0") + "%)" : "MC ..."
        string bt_txt = bt_table_ready ? "BT ✓" + str.tostring(bt_validated_setups) : bt_phase > 0 ? "BT " + str.tostring(bt_validated_setups) + "/" + str.tostring(bt_total_setups) + "(" + str.tostring(bt_validated_setups * 100.0 / math.max(bt_total_setups, 1), "#.0") + "%)" : "BT ..."
        string prog_text = "⏳ " + mc_txt + " | " + bt_txt
// Backtest summary table render function (inline, 3-column layout with progress)
f_render_bt_summary_table(table tbl) =>
    if bt_phase == 0 or not bt_show_table
        table.clear(tbl, 0, 0, 3, 20)
    else
        color hdr_bg = color.new(color.gray, 30)
        color row_bg = color.new(color.black, 20)
        float raw_wr = bt_raw_total > 0 ? bt_raw_wins * 100.0 / bt_raw_total : 0.0
        float filt_wr = bt_filt_total > 0 ? bt_filt_wins * 100.0 / bt_filt_total : 0.0
        float raw_avg = bt_raw_total > 0 ? bt_raw_pnl_sum / bt_raw_total : 0.0
        float filt_avg = bt_filt_total > 0 ? bt_filt_pnl_sum / bt_filt_total : 0.0
        float raw_var = bt_raw_total > 1 ? bt_raw_m2 / (bt_raw_total - 1) : 0.0
        float filt_var = bt_filt_total > 1 ? bt_filt_m2 / (bt_filt_total - 1) : 0.0
        float raw_mean = bt_raw_total > 0 ? bt_raw_pnl_sum / bt_raw_total : 0.0
        float filt_mean = bt_filt_total > 0 ? bt_filt_pnl_sum / bt_filt_total : 0.0
        float raw_sharpe = raw_var > 0 ? raw_mean / math.sqrt(raw_var) : 0.0
        float filt_sharpe = filt_var > 0 ? filt_mean / math.sqrt(filt_var) : 0.0
        float raw_rr = bt_raw_mae_sum > 0 ? bt_raw_mfe_sum / bt_raw_mae_sum : 0.0
        float filt_rr = bt_filt_mae_sum > 0 ? bt_filt_mfe_sum / bt_filt_mae_sum : 0.0
        table.cell(tbl, 0, 0, "kNN+MC Backtest", bgcolor=hdr_bg, text_color=color.white, text_size=size.small)
        table.cell(tbl, 1, 0, "Raw", bgcolor=hdr_bg, text_color=color.yellow, text_size=size.small)
        table.cell(tbl, 2, 0, "MC Conf", bgcolor=hdr_bg, text_color=color.aqua, text_size=size.small, tooltip="MC Confirmed: setups passing bt_filt_* thresholds (WR, MFE:MAE, etc.)")
        table.cell(tbl, 3, 0, "Closed", bgcolor=hdr_bg, text_color=color.lime, text_size=size.small, tooltip="Completed trades with actual_pnl != NaN")

        // WR
        table.cell(tbl, 0, 1, "Win Rate", bgcolor=row_bg, text_color=color.white, text_size=size.tiny)
        table.cell(tbl, 1, 1, str.tostring(raw_wr, "#.1") + "%", bgcolor=row_bg, text_color=raw_wr >= 55 ? color.lime : color.orange, text_size=size.tiny)
        table.cell(tbl, 2, 1, str.tostring(filt_wr, "#.1") + "%", bgcolor=row_bg, text_color=filt_wr >= 55 ? color.lime : color.orange, text_size=size.tiny)
        table.cell(tbl, 3, 1, str.tostring(raw_wr, "#.1") + "%", bgcolor=row_bg, text_color=raw_wr >= 55 ? color.lime : color.orange, text_size=size.tiny)

        // Avg PnL
        table.cell(tbl, 0, 2, "Avg PnL%", bgcolor=row_bg, text_color=color.white, text_size=size.tiny)
        table.cell(tbl, 1, 2, str.tostring(raw_avg, "#.2") + "%", bgcolor=row_bg, text_color=raw_avg > 0 ? color.lime : color.red, text_size=size.tiny)
        table.cell(tbl, 2, 2, str.tostring(filt_avg, "#.2") + "%", bgcolor=row_bg, text_color=filt_avg > 0 ? color.lime : color.red, text_size=size.tiny)
        table.cell(tbl, 3, 2, str.tostring(raw_avg, "#.2") + "%", bgcolor=row_bg, text_color=raw_avg > 0 ? color.lime : color.red, text_size=size.tiny)

        // Sharpe
        table.cell(tbl, 0, 3, "Sharpe", bgcolor=row_bg, text_color=color.white, text_size=size.tiny)
        table.cell(tbl, 1, 3, str.tostring(raw_sharpe, "#.2"), bgcolor=row_bg, text_color=raw_sharpe > 0.5 ? color.lime : color.gray, text_size=size.tiny)
        table.cell(tbl, 2, 3, str.tostring(filt_sharpe, "#.2"), bgcolor=row_bg, text_color=filt_sharpe > 0.5 ? color.lime : color.gray, text_size=size.tiny)
        table.cell(tbl, 3, 3, str.tostring(raw_sharpe, "#.2"), bgcolor=row_bg, text_color=raw_sharpe > 0.5 ? color.lime : color.gray, text_size=size.tiny)
        
        // MFE:MAE
        table.cell(tbl, 0, 4, "MFE:MAE", bgcolor=row_bg, text_color=color.white, text_size=size.tiny)
        table.cell(tbl, 1, 4, str.tostring(raw_rr, "#.2"), bgcolor=row_bg, text_color=raw_rr > 1.0 ? color.lime : color.red, text_size=size.tiny)
        table.cell(tbl, 2, 4, str.tostring(filt_rr, "#.2"), bgcolor=row_bg, text_color=filt_rr > 1.0 ? color.lime : color.red, text_size=size.tiny)
        table.cell(tbl, 3, 4, str.tostring(raw_rr, "#.2"), bgcolor=row_bg, text_color=raw_rr > 1.0 ? color.lime : color.red, text_size=size.tiny)
        
        // Setups count
        table.cell(tbl, 0, 5, "Setups", bgcolor=row_bg, text_color=color.white, text_size=size.tiny)
        table.cell(tbl, 1, 5, str.tostring(bt_validated_setups), bgcolor=row_bg, text_color=color.yellow, text_size=size.tiny)
        table.cell(tbl, 2, 5, str.tostring(bt_confirmed_setups), bgcolor=row_bg, text_color=color.aqua, text_size=size.tiny)
        table.cell(tbl, 3, 5, str.tostring(bt_raw_total), bgcolor=row_bg, text_color=color.lime, text_size=size.tiny)
        
        // MC Agreement
        table.cell(tbl, 0, 6, "MC Agree", bgcolor=row_bg, text_color=color.white, text_size=size.tiny)
        string agree_txt = na(bt_avg_agree) ? "..." : str.tostring(bt_avg_agree, "#.1") + "%"
        table.cell(tbl, 1, 6, agree_txt, bgcolor=row_bg, text_color=nz(bt_avg_agree) > 60 ? color.lime : color.orange, text_size=size.tiny)
        table.cell(tbl, 2, 6, "", bgcolor=row_bg, text_color=color.gray, text_size=size.tiny)
        table.cell(tbl, 3, 6, "", bgcolor=row_bg, text_color=color.gray, text_size=size.tiny)
        
        // Progress row (includes Phase 3 label refresh status)
        int bt_size = array.size(bt_setups)
        bool phase3_done = bt_phase == 3 and bt_phase3_idx >= bt_size and not bt_phase3_overflow
        string prog = bt_phase3_overflow ? "⚠ Overflow" : 
                      phase3_done ? "✓ Done" : 
                      bt_phase == 3 ? "Labels: " + str.tostring(bt_phase3_idx) + "/" + str.tostring(bt_size) :
                      bt_table_ready ? "BT ✓" : 
                      str.tostring(bt_validated_setups) + "/" + str.tostring(bt_total_setups)
        color prog_color = bt_phase3_overflow ? color.orange : phase3_done ? color.lime : color.gray
        table.cell(tbl, 0, 7, "Progress", bgcolor=row_bg, text_color=color.white, text_size=size.tiny)
        table.cell(tbl, 1, 7, prog, bgcolor=row_bg, text_color=prog_color, text_size=size.tiny)
        table.cell(tbl, 2, 7, "", bgcolor=row_bg, text_color=color.gray, text_size=size.tiny)
        table.cell(tbl, 3, 7, "", bgcolor=row_bg, text_color=color.gray, text_size=size.tiny)
        
        // Scan Range row (bar indices where validation occurred)
        int scan_range = not na(bt_first_bar) and not na(bt_last_bar) ? bt_last_bar - bt_first_bar + 1 : 0
        string range_txt = scan_range > 0 ? str.tostring(scan_range) + " bars" : "..."
        table.cell(tbl, 0, 8, "Scan Range", bgcolor=row_bg, text_color=color.white, text_size=size.tiny)
        table.cell(tbl, 1, 8, range_txt, bgcolor=row_bg, text_color=color.gray, text_size=size.tiny)
        table.cell(tbl, 2, 8, "", bgcolor=row_bg, text_color=color.gray, text_size=size.tiny)
        table.cell(tbl, 3, 8, "", bgcolor=row_bg, text_color=color.gray, text_size=size.tiny)
        
        // Phase 3 Debug Log (always visible)
        string log_txt = bt_audit_log != "" ? bt_audit_log : "..."
        table.cell(tbl, 0, 9, "BT Audit", bgcolor=row_bg, text_color=color.white, text_size=size.tiny)
        table.cell(tbl, 1, 9, log_txt, bgcolor=row_bg, text_color=color.white, text_size=size.tiny, text_halign=text.align_left)
        table.cell(tbl, 2, 9, "", bgcolor=row_bg, text_color=color.gray, text_size=size.tiny)
        table.cell(tbl, 3, 9, "", bgcolor=row_bg, text_color=color.gray, text_size=size.tiny)
        
        // Phase 3 Stage (current processing state, always visible)
        string stage_txt = bt_phase >= 3 ? "✓ Maintained (" + str.tostring(current_painted_labels) + ")" : "⏳ Running"
        color stage_color = bt_phase >= 3 ? color.lime : color.gray
        table.cell(tbl, 0, 10, "Repaint", bgcolor=row_bg, text_color=color.white, text_size=size.tiny)
        table.cell(tbl, 1, 10, stage_txt, bgcolor=row_bg, text_color=stage_color, text_size=size.tiny)
        table.cell(tbl, 2, 10, "", bgcolor=row_bg, text_color=color.gray, text_size=size.tiny)
        table.cell(tbl, 3, 10, "", bgcolor=row_bg, text_color=color.gray, text_size=size.tiny)
        
        // Exhaustion Gate
        table.cell(tbl, 0, 11, "EXH Gate", bgcolor=row_bg, text_color=color.white, text_size=size.tiny)
        string exh_status = na(exh_p85) ? "warmup" : ((exh_block_long or exh_block_short) ? "⛔ BLOCKED" : "✅ OK")
        color exh_col = na(exh_p85) ? color.gray : ((exh_block_long or exh_block_short) ? color.red : color.lime)
        table.cell(tbl, 1, 11, exh_status + " p85=" + str.tostring(nz(exh_p85), "#.##"), bgcolor=row_bg, text_color=exh_col, text_size=size.tiny, text_halign=text.align_left)
        table.cell(tbl, 2, 11, "n=" + str.tostring(array.size(zz_leg_amps)), bgcolor=row_bg, text_color=color.gray, text_size=size.tiny)
        table.cell(tbl, 3, 11, "", bgcolor=row_bg, text_color=color.gray, text_size=size.tiny)

        // kNN Candidates Split Rows
        int u_size = array.size(bt_u_setups)
        if u_size > 0
            for i = 0 to 7 // Max 8 rows for individual setups
                int r = 12 + i
                if i < u_size
                    string sid = array.get(bt_u_setups, i)
                    int avg_cands = int(math.round(array.get(bt_u_cands, i) / array.get(bt_u_cnt, i)))
                    float avg_conf = array.get(bt_u_mc_conf, i) / array.get(bt_u_cnt, i)
                    color conf_col = avg_conf >= 50.0 ? color.lime : color.orange
                    color cand_col = avg_cands >= 15 ? color.lime : (avg_cands >= 7 ? color.yellow : color.red)
                    
                    table.cell(tbl, 0, r, sid + " cands", bgcolor=row_bg, text_color=color.white, text_size=size.tiny)
                    table.cell(tbl, 1, r, "n=" + str.tostring(avg_cands), bgcolor=row_bg, text_color=cand_col, text_size=size.tiny, text_halign=text.align_left)
                    table.cell(tbl, 2, r, str.tostring(avg_conf, "#.1") + "%", bgcolor=row_bg, text_color=conf_col, text_size=size.tiny)
                    table.cell(tbl, 3, r, "", bgcolor=row_bg, text_color=color.gray, text_size=size.tiny)
                else
                    table.cell(tbl, 0, r, "", bgcolor=na, text_color=na, text_size=size.tiny)
                    table.cell(tbl, 1, r, "", bgcolor=na, text_color=na, text_size=size.tiny)
                    table.cell(tbl, 2, r, "", bgcolor=na, text_color=na, text_size=size.tiny)
                    table.cell(tbl, 3, r, "", bgcolor=na, text_color=na, text_size=size.tiny)
        else
            table.cell(tbl, 0, 12, "kNN Cands", bgcolor=row_bg, text_color=color.white, text_size=size.tiny)
            table.cell(tbl, 1, 12, "...", bgcolor=row_bg, text_color=color.gray, text_size=size.tiny, text_halign=text.align_left)
            table.cell(tbl, 2, 12, "", bgcolor=row_bg, text_color=color.gray, text_size=size.tiny)
            table.cell(tbl, 3, 12, "", bgcolor=row_bg, text_color=color.gray, text_size=size.tiny)
            for i = 1 to 7
                int r = 12 + i
                table.cell(tbl, 0, r, "", bgcolor=na, text_color=na, text_size=size.tiny)
                table.cell(tbl, 1, r, "", bgcolor=na, text_color=na, text_size=size.tiny)
                table.cell(tbl, 2, r, "", bgcolor=na, text_color=na, text_size=size.tiny)
                table.cell(tbl, 3, r, "", bgcolor=na, text_color=na, text_size=size.tiny)

f_render_info_table(table info_tbl) =>
    string vec_context = macro_exhaustion ? "⚠️ EXHAUSTION" : (continuation_setup ? "✅ CONTINUATION" : (idiosyncratic_flow ? "🔀 IDIOSYNC" : "Neutral"))
    color vec_context_col = macro_exhaustion ? color.red : (continuation_setup ? color.lime : (idiosyncratic_flow ? color.orange : color.gray))
    string vec_tooltip = "V8: High Vector Context\nExhaustion: High Vec + MR>1.0 (Dump)\nContinuation: High Vec + MR<0.0 (Pump)\nIdiosync: High Vec + Decoupled\nVec=" + str.tostring(basket_vec_z, "#.2f") + " MR=" + str.tostring(mr_osc, "#.2f")
    bool ltf_active = ltf_enabled
    bool knife_state = is_falling_knife
    bool strong_bull_state = is_strong_bull_mr
    bool strong_bear_state = is_strong_bear_mr
    string basket_auto_status = basket_scan_ready ? basket_mode_label + " |ρ| " + str.tostring(nz((auto_score_1 + auto_score_2 + auto_score_3 + auto_score_4) / 4.0, 0.0), "#.2f") : basket_mode_label + " " + str.tostring(bar_index) + "/" + str.tostring(math.max(fit_eval_len * 3, len_z * 3))
    table.cell(info_tbl, 0, 0, "Vec Context", text_color=color.black, text_size=size.small, tooltip=vec_tooltip)
    table.cell(info_tbl, 1, 0, vec_context, text_color=vec_context_col, text_size=size.small)
    table.cell(info_tbl, 0, 1, "Vector Sens", text_color=color.black, text_size=size.small, tooltip="Noticeably low or high innovation pivots at bands or median are good entry points, but only after a peak on MR oscillator, confirmed by the predictive line color")
    table.cell(info_tbl, 1, 1, str.tostring(sens_final, "#.##"), text_color=enable_adaptive ? color.blue : color.black, text_size=size.small)
    table.cell(info_tbl, 0, 2, "SGD Updates", text_color=color.black, text_size=size.small)
    table.cell(info_tbl, 1, 2, str.tostring(sgd_updates), text_color=color.orange, text_size=size.small)
    table.cell(info_tbl, 0, 3, "Trend Z", text_color=color.black, text_size=size.small)
    table.cell(info_tbl, 1, 3, str.tostring(est_trend, "#.2f"), text_color=est_trend > 0 ? color.lime : color.red, text_size=size.small)
    table.cell(info_tbl, 0, 4, "Vol Mode", text_color=color.black, text_size=size.small)
    table.cell(info_tbl, 1, 4, "Standard", text_color=color.black, text_size=size.small)
    table.cell(info_tbl, 0, 5, "Corr / Damp", text_color=color.black, text_size=size.small)
    table.cell(info_tbl, 1, 5, (na(rho) ? "NaN" : str.tostring(rho, "#.2f")) + " / " + str.tostring(corr_damping, "#.2f"), text_color=is_decoupled ? color.red : (is_partial ? color.yellow : color.lime), text_size=size.small)
    if ltf_active
        string ltf_status = ltf_is_decoupled ? "⚡ DECOUPLED" : "⚡ COUPLED"
        color ltf_status_col = ltf_is_decoupled ? color.orange : color.aqua
        string ltf_corr_val = na(ltf_corr_ema) ? "..." : str.tostring(ltf_corr_ema, "#.##")
        string ltf_tooltip = "LTF Correlation Tracking (" + ltf_timeframe + "m)\nCorrelation: " + ltf_corr_val + "\nDecouple Thresh: " + str.tostring(ltf_decouple_thresh, "#.##") + "\nRecouple Thresh: " + str.tostring(ltf_recouple_thresh, "#.##")
        table.cell(info_tbl, 0, 5, "LTF " + ltf_timeframe + "m", text_color=color.black, text_size=size.tiny, tooltip=ltf_tooltip)
        table.cell(info_tbl, 1, 5, ltf_status + " " + ltf_corr_val, text_color=ltf_status_col, text_size=size.tiny)
    table.cell(info_tbl, 0, 6, "MR Status", text_color=color.black, text_size=size.small, tooltip="Innovation and MR potential side pre breakout is an indicator of a breakout direction")
    string mr_status = knife_state ? "⚠ Knife" : (strong_bull_state ? "🟢 Bull" : (strong_bear_state ? "🔴 Bear" : "Neutral"))
    string mr_mode = use_orthogonal_mr ? "⊥" : ""
    color mr_color = is_falling_knife ? color.yellow : (is_strong_bull_mr ? color.lime : (is_strong_bear_mr ? color.red : color.gray))
    table.cell(info_tbl, 1, 6, mr_status + mr_mode + " (" + str.tostring(mr_norm, "#.2f") + ")", text_color=mr_color, text_size=size.small)
    table.cell(info_tbl, 0, 7, "Coupling Q", text_color=color.black, text_size=size.small, tooltip="Avg ρ and explained variance R² from running returns correlation")
    table.cell(info_tbl, 1, 7, coupling_q_label + " ρ=" + str.tostring(avg_rho, "#.2f") + " R²=" + str.tostring(coupling_r2, "#.1f") + "%", text_color=coupling_q_color, text_size=size.small)
    string basket_mode_value = basket_preset == "Auto Scan" ? basket_auto_status : basket_mode_label
    table.cell(info_tbl, 0, 8, "Mode", text_color=color.black, text_size=size.small)
    table.cell(info_tbl, 1, 8, basket_mode_value, text_color=color.black, text_size=size.small)
    string tickers_str = sym1 + " | " + sym2 + " | " + sym3 + " | " + sym4
    table.cell(info_tbl, 0, 9, "Basket", text_color=color.black, text_size=size.tiny)
    table.cell(info_tbl, 1, 9, tickers_str, text_color=color.gray, text_size=size.tiny)
    float _lt = load_secs_latched
    string _prog = bar_index < 50 ? "█..." : (bar_index < 200 ? "██.." : (bar_index < 500 ? "███." : "████"))
    string _load_txt = na(_lt) ? _prog : str.tostring(_lt, "#.##") + "s"
    color _lt_col = na(_lt) ? color.gray : (_lt <= 15.0 ? color.lime : (_lt <= 32.0 ? color.orange : color.red))
    table.cell(info_tbl, 0, 10, "Load Time", text_color=color.black, text_size=size.small)
    table.cell(info_tbl, 1, 10, _load_txt, text_color=_lt_col, text_size=size.small)

    table.cell(info_tbl, 0, 11, "Cooldown Bars", text_color=color.black, text_size=size.small)
    table.cell(info_tbl, 1, 11, str.tostring(cooldown_bars), text_color=color.aqua, text_size=size.small, tooltip="Per-setup adaptive cooldown with 10 bars between any 2 consecutive same-direction setups hard limit")

    // Squeeze throat stats
    string hurst_col = hurst_exp < 0.4 ? "lime" : (hurst_exp > 0.6 ? "red" : "gray")
    color hurst_c = hurst_exp < 0.4 ? color.lime : (hurst_exp > 0.6 ? color.red : color.gray)
    table.cell(info_tbl, 0, 12, "Hurst H", text_color=color.black, text_size=size.tiny, tooltip="H < 0.5 = anti-persistent (energy accumulating), H > 0.5 = trending")
    table.cell(info_tbl, 1, 12, str.tostring(hurst_exp, "#.##"), text_color=hurst_c, text_size=size.tiny)
    color sqz_c = throat_active ? color.orange : (sqz_armed_state ? color.yellow : color.gray)
    table.cell(info_tbl, 0, 13, "Squeeze", text_color=color.black, text_size=size.tiny, tooltip="Throat active=fire, armed=waiting for expansion")
    table.cell(info_tbl, 1, 13, (throat_active ? "🔥" : (sqz_armed_state ? "💤" : "—")) + " " + str.tostring(squeeze_score, "#.##"), text_color=sqz_c, text_size=size.tiny)
    
    // Phi divergence + Mahalanobis armed gates
    color phi_c = phi_onset ? color.orange : (phi_div_score > 0.4 ? color.yellow : color.gray)
    table.cell(info_tbl, 0, 14, "Phi Div", text_color=color.black, text_size=size.tiny, tooltip="PhiLatch-PhiOrth spread intensity [0..1]. Onset=pressure accumulation start")
    table.cell(info_tbl, 1, 14, (phi_onset ? "⚡" : "") + str.tostring(phi_div_score, "#.##"), text_color=phi_c, text_size=size.tiny)
    color mahal_c = sqz_raw.mahal_armed ? color.orange : color.gray
    table.cell(info_tbl, 0, 15, "Mahal", text_color=color.black, text_size=size.tiny, tooltip="4D structural squeeze distance. >1.5 = armed (multi-feature compression)")
    table.cell(info_tbl, 1, 15, str.tostring(sqm_dist, "#.##") + (sqz_raw.mahal_armed ? " ✓" : ""), text_color=mahal_c, text_size=size.tiny)

    table.cell(info_tbl, 0, 16, "Basket Fit", text_color=color.black, text_size=size.tiny)
    table.cell(info_tbl, 1, 16, fit_label + " " + str.tostring(basket_fit, "#.0") + "%", text_color=fit_color, text_size=size.tiny)

f_render_knn_debug_table(table knn_dbg_tbl) =>
    int hist_size = array.size(f1_history)
    int min_required = math.max(knn_k * 3, 300)
    int final_knn_count = array.size(final_knn_ids_display)
    int mc_progressive_size = array.size(mc_progressive_p50)
    bool has_cone = mc_progressive_size > 0
    string status_txt = mc_has_results ? "MC: ✓" : (hist_size < min_required ? "MC: " + str.tostring(hist_size) + "/" + str.tostring(min_required) : "MC: —")
    string pct_up_str = na(mc_oracle_pct_up) ? "na" : str.tostring(mc_oracle_pct_up, "0.0")
    string state_txt = status_txt + "  Dir=" + str.tostring(mc_oracle_direction) + "  PctUp=" + pct_up_str
    string neigh_txt = str.tostring(final_knn_count) + "/" + str.tostring(knn_k)
    string conf_txt = na(mc_knn_confidence) or (mc_knn_confidence == 0.0 and final_knn_count == 0) ? "na" : str.tostring(mc_knn_confidence, "0.1")
    color hdr_bg = color.rgb(20, 24, 28)
    color row_bg = color.new(color.white, 0)
    color status_color = mc_has_results ? color.lime : (hist_size < min_required ? color.orange : color.gray)
    table.cell(knn_dbg_tbl, 0, 0, "kNN+MC", text_color=color.white, bgcolor=hdr_bg, text_size=size.small)
    table.cell(knn_dbg_tbl, 1, 0, state_txt, text_color=status_color, bgcolor=hdr_bg, text_size=size.small)
    table.cell(knn_dbg_tbl, 0, 1, "Neighbors", text_color=color.black, bgcolor=row_bg, text_size=size.small)
    table.cell(knn_dbg_tbl, 1, 1, neigh_txt, text_color=final_knn_count > 0 ? color.lime : color.gray, bgcolor=row_bg, text_size=size.small)
    table.cell(knn_dbg_tbl, 0, 2, "Conf", text_color=color.black, bgcolor=row_bg, text_size=size.small)
    table.cell(knn_dbg_tbl, 1, 2, conf_txt, text_color=mc_knn_confidence > 50 ? color.lime : color.orange, bgcolor=row_bg, text_size=size.small)
    table.cell(knn_dbg_tbl, 0, 3, "AvgDist", text_color=color.black, bgcolor=row_bg, text_size=size.small)
    table.cell(knn_dbg_tbl, 1, 3, na(dbg_avg_dist) ? "na" : str.tostring(dbg_avg_dist, "0.2f"), text_color=na(dbg_avg_dist) ? color.gray : color.aqua, bgcolor=row_bg, text_size=size.small)
    table.cell(knn_dbg_tbl, 0, 4, "Runs", text_color=color.black, bgcolor=row_bg, text_size=size.small)
    table.cell(knn_dbg_tbl, 1, 4, mc_has_results ? "done" : "pending", text_color=mc_has_results ? color.lime : color.gray, bgcolor=row_bg, text_size=size.small)
    table.cell(knn_dbg_tbl, 0, 5, "Mode", text_color=color.black, bgcolor=row_bg, text_size=size.small)
    table.cell(knn_dbg_tbl, 1, 5, "single-pass", text_color=color.aqua, bgcolor=row_bg, text_size=size.small)
    table.cell(knn_dbg_tbl, 0, 6, "Iter", text_color=color.black, bgcolor=row_bg, text_size=size.tiny)
    table.cell(knn_dbg_tbl, 1, 6, str.tostring(dbg_total_iter), text_color=color.gray, bgcolor=row_bg, text_size=size.tiny)
    table.cell(knn_dbg_tbl, 0, 7, "Hamm/NA skip", text_color=color.black, bgcolor=row_bg, text_size=size.tiny)
    table.cell(knn_dbg_tbl, 1, 7, str.tostring(dbg_hamming_skip) + "/" + str.tostring(dbg_na_skip), text_color=color.gray, bgcolor=row_bg, text_size=size.tiny)
    table.cell(knn_dbg_tbl, 0, 8, "Cands", text_color=color.black, bgcolor=row_bg, text_size=size.tiny)
    table.cell(knn_dbg_tbl, 1, 8, str.tostring(dbg_cands), text_color=color.gray, bgcolor=row_bg, text_size=size.tiny)

// REMOVED: Legend Table function (saves ~25 vars)

// --- INFO TABLE ---
var table info_tbl = table.new(position.bottom_right, 2, 13, bgcolor=color.white, border_width=1)
var table knn_dbg_tbl = table.new(position.bottom_left, 2, 9, bgcolor=color.white, border_width=2)

if show_tables and (allow_chunking or is_history_edge or is_right_edge)
    f_render_info_table(info_tbl)

if enable_knn and show_knn_debug_table and (allow_chunking or is_history_edge or is_right_edge)
    f_render_knn_debug_table(knn_dbg_tbl)
else if (allow_chunking or is_history_edge or is_right_edge)
    table.clear(knn_dbg_tbl, 0, 0, 1, 7)

// BACKTEST TABLE - Rendered persistently when ready
if bt_enable and bt_show_table and (allow_chunking or is_history_edge or is_right_edge)
    f_render_bt_summary_table(bt_summary_tbl)

else if not bt_enable or not bt_show_table
    table.clear(bt_summary_tbl, 0, 0, 3, 20)

// ═══════════════════════════════════════════════════════════════════════════
// OSCILLATOR LABELS - Managed through OscMeta.lbl in 2-UDT system
