//@version=5
indicator("Phase 2: Kalman Regime Classifier (KRC)", shorttitle="KRC", overlay=false, max_bars_back=5000)

// ══════════════════════════════════════════════════════════════════════════════
// LOAD TIME TRACKING
// ══════════════════════════════════════════════════════════════════════════════
var int load_start_ms = na
load_start_ms := na(load_start_ms) ? timenow : load_start_ms
var float load_secs_latched = na
var bool load_secs_captured = false
if barstate.islastconfirmedhistory and not load_secs_captured
    load_secs_latched := (timenow - load_start_ms) / 1000.0
    load_secs_captured := true
float load_secs_live = load_secs_captured ? load_secs_latched : (na(load_start_ms) ? na : (timenow - load_start_ms) / 1000.0)

// ══════════════════════════════════════════════════════════════════════════════
// PHASE 2: KALMAN STATE MACHINE WITH MONTE CARLO FORWARD PROJECTION
// ══════════════════════════════════════════════════════════════════════════════
// Architecture:
// - State vector: x_t = [μ_t, β_1t, β_2t, ..., β_Kt]
// - Observation: y_t = μ_t + Σ(β_it * z_it) + v_t
// - MC Engine: Forward path simulation using bootstrapped residuals
// - Output: Empirical 1/5/10% bands + H-bar future probability cone
// ══════════════════════════════════════════════════════════════════════════════

// ══════════════════════════════════════════════════════════════════════════════
// INPUTS
// ══════════════════════════════════════════════════════════════════════════════

grp_bands = "═══ Band Configuration ═══"
string mapping_algo_breakout = input.string("Precise Mapping", "Breakout Projection / Mapping Mode", options=["Algebraic Inversion", "Precise Mapping"], group=grp_bands, tooltip="Controls how the Breakout Kalman fair-value projection is translated back into price.")
string mapping_algo_mean_reversion = input.string("Algebraic Inversion", "Mean-Reversion Projection / Mapping Mode", options=["Algebraic Inversion", "Precise Mapping"], group=grp_bands, tooltip="Controls how the Mean-Reversion Kalman fair-value projection is translated back into price.")
grp_prob = "═══ Probability Combiners ═══"
string combiner_mode_breakout = input.string("Stouffer", "Breakout Combiner Mode", options=["Stouffer", "Mahalanobis", "Joint Independent"], group=grp_prob, tooltip="Controls how multiple feature extremes affect Breakout band confidence and width.")
string combiner_mode_mean_reversion = input.string("Mahalanobis", "Mean-Reversion Combiner Mode", options=["Stouffer", "Mahalanobis", "Joint Independent"], group=grp_prob, tooltip="Controls how multiple feature extremes affect Mean-Reversion band confidence and width.")
bool show_breakout_band_set = input.bool(true, "Show Breakout Band Set", group=grp_prob, tooltip="Plots the directional volatility breakout band set. In Stouffer mode it expands the target-side band using kinetic flow and compresses the opposite side into a tighter trailing-stop style structure.")
bool show_mean_reversion_band_set = input.bool(true, "Show Mean-Reversion Band Set", group=grp_prob, tooltip="Plots the mean-reversion band set. In Stouffer mode it compresses the trend-side band into a wall and opens the opposite side as the return-to-fair-value target.")

