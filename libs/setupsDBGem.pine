//@version=6
// @description Setups Database: GEM Version (Market Orders, 0.15% Friction)
library("setupsDBGem", overlay = true)

// =====================================================================
// UDT: Setup Contract
// =====================================================================
export type SetupConfig
    string id
    string name
    string dir
    float tp_pct
    float sl_pct
    int hold_bars
    float wr
    float sharpe
    bool is_active
    float edgeratio       // replaces f_get_edgeratio_meta()
    string thesis         // replaces f_get_thesis_meta()
    int showstopper_mask  // replaces f_get_showstopper_mask_meta()
    int code              // replaces f_setup_id_to_code()
    int mask              // replaces f_setup_id_to_mask()
    int mc_family         // replaces f_get_mc_family_from_setup()

// =====================================================================
// EVALUATE ALL SETUPS (MASTER FUNCTION)
// =====================================================================
export evaluate_all(
      int entryCtx, float mr, float vec, float basket, float burst, float te, 
      float close_price, float cyclicFV, float baseMA, float predVecMA, float phiTotal, 
      float innL, float innU, float innWidth, float innWidthMed, float z3L, 
      bool vwapShortActive, bool vwapLongActive, float squeezeBull, float knnConf
 ) =>
    array<SetupConfig> active = array.new<SetupConfig>()
    
    // Validity gates: valid_te requires te; valid_base does not (allows LONG setups before te warmup)
    bool valid_base = not na(phiTotal) and not na(innU) and not na(z3L) and not na(squeezeBull)
    bool valid_te   = valid_base and not na(te)
    bool valid_data = valid_te  // Keep alias for SHORT setups that need te
    if not valid_base
        active  // Return empty array if core oscillators unavailable

    // =================================================================
    // 1. SHORT SETUPS — strongest-first so is_stale shadows weaker setups
    // Push order by Sharpe: S3(0.267) → S_Trap(0.113) → S_Inn(0.073) → S4(0.025) → S8(0.004) → S11(-0.013 fallback)
    // =================================================================

    // 1. S3_Sniper: Deep Reversion (MR < -0.2, VEC bearish) + Quiet Market + Not at support (strongest)
    bool s3 = valid_data and (entryCtx == 1200) and (mr < -0.2) and (vec < -0.8) and not (((close_price - innL) / close_price) < 0.01) and (burst < 0.5)
    if s3
        active.push(SetupConfig.new("S3", "Decoupled Reversion", "SHORT", 6.0, 1.5, 16, 54.0, 0.267, true, 0.95, "Asset is heavily overbought (MR Osc < -0.2) while its peers are pulling down (Vector Pressure < -0.8). Market lacks momentum (BURST Osc < 0.5) and is not at immediate support, creating an ideal counter-trend opportunity.", 2, 103, 0, 4))

    // 2. S_Trapped_MA: Trapped between BaseMA and PredVecMA (Quiet Market)
    bool s_trap = valid_data and (entryCtx == 1200) and (close_price < baseMA) and (close_price > predVecMA) and not (close_price < cyclicFV) and (burst < 0.5)
    if s_trap
        active.push(SetupConfig.new("S_Trap", "Trapped Price", "SHORT", 6.0, 1.5, 16, 51.2, 0.113, true, 1.0, "Price is compressed below the baseline trend (Basis MA) but still holds above predictive fair value (Pred FV Line). Lack of upside momentum (BURST Osc < 0.5) suggests an impending downside resolution.", 0, 116, 67108864, 4))

    // 3. S_Inn_Contraction: Volatility Squeeze Breakout (Peak Momentum Only)
    bool s_inn = valid_data and (entryCtx == 1200) and (innWidth < innWidthMed) and not vwapShortActive and (burst > 0.3)
    if s_inn
        active.push(SetupConfig.new("S_Inn", "Volatility Breakdown", "SHORT", 6.0, 1.5, 16, 50.7, 0.073, true, 1.0, "Market volatility has compressed (Innov Bands Width) and is now resolving with a sudden downside impulse (BURST Osc > 0.3). VWAP support is cleared, confirming bearish momentum.", 0, 115, 33554432, 4))

    // 4. S4_Basket: Highly Correlated Breakout (Peak Momentum Only)
    bool s4 = valid_data and (entryCtx == 1200) and (basket > 70) and not (te >= 4.0) and (burst > 0.3)
    if s4
        active.push(SetupConfig.new("S4", "Correlated Breakdown", "SHORT", 6.0, 1.5, 16, 48.5, 0.025, true, 1.0, "The asset is highly synchronized with its peers (Basket Fit > 70) and is confirming a coordinated downside impulse (BURST Osc > 0.3). The move is supported by broad market weakness.", 0, 113, 134217728, 4))

    // 5. S8_BURST: Impulse momentum + Valid Correlation (SHORT only — entryCtx guard prevents firing in LONG zone)
    bool s8 = valid_data and (entryCtx == 1200) and (burst != 0) and (mr < -0.3) and not (basket < 30)
    if s8
        active.push(SetupConfig.new("S8", "Overbought Impulse", "SHORT", 6.0, 1.5, 16, 44.0, 0.004, true, 1.20, "Extreme local overbought conditions (MR Osc < -0.3) are meeting sudden directional momentum (BURST Osc). The asset is tightly coupled with its basket, validating the reversal structure.", 2, 108, 32768, 4))

    // 6. S11_Cyclic_Div: Price > Fair Value — fallback (weakest, Sharpe -0.013)
    bool s11 = valid_data and (entryCtx == 1200) and (close_price > cyclicFV) and not (innWidth > innWidthMed) and (burst < 0.5)
    if s11
        active.push(SetupConfig.new("S11", "Fair Value Reversion", "SHORT", 6.0, 1.5, 16, 48.2, -0.013, true, 1.0, "Price has drifted significantly above its calculated fair value (Kalman Cyclic FV) during a quiet market regime (BURST Osc < 0.5). Lack of volatility expansion suggests an imminent reversion.", 0, 111, 16777216, 4))

    // =================================================================
    // 2. LONG SETUPS (Market Profile: TP=8%, SL=1.5%, H=24)
    // =================================================================

    // 7-9. LONG setups: use valid_base (te not required for oversold detection)
    // Push strongest-first so engine_events fires L_Exp > L6 > L_Basic (is_stale shadows weaker)

    // 9. L_Exp: Volatility expansion capitulation bounce (strongest — Sharpe 0.459)
    bool l_inn = valid_base and (entryCtx == 1000) and (mr > 0.5) and (vec < -0.3) and (innWidth > innWidthMed) and not (close_price < cyclicFV)
    if l_inn
        active.push(SetupConfig.new("L_Exp", "Capitulation Bounce", "LONG", 8.0, 1.5, 24, 63.4, 0.459, true, 1.28, "Extreme panic selling has triggered maximum volatility expansion (Innov Bands Width). The asset is deeply oversold (MR Osc > 0.5) but holds above structural fair value (Kalman Cyclic FV), creating a high-probability bounce.", 0, 211, 536870912, 1))

    // 8. L6_Neutral_Bounce: Confirmed bounce + ML filter (mid — Sharpe 0.153)
    bool l6 = valid_base and (entryCtx == 1000) and (mr > 0.2) and (vec < -0.3) and not vwapLongActive and (na(knnConf) or knnConf >= 50.0)
    if l6
        active.push(SetupConfig.new("L6", "Model-Confirmed Bounce", "LONG", 8.0, 1.5, 24, 44.0, 0.153, true, 1.12, "Asset has reached standard oversold territory (MR Osc > 0.2) while peers drag it down (Vector Pressure < -0.3). The k-Nearest Neighbor machine learning model (kNN Confidence) confirms historical probability of an immediate bounce.", 32, 206, 524288, 4))

    // 7. L_Basic: Low-threshold oversold entry — fallback when L_Exp/L6 don't qualify (Sharpe 0.05)
    bool l_basic = valid_base and (entryCtx == 1000) and (mr > 0.1) and (vec < -0.3) and not vwapLongActive
    if l_basic
        active.push(SetupConfig.new("L_Basic", "Micro-Bounce Scalp", "LONG", 6.0, 1.5, 20, 42.0, 0.05, true, 1.05, "Initial signs of oversold conditions (MR Osc > 0.1) while structurally dislocated from basket peers (Vector Pressure < -0.3). A basic reversion scalp prioritizing quick structural correction.", 0, 210, 268435456, 1))

    // =================================================================
    // 3. NEUTRAL ZONE SETUPS (entryCtx == 1100, z0 ∈ [-0.5, 0.5])
    // Trend-following and TE-driven setups for balanced market
    // =================================================================

    // 9. N_TE_Short: Transfer Entropy driven short in neutral zone
    bool n_te_short = valid_te and (entryCtx == 1100) and (te > 0.06) and (basket > 30) and (burst > 0.3) and not vwapShortActive
    if n_te_short
        active.push(SetupConfig.new("N_TE_S", "Lead-Lag Breakdown", "SHORT", 4.0, 1.2, 12, 52.0, 0.15, true, 1.0, "The broader market is trading sideways (Combined Z-Score), but Transfer Entropy (TE Osc) detects that peers are beginning to pull this asset down. High correlation (Basket Fit) and rising momentum (BURST Osc) confirm the drop.", 0, 120, 1073741824, 4))
    
    // 10. N_TE_Long: Transfer Entropy driven long in neutral zone
    bool n_te_long = valid_te and (entryCtx == 1100) and (te > 0.05) and (basket > 30) and (mr > 0.3) and not vwapLongActive
    if n_te_long
        active.push(SetupConfig.new("N_TE_L", "Lead-Lag Surge", "LONG", 4.0, 1.2, 12, 52.0, 0.15, true, 1.0, "Market is in an equilibrium state (Combined Z-Score), but predictive information flow (TE Osc) indicates peers will pull the asset higher. The asset is slightly oversold locally (MR Osc > 0.3), offering an optimal entry point.", 0, 221, 2147483648, 1))

    active
