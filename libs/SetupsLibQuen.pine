    else if setup_id == "S10"
        setup_code := 110
    else if setup_id == "S11"
        setup_code := 111
    else if setup_id == "S12"
        setup_code := 112
    else if setup_id == "L1"
        setup_code := 201
    else if setup_id == "L2"
        setup_code := 202
    else if setup_id == "L3"
        setup_code := 203
    else if setup_id == "L4"
        setup_code := 104
    else if setup_id == "L5"
        setup_code := 205
    else if setup_id == "L6"
        setup_code := 206
    else if setup_id == "L7"
        setup_code := 207
    else if setup_id == "L8"
        setup_code := 208
    else if setup_id == "L9"
        setup_code := 209
    else if setup_id == "V1"
        setup_code := 301
    else if setup_id == "V2"
        setup_code := 302
    else if setup_id == "V3"
        setup_code := 303
    else if setup_id == "V4"
        setup_code := 304
    else if setup_id == "81"
        setup_code := 381
    else if setup_id == "73"
        setup_code := 373
    else if setup_id == "75"
        setup_code := 375
    else if setup_id == "64"
        setup_code := 364
    setup_code

export f_setup_id_to_mask(string setup_id) =>
    int setup_mask = 0
    if setup_id == "S1"
        setup_mask := 1
    else if setup_id == "S5"
        setup_mask := 4
    else if setup_id == "S6"
        setup_mask := 8192
    else if setup_id == "S7"
        setup_mask := 16384
    else if setup_id == "S8"
        setup_mask := 32768
    else if setup_id == "S9"
        setup_mask := 65536
    else if setup_id == "S10"
        setup_mask := 131072
    else if setup_id == "S11"
        setup_mask := 16777216
    else if setup_id == "S12"
        setup_mask := 8388608
    else if setup_id == "L1"
        setup_mask := 8
    else if setup_id == "L2"
        setup_mask := 16
    else if setup_id == "L3"
        setup_mask := 32
    else if setup_id == "L4"
        setup_mask := 2
    else if setup_id == "L5"
        setup_mask := 262144
    else if setup_id == "L6"
        setup_mask := 524288
    else if setup_id == "L7"
        setup_mask := 1048576
    else if setup_id == "L8"
        setup_mask := 2097152
    else if setup_id == "L9"
        setup_mask := 4194304
    else if setup_id == "V1"
        setup_mask := 64
    else if setup_id == "V2"
        setup_mask := 128
    else if setup_id == "V3"
        setup_mask := 256
    else if setup_id == "V4"
        setup_mask := 512
    else if setup_id == "81"
        setup_mask := 1024
    else if setup_id == "73"
        setup_mask := 2048
    else if setup_id == "75"
        setup_mask := 4096
    else if setup_id == "64"
        setup_mask := 4194304
    setup_mask

export f_calc_tpsl(string dir, float ep, float tp_pct, float sl_pct, float z2_up, float z2_dn, float z3_up, float z3_dn, bool use_zones) =>
    float raw_tp = dir == "LONG" ? ep * (1 + tp_pct / 100) : ep * (1 - tp_pct / 100)
    float raw_sl = dir == "LONG" ? ep * (1 + sl_pct / 100) : ep * (1 - sl_pct / 100)
    float tp1 = raw_tp
    float zone_tp2 = dir == "LONG" ? z2_up : z2_dn
    float zone_tp3 = dir == "LONG" ? z3_up : z3_dn
    float zone_sl = dir == "LONG" ? z2_dn : z2_up
    bool zone_tp2_valid = not na(zone_tp2) and (dir == "LONG" ? zone_tp2 > ep : zone_tp2 < ep)
    bool zone_tp3_valid = not na(zone_tp3) and (dir == "LONG" ? zone_tp3 > ep : zone_tp3 < ep)
    bool zone_sl_valid = not na(zone_sl) and (dir == "LONG" ? zone_sl < ep : zone_sl > ep)
    float tp2 = use_zones and zone_tp2_valid ? zone_tp2 : raw_tp
    float tp3 = use_zones and zone_tp3_valid ? zone_tp3 : raw_tp
    float sl = use_zones ? (zone_sl_valid ? (dir == "LONG" ? math.min(raw_sl, zone_sl) : math.max(raw_sl, zone_sl)) : raw_sl) : raw_sl
    [tp1, tp2, tp3, sl]

export f_find_setup_spec(array<SetupSpec> setup_db, string setup_id) =>
    string found_name = ""
    string found_dir = ""
    float found_wr = na
    float found_sharpe = na
    float found_tp = na
    float found_sl = na
    int found_avg_bars = na
    string found_tooltip = ""
    int db_size = array.size(setup_db)
    for i = 0 to db_size - 1
        SetupSpec spec = array.get(setup_db, i)
        if spec.id == setup_id
            found_name := spec.name
            found_dir := spec.dir
            found_wr := spec.wr
            found_sharpe := spec.sharpe
            found_tp := spec.tp_pct
            found_sl := spec.sl_pct
            found_avg_bars := spec.avg_bars
            found_tooltip := spec.tooltip
            break
    [found_name, found_dir, found_wr, found_sharpe, found_tp, found_sl, found_avg_bars, found_tooltip]

export f_get_setup_horizon(array<SetupSpec> setup_db, string setup_id, int fallback_horizon) =>
    int horizon = fallback_horizon
    int setup_db_size = array.size(setup_db)
    if setup_db_size > 0
        for i = 0 to setup_db_size - 1
            SetupSpec spec = array.get(setup_db, i)
            if spec.id == setup_id
                horizon := spec.avg_bars
                break
    horizon

export f_register_event(array<SetupEvent> engine_events, bool fire_condition, string setup_id, string setup_tooltip, string setup_size_info) =>
    if fire_condition
        array.push(engine_events, SetupEvent.new(setup_id, setup_tooltip, setup_size_info, 0.5, 0))

export f_register_event_auto(array<SetupEvent> engine_events, array<SetupSpec> setup_db, bool fire_condition, string setup_id, string setup_size_info) =>
    if fire_condition
        string tooltip = ""
        int db_size = array.size(setup_db)
        for i = 0 to db_size - 1
            SetupSpec spec = array.get(setup_db, i)
            if spec.id == setup_id
                tooltip := spec.tooltip
                break
        array.push(engine_events, SetupEvent.new(setup_id, tooltip, setup_size_info, 0.5, 0))

export f_collect_debug(array<SetupEvent> engine_events) =>
    int setup_debug_code = 0
    int setup_debug_mask = 0
    int event_count = array.size(engine_events)
    if event_count > 0
        for i = 0 to event_count - 1
            SetupEvent setup_event = array.get(engine_events, i)
            setup_debug_code := f_setup_id_to_code(setup_event.id)
            setup_debug_mask += f_setup_id_to_mask(setup_event.id)
    [setup_debug_code, setup_debug_mask]

export f_get_spec(array<SetupSpec> setup_db, string setup_id) =>
    SetupSpec result = na
    int db_size = array.size(setup_db)
    if db_size > 0
        for i = 0 to db_size - 1
            SetupSpec spec = array.get(setup_db, i)
            if spec.id == setup_id
                result := spec
                break
    result

