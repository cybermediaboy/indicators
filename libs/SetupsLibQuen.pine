    SetupSpec v3 = SetupSpec.new("V3", "Transition", "LONG", FAM_TRAN, 75.0, 2.30, 0.80, -1.20, 12, "N=92 merge→V1 boost", na, 1.14, "MR", 0, SS_VEC_GT_P75 + SS_PRED_GT_P75, 1.0, 303, 256)
    SetupSpec v4 = SetupSpec.new("V4", "VelRecouple", "LONG", FAM_TRAN, 64.0, 2.80, 0.80, -1.50, 14, "WR64 edge<1 tighten", na, 0.97, "RECOUPLE", 0, SS_TE_LT_P25, 1.0, 304, 512)
    SetupSpec s81 = SetupSpec.new("81", "CORR⊥+MR", "LONG", FAM_UNC, 81.0, 0.0, 0.80, -1.20, 12, "81% WR corr-bottom+MR", na, 1.20, "MR", 0, SS_VEC_GT_P75, 1.0, 381, 1024)
