    SetupSpec s64 = SetupSpec.new("64", "CLD↗", "LONG", FAM_CONT, 64.0, 0.0, 0.80, -1.20, 14, "97% continuation pattern", na, 1.05, "MOMENTUM", 0, SS_NONE, 1.0, 364, 4194304)

