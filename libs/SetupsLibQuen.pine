library("SetupsLibQuen", overlay=false, dynamic_requests=true)

// ═══════════════════════════════════════════════════════════════════════════
// LEVEL TRACKER — sweep-aware TP/SL/Entry line management
// ═══════════════════════════════════════════════════════════════════════════

export type LevelTracker
    line ln
    float price
    int start_bar
    int sweep_dir       // +1=swept when high>=price, -1=swept when low<=price, 0=fixed
    int default_len     // 10 for entry, 20 for TP/SL
    int max_scan        // 0 for entry (no scan), 300 for TP/SL
    bool done

export f_create_level(float price, int bar_idx, int sweep_dir, int default_len, int max_scan, color col, int width, bool dashed) =>
    LevelTracker t = LevelTracker.new(na, nz(price), bar_idx, sweep_dir, default_len, max_scan, true)
    if not na(price)
        t.ln := line.new(bar_idx, price, bar_idx + (sweep_dir == 0 ? default_len : 0), price, color=col, style=dashed ? line.style_dashed : line.style_solid, width=width, force_overlay=true)
        t.done := sweep_dir == 0
    t

export f_create_tpsl_levels(array<LevelTracker> levels, string dir, float ep, float tp1, float tp2, float sl, int bar_idx, int entry_len, int default_len, int max_scan, color tp_col, color sl_col, color ep_col) =>
    int start_idx = array.size(levels)
    int tp_sw = dir == "LONG" ? 1 : -1
    int sl_sw = dir == "LONG" ? -1 : 1
    array.push(levels, f_create_level(ep, bar_idx, 0, entry_len, 0, ep_col, 1, true))
    array.push(levels, f_create_level(tp1, bar_idx, tp_sw, default_len, max_scan, tp_col, 2, false))
    array.push(levels, f_create_level(tp2, bar_idx, tp_sw, default_len, max_scan, tp_col, 1, true))
    array.push(levels, f_create_level(sl, bar_idx, sl_sw, default_len, max_scan, sl_col, 2, false))
    [start_idx, 4]

export f_update_levels(array<LevelTracker> levels, float hi, float lo, int current_bar) =>
    bool updated = false
    int n = array.size(levels)
    if n > 0
        for i = 0 to n - 1
            LevelTracker t = array.get(levels, i)
            if not t.done and not na(t.ln)
                int age = current_bar - t.start_bar
                bool swept = (t.sweep_dir > 0 and hi >= t.price) or (t.sweep_dir < 0 and lo <= t.price)
                bool late_expired = age > t.max_scan
                bool within_active_window = age <= t.default_len and age <= t.max_scan
                int new_x2 = late_expired ? (t.start_bar + t.default_len) : (swept ? current_bar : (within_active_window ? current_bar : na))
                if not na(new_x2)
                    line.set_x2(t.ln, new_x2)
                    t.done := late_expired or swept
                    updated := true
    updated

export f_remove_levels(array<LevelTracker> levels, int start_idx, int count) =>
    int end_idx = math.min(start_idx + count, array.size(levels))
    if start_idx >= 0 and start_idx < array.size(levels)
        for i = start_idx to end_idx - 1
            LevelTracker t = array.get(levels, i)
            if not na(t.ln)
                line.delete(t.ln)
            t.done := true

export f_freeze_levels(array<LevelTracker> levels, int start_idx, int count) =>
    int end_idx = math.min(start_idx + count, array.size(levels))
    if start_idx >= 0 and start_idx < array.size(levels)
        for i = start_idx to end_idx - 1
            LevelTracker t = array.get(levels, i)
            t.done := true

// ═══════════════════════════════════════════════════════════════════════════
// FAMILY + SETUP V19 CORE TYPES
// ═══════════════════════════════════════════════════════════════════════════

export type Family
    int id = 4
    string label = "UNC"
    string name = "Uncertain"
    int direction = 0
    bool directional = false
    color col = color.gray

export type SetupSpec
    string id
    string name
    string dir
    Family family = na
    float wr
    float sharpe
    float tp_pct
    float sl_pct
    int avg_bars
    string tooltip
    int timestop = na
    float edge_ratio = 1.0
    string thesis = "MOMENTUM"
    int thesis_flags = 0
    int showstopper_mask = 0
    float impulse_penalty_scale = 1.0
    int code = 0
    int mask = 0

export f_build_family_table() =>
    array<Family> fam = array.new<Family>(5)
    array.set(fam, 0, Family.new(0, "CONT", "Continuation", 0, false, color.green))
    array.set(fam, 1, Family.new(1, "MR", "Mean Reversion", 0, false, color.purple))
    array.set(fam, 2, Family.new(2, "TRAN", "Transition", 0, false, color.orange))
    array.set(fam, 3, Family.new(3, "VEL", "Velocity", 0, false, color.aqua))
    array.set(fam, 4, Family.new(4, "UNC", "Uncertain", 0, false, color.gray))
    fam

export f_family_get(array<Family> fam, int id) =>
    int safe = math.max(0, math.min(id, array.size(fam) - 1))
    array.get(fam, safe)

export f_family_match(int fam_a, int fam_b, bool soft) =>
    if fam_a == fam_b
        true
    else if soft and (fam_a == 4 or fam_b == 4)
        fam_a != 4 or fam_b != 4
    else
        false

export f_classify_market_state(array<Family> fam,
     float position, float velocity, float pressure,
     float coupling, float mrstate) =>
    bool mr_bias = mrstate > 0.5
    bool mr_override = mrstate > 0.85
    bool continuation = math.abs(velocity) > 0.12 and math.sign(velocity) == math.sign(pressure) and coupling > 0.5 and not mr_bias
    bool meanrevert = math.abs(position) > 1.0 and (mr_bias or math.sign(position) != math.sign(velocity) or math.abs(velocity) < 0.08 or mr_override)
    bool transition = (math.abs(velocity) < 0.06 and math.abs(pressure) > 0.75) or (math.abs(position) < 0.4 and math.abs(pressure) > 1.0 and coupling > 0.35 and not mr_bias)
    bool velocityctx = coupling < 0.35 or (coupling < 0.5 and math.abs(pressure) > 0.8)

    if mr_override
        array.get(fam, 1)
    else if mr_bias and not meanrevert and not transition and not velocityctx
        array.get(fam, 1)
    else if meanrevert
        array.get(fam, 1)
    else if transition
        array.get(fam, 2)
    else if velocityctx
        array.get(fam, 3)
    else if continuation
        array.get(fam, 0)
    else
        array.get(fam, 4)

export type SetupSignal
    string id
    string tooltip
    bool use_pred_rounding
    bool debug_enabled
    string size_info

export type SetupEvent
    string id
    string tooltip
    string size_info
