// Touch detection function with grouped toggleable detection methods
// @param level - Level to check against (EMA, band, any threshold)
// @param toleranceAbs - Absolute tolerance value (optional, default = 0)
// @param tolerancePerc - Percentage tolerance (as decimal, optional, default = 0)
// @param useATR - Use ATR to scale tolerance (default=false)
// @param atrPeriod - ATR period if useATR is true (default=14)
// @param atrMultiplier - Multiplier for ATR-based tolerance (default=1.0)
// @param atrNormPeriod - Period for ATR normalization (default=20)
// @param enableBodyDetection - Enable all body-related detections (default=true)
// @param enableWickDetection - Enable all wick-related detections (default=true)
// @param enableHistoricalDetection - Enable detection using previous bar data (default=true)
// @returns 0 for body cross, -1 for touch from above, 1 for touch from below, na for no touch
export touch(float level, float toleranceAbs = 0.0, float tolerancePerc = 0.0,
      bool useATR = false, int atrPeriod = 14, float atrMultiplier = 1.0, int atrNormPeriod = 20,
      bool enableBodyDetection = true, bool enableWickDetection = true, 
      bool enableHistoricalDetection = true, float ltf_delta = na) =>
    
    // Calculate tolerance
    float tolerance = toleranceAbs + (level * tolerancePerc)
    
    // Add ATR-based tolerance if enabled
    if useATR
        float atrValue = ta.atr(atrPeriod)
        float normalizedATR = getNormalizedCoefficient(atrValue, atrNormPeriod, 3, 1, false, 0, true)
        tolerance := tolerance * (1.0 + (normalizedATR * atrMultiplier))
    
    // Body detection (body crossed)
    bodyCrossed = enableBodyDetection and ((open > level and close < level) or (open < level and close > level))
    
    // Wick detection (upper and lower wick touches/crosses)
    upperWickTouched = enableWickDetection and (high >= level - tolerance and high > math.max(open, close) and close < level)
    upperWickCrossed = enableWickDetection and (high >= level and close < level and math.max(open, close) < high)
    lowerWickTouched = enableWickDetection and (low <= level + tolerance and low < math.min(open, close) and close > level)
    lowerWickCrossed = enableWickDetection and (low <= level and close > level and math.min(open, close) > low)
    
    // Historical detection (using previous bar data)
    bodyCrossedDown = enableHistoricalDetection and (high[1] >= level and close < level - tolerance)
    bodyCrossedUp = enableHistoricalDetection and (low[1] <= level and close > level + tolerance)

    // Determine touch direction
    touchDirection = bodyCrossed ? 0 : (upperWickTouched or upperWickCrossed or bodyCrossedDown) ? -1 : (lowerWickTouched or lowerWickCrossed or bodyCrossedUp) ? 1 : na

    if not na(ltf_delta)
        bool ok = touchDirection == 0 ? true : (touchDirection > 0 ? (ltf_delta > 0) : (ltf_delta < 0))
        touchDirection := ok ? touchDirection : na
    
    touchDirection


// @function Calculates covariance between two series
// @param x First data series
// @param y Second data series  
// @param length Lookback period
// @returns Covariance value
export cov(series float x, series float y, simple int length) =>
    mean_x = ta.sma(x, length)
    mean_y = ta.sma(y, length)
    
    sum_cov = 0.0
    for i = 0 to length - 1
        sum_cov := sum_cov + (x[i] - mean_x) * (y[i] - mean_y)
    
    sum_cov / length


// @function Dynamic RMA (Wilder) with series length
// @param src Input series
// @param dynamic_len Series-type period (>=1). If <1, coerced to 1.
// @returns RMA with variable length, stable and stateful
export f_dynamic_rma(series float src, series float dynamic_len) =>
    var float dyn_rma = na
    L = math.max(1.0, dynamic_len)
    alpha = 1.0 / L
    dyn_rma := na(dyn_rma[1]) ? src : (alpha * src + (1.0 - alpha) * dyn_rma[1])
    dyn_rma

// @function Dynamic SMA (stateful, O(1) update) with series window
// Note: exact rolling SMA with variable window requires O(N) sum; this version approximates SMA by adaptive EMA with alpha=2/(L+1) when L varies smoothly.
// For exact SMA, keep your f_dynamic_sma above.
// @param src Input series
// @param dynamic_len Series-type window length (>=1)
// @returns Adaptive-EMA SMA approximation for speed-critical paths
export f_dynamic_sma_fast(series float src, series float dynamic_len) =>
    var float dyn_sma = na
    L = math.max(1.0, dynamic_len)
    alpha = 2.0 / (L + 1.0)
    dyn_sma := na(dyn_sma[1]) ? src : (alpha * src + (1.0 - alpha) * dyn_sma[1])
    dyn_sma


// @function Dynamic Covariance with series length support
// @param x First data series
// @param y Second data series  
// @param dynamic_length Lookback period (can be series)
// @returns Covariance value with dynamic window
export cov_dynamic(series float x, series float y, series int dynamic_length) =>
    // Convert to valid integer length
    len = math.max(2, int(dynamic_length))
    
    // Calculate dynamic means
    mean_x = 0.0
    mean_y = 0.0
    for i = 0 to len - 1
        mean_x := mean_x + nz(x[i], 0)
        mean_y := mean_y + nz(y[i], 0)
    mean_x := mean_x / len
    mean_y := mean_y / len
    
    // Calculate covariance
    sum_cov = 0.0
    for i = 0 to len - 1
        sum_cov := sum_cov + (nz(x[i], mean_x) - mean_x) * (nz(y[i], mean_y) - mean_y)
    
    sum_cov / len

