// @function 5-layer regime-switched normalization system for adaptive thresholds
// @param enable_norm Whether normalization is enabled
// @param te_val TE oscillator value
// @param mr_val Mean reversion oscillator value
// @param vec_val Vector oscillator value
// @param corr_val Correlation oscillator value
// @param te_p25 TE 25th percentile
// @param te_p75 TE 75th percentile
// @param mr_p25 MR 25th percentile
// @param mr_p75 MR 75th percentile
// @param vec_p25 Vector 25th percentile
// @param vec_p75 Vector 75th percentile
// @param corr_p25 Correlation 25th percentile
// @param corr_p75 Correlation 75th percentile
// @param ltf_p20 LTF 20th percentile
// @param ltf_p50 LTF 50th percentile
// @param coupling_strong Strong coupling threshold
// @param coupling_weak Weak coupling threshold
// @param ltf_decouple_default Default LTF decouple threshold
// @param ltf_recouple_default Default LTF recouple threshold
// @param ltf_en Whether LTF is enabled
// @param mr_vol_look MR volatility lookback period
// @returns [coupling_regime, te_norm, mr_norm, vec_norm, corr_norm, te_effective, ltf_decouple_adaptive, ltf_recouple_adaptive, mr_vol_adj]
export f_norm_system(bool enable_norm, float te_val, float mr_val, float vec_val, float corr_val, 
              float te_p25, float te_p75, float mr_p25, float mr_p75, float vec_p25, float vec_p75, float corr_p25, float corr_p75,
              float ltf_p20, float ltf_p50, float coupling_strong, float coupling_weak, 
              float ltf_decouple_default, float ltf_recouple_default, bool ltf_en, int mr_vol_look) =>
    // Layer 1: Coupling Regime Detection
    float coupling_strength = enable_norm ? nz(te_p75, 0.5) : 0.8
    int regime = coupling_strength > coupling_strong ? 2 : (coupling_strength > coupling_weak ? 1 : 0)
    
    // Layer 2: IQR-Normalized Oscillators
    float te_normalized = enable_norm ? f_iqr_normalize(te_val, nz(te_p25, 0.0), nz(te_p75, 0.1)) : te_val
    
    float mr_normalized = enable_norm ? f_iqr_normalize(mr_val, nz(mr_p25, 0.0), nz(mr_p75, 1.0)) : mr_val
    
    float vec_normalized = enable_norm ? f_iqr_normalize(vec_val, nz(vec_p25, 0.0), nz(vec_p75, 1.0)) : vec_val
    
    float corr_normalized = enable_norm ? f_iqr_normalize(corr_val, nz(corr_p25, 0.0), nz(corr_p75, 1.0)) : corr_val
    
    // Layer 3: Hybrid TE Threshold (regime-based blending)
    float te_iqr = math.max(nz(te_p75, 0.1) - nz(te_p25, 0.0), 1e-10)
    float te_eff = enable_norm ? (regime == 2 ? te_val : (regime == 1 ? (te_val * 0.5 + (te_normalized * te_iqr + nz(te_p25, 0.0)) * 0.5) : (te_normalized * te_iqr + nz(te_p25, 0.0)))) : te_val
    
    // LTF adaptive thresholds
    float ltf_decouple = enable_norm and ltf_en ? nz(ltf_p20, ltf_decouple_default) : ltf_decouple_default
    float ltf_recouple = enable_norm and ltf_en ? nz(ltf_p50, ltf_recouple_default) : ltf_recouple_default
    
    // Layer 4: Volatility-Homoscedastic MR Adjustment
    float atr_cur = ta.atr(14)
    float atr_base = ta.sma(atr_cur, mr_vol_look)
    float vol_exp = enable_norm ? math.max(0.5, atr_cur / math.max(atr_base, syminfo.mintick)) : 1.0
    float mr_vol_adjusted = enable_norm ? mr_val / vol_exp : mr_val
    
    [regime, te_normalized, mr_normalized, vec_normalized, corr_normalized, te_eff, ltf_decouple, ltf_recouple, mr_vol_adjusted]

// @function Stable percentile-rank normalization with Fisher transform
// @description Converts raw values to time-invariant normalized features using ordinal ranking.
//              Eliminates temporal drift from rolling z-scores by using percentile position,
//              then applies Fisher/logit transform to produce Gaussian-like distribution.
// @param raw Raw input value to normalize
// @param window Lookback window for percentile calculation (e.g., 200)
// @returns Normalized value in approximate range [-2.65, +2.65] with Gaussian shape
// @note Output is time-invariant: percentile 85 two weeks ago = percentile 85 now
// @note Ideal for kNN distance calculations where temporal consistency is critical
export f_percentile_rank_fisher(float raw, int window) =>
    float pct = ta.percentrank(raw, window)           // 0–100, O(1) built-in
    float u = math.max(0.5, math.min(99.5, pct)) / 100.0  // clamp away from 0/1
    0.5 * math.log(u / (1.0 - u))                     // logit → ≈ N(0,1)

