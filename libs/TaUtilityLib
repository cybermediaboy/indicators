export f_find_key(array<int> keys, int key) =>
    int pos = -1
    int n = array.size(keys)
    if n > 0
        for i = 0 to n - 1
            if array.get(keys, i) == key
                pos := i
                break
    pos

export f_lower_bound(array<int> a, int x) =>
    int lo = 0
    int hi = array.size(a)
    while lo < hi
        int mid = int(math.floor((lo + hi) / 2))
        int v = array.get(a, mid)
        if v < x
            lo := mid + 1
        else
            hi := mid
    lo

export f_upper_bound(array<int> a, int x) =>
    int lo = 0
    int hi = array.size(a)
    while lo < hi
        int mid = int(math.floor((lo + hi) / 2))
        int v = array.get(a, mid)
        if v <= x
            lo := mid + 1
        else
            hi := mid
    lo

export f_find_key_sorted(array<int> keys, int key) =>
    int pos = -1
    int n = array.size(keys)
    if n > 0
        int i = f_lower_bound(keys, key)
        if i >= 0 and i < n and array.get(keys, i) == key
            pos := i
    pos

export f_map_add4(map<int, float> m1, map<int, float> m2, map<int, float> m3, map<int, float> m4, int k, float d1, float d2, float d3, float d4) =>
    float p1 = map.contains(m1, k) ? map.get(m1, k) : 0.0
    float p2 = map.contains(m2, k) ? map.get(m2, k) : 0.0
    float p3 = map.contains(m3, k) ? map.get(m3, k) : 0.0
    float p4 = map.contains(m4, k) ? map.get(m4, k) : 0.0
    map.put(m1, k, p1 + d1)
    map.put(m2, k, p2 + d2)
    map.put(m3, k, p3 + d3)
    map.put(m4, k, p4 + d4)

export f_get_by_key(array<int> keys, array<float> vals, int key) =>
    float out = 0.0
    int mn = math.min(array.size(keys), array.size(vals))
    if array.size(keys) > mn
        for i = array.size(keys) - 1 to mn
            array.remove(keys, i)
    if array.size(vals) > mn
        for i = array.size(vals) - 1 to mn
            array.remove(vals, i)
    int pos = f_find_key(keys, key)
    out := pos >= 0 and pos < array.size(vals) ? array.get(vals, pos) : 0.0
    out

export f_add_to_map(array<int> keys, array<float> vals, int key, float delta) =>
    int mn = math.min(array.size(keys), array.size(vals))
    if array.size(keys) > mn
        for i = array.size(keys) - 1 to mn
            array.remove(keys, i)
    if array.size(vals) > mn
        for i = array.size(vals) - 1 to mn
            array.remove(vals, i)
    int pos = f_find_key(keys, key)
    if pos < 0
        array.push(keys, key)
        array.push(vals, delta)
    else if pos < array.size(vals)
        array.set(vals, pos, array.get(vals, pos) + delta)
    else
        array.push(keys, key)
        array.push(vals, delta)

export f_add_to_map2(array<int> keys, array<float> vals1, array<float> vals2, int key, float d1, float d2) =>
    int mn = math.min(array.size(keys), math.min(array.size(vals1), array.size(vals2)))
    if array.size(keys) > mn
        for i = array.size(keys) - 1 to mn
            array.remove(keys, i)
    if array.size(vals1) > mn
        for i = array.size(vals1) - 1 to mn
            array.remove(vals1, i)
    if array.size(vals2) > mn
        for i = array.size(vals2) - 1 to mn
            array.remove(vals2, i)
    int pos = f_find_key(keys, key)
    if pos < 0
        array.push(keys, key)
        array.push(vals1, d1)
        array.push(vals2, d2)
    else if pos < array.size(vals1) and pos < array.size(vals2)
        array.set(vals1, pos, array.get(vals1, pos) + d1)
        array.set(vals2, pos, array.get(vals2, pos) + d2)
    else
        array.push(keys, key)
        array.push(vals1, d1)
        array.push(vals2, d2)

