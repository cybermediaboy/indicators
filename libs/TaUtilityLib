// @function Detects squeeze/bottleneck breakout conditions based on band width dynamics
// @param band_up Upper band price level
// @param band_dn Lower band price level
// @param price Current price for direction detection
// @param damping Correlation damping factor (0-1) for directional confirmation
// @param z_len Lookback length for band width percentile calculation
// @returns [squeeze_bull, squeeze_bear, final_squeeze_signal, bw_pct] Bullish squeeze, bearish squeeze, any squeeze signal, band width percentile
export f_detect_squeeze(float band_up, float band_dn, float price, float damping, int z_len) =>
    float bw = band_up - band_dn
    float bw_roc = (bw - nz(bw[1])) / math.max(nz(bw[1]), syminfo.mintick)
    float bw_roc2 = bw_roc - nz(bw_roc[1])
    float bw_min_30 = ta.lowest(bw, 30)
    bool is_squeeze = bw < bw_min_30 * 1.05
    bool bw_expanding = bw_roc > 0.0 and (bw_roc2 > 0.0 or nz(bw_roc2[1]) > 0.0)
    bool bottleneck_break = is_squeeze[1] and bw_expanding
    float _bw_pct = 0.0
    int bw_pct_len = z_len
    for i = 0 to bw_pct_len - 1
        if bw >= nz(bw[i])
            _bw_pct += 1.0
    _bw_pct := _bw_pct / bw_pct_len
    float vol_short = ta.stdev(price, 5)
    float vol_long = ta.stdev(price, 30)
    float vol_ratio = vol_short / math.max(vol_long, syminfo.mintick)
    float bw_roc_z = bw_roc / math.max(ta.stdev(bw_roc, 20), 0.001)
    bool expand_by_bw = bw_roc_z > 1.5
    bool expand_by_vol = ta.crossover(vol_ratio, 0.80) and nz(vol_ratio[3]) < 0.65
    bool expansion_confirmed = expand_by_bw or expand_by_vol
    float squeeze_intensity = math.max(0.0, 1.0 - _bw_pct)
    bool confirmed_break = squeeze_intensity > 0.70 and expansion_confirmed and bottleneck_break
    float break_dir = math.sign(price - nz(price[3], price))
    bool dir_ok = damping > 0.4
    bool _final_sq = confirmed_break and dir_ok
    bool sq_bull = _final_sq and break_dir > 0
    bool sq_bear = _final_sq and break_dir < 0
    [sq_bull, sq_bear, _final_sq, _bw_pct]

// @function Detects confluence zones where multiple price levels cluster together
// @param basis Baseline MA price level
// @param fv Fair value (cyclic FV) price level
// @param dev Standard deviation for band multiples
// @param tol_mult ATR tolerance multiplier for clustering
// @param min_lines Minimum number of lines required to form a confluence cluster
// @returns bool Always returns true (draws confluence lines as side effect)
export f_detect_confluence(float basis, float fv, float dev, float tol_mult, int min_lines) =>
    float atr_tol = ta.atr(14) * tol_mult
    var levels = array.new<float>()
    array.clear(levels)
    array.push(levels, basis)
    array.push(levels, fv)
    if dev > 0
        for k = 1 to 6
            float mult = k * 0.5
            array.push(levels, basis + mult * dev)
            array.push(levels, basis - mult * dev)
            if math.abs(fv - basis) > atr_tol * 2
                array.push(levels, fv + mult * dev)
                array.push(levels, fv - mult * dev)
    array.sort(levels, order.ascending)
    var prev_cluster_levels = array.new<float>()
    var next_cluster_levels = array.new<float>()
    array.clear(next_cluster_levels)
    int n_levels = array.size(levels)
    if n_levels > 0
        int i = 0
        while i < n_levels
            float base_level = array.get(levels, i)
            int current_count = 1
            float current_sum = base_level
            int j = i + 1
            while j < n_levels
                float check_level = array.get(levels, j)
                if check_level - base_level <= atr_tol
                    current_count += 1
                    current_sum += check_level
                    j += 1
                else
                    break
            if current_count >= min_lines
                float avg_level = current_sum / current_count
                array.push(next_cluster_levels, avg_level)
                float vicinity = atr_tol * 2.0
                if math.abs(close - avg_level) < vicinity
                    bool is_support = avg_level < close
                    color conf_col = is_support ? color.lime : color.red
                    float best_prev = na
                    float min_dist = 1e10
                    int prev_cluster_size = array.size(prev_cluster_levels)
                    if prev_cluster_size > 0
                        for prev_idx = 0 to prev_cluster_size - 1
                            float p = array.get(prev_cluster_levels, prev_idx)
                            float d = math.abs(p - avg_level)
                            if d < min_dist
                                min_dist = d
                                best_prev = p
                    if not na(best_prev) and min_dist < atr_tol * 2.0
                        line.new(bar_index - 1, best_prev, bar_index, avg_level, color=conf_col, width=1)
            i += current_count
    array.clear(prev_cluster_levels)
    int next_cluster_size = array.size(next_cluster_levels)
    if next_cluster_size > 0
        for next_idx = 0 to next_cluster_size - 1
            array.push(prev_cluster_levels, array.get(next_cluster_levels, next_idx))
    true

// @function Updates CUSUM (Cumulative Sum) control chart for detecting persistent deviations
// @param cusum_pos Current positive CUSUM value
// @param cusum_neg Current negative CUSUM value
// @param innovation Current innovation/residual value
// @param threshold Threshold multiplier for CUSUM reset
// @param innov_abs_dev Absolute deviation of innovation for scaling
// @returns [new_cusum_pos, new_cusum_neg, cusum_triggered] Updated CUSUM values and trigger signal
export f_update_cusum(float cusum_pos, float cusum_neg, float innovation, float threshold, float innov_abs_dev) =>
    float new_pos = math.max(0.0, cusum_pos + innovation - threshold * innov_abs_dev)
    float new_neg = math.max(0.0, cusum_neg - innovation - threshold * innov_abs_dev)
    bool triggered = new_pos > 3.0 * innov_abs_dev or new_neg > 3.0 * innov_abs_dev
    if triggered
        new_pos := 0.0
        new_neg := 0.0
    [new_pos, new_neg, triggered]

// @function Detects bounce at a level (e.g., MA) after price was stretched away
// @param price Current price level (z-score or normalized position)
// @param velocity Trend velocity/momentum
// @param pressure External pressure (e.g., basket vector)
// @param coupling Coupling strength (e.g., correlation damping)
// @param hist_price Historical price level at lookback
// @param price_momentum Price momentum for resumption check
// @param bounce_thresh Threshold for "near level" detection
// @param lookback Lookback period for "was stretched" check
// @returns bool True if bounce condition detected
export f_detect_bounce_at_level(float price, float velocity, float pressure, float coupling, float hist_price, float price_momentum, float bounce_thresh, int lookback) =>
    bool near_level = math.abs(price) < bounce_thresh
    bool trend_alive = math.abs(velocity) > 0.12
    bool dir_aligned = math.sign(velocity) == math.sign(pressure) and coupling > 0.5
    // Use lookback parameter to verify historical stretch
    float price_at_lookback = nz(price[lookback], price)
    bool was_stretched = math.abs(nz(hist_price)) > bounce_thresh * 1.5 or math.abs(price_at_lookback) > bounce_thresh * 1.5
    bool resuming = (velocity > 0 and price_momentum > nz(price_momentum[1])) or (velocity < 0 and price_momentum < nz(price_momentum[1]))
    bool is_bounce = near_level and trend_alive and dir_aligned and was_stretched and resuming
    is_bounce and not is_bounce[1] and not is_bounce[2]
