// @function Checks if price crosses through correlation/pivot lines and counts touches
// @param pivot_bars Array of pivot bar indices
// @param pivot_prices Array of pivot prices  
// @param pivot_strengths Array of pivot strengths/scores
// @param current_bar Current bar index being checked
// @param current_price Current price level
// @param is_high True if checking high pivots, false for lows
// @param max_age Maximum age of pivots to check
// @param max_touches Maximum touches before pivot expires
// @returns [bullish_score, bearish_score, touch_count, touched_pivots_string, crossed_price]
export check_pivot_crossings(array<int> pivot_bars, array<float> pivot_prices, array<float> pivot_strengths, int current_bar, float current_price, bool is_high, int max_age, int max_touches) =>
    
    float bullish_score = 0.0
    float bearish_score = 0.0
    int touch_count = 0
    string touched_pivots = ""
    float crossed_price = na
    
    if array.size(pivot_bars) == 0
        [bullish_score, bearish_score, touch_count, touched_pivots, crossed_price]
    else
        // Arrays to track touches per pivot
        var array<int> pivot_touch_counts = array.new<int>()
        
        // Ensure touch count array matches pivot arrays
        while array.size(pivot_touch_counts) < array.size(pivot_bars)
            array.push(pivot_touch_counts, 0)
        
        // Check each pivot for crossings
        for i = 0 to math.min(array.size(pivot_bars) - 1, 100)
            pivot_bar = array.get(pivot_bars, i)
            pivot_price = array.get(pivot_prices, i) 
            pivot_strength = array.size(pivot_strengths) > i ? array.get(pivot_strengths, i) : 1.0
            
            // Skip if pivot too old
            if current_bar - pivot_bar > max_age
                continue
            
            // Get current touch count
            current_touches = array.get(pivot_touch_counts, i)
            
            // Skip if max touches exceeded
            if current_touches >= max_touches
                continue
            
            // Check for crossing
            crossed = false
            if is_high  // Resistance line
                if current_price >= pivot_price and current_price[1] < pivot_price
                    crossed := true
                    bullish_score += pivot_strength
            else  // Support line
                if current_price <= pivot_price and current_price[1] > pivot_price
                    crossed := true
                    bearish_score += pivot_strength
            
            // Update touch count if crossed
            if crossed
                array.set(pivot_touch_counts, i, current_touches + 1)
                touch_count += 1
                crossed_price := pivot_price
                
                // Build touched pivots string
                if touched_pivots != ""
                    touched_pivots += ", "
                touched_pivots += str.tostring(pivot_bar) + ":" + str.tostring(math.round(pivot_strength, 2))
        
        [bullish_score, bearish_score, touch_count, touched_pivots, crossed_price]


