export scale_for_subchart(series float primary_line, series float secondary_line, 
                          int lookback, float percentile, float chart_level,
                          float offset_value, bool offset_is_percent) =>
    
    // Use existing f_scale_percentile for base scaling
    scaled = f_scale_percentile(primary_line, secondary_line, lookback, percentile, chart_level)
    
