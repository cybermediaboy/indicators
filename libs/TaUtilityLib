export f_kalman_update(KalmanState state, float measurement, float Q_price_scaled, float Q_vel_scaled, float R_scaled) =>
    float filtered_value = na
    if na(state.price) or state.bars_run == 0
        state.price := measurement
        state.velocity := 0.0
        state.P_price := R_scaled * 10.0
        state.P_vel := Q_vel_scaled * 100.0
        state.P_cross := 0.0
        state.R_ewma := R_scaled
        state.bars_run := 1
        filtered_value := measurement
    else
        float x_pred_price = state.price + state.velocity
        float x_pred_vel = state.velocity
        float P_pred_price_base = state.P_price + 2.0 * state.P_cross + state.P_vel + Q_price_scaled
        float innovation = measurement - x_pred_price
        float innovation_sq = innovation * innovation
        float S = P_pred_price_base + state.R_ewma
        float _tanh_x = innovation_sq / math.max(S, 0.0001)
        float _exp_pos = math.exp(math.min(_tanh_x, 20.0))
        float _exp_neg = math.exp(math.min(-_tanh_x, 20.0))
        float _tanh_val = (_exp_pos - _exp_neg) / (_exp_pos + _exp_neg)
        float Q_adaptive = Q_price_scaled * (1.0 + _tanh_val)
        state.R_ewma := 0.95 * state.R_ewma + 0.05 * innovation_sq
        state.R_ewma := math.max(state.R_ewma, R_scaled * 0.1)
        float P_pred_price = state.P_price + 2.0 * state.P_cross + state.P_vel + Q_adaptive
        float P_pred_cross = state.P_cross + state.P_vel
        float P_pred_vel = state.P_vel + Q_vel_scaled
        float S_final = P_pred_price + state.R_ewma
        float K_price = S_final > 0 ? P_pred_price / S_final : 0.0
        float K_vel = S_final > 0 ? P_pred_cross / S_final : 0.0
        state.price := x_pred_price + K_price * innovation
        state.velocity := x_pred_vel + K_vel * innovation
        float one_minus_K = 1.0 - K_price
        state.P_price := math.max(one_minus_K * P_pred_price, Q_adaptive * 0.01)
        state.P_cross := one_minus_K * P_pred_cross
        state.P_vel := math.max(P_pred_vel - K_vel * P_pred_cross, Q_vel_scaled * 0.01)
        state.bars_run += 1
        filtered_value := state.price
    filtered_value

export f_kalman_update_te(KalmanState state, float measurement, float Q_price_scaled, float Q_vel_scaled, float R_scaled, float te_unit, float te_q_gain, float te_r_gain, float te_scale_min, float te_scale_max) =>
    float u = math.max(0.0, math.min(1.0, nz(te_unit, 0.0)))
    float q_mult_raw = 1.0 + te_q_gain * u
    float r_mult_raw = 1.0 + te_r_gain * (1.0 - u)
    float q_mult = math.max(te_scale_min, math.min(te_scale_max, q_mult_raw))
    float r_mult = math.max(te_scale_min, math.min(te_scale_max, r_mult_raw))
    f_kalman_update(state, measurement, Q_price_scaled * q_mult, Q_vel_scaled * q_mult, R_scaled * r_mult)

export f_te_enhanced_kalman_update(KalmanState state, float measurement, float Q_price_base, float Q_vel_base, float R_base, float te_norm, float te_q_sensitivity, float te_r_sensitivity, float te_scale_min, float te_scale_max) =>
    float q_mult_raw = 1.0 + te_q_sensitivity * te_norm
    float r_mult_raw = 1.0 + te_r_sensitivity * te_norm
    float q_mult = math.max(te_scale_min, math.min(te_scale_max, q_mult_raw))
    float r_mult = math.max(te_scale_min, math.min(te_scale_max, r_mult_raw))
    f_kalman_update(state, measurement, Q_price_base * q_mult, Q_vel_base * q_mult, R_base * r_mult)

export f_winsorize(float val, float p2, float p98) =>
    na(val) ? na : math.max(p2, math.min(val, p98))

export f_basis_median_mad(float src, int basis_len) =>
    array<float> price_array = array.new<float>()
    for i = 0 to basis_len - 1
        array.push(price_array, src[i])
    array.sort(price_array, order.ascending)
    int med_idx = int(array.size(price_array) / 2)
    float ma_local = array.size(price_array) > 0 ? array.get(price_array, med_idx) : src
    array<float> dev_array = array.new<float>()
    for i = 0 to basis_len - 1
        array.push(dev_array, math.abs(src[i] - ma_local))
    array.sort(dev_array, order.ascending)
    float mad = array.size(dev_array) > 0 ? array.get(dev_array, med_idx) : 0.0
    float dev_local = mad * 1.4826
    float z_local = dev_local > 0 ? (src - ma_local) / dev_local : 0.0
    [ma_local, dev_local, dev_local, 1.0, z_local]

export f_basis_vwma(float src, float vol, int basis_len) =>
    float vwma = ta.sma(src * vol, basis_len) / ta.sma(vol, basis_len)
    float vw_variance = ta.sma(vol * math.pow(src - vwma, 2), basis_len) / ta.sma(vol, basis_len)
    float dev_local = math.sqrt(math.max(vw_variance, 0.0))
    float z_local = dev_local > 0 ? (src - vwma) / dev_local : 0.0
    [vwma, dev_local, dev_local, 1.0, z_local]

export f_sgd_update_gated(float current_param, float gradient, float learning_rate, float param_min, float param_max, float coupling_damping, float gate_thresh) =>
    if na(coupling_damping) or coupling_damping < gate_thresh
        current_param
    else
        float eff_lr = learning_rate * math.min(1.0, coupling_damping)
        float new_val = current_param - eff_lr * gradient
        math.max(param_min, math.min(new_val, param_max))

export f_kalman_robust(float measurement, float state, float P, float Q, float R, float innov_std, float clip_sigma) =>
    float x_pred = state
    float P_pred = P + Q
    float raw_innov = measurement - x_pred
    float max_innov = clip_sigma * math.max(innov_std, 1e-10)
    float clipped_innov = math.max(-max_innov, math.min(raw_innov, max_innov))
    float S = P_pred + R
    float K = S > 0 ? P_pred / S : 0.0
    x_pred + K * clipped_innov

export f_mr_vol_adjusted(float mr_raw, float atr_current, float atr_baseline) =>
    float expansion = math.max(0.5, atr_current / math.max(atr_baseline, 1e-10))
    mr_raw / expansion

export f_ddivf_update(float innov, float prev_sigma, array<float> innov_hist, int k) =>
    int hist_size = array.size(innov_hist)
    int n = math.min(hist_size, k)
    if n < 5
        prev_sigma
    else
        float v_bar = 0.0
        for i = hist_size - n to hist_size - 1
            v_bar += array.get(innov_hist, i)
        v_bar /= n
        float sum_prod = 0.0
        float sum_sq_dev = 0.0
        for i = hist_size - n to hist_size - 1
            float dev = array.get(innov_hist, i) - v_bar
            float sign_dev = dev > 0 ? 1.0 : dev < 0 ? -1.0 : 0.0
            sum_prod += dev * sign_dev
            sum_sq_dev += dev * dev
        float rho_v = sum_sq_dev > 0 ? sum_prod / math.sqrt(n * sum_sq_dev) : 0.7979
        float alpha = 0.06
        float sigma_seed = na(prev_sigma) or prev_sigma <= 0 ? math.abs(innov) : prev_sigma
        float new_sigma = (1.0 - alpha) * sigma_seed + alpha * math.abs(innov - v_bar) / math.max(rho_v, 0.01)
        math.max(new_sigma, 1e-10)

export f_estimate_adaptive_Q(array<float> innov_hist, int window, float current_K, float min_Q, float max_Q) =>
    int hist_size = array.size(innov_hist)
    int n = math.min(hist_size, window)
    if n < 20
        min_Q
    else
        float sum_sq = 0.0
        for i = hist_size - n to hist_size - 1
            float v = array.get(innov_hist, i)
            sum_sq += v * v
        float C_v0 = sum_sq / n
        float Q_est = current_K * C_v0 * current_K
        math.max(min_Q, math.min(Q_est, max_Q))

export f_update_percentile_cache(float te_osc, float mr_osc, float vec_osc, float corr_osc, float ltf_corr, float pred_slope, int window) =>
    array<float> c = array.new<float>(16, na)
    array.set(c, 0, ta.percentile_linear_interpolation(te_osc, window, 25))
    array.set(c, 1, ta.percentile_linear_interpolation(te_osc, window, 75))
    array.set(c, 2, ta.percentile_linear_interpolation(mr_osc, window, 2))
    array.set(c, 3, ta.percentile_linear_interpolation(mr_osc, window, 25))
    array.set(c, 4, ta.percentile_linear_interpolation(mr_osc, window, 75))
    array.set(c, 5, ta.percentile_linear_interpolation(mr_osc, window, 98))
    array.set(c, 6, ta.percentile_linear_interpolation(vec_osc, window, 25))
    array.set(c, 7, ta.percentile_linear_interpolation(vec_osc, window, 75))
    array.set(c, 8, ta.percentile_linear_interpolation(corr_osc, window, 20))
    array.set(c, 9, ta.percentile_linear_interpolation(corr_osc, window, 80))
    array.set(c, 10, ta.percentile_linear_interpolation(ltf_corr, window, 20))
    array.set(c, 11, ta.percentile_linear_interpolation(ltf_corr, window, 80))
    array.set(c, 12, ta.percentile_linear_interpolation(pred_slope, window, 25))
    array.set(c, 13, ta.percentile_linear_interpolation(pred_slope, window, 75))
    float mr_w = f_winsorize(mr_osc, nz(array.get(c, 2), -5.0), nz(array.get(c, 5), 5.0))
    array.set(c, 14, ta.percentile_linear_interpolation(mr_w, window, 25))
    array.set(c, 15, ta.percentile_linear_interpolation(mr_w, window, 75))
    c

export f_symbol_activity_1m(float s_timeClose_1m, bool s_inAnySess_1m, float fresh_secs) =>
    float nowMs = barstate.isrealtime ? timenow : time_close
    float ageMs = nowMs - s_timeClose_1m
    bool fresh = ageMs <= fresh_secs * 1000.0
    bool tradingNow = s_inAnySess_1m and fresh
    bool exchangeClosed = not s_inAnySess_1m
    bool sessionOpenButStale = s_inAnySess_1m and not fresh
    [tradingNow, exchangeClosed, sessionOpenButStale]

export f_is_trading_now(string sym, float fresh_secs) =>
    float s_timeClose_1m = request.security(sym, "1", time_close, barmerge.gaps_off, barmerge.lookahead_off)
    bool s_inAnySess_1m = request.security(sym, "1", session.ismarket or session.ispremarket or session.ispostmarket, barmerge.gaps_off, barmerge.lookahead_off)
    f_symbol_activity_1m(s_timeClose_1m, s_inAnySess_1m, fresh_secs)

export f_is_active_symbol(string sym, float fresh_secs) =>
    [tradingNow, _, _] = f_is_trading_now(sym, fresh_secs)
    tradingNow

export f_status_icon(string sym, float fresh_secs) =>
    [tradingNow, exchangeClosed, sessionOpenButStale] = f_is_trading_now(sym, fresh_secs)
    tradingNow ? "🟢" : exchangeClosed ? "🔴" : sessionOpenButStale ? "🟠" : "🟠"

export f_is_active_symbol(bool tradingNow) =>
    tradingNow

export f_symbol_status_icon(bool tradingNow, bool exchangeClosed, bool sessionOpenButStale) =>
    tradingNow ? "🟢" : exchangeClosed ? "🔴" : sessionOpenButStale ? "🟠" : "🟠"

export f_status_icon_from_1m(float s_timeClose_1m, bool s_inAnySess_1m, float fresh_secs) =>
    [tradingNow, exchangeClosed, sessionOpenButStale] = f_symbol_activity_1m(s_timeClose_1m, s_inAnySess_1m, fresh_secs)
    f_symbol_status_icon(tradingNow, exchangeClosed, sessionOpenButStale)

