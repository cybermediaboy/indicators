export f_array_mean_stdev_tail(array<float> arr, int len) =>
    int arr_size = array.size(arr)
    int n = math.min(len, arr_size)
    float mean = 0.0
    float stdev = 0.0
    if n > 1
        int start_idx = arr_size - n
        for i = start_idx to arr_size - 1
            mean += array.get(arr, i)
        mean /= n
        float var_sum = 0.0
        for i = start_idx to arr_size - 1
            float v = array.get(arr, i)
            var_sum += math.pow(v - mean, 2)
        stdev := math.sqrt(var_sum / math.max(1, n - 1))
    [mean, stdev]

export f_norm_cdf(float x) =>
    float ax = math.abs(x)
    float t = 1.0 / (1.0 + 0.2316419 * ax)
    float d = 0.3989422804 * math.exp(-ax * ax / 2.0)
    float p = d * t * (0.3193815 + t * (-0.3565638 + t * (1.781478 + t * (-1.8212560 + t * 1.330274))))
    x >= 0 ? 1.0 - p : p

export f_kalman(float src, float gain) =>
    var float k_est = na
    var float k_err = 1.0
    if na(k_est)
        k_est := src
        k_err := 1.0
    else
        k_err := math.max(0.1, k_err + gain)
        float kalman_gain = k_err / (k_err + 1.0)
        k_est := k_est + kalman_gain * (src - k_est)
        k_err := (1.0 - kalman_gain) * k_err
    k_est

export f_kalman_control(float meas, float control, float reactivity) =>
    var float x_est = na
    var float P = 1.0
    if na(x_est)
        x_est := meas
        P := 1.0
    else
        float x_pred = x_est + control * reactivity
        float P_pred = P + 0.01
        float K = P_pred / (P_pred + 0.1)
        x_est := x_pred + K * (meas - x_pred)
        P := (1.0 - K) * P_pred
    x_est

export f_kama(series float src, int len, int fast_len, int slow_len) =>
    float change = math.abs(src - src[len])
    float volatility = 0.0
    for i = 0 to len - 1
        volatility += math.abs(src[i] - src[i + 1])
    float er = volatility > 0 ? change / volatility : 0.0
    float fast_sc = 2.0 / (fast_len + 1.0)
    float slow_sc = 2.0 / (slow_len + 1.0)
    float sc = math.pow(er * (fast_sc - slow_sc) + slow_sc, 2)
    var float kama = na
    kama := na(kama[1]) ? src : kama[1] + sc * (src - kama[1])
    kama

export f_zscore_standard(series float src, int len) =>
    float ma = ta.sma(src, len)
    float dev = ta.stdev(src, len)
    float z = dev == 0 ? 0 : (src - ma) / dev
    [ma, z, dev]

export f_corr_weighted_zscore(series float src_base, series float src_ext, int len, float corr_power) =>
    float ma = ta.sma(src_ext, len)
    float dev = ta.stdev(src_ext, len)
    float z = dev == 0 ? 0 : (src_ext - ma) / dev
    float corr = ta.correlation(src_base, src_ext, len)
    float corr_weighted = math.pow(nz(corr, 0), corr_power)
    z * corr_weighted

f_cld_impl(series float corr_osc, series float price, float z_score, float slope_thresh, bool cld_enable, int cld_min_bars, int cld_max_bars, float cld_price_consist, float cld_z_min) =>
    float best_signal = 0.0
    float best_confidence = 0.0
    int best_bars = 0
    if cld_enable and bar_index > cld_max_bars * 2 + 10
        for half_len = cld_min_bars to cld_max_bars
            float sum_x1 = 0.0
            float sum_y1 = 0.0
            float sum_xy1 = 0.0
            float sum_x21 = 0.0
            int n1 = half_len
            for i = 0 to half_len - 1
                int bar_back = half_len + (half_len - 1 - i)
                float x = float(i)
                float y = nz(corr_osc[bar_back])
                sum_x1 += x
                sum_y1 += y
                sum_xy1 += x * y
                sum_x21 += x * x
            float denom1 = n1 * sum_x21 - sum_x1 * sum_x1
            float slope1 = denom1 != 0 ? (n1 * sum_xy1 - sum_x1 * sum_y1) / denom1 : 0.0
            float sum_x2 = 0.0
            float sum_y2 = 0.0
            float sum_xy2 = 0.0
            float sum_x22 = 0.0
            int n2 = half_len
            for i = 0 to half_len - 1
                int bar_back = half_len - 1 - i
                float x = float(i)
                float y = nz(corr_osc[bar_back])
                sum_x2 += x
                sum_y2 += y
                sum_xy2 += x * y
                sum_x22 += x * x
            float denom2 = n2 * sum_x22 - sum_x2 * sum_x2
            float slope2 = denom2 != 0 ? (n2 * sum_xy2 - sum_x2 * sum_y2) / denom2 : 0.0
            float price_start = nz(price[2 * half_len - 1])
            float price_end = price
            float total_move = price_end - price_start
            int agreeing = 0
            int total_bars_check = 2 * half_len - 1
            for i = 0 to total_bars_check - 1
                float bar_move = nz(price[total_bars_check - 1 - i]) - nz(price[total_bars_check - i])
                agreeing += (math.sign(bar_move) == math.sign(total_move)) ? 1 : 0
            float consistency = total_bars_check > 0 ? float(agreeing) / float(total_bars_check) : 0.0
            bool has_direction = consistency >= (cld_price_consist * 0.7) and math.abs(total_move) > 0
            bool has_z_stretch = math.abs(z_score) >= (cld_z_min * 0.5)
            bool slope1_rising = slope1 > slope_thresh
            bool slope1_falling = slope1 < -slope_thresh
            bool slope2_rising = slope2 > slope_thresh
            bool slope2_falling = slope2 < -slope_thresh
            float this_signal = 0.0
            if has_direction and has_z_stretch
                if slope1_falling and slope2_rising
                    this_signal := 1.0
                else if slope1_rising and slope2_falling
                    this_signal := -1.0
            if this_signal != 0
                float slope_strength = (math.abs(slope1) + math.abs(slope2)) / 2.0
                float slope_conf = math.min(slope_strength / 0.25, 1.0)
                float z_conf = math.min(math.abs(z_score) / 2.0, 1.0)
                float consist_conf = math.max(0, (consistency - cld_price_consist) / (0.85 - cld_price_consist))
                float asym = math.abs(slope1 - slope2) / math.max(math.abs(slope1) + math.abs(slope2), 0.001)
                float conf = (slope_conf * 0.35 + z_conf * 0.30 + consist_conf * 0.20 + asym * 0.15)
                if conf > best_confidence
                    best_signal := this_signal
                    best_confidence := conf
                    best_bars := 2 * half_len
    [best_signal, best_confidence, best_bars]

export f_cld(series float corr_osc, series float price, float z_score, float slope_thresh, bool cld_enable, int cld_min_bars, int cld_max_bars, float cld_price_consist, float cld_z_min) =>
    f_cld_impl(corr_osc, price, z_score, slope_thresh, cld_enable, cld_min_bars, cld_max_bars, cld_price_consist, cld_z_min)

export f_calc_survival_bands(float basis, float dev, float shift_z, float prob_pct, float mr_shift=0.0) =>
    float prob = prob_pct / 100.0
    float combined_shift = shift_z - mr_shift
    float _exp_pos = math.exp(math.min(combined_shift, 20.0))
    float _exp_neg = math.exp(math.min(-combined_shift, 20.0))
    float bound_shift = (_exp_pos - _exp_neg) / (_exp_pos + _exp_neg)
    float adj_prob_upper = prob * math.exp(-bound_shift * 0.693)
    float adj_prob_lower = prob * math.exp(bound_shift * 0.693)
    adj_prob_upper := math.max(0.0001, math.min(adj_prob_upper, 0.5))
    adj_prob_lower := math.max(0.0001, math.min(adj_prob_lower, 0.5))
    float z_upper = math.sqrt(-2.0 * math.log(adj_prob_upper))
    float z_lower = math.sqrt(-2.0 * math.log(adj_prob_lower))
    float band_upper = basis + (z_upper * dev)
    float band_lower = basis - (z_lower * dev)
    [band_upper, band_lower]

