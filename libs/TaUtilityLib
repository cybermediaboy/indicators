// @function Layout subpanes: compute Y ranges with gap support
// @param panes array<SubPane> to layout
// @param panetop Top Y coordinate of entire oscillator area
// @param panebottom Bottom Y coordinate of entire oscillator area
// @param gappct Gap between subpanes as percentage of total range (e.g., 0.10 = 10%)
export f_layout_subpanes(array<SubPane> panes, float panetop, float panebottom, float gappct) =>
    int n = array.size(panes)
    if n > 0
        float totalrange = panetop - panebottom
        float totalgap = n > 1 ? totalrange * gappct : 0.0
        float gapsize = n > 1 ? totalgap / (n - 1) : 0.0
        float subheight = (totalrange - totalgap) / n
        for i = 0 to n - 1
            SubPane sp = array.get(panes, i)
            sp.ytop := panetop - i * (subheight + gapsize)
            sp.ybottom := sp.ytop - subheight
            sp.yoffset := (sp.ytop + sp.ybottom) / 2.0
            sp.plotscale := subheight / 2.0
            array.set(panes, i, sp)

// @function Update subpane visibility: true if ANY child osc should_display
// @param panes array<SubPane> to update
// @param oscs array<OscMeta> children
export f_update_visibility(array<SubPane> panes, array<OscMeta> oscs) =>
    int np = array.size(panes)
    if np > 0
        for p = 0 to np - 1
            SubPane sp = array.get(panes, p)
            sp.visible := false
            array.set(panes, p, sp)
    int no = array.size(oscs)
    if no > 0
        for i = 0 to no - 1
            OscMeta m = array.get(oscs, i)
            if m.should_display and m.subpaneidx >= 0 and m.subpaneidx < np
                SubPane sp = array.get(panes, m.subpaneidx)
                sp.visible := true
                array.set(panes, m.subpaneidx, sp)

export f_manage_subpane_lines(array<SubPane> panes) =>
    int n = array.size(panes)
    if n > 0
        for i = 0 to n - 1
            SubPane sp = array.get(panes, i)
            if not na(sp.hlinetop)
                line.delete(sp.hlinetop)
            if not na(sp.hlinebottom)
                line.delete(sp.hlinebottom)
            if not na(sp.hlinezero)
                line.delete(sp.hlinezero)
            
            if sp.visible
                sp.hlinetop := line.new(bar_index, sp.ytop, bar_index + 1, sp.ytop,color=sp.bordercolor, style=line.style_dotted, extend=extend.both)
                sp.hlinebottom := line.new(bar_index, sp.ybottom, bar_index + 1, sp.ybottom,color=sp.bordercolor, style=line.style_dotted, extend=extend.both)
                sp.hlinezero := line.new(bar_index, sp.yoffset, bar_index + 1, sp.yoffset,color=sp.zerocolor, style=line.style_dashed, extend=extend.both)
            else
                sp.hlinetop := na
                sp.hlinebottom := na
                sp.hlinezero := na
            array.set(panes, i, sp)

// @function Private: apply softclip to [-1, +1]
// @param rawz Raw z-score value
// @param method "tanh" | "sigmoid" | "clamp" | "none"
// @param steep Steepness parameter
// @param zlo Lower clip bound
// @param zhi Upper clip bound
// @returns Clipped value in [-1, +1]
export f_apply_softclip(float rawz, string method, float steep, float zlo, float zhi) =>
    switch method
        "tanh" =>
            float tx = rawz * steep
            float ep = math.exp(math.min(tx, 20.0))
            float en = math.exp(math.min(-tx, 20.0))
            (ep - en) / (ep + en)
        "sigmoid" =>
            1.0 / (1.0 + math.exp(-rawz * steep)) * 2.0 - 1.0
        "clamp" =>
            float range2 = math.max(math.abs(zhi), math.abs(zlo), 1.0)
            math.max(-1.0, math.min(1.0, rawz / range2))
        => // "none"
            float range2 = math.max(math.abs(zhi), math.abs(zlo), 1.0)
            math.max(-1.0, math.min(1.0, rawz / range2))

// @function Main per-bar manager: compute visualvalue and rawclipped for all oscs
// @param panes array<SubPane> parent containers
// @param oscs array<OscMeta> oscillators
// @param states array<OscState> oscillator states (written)
// @param rawvalues array<float> raw z-score values (same order as oscs)
export f_manage_osc_values(array<SubPane> panes, array<OscMeta> oscs, array<OscState> states, array<float> rawvalues) =>
    int n = math.min(array.size(oscs), array.size(rawvalues))
    int npanes = array.size(panes)
    if n > 0 and npanes > 0
        for i = 0 to n - 1
            OscMeta m = array.get(oscs, i)
            OscState st = array.get(states, i)
            float raw = array.get(rawvalues, i)
            
            // Get parent subpane (with bounds check)
            int safe_idx = math.max(0, math.min(m.subpaneidx, npanes - 1))
            SubPane sp = array.get(panes, safe_idx)
            
            // 1. Raw clip for kNN/MC
            if m.clip_raw_value and not na(raw)
                st.rawclipped := m.clip_method == "clamp" ?math.max(m.z_clip_lo, math.min(m.z_clip_hi, raw)) : raw
            else
                st.rawclipped := raw
            
            // 2. Visual value → mapped into parent subpane coordinates
            if m.should_display and not na(raw)
                float normed = f_apply_softclip(raw, m.clip_method,m.clip_steepness, m.z_clip_lo, m.z_clip_hi)
                st.visualvalue := sp.yoffset + normed * sp.plotscale
            else
                st.visualvalue := na
            
            array.set(states, i, st)

// @function Process oscillators: compute visualvalue and rawclipped for all oscs
// @param panes array<SubPane> parent containers
// @param oscs array<OscMeta> oscillator configs (read-only)
// @param states array<OscState> oscillator states (written)
// @param rawvalues array<float> raw z-score values (same order as oscs)
export f_process_oscs(array<SubPane> panes, array<OscMeta> oscs, array<OscState> states, array<float> rawvalues) =>
    int n = math.min(array.size(oscs), math.min(array.size(states), array.size(rawvalues)))
    if n > 0
        for i = 0 to n - 1
            OscMeta m = array.get(oscs, i)
            OscState st = array.get(states, i)
            float raw = array.get(rawvalues, i)
            st.rawvalue := raw
            int pidx = math.max(0, math.min(m.subpaneidx, array.size(panes) - 1))
            SubPane sp = array.get(panes, pidx)
            if m.clip_raw_value and not na(raw)
                st.rawclipped := m.clip_method == "clamp" ? math.max(m.z_clip_lo, math.min(m.z_clip_hi, raw)) : raw
            else
                st.rawclipped := raw
            if m.should_display and not na(raw)
                float normed = f_apply_softclip(raw, m.clip_method, m.clip_steepness, m.z_clip_lo, m.z_clip_hi)
                st.visualvalue := sp.yoffset + normed * sp.plotscale
            else
                st.visualvalue := na
            array.set(states, i, st)

// @function Manage oscillator labels: render end-of-chart value labels
// @param oscs array<OscMeta> oscillator configs (read-only)
// @param states array<OscState> oscillator states (written)
// @param labeloffset Horizontal offset for labels (e.g., 3)
export f_manage_labels(array<OscMeta> oscs, array<OscState> states, int labeloffset) =>
    int n = math.min(array.size(oscs), array.size(states))
    if n > 0
        for i = 0 to n - 1
            OscMeta m = array.get(oscs, i)
            OscState st = array.get(states, i)
            if not na(st.lbl)
                label.delete(st.lbl)
                st.lbl := na
            if m.should_display and not na(st.visualvalue)
                st.tooltiptext := m.full_name + "\n" + m.explanation +"\nRaw: " + str.tostring(st.rawvalue, "#.####") +"\nClipped: " + str.tostring(st.rawclipped, "#.####")
                color lcol = nz(st.rawvalue) >= 0 ? m.bull_color : m.bear_color
                st.lbl := label.new(bar_index + labeloffset, st.visualvalue,m.id + ": " + str.tostring(st.rawvalue, "#.##"),color=color.new(color.black, 100),textcolor=lcol,style=label.style_label_left,size=size.small,tooltip=st.tooltiptext)
            array.set(states, i, st)

// @function Register oscillator: push OscMeta + blank OscState in one call
// @param oscs array<OscMeta> to append to
// @param states array<OscState> to append to
export f_register_osc(array<OscMeta> oscs, array<OscState> states,
     string id, string fullname, string explanation,
     int subpaneidx, float zcliplo, float zcliphi,
     string clipmethod, float clipsteepness, bool cliprawvalue,
     bool enabled, bool shoulddisplay,
     color bullcol, color bearcol) =>
    array.push(oscs, OscMeta.new(id, fullname, explanation,subpaneidx, zcliplo, zcliphi,clipmethod, clipsteepness, cliprawvalue,enabled, shoulddisplay, bullcol, bearcol))
    array.push(states, OscState.new(na, na, na, na, "", na, na))

// @function Update overbought/oversold boundary lines for oscillators using line.new()
// @param panes array<SubPane> parent containers
// @param oscs array<OscMeta> oscillator configs
// @param states array<OscState> oscillator states (written)
// @param ob_values array<float> raw overbought values per oscillator (na = skip)
// @param os_values array<float> raw oversold values per oscillator (na = skip)
// @param ob_color Color for overbought line
// @param os_color Color for oversold line
export f_update_osc_ob_os_lines(array<SubPane> panes, array<OscMeta> oscs, array<OscState> states, array<float> ob_values, array<float> os_values, color ob_color, color os_color) =>
    int n = math.min(array.size(oscs), array.size(states))
    int npanes = array.size(panes)
    if n > 0 and npanes > 0
        for i = 0 to n - 1
            OscMeta m = array.get(oscs, i)
            OscState st = array.get(states, i)
            int pidx = math.max(0, math.min(m.subpaneidx, npanes - 1))
            SubPane sp = array.get(panes, pidx)
            float ob_raw = f_getOrFloat(ob_values, i, na)
            float os_raw = f_getOrFloat(os_values, i, na)

            if not na(st.ob_line)
                line.delete(st.ob_line)
                st.ob_line := na
            if not na(st.os_line)
                line.delete(st.os_line)
                st.os_line := na

            if m.should_display and not na(ob_raw)
                float ob_vis = sp.yoffset + f_apply_softclip(ob_raw, m.clip_method, m.clip_steepness, m.z_clip_lo, m.z_clip_hi) * sp.plotscale
                st.ob_line := line.new(bar_index, ob_vis, bar_index + 1, ob_vis, color=ob_color, style=line.style_dashed, extend=extend.both, width=1)
            if m.should_display and not na(os_raw)
                float os_vis = sp.yoffset + f_apply_softclip(os_raw, m.clip_method, m.clip_steepness, m.z_clip_lo, m.z_clip_hi) * sp.plotscale
                st.os_line := line.new(bar_index, os_vis, bar_index + 1, os_vis, color=os_color, style=line.style_dashed, extend=extend.both, width=1)

            array.set(states, i, st)

