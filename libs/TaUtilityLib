// @function Safe array access that prevents out-of-bounds errors
// @param arr The array to access (float array)
// @param index The index to access (can be negative or exceed array size)
// @returns The value at the safe index, or 0.0 if array is empty
export f_safeArrayGet(array<float> arr, int index) =>
    int size = array.size(arr)
    float sagresult = 0.0
    if size > 0
        int safeIndex = math.max(0, math.min(index, size - 1))
        sagresult := array.get(arr, safeIndex)
    sagresult

