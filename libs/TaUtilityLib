export getNormalizedCoefficient(series float sourceValue, series int lookbackPeriod, float percentileMargin = 5.0, simple int smoothingLength = 0, bool useZScore = false, float zScoreClamp = 3.0, bool oneRange = false) =>
    
    // Handle variable lookback period (can be series or constant) and clamp for safety
    lookback = int(math.max(1, math.min(math.max(0, bar_index - 10), math.min(int(lookbackPeriod), 4999))))
    
    // Apply smoothing if requested
    smoothedValue = smoothingLength > 0 ? ta.ema(sourceValue, smoothingLength) : sourceValue
    
    max_bars_back(smoothedValue, 4500)

    var float normalizedCoeff = na
    
    if useZScore
        // Z-SCORE METHOD
        mean = ta.sma(smoothedValue, lookback)
        stdev = ta.stdev(smoothedValue, lookback)
        zScore = stdev > 0 ? (smoothedValue - mean) / stdev : 0
        zScoreClamped = math.max(-zScoreClamp, math.min(zScoreClamp, zScore))
        normalizedCoeff := zScoreClamped / zScoreClamp
    else
        // PERCENTILE METHOD  
        lowerPercentile = ta.percentile_nearest_rank(smoothedValue, lookback, percentileMargin)
        upperPercentile = ta.percentile_nearest_rank(smoothedValue, lookback, 100 - percentileMargin)
        
        if upperPercentile == lowerPercentile
            normalizedCoeff := 0.0
        else
            normalized01 = (smoothedValue - lowerPercentile) / (upperPercentile - lowerPercentile)
            normalized01 := math.max(0, math.min(1, normalized01))
            normalizedCoeff := oneRange ? (normalized01 * 2 - 1) : normalized01

    
    normalizedCoeff

