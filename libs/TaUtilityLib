    else
        array.push(keys, key)
        array.push(v1, d1)
        array.push(v2, d2)
        array.push(v3, d3)
        array.push(v4, d4)

export f_add_to_map2_sorted(array<int> keys, array<float> vals1, array<float> vals2, int key, float d1, float d2) =>
    int nk = array.size(keys)
    int n1 = array.size(vals1)
    int n2 = array.size(vals2)
    int mn = math.min(nk, math.min(n1, n2))
    if nk > mn
        for i = nk - 1 to mn
            array.remove(keys, i)
    if n1 > mn
        for i = n1 - 1 to mn
            array.remove(vals1, i)
    if n2 > mn
        for i = n2 - 1 to mn
            array.remove(vals2, i)
    if mn <= 0
        array.push(keys, key)
        array.push(vals1, d1)
        array.push(vals2, d2)
    else
        int ins = f_lower_bound(keys, key)
        bool exists = false
        if ins >= 0 and ins < array.size(keys)
            exists := array.get(keys, ins) == key
        if exists and ins < array.size(vals1) and ins < array.size(vals2)
            array.set(vals1, ins, array.get(vals1, ins) + d1)
            array.set(vals2, ins, array.get(vals2, ins) + d2)
        else
            int ip = math.max(0, math.min(ins, array.size(keys)))
            array.insert(keys, ip, key)
            array.insert(vals1, ip, d1)
            array.insert(vals2, ip, d2)

export f_merge_row_vols_dual(array<int> in_rows, array<float> in_vols, array<int> out_keys, array<float> out_vol, array<float> out_tpo) =>
    int n = math.min(array.size(in_rows), array.size(in_vols))
    if n > 0
        for i = 0 to n - 1
            f_add_to_map2(out_keys, out_vol, out_tpo, array.get(in_rows, i), array.get(in_vols, i), 0.0)

export f_prune_zero(array<int> keys, array<float> vals1, array<float> vals2) =>
    int n = math.min(array.size(keys), math.min(array.size(vals1), array.size(vals2)))
    if array.size(keys) > n
        for i = array.size(keys) - 1 to n
            array.remove(keys, i)
    if array.size(vals1) > n
        for i = array.size(vals1) - 1 to n
            array.remove(vals1, i)
    if array.size(vals2) > n
        for i = array.size(vals2) - 1 to n
            array.remove(vals2, i)
    if n > 0
        for i = n - 1 to 0
            float v1 = array.get(vals1, i)
            float v2 = array.get(vals2, i)
            if v1 < 0
                array.set(vals1, i, 0.0)
                v1 := 0.0
            if v2 < 0
                array.set(vals2, i, 0.0)
                v2 := 0.0
            if v1 < 1e-8 and v2 < 1e-8
                array.remove(keys, i)
                array.remove(vals1, i)
                array.remove(vals2, i)

export f_prune_zero3(array<int> keys, array<float> vals1, array<float> vals2, array<float> vals3) =>
    int n = math.min(array.size(keys), math.min(array.size(vals1), math.min(array.size(vals2), array.size(vals3))))
    if array.size(keys) > n
        for i = array.size(keys) - 1 to n
            array.remove(keys, i)
    if array.size(vals1) > n
        for i = array.size(vals1) - 1 to n
            array.remove(vals1, i)
    if array.size(vals2) > n
        for i = array.size(vals2) - 1 to n
            array.remove(vals2, i)
    if array.size(vals3) > n
        for i = array.size(vals3) - 1 to n
            array.remove(vals3, i)
    if n > 0
        for i = n - 1 to 0
            float v1 = array.get(vals1, i)
            float v2 = array.get(vals2, i)
            float v3 = array.get(vals3, i)
            if v1 < 0
                array.set(vals1, i, 0.0)
                v1 := 0.0
            if v2 < 0
                array.set(vals2, i, 0.0)
                v2 := 0.0
            if v3 < 0
                array.set(vals3, i, 0.0)
                v3 := 0.0
            if v1 < 1e-8 and v2 < 1e-8 and v3 < 1e-8
                array.remove(keys, i)
                array.remove(vals1, i)
                array.remove(vals2, i)
                array.remove(vals3, i)

export f_prune_zero4(array<int> keys, array<float> v1, array<float> v2, array<float> v3, array<float> v4) =>
    int n = math.min(array.size(keys), math.min(array.size(v1), math.min(array.size(v2), math.min(array.size(v3), array.size(v4)))))
    if array.size(keys) > n
        for i = array.size(keys) - 1 to n
            array.remove(keys, i)
    if array.size(v1) > n
        for i = array.size(v1) - 1 to n
            array.remove(v1, i)
    if array.size(v2) > n
        for i = array.size(v2) - 1 to n
            array.remove(v2, i)
    if array.size(v3) > n
        for i = array.size(v3) - 1 to n
            array.remove(v3, i)
    if array.size(v4) > n
        for i = array.size(v4) - 1 to n
            array.remove(v4, i)
    if n > 0
        for i = n - 1 to 0
            float a = array.get(v1, i)
            float b = array.get(v2, i)
            float c = array.get(v3, i)
            float d = array.get(v4, i)
            if a < 0
                array.set(v1, i, 0.0)
                a := 0.0
            if b < 0
                array.set(v2, i, 0.0)
                b := 0.0
            if c < 0
                array.set(v3, i, 0.0)
                c := 0.0
            if d < 0
                array.set(v4, i, 0.0)
                d := 0.0
            if a < 1e-8 and b < 1e-8 and c < 1e-8 and d < 1e-8
                array.remove(keys, i)
                array.remove(v1, i)
                array.remove(v2, i)
                array.remove(v3, i)
                array.remove(v4, i)

export f_min_max_key(array<int> keys) =>
    int mn = 0
    int mx = 0
    int n = array.size(keys)
    if n > 0
        mn := array.get(keys, 0)
        mx := array.get(keys, 0)
        if n > 1
            for i = 1 to n - 1
                int k = array.get(keys, i)
                mn := math.min(mn, k)
