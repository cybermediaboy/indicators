// @param section_titles Array of section titles
// @param section_icons Array of section unicode icons
// @param param_names Array of parameter names (use "|" to separate sections)
// @param param_values Array of parameter values (parallel to param_names)
// @param param_icons Array of parameter icons (parallel to param_names)
// @param use_dividers Whether to add dividers between sections
// @returns Formatted tooltip string
export create_tooltip(string title, string title_icon,
                     array<string> section_titles, array<string> section_icons,
                     array<string> param_names, array<float> param_values, array<string> param_icons,
                     bool use_dividers) =>
    
    // Start with main title
    tooltip = title_icon + " " + title + "\n"//
    
    // Track current parameter index
    param_index = 0
    
    // Process each section
    for s = 0 to array.size(section_titles) - 1
        // Add divider if needed (not before first section)
        if use_dividers and s > 0
            tooltip := tooltip + "━━━━━━━━━━━━━━━\n"
        
        // Add section header
        section_title = array.get(section_titles, s)
        section_icon = s < array.size(section_icons) ? array.get(section_icons, s) : ""
        
        if section_title != ""
            tooltip := tooltip + "\n" + section_icon + " " + section_title + "\n"
        
        // Add parameters for this section (until we hit a delimiter or end)
        while param_index < array.size(param_names)
            param_name = array.get(param_names, param_index)
            
            // Check if this is a section delimiter
            if param_name == "|"
                param_index += 1
                break  // Move to next section
            
            // Get parameter details
            param_value = param_index < array.size(param_values) ? array.get(param_values, param_index) : na
            param_icon = param_index < array.size(param_icons) ? array.get(param_icons, param_index) : "  •"
            
            // Format the parameter line
            value_str = na(param_value) ? "N/A" : str.tostring(param_value, "#.##")
            tooltip := tooltip + param_icon + " " + param_name + ": " + value_str + "\n"
            
            param_index += 1
    
    tooltip

export f_zscore(series float sourceValue, series int lookbackPeriod, simple int smoothingLength = 0) =>
    int lookback = int(math.max(2, math.min(math.max(0, bar_index - 10), math.min(int(lookbackPeriod), 4999))))
    series float smoothedValue = smoothingLength > 0 ? ta.ema(sourceValue, smoothingLength) : sourceValue
    max_bars_back(smoothedValue, 4500)
    float mean = ta.sma(smoothedValue, lookback)
    float stdev = ta.stdev(smoothedValue, lookback)
    stdev > 0 ? (smoothedValue - mean) / stdev : 0.0

export getNormalizedCoefficientNoClamp(series float sourceValue, series int lookbackPeriod, float percentileMargin = 5.0, simple int smoothingLength = 0, bool useZScore = false, bool oneRange = false) =>
    int lookback = int(math.max(1, math.min(math.max(0, bar_index - 10), math.min(int(lookbackPeriod), 4999))))
    series float smoothedValue = smoothingLength > 0 ? ta.ema(sourceValue, smoothingLength) : sourceValue
    max_bars_back(smoothedValue, 4500)

    float out = na
    if useZScore
        out := f_zscore(smoothedValue, lookback, 0)
    else
        float lowerPercentile = ta.percentile_nearest_rank(smoothedValue, lookback, percentileMargin)
        float upperPercentile = ta.percentile_nearest_rank(smoothedValue, lookback, 100 - percentileMargin)
        if upperPercentile == lowerPercentile
            out := 0.0
        else
            float normalized01 = (smoothedValue - lowerPercentile) / (upperPercentile - lowerPercentile)
            normalized01 := math.max(0.0, math.min(1.0, normalized01))
            out := oneRange ? (normalized01 * 2.0 - 1.0) : normalized01
    out

