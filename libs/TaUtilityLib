export f_clamp(float x, float lo, float hi) => math.max(lo, math.min(x, hi))

// @function Hyperbolic tangent for soft symmetric clipping to [-1, 1]
// @param x Input value
// @returns tanh(x) bounded to [-1, 1]
export f_tanh(float x) =>
    float abs_x = math.abs(x)
    if abs_x > 10.0
        x > 0 ? 1.0 : -1.0
    else if abs_x < 0.0001
        x
    else
        float exp_pos = math.exp(math.min(x, 20.0))
        float exp_neg = math.exp(math.min(-x, 20.0))
        (exp_pos - exp_neg) / (exp_pos + exp_neg)

// @function Sigmoid normalization to [0, 1] with configurable steepness
// @param x Input value
// @param steepness Steepness parameter (default 2.0)
// @returns Sigmoid-normalized value in [0, 1]
export f_sigmoid_norm(float x, float steepness = 2.0) =>
    float sigmoid_x = x * steepness
    1.0 / (1.0 + math.exp(-sigmoid_x))

// @function IQR normalization using 25th and 75th percentiles
// @param val Value to normalize
// @param p25 25th percentile
// @param p75 75th percentile
// @returns IQR-normalized value
export f_iqr_normalize(float val, float p25, float p75) =>
    float iqr = math.max(p75 - p25, 1e-10)
    (val - p25) / iqr

// @function Tanh normalization for oscillator visual rendering
// @param raw_z Raw z-score or oscillator value
// @param y_offset Vertical offset (e.g., 0 for MR, -6 for TE/VEC/CORR/LTF)
// @param steepness Tanh steepness (0.5 for MR, 1.5 for TE, 0.75 for VEC/CORR/LTF)
// @param amplitude Visual amplitude (typically 3.0)
// @returns Visually scaled oscillator value: offset + tanh(raw_z × steepness) × amplitude
export f_tanh_norm(float raw_z, float y_offset, float steepness, float amplitude) =>
    y_offset + f_tanh(raw_z * steepness) * amplitude

