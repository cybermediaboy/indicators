// @function Convert prices array to returns array
// @param prices Array of price values
// @returns Array of returns (percentage changes)
export f_prices_to_returns(array<float> prices) =>
    array<float> rets = array.new<float>()
    int n = array.size(prices)
    if n > 1
        for i = 1 to n - 1
            float p0 = array.get(prices, i)
            float p1 = array.get(prices, i-1)
            if p1 != 0
                array.push(rets, (p0 - p1) / p1)
    rets

// @function Pearson correlation on the TAIL of arrays (newest data)
// @param x First array
// @param y Second array  
// @param length Number of elements from tail to use
// @returns Correlation coefficient [-1, 1]
export f_pearson_tail(array<float> x, array<float> y, int length) =>
    float correlation = 0.0
    int xs = array.size(x)
    int ys = array.size(y)
    int n = math.min(length, math.min(xs, ys))
    if n >= 5
        float sum_x = 0.0
        float sum_y = 0.0
        float sum_xy = 0.0
        float sum_x2 = 0.0
        float sum_y2 = 0.0
        for i = 0 to n - 1
            float xv = array.get(x, xs - 1 - i)
            float yv = array.get(y, ys - 1 - i)
            sum_x += xv
            sum_y += yv
            sum_xy += xv * yv
            sum_x2 += xv * xv
            sum_y2 += yv * yv
        float num = n * sum_xy - sum_x * sum_y
        float den = math.sqrt((n * sum_x2 - sum_x * sum_x) * (n * sum_y2 - sum_y * sum_y))
        correlation := den > 0.0001 ? num / den : 0.0
    correlation

// @function Pearson correlation on arrays (from beginning)
// @param x First array
// @param y Second array
// @param length Number of elements to use
// @returns Correlation coefficient [-1, 1]
export f_pearson(array<float> x, array<float> y, int length) =>
    float correlation = 0.0
    int safe_length = math.min(length, math.min(array.size(x), array.size(y)))
    if safe_length >= 5
        float sum_x = 0.0
        float sum_y = 0.0
        float sum_xy = 0.0
        float sum_x2 = 0.0
        float sum_y2 = 0.0
        for i = 0 to safe_length - 1
            float xv = array.get(x, i)
            float yv = array.get(y, i)
            sum_x += xv
            sum_y += yv
            sum_xy += xv * yv
            sum_x2 += xv * xv
            sum_y2 += yv * yv
        float n = safe_length
        float num = n * sum_xy - sum_x * sum_y
        float den = math.sqrt((n * sum_x2 - sum_x * sum_x) * (n * sum_y2 - sum_y * sum_y))
        correlation := den > 0.0001 ? num / den : 0.0
    correlation

// @function Spearman rank correlation (robust to outliers)
// @param x First array
// @param y Second array
// @param length Number of elements to use
// @returns Rank correlation coefficient [-1, 1]
export f_spearman(array<float> x, array<float> y, int length) =>
    float correlation = 0.0
    int safe_length = math.min(length, math.min(array.size(x), array.size(y)))
    if safe_length >= 5
        array<float> x_ranks = array.new<float>(safe_length, 0.0)
        array<float> y_ranks = array.new<float>(safe_length, 0.0)
        for i = 0 to safe_length - 1
            float x_val = array.get(x, i)
            float y_val = array.get(y, i)
            float x_rank = 1.0
            float y_rank = 1.0
            for j = 0 to safe_length - 1
                if array.get(x, j) < x_val
                    x_rank += 1.0
                else if array.get(x, j) == x_val and j < i
                    x_rank += 1.0
                if array.get(y, j) < y_val
                    y_rank += 1.0
                else if array.get(y, j) == y_val and j < i
                    y_rank += 1.0
            array.set(x_ranks, i, x_rank)
            array.set(y_ranks, i, y_rank)
        float x_mean = array.avg(x_ranks)
        float y_mean = array.avg(y_ranks)
        float sum_xy = 0.0
        float sum_x2 = 0.0
        float sum_y2 = 0.0
        for i = 0 to safe_length - 1
            float x_diff = array.get(x_ranks, i) - x_mean
            float y_diff = array.get(y_ranks, i) - y_mean
            sum_xy += x_diff * y_diff
            sum_x2 += x_diff * x_diff
            sum_y2 += y_diff * y_diff
        float den = math.sqrt(sum_x2 * sum_y2)
        correlation := den > 0 ? sum_xy / den : 0.0
    correlation

// @function Kendall Tau correlation (concordant pairs, most robust)
// @param x First array
// @param y Second array
// @param length Number of elements to use
// @param sampling_step Step for sampling (1 = full precision, higher = faster)
// @returns Kendall Tau coefficient [-1, 1]
export f_kendall(array<float> x, array<float> y, int length, int sampling_step) =>
    float concordant = 0.0
    float discordant = 0.0
    int safe_length = math.min(length, math.min(array.size(x), array.size(y)))
    if safe_length >= 5
        int step = sampling_step == 0 ? 1 : math.max(1, sampling_step)
        for i = 0 to safe_length - 2 by step
            for j = i + 1 to safe_length - 1 by step
                float x_diff = array.get(x, i) - array.get(x, j)
                float y_diff = array.get(y, i) - array.get(y, j)
                if (x_diff * y_diff) > 0
                    concordant += 1.0
                else if (x_diff * y_diff) < 0
                    discordant += 1.0
    float pairs = concordant + discordant
    pairs > 0 ? (concordant - discordant) / pairs : 0.0


export f_calc_delta(float h, float l, float c, float v) =>
    float chrange = h - l
    float buyVol = chrange > 0 ? v * (c - l) / chrange : v / 2
    float sellVol = chrange > 0 ? v * (h - c) / chrange : v / 2
    buyVol - sellVol

export f_calc_buy_sell(float h, float l, float c, float v) =>
    float chrange = h - l
    float buyVol = chrange > 0 ? v * (c - l) / chrange : v / 2
    float sellVol = chrange > 0 ? v * (h - c) / chrange : v / 2
    [buyVol, sellVol]

export f_atr_dynamic(int len) =>
    float tr1 = high - low
    float tr2 = math.abs(high - nz(close[1], close))
    float tr3 = math.abs(low - nz(close[1], close))
    float tr = math.max(tr1, math.max(tr2, tr3))
    float alpha = 1.0 / math.max(1.0, float(len))
    var float atr = na
    atr := na(atr[1]) ? tr : nz(atr[1]) + alpha * (tr - nz(atr[1]))
    atr

export f_apply_weight(float p, float w) =>
    1.0 + w * (p - 1.0)

export f_ema_stateful(float src, int len) =>
    var float ema_val = na
    if na(ema_val)
        ema_val := src
    else
        float alpha = 2.0 / (math.max(1, len) + 1)
        ema_val := alpha * src + (1.0 - alpha) * ema_val
    ema_val

export f_ema_custom(float src, int len) =>
    f_ema_stateful(src, len)

