// @function Calculate percentile-based slope score with optional tanh transformation
// @param dema_momentums Series of DEMA momentum values
// @param lookback_bars Number of bars to look back for slope calculation
// @param percentile_period Period for percentile calculation
// @param percentile_margin Margin for percentile boundaries (e.g., 5 for 5th and 95th percentiles)
// @param tanh_strength Strength of tanh transformation (0 for linear, >0 for curved response)
// @returns Score between -1 and 1 based on percentile position with optional tanh emphasis
export calculateSlopeScore(series float dema_momentums, int lookback_bars, int percentile_period, float percentile_margin, float tanh_strength) =>
    // Clamp percentile period to bar_index to prevent history referencing errors
    safe_percentile_period = int(math.max(1, math.min(math.max(0, bar_index - 10), percentile_period)))
    
    slope = dema_momentums - nz(dema_momentums[lookback_bars], dema_momentums)
    max_bars_back(slope, 4500)
    low_pct = ta.percentile_nearest_rank(slope, safe_percentile_period, percentile_margin)
    high_pct = ta.percentile_nearest_rank(slope, safe_percentile_period, 100 - percentile_margin)
    linear_score = high_pct != low_pct ? math.max(-1, math.min(1, (slope - low_pct) / (high_pct - low_pct) * 2 - 1)) : 0.0
    e = 2.71828182845904523536
    tanh_x = tanh_strength > 0 ? linear_score * tanh_strength : linear_score
    abs_x = math.abs(tanh_x)
    tanh_result = abs_x > 10 ? (tanh_x > 0 ? 1.0 : -1.0) : (abs_x < 0.0001 ? tanh_x : (math.pow(e, 2 * tanh_x) - 1) / (math.pow(e, 2 * tanh_x) + 1))
    score = tanh_strength > 0 ? tanh_result : linear_score
    bar_index >= safe_percentile_period ? score : na


// 
//  SMOOTHING & FILTERING FUNCTIONS
// 

// @function Ehler's SuperSmoother - low-lag smoothing filter
// @param _src Source series to smooth
// @param _length Smoothing period
// @returns Smoothed series
export supersmoother(series float _src, simple int _length) =>
    s_a1 = math.exp(-math.sqrt(2) * math.pi / _length)
    s_b1 = 2 * s_a1 * math.cos(math.sqrt(2) * math.pi / _length)
    s_c3 = -math.pow(s_a1, 2)
    s_c2 = s_b1
    s_c1 = 1 - s_c2 - s_c3
    ss = 0.0
    ss := s_c1 * _src + s_c2 * nz(ss[1], _src[1]) + s_c3 * nz(ss[2], _src[2])

// @function Butterworth filter for ultra-smooth price filtering
// @param src Source series
// @param len Filter period
// @returns Butterworth smoothed series
export butter_smooth(series float src, simple int len) =>
    butter_pi = 2 * math.asin(1)
    butter_cycle = 2 * butter_pi / len
    butter_beta = 2.415 * (1 - math.cos(butter_cycle))
    butter_alpha = -butter_beta + math.sqrt(butter_beta * butter_beta + 2 * butter_beta)
    butter_c0 = butter_alpha * butter_alpha / 4
    butter_b0 = 1.0
    butter_b1 = 2.0
    butter_b2 = 1.0
    butter_a1 = 2 * (1 - butter_alpha)
    butter_a2 = -(1 - butter_alpha) * (1 - butter_alpha)
    butter_out = 0.0
    butter_out := (butter_c0 * ((butter_b0 * src) + (butter_b1 * nz(src[1])) + (butter_b2 * nz(src[2])))) + (butter_a1 * nz(butter_out[1])) + (butter_a2 * nz(butter_out[2]))

// @function Dynamic EMA with variable length
// @param source Source series
// @param dynamic_length Dynamic period (can vary bar to bar)
// @returns Dynamically adjusted EMA
export f_dynamic_ema(series float source, series float dynamic_length) =>
    var float dyn_ema = na
    alpha = 2.0 / (dynamic_length + 1)
    dyn_ema := na(dyn_ema[1]) ? source : alpha * source + (1 - alpha) * dyn_ema[1]
    dyn_ema


// @function Dynamic SMA (series period)
// @param src The input series
// @param dynamic_len Series-type window length for SMA (must be >=1)
// @returns SMA with dynamic window length
export f_dynamic_sma(series float src, series float dynamic_len) =>
    float val = na, sum = 0.0
    llen = math.max(1, int(dynamic_len))
    if bar_index >= llen - 1
        for i = 0 to llen - 1
            sum += nz(src[i])
        val := sum / llen
    val

// @function Dynamic Standard Deviation (series period)
// @param src The input series
// @param dynamic_len Series-type window length for StdDev (must be >=2)
// @returns Stdev with dynamic window length
export f_dynamic_stdev(series float src, series float dynamic_len) =>
    float std = na
    llen = math.max(2, int(dynamic_len))
    if bar_index >= llen - 1
        mean = f_dynamic_sma(src, llen)
        sumsq = 0.0
        for i = 0 to llen - 1
            sumsq += math.pow(nz(src[i]) - mean, 2)
        std := math.sqrt(sumsq / (llen - 1))
    std

// @function Double Exponential Moving Average (DEMA)
// @param source Source series
// @param length Period for DEMA calculation
// @returns DEMA value
export dema(series float source, simple int length) =>
    ema1 = ta.ema(source, length)
    ema2 = ta.ema(ema1, length)
    2 * ema1 - ema2

// 
//  SCALING & NORMALIZATION FUNCTIONS
// 

// @function Scales secondary line to match primary line using percentile ranges
// @param primary_line Reference series for target scale
// @param secondary_line Series to be scaled
// @param lookback Lookback bars for percentile calculation
// @param percentile Percentile value (e.g., 5 for 5th and 95th percentiles)
// @param chart_level Base chart level offset
// @returns Scaled version of secondary_line
export f_scale_percentile(series float primary_line, series float secondary_line, int lookback, float percentile, float chart_level) =>
    // Clamp lookback to bar_index to prevent history referencing errors
    safe_lookback = int(math.max(1, math.min(math.max(0, bar_index - 20), lookback)))
    
    max_bars_back(primary_line, 4500)
    max_bars_back(secondary_line, 4500)

    if bar_index < safe_lookback
        secondary_line + chart_level
    else
        primary_p90 = ta.percentile_nearest_rank(primary_line, safe_lookback, 100-percentile)
        primary_p10 = ta.percentile_nearest_rank(primary_line, safe_lookback, percentile)
        primary_range = primary_p90 - primary_p10
        
        secondary_p90 = ta.percentile_nearest_rank(secondary_line, safe_lookback, 100-percentile)
        secondary_p10 = ta.percentile_nearest_rank(secondary_line, safe_lookback, percentile)
        secondary_range = secondary_p90 - secondary_p10
        
        scale_coef = secondary_range != 0 ? primary_range / secondary_range : 1
        scaled_line = secondary_line * scale_coef + chart_level
        scaled_line

// @function Calculates Bollinger Bands with chart level offset
// @param src Source series
// @param length MA period
// @param mult Standard deviation multiplier
// @param chartlevel Vertical offset for plotting
// @returns [upper, lower, basis] tuple
export getBB(series float src, simple int length, simple float mult, simple float chartlevel) =>
    basis = ta.sma(src, length)
    dev = ta.stdev(src, length)
    upper = chartlevel + basis + mult * dev
    lower = chartlevel + basis - mult * dev
    [upper, lower, basis]

// @function Mean Reversion Channel with multiple bands and conditions
// @param source Price source
// @param length Channel period
// @param mult First band multiplier
// @param mult2 Second band multiplier
// @param gradsize Gradient size for zone detection
// @returns [meanline, meanrange, upband1, loband1, upband2, loband2, condition]
export get_mrc(series float source, simple int length, simple float mult, simple float mult2, simple float gradsize) =>

    tr = ta.tr
    v_condition = 0
    v_meanline = supersmoother(source, length)
    v_meanrange = supersmoother(tr, length)
    
    v_upband1 = v_meanline + (v_meanrange * mult)
    v_loband1 = v_meanline - (v_meanrange * mult)
    v_upband2 = v_meanline + (v_meanrange * mult2)
    v_loband2 = v_meanline - (v_meanrange * mult2)
    
    if(close > v_meanline)
        v_upband2_1 = v_upband2 + (v_meanrange * gradsize * 4)
        v_upband2_9 = v_upband2 + (v_meanrange * gradsize * -4)
        if(high >= v_upband2_9 and high < v_upband2)
            v_condition := 1
        else if(high >= v_upband2 and high < v_upband2_1)
            v_condition := 2
        else if(high >= v_upband2_1)
            v_condition := 3
        else if(close <= v_meanline + v_meanrange)
            v_condition := 4
        else
            v_condition := 5
    
    if(close < v_meanline)
        v_loband2_1 = v_loband2 - (v_meanrange * gradsize * 4)
        v_loband2_9 = v_loband2 - (v_meanrange * gradsize * -4)
        if(low <= v_loband2_9 and low > v_loband2)
            v_condition := -1
        else if(low <= v_loband2 and low > v_loband2_1)
            v_condition := -2
        else if(low <= v_loband2_1)
            v_condition := -3
        else if(close >= v_meanline + v_meanrange)
            v_condition := -4
        else
            v_condition := -5
            
    [v_meanline, v_meanrange, v_upband1, v_loband1, v_upband2, v_loband2, v_condition]

// 
//  MARKET STRUCTURE ANALYSIS
// 

// @function Analyzes market structure for ChoCH and BOS patterns
// @param highFractalBars Array of high fractal bar indices
// @param highFractalPrices Array of high fractal prices
// @param lowFractalBars Array of low fractal bar indices
// @param lowFractalPrices Array of low fractal prices
// @param trendDirection Current trend (1=up, -1=down, 0=neutral)
// @returns [choch, bos, newTrend] - change signals and new trend direction
export analyzeMarketStructure(array<int> highFractalBars, array<float> highFractalPrices, 
                             array<int> lowFractalBars, array<float> lowFractalPrices, 
                             int trendDirection) =>
    choch = false
    bos = false
    newTrend = trendDirection
    
    if array.size(highFractalBars) >= 2 and array.size(lowFractalBars) >= 2
        lastHigh1 = array.get(highFractalPrices, array.size(highFractalPrices) - 1)
        lastHigh2 = array.get(highFractalPrices, array.size(highFractalPrices) - 2)
        lastLow1 = array.get(lowFractalPrices, array.size(lowFractalPrices) - 1)
        lastLow2 = array.get(lowFractalPrices, array.size(lowFractalPrices) - 2)
        
        lastHighBar1 = array.get(highFractalBars, array.size(highFractalBars) - 1)
        lastLowBar1 = array.get(lowFractalBars, array.size(lowFractalBars) - 1)
        
        higherHigh = lastHigh1 > lastHigh2
        higherLow = lastLow1 > lastLow2
        lowerHigh = lastHigh1 < lastHigh2
        lowerLow = lastLow1 < lastLow2
        
        // BOS - Break of Structure
        if trendDirection == 1 and higherHigh and high > lastHigh1
            bos := true
            newTrend := 1
        else if trendDirection == -1 and lowerLow and low < lastLow1
            bos := true
            newTrend := -1
        
        // ChoCH - Change of Character
        if trendDirection == 1 and low < lastLow1 and lastLowBar1 > lastHighBar1
            choch := true
            newTrend := -1
        else if trendDirection == -1 and high > lastHigh1 and lastHighBar1 > lastLowBar1
            choch := true
            newTrend := 1
        else if trendDirection == 0
            if higherHigh and higherLow
                newTrend := 1
            else if lowerHigh and lowerLow
                newTrend := -1
    
    [choch, bos, newTrend]

// @function Enhanced function to get the true sweep range for fractals
// @param fractalBar Bar index of the current fractal
// @param fractalPrice Price of the current fractal (high for bearish, low for bullish)
// @param isFractalHigh True if current fractal is a HIGH fractal, false for LOW
// @param prevFractalBar Bar index of the previous fractal
// @param prevFractalPrice Price of the previous fractal
// @param prevFractalWasHigh True if previous fractal was a HIGH fractal
// @returns [rangeHigh, rangeLow] tuple representing sweep range boundaries
export getfractalSweepRange(int fractalBar, float fractalPrice, bool isFractalHigh, int prevFractalBar, bool prevFractalWasHigh) => //float prevFractalPrice,
    float rangeHigh = na
    float rangeLow = na

    if isFractalHigh  // Current is a HIGH fractal
        // For high fractals, we need the LOWEST point for sweep range

        // Option 1: If previous was a LOW fractal, use its low
        float prevFractalLow = na
        if not na(prevFractalBar) and not prevFractalWasHigh
            bars_ago = bar_index - prevFractalBar
            if bars_ago >= 0 and bars_ago < bar_index
                prevFractalLow := low[bars_ago]

        // Option 2: Get lowest low from the 5 bars of current fractal
        float fractalStructureLow = fractalPrice
        fractal_bars_ago = bar_index - fractalBar

        // Check the fractal bar and 2 bars on each side
        for i = -2 to 2
            check_bars_ago = fractal_bars_ago + i
            if check_bars_ago >= 0 and check_bars_ago < bar_index
                fractalStructureLow := math.min(fractalStructureLow, low[check_bars_ago])

        // Use the lower of the two options
        rangeLow := na(prevFractalLow) ? fractalStructureLow : math.min(prevFractalLow, fractalStructureLow)
        rangeHigh := fractalPrice

    else  // Current is a LOW fractal
        // For low fractals, we need the HIGHEST point for sweep range

        // Option 1: If previous was a HIGH fractal, use its high
        float prevFractalHigh = na
        if not na(prevFractalBar) and prevFractalWasHigh
            bars_ago = bar_index - prevFractalBar
            if bars_ago >= 0 and bars_ago < bar_index
                prevFractalHigh := high[bars_ago]

        // Option 2: Get highest high from the 5 bars of current fractal
        float fractalStructureHigh = fractalPrice
        fractal_bars_ago = bar_index - fractalBar

        // Check the fractal bar and 2 bars on each side
        for i = -2 to 2
            check_bars_ago = fractal_bars_ago + i
            if check_bars_ago >= 0 and check_bars_ago < bar_index
                fractalStructureHigh := math.max(fractalStructureHigh, high[check_bars_ago])

        // Use the higher of the two options
        rangeHigh := na(prevFractalHigh) ? fractalStructureHigh : math.max(prevFractalHigh, fractalStructureHigh)
        rangeLow := fractalPrice

    [rangeHigh, rangeLow]


