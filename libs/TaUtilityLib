export f_draw_tpsl(float ep, float tp1, float tp2, float sl, int entry_bar, int line_len, color tp_col, color sl_col, color ep_col) =>
    line l_ep = na(ep) ? na : line.new(entry_bar, ep, entry_bar + line_len, ep, color=ep_col, style=line.style_dashed, width=1, force_overlay=true)
