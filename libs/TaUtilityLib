export f_add_to_map4(array<int> keys, array<float> v1, array<float> v2, array<float> v3, array<float> v4, int key, float d1, float d2, float d3, float d4) =>
    int mn = math.min(array.size(keys), math.min(array.size(v1), math.min(array.size(v2), math.min(array.size(v3), array.size(v4)))))
    if array.size(keys) > mn
        for i = array.size(keys) - 1 to mn
            array.remove(keys, i)
    if array.size(v1) > mn
        for i = array.size(v1) - 1 to mn
            array.remove(v1, i)
    if array.size(v2) > mn
        for i = array.size(v2) - 1 to mn
            array.remove(v2, i)
    if array.size(v3) > mn
        for i = array.size(v3) - 1 to mn
            array.remove(v3, i)
    if array.size(v4) > mn
        for i = array.size(v4) - 1 to mn
            array.remove(v4, i)
    int pos = f_find_key(keys, key)
    if pos < 0
        array.push(keys, key)
        array.push(v1, d1)
        array.push(v2, d2)
        array.push(v3, d3)
        array.push(v4, d4)
    else if pos < array.size(v1) and pos < array.size(v2) and pos < array.size(v3) and pos < array.size(v4)
        array.set(v1, pos, array.get(v1, pos) + d1)
        array.set(v2, pos, array.get(v2, pos) + d2)
        array.set(v3, pos, array.get(v3, pos) + d3)
