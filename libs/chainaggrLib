f_is_digit(c) =>
     not na(str.tonumber(c))

f_strip_trailing_digits(s) =>
    res = s
    for _i = 0 to 6
        if str.length(res) > 0 and f_is_digit(str.substring(res, str.length(res) - 1, str.length(res)))
            res := str.substring(res, 0, str.length(res) - 1)
    res

 // Parse BASE asset from a full symbol
export get_base_from_symbol(string full_symbol) =>
    parts = str.split(full_symbol, ":")
    sym = array.size(parts) > 1 ? array.get(parts, 1) : full_symbol
    sym := str.replace_all(sym, "-", "")
    sym := str.replace_all(sym, "_", "")
    sym := str.replace(sym, ".P", "")
    sym := str.replace(sym, "PERP", "")
    sym := str.replace(sym, "SWAP", "")
    if str.endswith(sym, "!")
        sym := str.substring(sym, 0, str.length(sym) - 1)
    month_codes = array.from<string>("F","G","H","J","K","M","N","Q","U","V","X","Z")
    if str.length(sym) >= 6
        string last4 = str.substring(sym, str.length(sym) - 4, str.length(sym))
        string month = str.substring(sym, str.length(sym) - 5, str.length(sym) - 4)
        bool last4_is_year = f_is_digit(str.substring(last4, 0, 1)) and f_is_digit(str.substring(last4, 1, 2)) and f_is_digit(str.substring(last4, 2, 3)) and f_is_digit(str.substring(last4, 3, 4))
        bool is_month_code = array.indexof(month_codes, month) != -1
        if last4_is_year and is_month_code
            sym := str.substring(sym, 0, str.length(sym) - 5)
    sym := f_strip_trailing_digits(sym)
    quotes = array.from<string>("USDT","USD","USDC","BTC","ETH","BUSD","EUR","TRY","BRL","AUD","CAD","JPY","GBP","HKD","MXN","ZAR")
    base = sym
    for qi = 0 to array.size(quotes) - 1
        q = array.get(quotes, qi)
        if str.endswith(sym, q) and (str.length(sym) > str.length(q))
            base := str.substring(sym, 0, str.length(sym) - str.length(q))
            break
    init_norm_sym(base)

