// Returns [class, type, hours] for any input like "CME_MINI:MES1!", "SPX", "BINANCE:BTCUSDT", or bare tokens.
// Strategy:
// 1) Try full symbol in maps. 2) If crypto exchange symbol, use base token to decide class/type and crypto hours.
// 3) Fallbacks: token DB (alts), indexes/commodities heuristics, else 'shares'/'US'.
export get_asset_meta(string symbol_or_token) =>
    // Build maps as plain locals (no typed lhs)
    class_map = init_asset_class_map()
    hours_map = init_trading_hours_map()

    s_full = norm_full_symbol(symbol_or_token)
    s_base = get_base_from_symbol(s_full)

    ct = map.get(class_map, s_full)
    hr = map.get(hours_map, s_full)

    if na(ct) and is_token_known(s_base)
        main = (s_base == "BTC" or s_base == "ETH" or s_base == "SOL")
        ct := (main ? CLASS_CRYPTO_MAIN : CLASS_ALTS) + "|" + str.lower(s_base)
        hr := na(hr) ? HOURS_23x5 : hr

    if na(ct)
        if str.contains(s_full, "SPX") or str.contains(s_full, "ES1!") or str.contains(s_full, "MES1!")
            ct := CLASS_INDEX + "|sp500"
            hr := na(hr) ? (str.contains(s_full, "ES") or str.contains(s_full, "MES") ? HOURS_23x5 : HOURS_US) : hr
        else if str.contains(s_full, "DAX") or str.contains(s_full, "GER40")
            ct := CLASS_INDEX + "|dax40"
            hr := na(hr) ? HOURS_EU : hr
        else if str.contains(s_full, "XAU") or str.contains(s_full, ":GC1!")
            ct := CLASS_COMMODITY + "|gold"
            hr := na(hr) ? HOURS_23x5 : hr
        else if str.contains(s_full, "XAG") or str.contains(s_full, ":SI1!")
            ct := CLASS_COMMODITY + "|silver"
            hr := na(hr) ? HOURS_23x5 : hr
        else if str.contains(s_full, "WTI") or str.contains(s_full, "CL1!")
            ct := CLASS_COMMODITY + "|crude-wti"
            hr := na(hr) ? HOURS_23x5 : hr
        else if str.contains(s_full, "EURUSD") or s_full == "DXY"
            ct := CLASS_FX + "|" + str.lower(s_full)
            hr := na(hr) ? HOURS_23x5 : hr

    if na(ct)
        ct := CLASS_SHARES + "|unknown"
    if na(hr)
        hr := HOURS_US

    parts = str.split(ct, "|")
    [array.get(parts, 0), array.get(parts, 1), hr]




