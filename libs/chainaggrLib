// Get token info from database
export get_token_info(map<string, string> db, string token_symbol) =>
    t = init_norm_sym(token_symbol)
    info = map.get(db, t)
    
    if na(info)
        // Token not found - return default ETH
        ["ETH", false, array.new_string()]
    else
        parts = str.split(info, "|")
        chain = array.get(parts, 0)
        is_l1 = array.get(parts, 1) == "1"
        
        exchanges = array.new_string()
        if array.size(parts) > 2
            exchange_str = array.get(parts, 2)
            if str.length(exchange_str) > 0
                exchanges := str.split(exchange_str, ",")
        
        [chain, is_l1, exchanges]

// Расширенный разбор: возвращает agg, spot, perp, futures
export get_token_info_extended(map<string, string> db, string token_symbol) =>
    t = init_norm_sym(token_symbol)
    info = map.get(db, t)

    // Базовые пустые массивы
    agg_arr  = array.new_string()
    spot_arr = array.new_string()
    perp_arr = array.new_string()
    fut_arr  = array.new_string()

    if na(info)
        // Фоллбек: используем старый get_token_info и всё кладём в agg
        [chain0, is_l10, exchanges0] = get_token_info(db, token_symbol)
        agg_arr := exchanges0
        [chain0, is_l10, agg_arr, spot_arr, perp_arr, fut_arr]
    else
        parts = str.split(info, "|")
        chain = array.get(parts, 0)
        is_l1 = array.get(parts, 1) == "1"

        // 2‑й сегмент: общий список, как раньше
        if array.size(parts) > 2
            s = array.get(parts, 2)
            if str.length(s) > 0
                agg_arr := str.split(s, ",")

        // 3‑й сегмент: spot
        if array.size(parts) > 3
            s = array.get(parts, 3)
            if str.length(s) > 0
                spot_arr := str.split(s, ",")

        // 4‑й сегмент: perp
        if array.size(parts) > 4
            s = array.get(parts, 4)
            if str.length(s) > 0
                perp_arr := str.split(s, ",")

        // 5‑й сегмент: futures
        if array.size(parts) > 5
            s = array.get(parts, 5)
            if str.length(s) > 0
                fut_arr := str.split(s, ",")

        [chain, is_l1, agg_arr, spot_arr, perp_arr, fut_arr]


// Вспомогательная функция: разбивает agg на spot/perp/fut
split_exchanges_by_type(array<string> agg_arr) =>
    spot = array.new_string()
    perp = array.new_string()
    fut  = array.new_string()

    for i = 0 to array.size(agg_arr) - 1
        sym = array.get(agg_arr, i)
        u   = str.upper(str.trim(sym))

        is_perp = str.contains(u, ".P") or str.contains(u, "PERP") or str.contains(u, "SWAP")
        is_fut  = str.contains(u, "1!") or str.contains(u, "FUT")

        if is_perp
            array.push(perp, sym)
        else if is_fut
            array.push(fut, sym)
        else
            array.push(spot, sym)

    [spot, perp, fut]


// Главный хелпер: по токену/цепочке вернуть массивы spot/perp/fut
export get_chain_market_tickers(string token_or_chain) =>
    db = init_token_database()
    [chain, is_l1, agg_arr, spot_db, perp_db, fut_db] = get_token_info_extended(db, token_or_chain)

    // Если в БД уже заданы отдельные списки — используем их
    spot = array.size(spot_db) > 0 ? array.copy(spot_db) : array.new_string()
    perp = array.size(perp_db) > 0 ? array.copy(perp_db) : array.new_string()
    fut  = array.size(fut_db)  > 0 ? array.copy(fut_db)  : array.new_string()

    // Если явных списков нет, разбиваем agg по эвристике
    if array.size(spot) == 0 and array.size(perp) == 0 and array.size(fut) == 0
        [spot, perp, fut] = split_exchanges_by_type(agg_arr)

    [spot, perp, fut]


