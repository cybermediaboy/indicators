// Core output type for any asset
export type MicroState
    float  volume_total      // Total aggregated volume
    float  delta_aggressor   // True Aggressor Delta (Tick Rule / BVC Hybrid)
    float  delta_absorb      // Passive Absorption (Limit orders filled against trend)
    float  market_impact     // Kyle's Lambda (Cost per unit of volume)
    float  flow_toxicity     // VPIN Proxy (Informed trading probability)
    float  efficiency_ratio  // Price displacement efficiency (Trend strength)

// Helper: Select best LTF based on current timeframe
// Prioritizes 1-5 second resolution
f_get_best_ltf() =>
    int sec = timeframe.in_seconds(timeframe.period)
    string ltf = "1S"
    if sec <= 5
        ltf := "1S" // Fallback (should ideally be ticks but 1S is min)
    else if sec <= 15
        ltf := "1S"
    else if sec <= 60
        ltf := "5S"
    else if sec <= 300 // 5m
        ltf := "15S"
    else if sec <= 3600 // 1h
        ltf := "1" // 1m
    else
        ltf := "5" // 5m for higher TFs
    ltf

// Helper: Calculate standard deviation from sum and sum_sq
f_calc_std(float sum_x, float sum_x2, float n) =>
    if n < 2
        0.0
    else
        float mean = sum_x / n
        float var_val = (sum_x2 / n) - (mean * mean)
        math.sqrt(math.max(0.0, var_val))

// Helper: Hyperbolic Tangent (Polyfill for v5)
f_tanh(float x) =>
    float exp_pos = math.exp(math.min(x, 20.0))
    float exp_neg = math.exp(math.min(-x, 20.0))
    (exp_pos - exp_neg) / (exp_pos + exp_neg)

// Helper: Process LTF arrays to calculate micro metrics (for current ticker)
f_process_ltf_arrays(array<float> ltf_o, array<float> ltf_c, array<float> ltf_v) =>
    float t_vol = 0.0
    float t_delta = 0.0
    float t_abs_price_chg = 0.0
    
    if array.size(ltf_c) > 0
        int n = array.size(ltf_c)
        float prev_close = array.get(ltf_o, 0) // Approximation for first bar
        
        for i = 0 to n - 1
            float c = array.get(ltf_c, i)
            float o = array.get(ltf_o, i)
            float v = nz(array.get(ltf_v, i))
            
            // --- Hybrid Delta Engine ---
            float price_diff = c - o
            float tick_sz = syminfo.mintick
            
            float d = 0.0
            
            // State 1: Trend Bar
            if math.abs(price_diff) > tick_sz
                d := v * math.sign(price_diff)
            else
                // State 2: Flat Bar (Fat-Tail BVC)
                float drift = c - prev_close
                float vol_proxy = math.max(tick_sz, math.abs(drift))
                float z = drift / (vol_proxy > 0 ? vol_proxy : tick_sz)
                float phi = f_tanh(z) 
                d := v * phi
            
            t_delta += d
            t_vol += v
            
            // --- Market Impact Helper ---
            t_abs_price_chg += math.abs(c - prev_close)
            
            prev_close := c
            
    [t_vol, t_delta, t_abs_price_chg]

// Primary function to get full state
export get_micro_state(simple string symbol_override = "") =>
    // Internal state for Market Impact normalization (per symbol)
    var map<string, float> _lambda_sum = map.new<string, float>()
    var map<string, float> _lambda_sum_sq = map.new<string, float>()
    var map<string, float> _lambda_n = map.new<string, float>()

    string target_sym = symbol_override == "" ? syminfo.ticker : symbol_override
    
    // NOTE: Automatic peer aggregation is disabled due to Pine Script limitations 
    // (request.security_lower_tf requires simple strings, dynamic array iteration is not supported).
    // This function now calculates metrics strictly for the target_sym.
    // To aggregate multiple tickers, call this function for each ticker in the main script and sum the results.
    
    // Determine LTF
    string ltf = f_get_best_ltf()
    
    // Fetch Data for Target (High Precision)
    array<float> ltf_o = request.security_lower_tf(target_sym, ltf, open, ignore_invalid_symbol=true)
    array<float> ltf_c = request.security_lower_tf(target_sym, ltf, close, ignore_invalid_symbol=true)
    array<float> ltf_v = request.security_lower_tf(target_sym, ltf, volume, ignore_invalid_symbol=true)
    
    // Fetch Macro Data for Efficiency (Current timeframe)
    [d_o, d_h, d_l, d_c] = request.security(target_sym, timeframe.period, [open, high, low, close], ignore_invalid_symbol=true)

    // Process Microstructure
    [t_vol, t_delta, t_abs_price_chg] = f_process_ltf_arrays(ltf_o, ltf_c, ltf_v)
    
    // --- Computed Metrics ---
    
    // 1. Market Impact (Kyle's Lambda)
    float raw_lambda = t_vol > 0 ? t_abs_price_chg / t_vol : 0.0
    
    // Normalize Lambda (Z-score)
    string state_key = target_sym
    float cur_sum = nz(map.get(_lambda_sum, state_key))
    float cur_sum_sq = nz(map.get(_lambda_sum_sq, state_key))
    float cur_n = nz(map.get(_lambda_n, state_key))
    
    if t_vol > 0
        cur_sum += raw_lambda
        cur_sum_sq += raw_lambda * raw_lambda
        cur_n += 1.0
        map.put(_lambda_sum, state_key, cur_sum)
        map.put(_lambda_sum_sq, state_key, cur_sum_sq)
        map.put(_lambda_n, state_key, cur_n)
    
    float lambda_mean = cur_n > 0 ? cur_sum / cur_n : 0.0
    float lambda_std = f_calc_std(cur_sum, cur_sum_sq, cur_n)
    float norm_lambda = lambda_std > 0 ? (raw_lambda - lambda_mean) / lambda_std : 0.0
    
    // 2. Efficiency Ratio
    // Use fetched macro data for correctness if override is used
    float efficiency = (d_h - d_l) > 0 ? math.abs(d_c - d_o) / (d_h - d_l) : 0.0
    
    // 3. Absorption
    float absorb = t_vol * (1.0 - efficiency)
    
    // 4. Flow Toxicity (VPIN Proxy)
    float toxicity = t_vol > 0 ? math.abs(t_delta) / t_vol : 0.0
    
    // Construct Result
    MicroState.new(
         t_vol, 
         t_delta, 
         absorb, 
         norm_lambda, 
         toxicity, 
         efficiency
     )

// Helper: Get just the "Scientific Delta"
export get_scientific_delta(simple string symbol_override = "") =>
    ms = get_micro_state(symbol_override)
    ms.delta_aggressor

// Helper: Get Aggregated Volume
export get_aggregated_volume(simple string symbol_override = "") =>
