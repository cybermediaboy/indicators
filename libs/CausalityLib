// @function Calculate Shannon entropy of data distribution
// @param data Array of continuous values
// @param num_bins Number of bins for discretization
// @returns Entropy value (higher = more randomness)
export f_shannon_entropy(array<float> data, int num_bins) =>
    int data_size = array.size(data)
    if data_size < num_bins * 2
        0.0
    else
        // Calculate fixed boundaries based on global min/max
        float min_val = array.min(data), max_val = array.max(data), data_range = max_val - min_val
        
        if data_range < 0.0001
            0.0  // All values same = zero entropy
        else
            // Count occurrences in fixed bins
            array<float> counts = array.new<float>(num_bins, 0.0)
            
            // First pass: count values in each bin
            int bin_idx = 0
            for j = 0 to data_size - 1
                float val = array.get(data, j)
                if not na(val)
                    bin_idx := int(math.floor((val - min_val) / data_range * float(num_bins)))
                    bin_idx := math.max(0, math.min(bin_idx, num_bins - 1))
                    float c = array.get(counts, bin_idx)
                    array.set(counts, bin_idx, c + 1.0)
            
            // Second pass: calculate entropy
            float entropy = 0.0, log2 = math.log(2.0)
            
            for k = 0 to num_bins - 1
                float prob = array.get(counts, k) / float(data_size)
                if prob > 0.0001
                    entropy -= prob * math.log(prob) / log2
            
            entropy

// @function Calculate Shannon entropy of data distribution using explicit discretize->probability pipeline
// @param data Array of continuous values
// @param num_bins Number of bins for discretization
// @returns Entropy value (higher = more randomness)
export f_shannon_entropy_v2(array<float> data, int num_bins) =>
    float entropy = 0.0
    int data_size = array.size(data)
    if data_size >= num_bins * 2
        array<int> discretized = f_discretize(data, num_bins)
        array<float> probs = array.new<float>()
        for i = 0 to num_bins - 1
            array.push(probs, 0.0)
        for i = 0 to array.size(discretized) - 1
            int bin = array.get(discretized, i)
            if bin >= 0 and bin < num_bins
                float count = array.get(probs, bin)
                array.set(probs, bin, count + 1.0)
        for i = 0 to num_bins - 1
            float count = array.get(probs, i)
            array.set(probs, i, count / math.max(1.0, data_size))
        int probs_size = array.size(probs)
        if probs_size > 0
            for i = 0 to probs_size - 1
                float p = array.get(probs, i)
                if p > 0
                    entropy -= p * math.log(p) / math.log(2)
    entropy

// @function Calculate Transfer Entropy from source to target
// @param primary_arr Target series (e.g., primary ticker returns)
// @param ticker_arr Source series (e.g., basket ticker returns)
// @param window Window size for TE calculation
// @param bins Number of bins for discretization
// @param lag Lag for source series
// @returns [te_score, direction] - TE score and direction (-1 or 1)
export f_calculate_te_score(array<float> primary_arr, array<float> ticker_arr, int window, int bins, int lag) =>
    // Initialize results with default values (0.0)
    float te_final = 0.0
    float dir_final = 0.0
    
    int primary_size = array.size(primary_arr), ticker_size = array.size(ticker_arr)
    
    // Only proceed if we have enough data
    if primary_size >= window + lag and ticker_size >= window
        // Extract relevant windows
        array<float> primary_window = array.new<float>(), ticker_window = array.new<float>()
        
        for i = 0 to window - 1
            int p_idx = primary_size - window + i, t_idx = ticker_size - window + i
            if p_idx >= 0 and t_idx >= 0
                array.push(primary_window, array.get(primary_arr, p_idx))
                array.push(ticker_window, array.get(ticker_arr, t_idx))
        
        // Ensure we have enough data in the window
        int win_size = array.size(primary_window)
        if win_size >= 30
            // Build lagged series for TE calculation
            array<float> x_past = array.new<float>(), y_past = array.new<float>(), y_future = array.new<float>()
            
            int valid_count = 0
            for i = lag + 1 to win_size - 1
                float xp = array.get(ticker_window, i - lag), yp = array.get(primary_window, i - 1), yf = array.get(primary_window, i)
                
                if not na(xp) and not na(yp) and not na(yf)
                    array.push(x_past, xp)
                    array.push(y_past, yp)
                    array.push(y_future, yf)
                    valid_count += 1
            
            // Only calculate if we have enough valid samples
            if valid_count >= 20
                // Discretize all three series
                array<int> x_disc = f_discretize(x_past, bins), yp_disc = f_discretize(y_past, bins), yf_disc = f_discretize(y_future, bins)
                
                // Build 3D contingency table: P(Y_future, Y_past, X_past)
                int table_size = bins * bins * bins
                array<float> p_triple = array.new<float>(table_size, 0.0)
                
                // Count occurrences
                for i = 0 to valid_count - 1
                    int yf_bin = array.get(yf_disc, i), yp_bin = array.get(yp_disc, i), xp_bin = array.get(x_disc, i)
                    
                    if yf_bin >= 0 and yf_bin < bins and yp_bin >= 0 and yp_bin < bins and xp_bin >= 0 and xp_bin < bins
                        int idx_3d = yf_bin * bins * bins + yp_bin * bins + xp_bin
                        if idx_3d >= 0 and idx_3d < table_size
                            float cnt = array.get(p_triple, idx_3d)
                            array.set(p_triple, idx_3d, cnt + 1.0)
                
                // Normalize to probabilities with Laplace-style smoothing (alpha=0.001)
                float total = float(valid_count)
                float alpha = 0.001
                float smoothed_total = total + alpha * table_size
                for k = 0 to table_size - 1
                    float cnt = array.get(p_triple, k)
                    array.set(p_triple, k, (cnt + alpha) / smoothed_total)
                
                // Calculate marginals: P(Y_past, X_past) and P(Y_past)
                array<float> p_yp_xp = array.new<float>(), p_yp = array.new<float>(), p_yf_yp = array.new<float>()
                for k = 0 to bins * bins - 1
                    array.push(p_yp_xp, 0.0)
                for k = 0 to bins - 1
                    array.push(p_yp, 0.0)
                for k = 0 to bins * bins - 1
                    array.push(p_yf_yp, 0.0)
                
                for yp_bin = 0 to bins - 1
                    float sum_xp = 0.0
                    for xp_bin = 0 to bins - 1
                        float sum_yf = 0.0
                        for yf_bin = 0 to bins - 1
                            int idx_3d = yf_bin * bins * bins + yp_bin * bins + xp_bin
                            sum_yf += array.get(p_triple, idx_3d)
                        int idx_2d = yp_bin * bins + xp_bin
                        array.set(p_yp_xp, idx_2d, sum_yf)
                        sum_xp += sum_yf
                    array.set(p_yp, yp_bin, sum_xp)
                
                for yf_bin = 0 to bins - 1
                    for yp_bin = 0 to bins - 1
                        float sum_xp = 0.0
                        for xp_bin = 0 to bins - 1
                            int idx_3d = yf_bin * bins * bins + yp_bin * bins + xp_bin
                            sum_xp += array.get(p_triple, idx_3d)
                        int idx_2d = yf_bin * bins + yp_bin
                        array.set(p_yf_yp, idx_2d, sum_xp)
                
                // Calculate H(Y_future | Y_past) = -Σ P(yf,yp) * log(P(yf,yp)/P(yp))
                float log2 = math.log(2.0), h_yf_given_yp = 0.0, h_yf_given_both = 0.0
                
                for yf_bin = 0 to bins - 1
                    for yp_bin = 0 to bins - 1
                        int idx_2d = yf_bin * bins + yp_bin
                        float p_joint = array.get(p_yf_yp, idx_2d), p_marg = array.get(p_yp, yp_bin)
                        
                        if p_joint > 0.0001 and p_marg > 0.0001
                            h_yf_given_yp -= p_joint * (math.log(p_joint) - math.log(p_marg)) / log2
                
                // Calculate H(Y_future | Y_past, X_past) = -Σ P(yf,yp,xp) * log(P(yf,yp,xp)/P(yp,xp))
                for yf_bin = 0 to bins - 1
                    for yp_bin = 0 to bins - 1
                        for xp_bin = 0 to bins - 1
                            int idx_3d = yf_bin * bins * bins + yp_bin * bins + xp_bin, idx_2d = yp_bin * bins + xp_bin
                            float p_triple_val = array.get(p_triple, idx_3d), p_both_val = array.get(p_yp_xp, idx_2d)
                            
                            if p_triple_val > 0.0001 and p_both_val > 0.0001
                                h_yf_given_both -= p_triple_val * (math.log(p_triple_val) - math.log(p_both_val)) / log2
                
                // Transfer Entropy: TE(X→Y) = H(Y_fut|Y_past) - H(Y_fut|Y_past,X_past)
                float te_raw = h_yf_given_yp - h_yf_given_both
                float te_score = math.max(0.0, te_raw)
                
                // Scale TE to comparable range with Granger (TE is typically 0-0.5 bits)
                te_final := te_score * 2.0
                
                // Direction from correlation (TE doesn't give direction directly)
                float corr_inst = TAUtilityLib.f_pearson_tail(primary_window, ticker_window, math.min(window, 50))
                dir_final := corr_inst > 0 ? 1.0 : -1.0
                
    // Return single tuple to avoid type mismatch
    [te_final, dir_final]

