// @function Calculate partial correlation between X and Y controlling for Z
// @param x_arr First series
// @param y_arr Second series
// @param z_arr Mediator series
// @param window Window size for correlation
// @returns Partial correlation coefficient [-1, 1]
export f_partial_correlation(array<float> x_arr, array<float> y_arr, array<float> z_arr, int window) =>
    int min_size = math.min(math.min(array.size(x_arr), array.size(y_arr)), array.size(z_arr))
    if min_size < window
        float(0.0)
    else
        // Get correlations using tail (most recent data)
        float r_xy = TAUtilityLib.f_pearson_tail(x_arr, y_arr, window), r_xz = TAUtilityLib.f_pearson_tail(x_arr, z_arr, window), r_yz = TAUtilityLib.f_pearson_tail(y_arr, z_arr, window)
        
        // Partial correlation formula
        float denom_sq = (1.0 - r_xz * r_xz) * (1.0 - r_yz * r_yz)
        if denom_sq <= 0.0001
            float(r_xy)  // Can't compute partial, return raw correlation
        else
            float partial = (r_xy - r_xz * r_yz) / math.sqrt(denom_sq)
            math.max(-1.0, math.min(1.0, partial))  // Clamp to [-1, 1]

// @function PCMCI Filter: Adjust Granger score by checking for mediating tickers
// @param raw_score Original Granger score
// @param primary_arr Primary series
// @param ticker_arr Ticker series
// @param mediator1 First potential mediator series
// @param mediator2 Second potential mediator series
// @param mediator3 Third potential mediator series
// @param mediator4 Fourth potential mediator series
// @param window Window size for correlation
// @returns Filtered score (reduced if causality is indirect/spurious)
export f_pcmci_filter_score(float raw_score, array<float> primary_arr, array<float> ticker_arr, array<float> mediator1, array<float> mediator2, array<float> mediator3, array<float> mediator4, int window) =>
    // For each mediator, check if it mediates the relationship
    float max_mediation = 0.0
    
    // Check mediator1
    if array.size(mediator1) >= window
        float partial_corr1 = f_partial_correlation(primary_arr, ticker_arr, mediator1, window), raw_corr = TAUtilityLib.f_pearson_tail(primary_arr, ticker_arr, window)
        float mediation1 = math.abs(raw_corr) > 0.01 ? 1.0 - math.abs(partial_corr1) / math.abs(raw_corr) : 0.0
        mediation1 := math.max(0.0, mediation1)
        max_mediation := math.max(max_mediation, mediation1)
    
    // Check mediator2
    if array.size(mediator2) >= window
        float partial_corr2 = f_partial_correlation(primary_arr, ticker_arr, mediator2, window), raw_corr = TAUtilityLib.f_pearson_tail(primary_arr, ticker_arr, window)
        float mediation2 = math.abs(raw_corr) > 0.01 ? 1.0 - math.abs(partial_corr2) / math.abs(raw_corr) : 0.0
        mediation2 := math.max(0.0, mediation2)
        max_mediation := math.max(max_mediation, mediation2)
    
    // Check mediator3
    if array.size(mediator3) >= window
        float partial_corr3 = f_partial_correlation(primary_arr, ticker_arr, mediator3, window), raw_corr = TAUtilityLib.f_pearson_tail(primary_arr, ticker_arr, window)
        float mediation3 = math.abs(raw_corr) > 0.01 ? 1.0 - math.abs(partial_corr3) / math.abs(raw_corr) : 0.0
        mediation3 := math.max(0.0, mediation3)
        max_mediation := math.max(max_mediation, mediation3)
    
    // Check mediator4
    if array.size(mediator4) >= window
        float partial_corr4 = f_partial_correlation(primary_arr, ticker_arr, mediator4, window), raw_corr = TAUtilityLib.f_pearson_tail(primary_arr, ticker_arr, window)
        float mediation4 = math.abs(raw_corr) > 0.01 ? 1.0 - math.abs(partial_corr4) / math.abs(raw_corr) : 0.0
        mediation4 := math.max(0.0, mediation4)
        max_mediation := math.max(max_mediation, mediation4)
    
    // Reduce score proportionally to mediation (spurious causality)
    // If max_mediation = 0.8, score is reduced by 80% (it's mostly indirect)
    float filter_factor = 1.0 - max_mediation * 0.7  // Don't fully eliminate, keep 30% minimum
    filter_factor := math.max(0.3, filter_factor)
    float result = raw_score * filter_factor
    result

