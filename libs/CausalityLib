// @function Discretize continuous data into bins (for entropy calculations)
// @param data Array of continuous values
// @param bins Number of bins
// @returns Array of bin indices
export f_discretize(array<float> data, int bins) =>
    array<int> discretized = array.new<int>()
    int data_size = array.size(data)
    if data_size == 0
        discretized
    else
        if bins <= 1
            for i = 0 to data_size - 1
                array.push(discretized, 0)
        else
            array<float> sorted_copy = array.copy(data)
            array.sort(sorted_copy)
            array<float> boundaries = array.new<float>()
            for b = 1 to bins - 1
                int idx = int(math.floor(float(b) / float(bins) * float(data_size - 1)))
                idx := math.max(0, math.min(idx, data_size - 1))
                array.push(boundaries, array.get(sorted_copy, idx))

            for i = 0 to data_size - 1
                float val = array.get(data, i)
                if na(val)
                    array.push(discretized, 0)
                else
                    int assigned_bin = bins - 1
                    for b = 0 to bins - 2
                        if val <= array.get(boundaries, b)
                            assigned_bin := b
                            break
                    array.push(discretized, assigned_bin)
        discretized

// @function Simple correlation function without performance optimization
// @param x First array
// @param y Second array
// @param length Number of elements to use
// @param method Correlation method ("Pearson", "Spearman", "Kendall")
// @returns Correlation coefficient [-1, 1]
f_get_correlation_simple(array<float> x, array<float> y, int length, string method) =>
    float result = 0.0
    if method == "Pearson"
        result := TAUtilityLib.f_pearson(x, y, length)
    else if method == "Spearman"
        result := TAUtilityLib.f_spearman(x, y, length)
    else if method == "Kendall"
        result := TAUtilityLib.f_kendall(x, y, length, 1)
    result

