// @function Calculate Pearson correlation at specific lag
// @param primary_arr Primary series
// @param ticker_arr Ticker series
// @param lag Lag value (positive = ticker lags primary)
// @param window Window size for correlation
// @param correlation_method Correlation method to use ("Pearson", "Spearman", "Kendall")
// @returns Correlation coefficient [-1, 1]
export f_correlation_at_lag(array<float> primary_arr, array<float> ticker_arr, int lag, int window, string correlation_method) =>
    float correlation = 0.0
    int prim_size = array.size(primary_arr), tick_size = array.size(ticker_arr), required_primary = window + math.max(0, lag)
    if prim_size >= required_primary and tick_size >= window and window >= 10
        array<float> aligned_primary = array.new<float>(0), aligned_ticker = array.new<float>(0)
        // Use TAIL of arrays (newest data)
        // For lag correlation: primary[t] vs ticker[t-lag]
        // So we need: primary from end, ticker from end-lag
        int prim_start = math.max(0, prim_size - window), tick_start = math.max(0, tick_size - window - lag)
        for i = 0 to window - 1
            int p_idx = prim_start + i, t_idx = tick_start + i
            if p_idx >= 0 and p_idx < prim_size and t_idx >= 0 and t_idx < tick_size
                float p_val = array.get(primary_arr, p_idx), t_val = array.get(ticker_arr, t_idx)
                if not na(p_val) and not na(t_val)
                    array.push(aligned_primary, p_val)
                    array.push(aligned_ticker, t_val)
        if array.size(aligned_primary) >= 10
            correlation := f_get_correlation_simple(aligned_primary, aligned_ticker, array.size(aligned_primary), correlation_method)
    correlation

// @function Calculate Granger causality score with lag testing
// @param primary_arr Primary series
// @param ticker_arr Ticker series
// @param window Window size for correlation
// @param max_lag Maximum lag to test
// @param correlation_method Correlation method to use
// @returns [granger_score, beta_sum, best_lag] - Granger score, directional beta, and best lag (highest |correlation|)
export f_calculate_granger_score(array<float> primary_arr, array<float> ticker_arr, int window, int max_lag, string correlation_method) =>
    float total_score = 0.0, total_weight = 0.0, beta_sum = 0.0
    int best_lag = 1
    float best_corr = 0.0
    if array.size(primary_arr) >= window + max_lag and array.size(ticker_arr) >= window
        for lag = 1 to max_lag
            float corr_at_lag = f_correlation_at_lag(primary_arr, ticker_arr, lag, window, correlation_method), lag_weight = 1.0 / lag
            total_score += math.abs(corr_at_lag) * lag_weight
            total_weight += lag_weight
            beta_sum += corr_at_lag * lag_weight
            // Track best lag (highest absolute correlation)
            if math.abs(corr_at_lag) > best_corr
                best_corr := math.abs(corr_at_lag)
                best_lag := lag
    float granger_score = total_weight > 0 ? total_score / total_weight : 0.0
    [granger_score, beta_sum, best_lag]

