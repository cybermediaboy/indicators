                        int idx_2d = yf_bin * bins + yp_bin
                        array.set(p_yf_yp, idx_2d, sum_xp)
                float log2 = math.log(2.0)
                float h_yf_given_yp = 0.0
                float h_yf_given_both = 0.0
                for yf_bin = 0 to bins - 1
                    for yp_bin = 0 to bins - 1
                        int idx_2d = yf_bin * bins + yp_bin
                        float p_joint = array.get(p_yf_yp, idx_2d)
                        float p_marg = array.get(p_yp, yp_bin)
                        if p_joint > 0.0001 and p_marg > 0.0001
                            h_yf_given_yp -= p_joint * (math.log(p_joint) - math.log(p_marg)) / log2
                for yf_bin = 0 to bins - 1
                    for yp_bin = 0 to bins - 1
                        for xp_bin = 0 to bins - 1
                            int idx_3d = yf_bin * bins * bins + yp_bin * bins + xp_bin
                            int idx_2d = yp_bin * bins + xp_bin
                            float p_triple_val = array.get(p_triple, idx_3d)
                            float p_both_val = array.get(p_yp_xp, idx_2d)
                            if p_triple_val > 0.0001 and p_both_val > 0.0001
                                h_yf_given_both -= p_triple_val * (math.log(p_triple_val) - math.log(p_both_val)) / log2
                float te_raw = h_yf_given_yp - h_yf_given_both
                float nte = h_yf_given_yp > 0.001 ? te_raw / h_yf_given_yp : 0.0
                te_final := nte
                float corr_inst = TAUtilityLib.f_pearson_tail(primary_window, ticker_window, math.min(window, 50))
                dir_final := corr_inst > 0 ? 1.0 : -1.0
    [te_final, dir_final]

export f_compute_te_ensemble(array<float> pri_arr, array<float> b1, array<float> b2, array<float> b3, array<float> b4, array<float> b5, int window, int bins, int smoothing, bool self1, bool self2, bool self3, bool self4, bool self5, bool use5) =>
    float te_score1 = 0.0
    float te_dir1 = 0.0
    float te_score2 = 0.0
    float te_dir2 = 0.0
    float te_score3 = 0.0
    float te_dir3 = 0.0
    float te_score4 = 0.0
    float te_dir4 = 0.0
    float te_score5 = 0.0
    float te_dir5 = 0.0
    if not self1 and array.size(pri_arr) > window + 1 and array.size(b1) > window + 1
        [s1, d1] = f_calculate_te_score_v2(pri_arr, b1, window, bins, 1)
        te_score1 := nz(s1, 0.0)
        te_dir1 := nz(d1, 0.0)
    if not self2 and array.size(pri_arr) > window + 1 and array.size(b2) > window + 1
        [s2, d2] = f_calculate_te_score_v2(pri_arr, b2, window, bins, 1)
        te_score2 := nz(s2, 0.0)
        te_dir2 := nz(d2, 0.0)
    if not self3 and array.size(pri_arr) > window + 1 and array.size(b3) > window + 1
        [s3, d3] = f_calculate_te_score_v2(pri_arr, b3, window, bins, 1)
        te_score3 := nz(s3, 0.0)
        te_dir3 := nz(d3, 0.0)
    if not self4 and array.size(pri_arr) > window + 1 and array.size(b4) > window + 1
        [s4, d4] = f_calculate_te_score_v2(pri_arr, b4, window, bins, 1)
        te_score4 := nz(s4, 0.0)
        te_dir4 := nz(d4, 0.0)
    if use5 and not self5 and array.size(pri_arr) > window + 1 and array.size(b5) > window + 1
        [s5, d5] = f_calculate_te_score_v2(pri_arr, b5, window, bins, 1)
        te_score5 := nz(s5, 0.0)
        te_dir5 := nz(d5, 0.0)
    float te_total_score = 0.0
    float te_active_count = 0.0
    if not self1 and math.abs(te_score1) > 1e-10
        te_total_score += math.abs(te_score1)
        te_active_count += 1.0
    if not self2 and math.abs(te_score2) > 1e-10
        te_total_score += math.abs(te_score2)
        te_active_count += 1.0
    if not self3 and math.abs(te_score3) > 1e-10
        te_total_score += math.abs(te_score3)
        te_active_count += 1.0
    if not self4 and math.abs(te_score4) > 1e-10
        te_total_score += math.abs(te_score4)
        te_active_count += 1.0
    if use5 and not self5 and math.abs(te_score5) > 1e-10
        te_total_score += math.abs(te_score5)
        te_active_count += 1.0
    float te_osc_out = 0.0
    float te_str_out = 0.0
    float te_dir_out = 0.0
    if te_active_count > 0 and te_total_score > 0
        float te_w1 = not self1 and math.abs(te_score1) > 1e-10 ? math.abs(te_score1) / te_total_score : 0.0
        float te_w2 = not self2 and math.abs(te_score2) > 1e-10 ? math.abs(te_score2) / te_total_score : 0.0
        float te_w3 = not self3 and math.abs(te_score3) > 1e-10 ? math.abs(te_score3) / te_total_score : 0.0
        float te_w4 = not self4 and math.abs(te_score4) > 1e-10 ? math.abs(te_score4) / te_total_score : 0.0
        float te_w5 = use5 and not self5 and math.abs(te_score5) > 1e-10 ? math.abs(te_score5) / te_total_score : 0.0
        float te_dir_raw = te_w1 * te_dir1 + te_w2 * te_dir2 + te_w3 * te_dir3 + te_w4 * te_dir4 + te_w5 * te_dir5
        float te_str_raw = te_w1 * math.abs(te_score1) + te_w2 * math.abs(te_score2) + te_w3 * math.abs(te_score3) + te_w4 * math.abs(te_score4) + te_w5 * math.abs(te_score5)
        float te_signed_score = te_dir_raw * te_str_raw
        te_osc_out := smoothing > 1 ? ta.ema(te_signed_score, smoothing) : te_signed_score
        te_str_out := smoothing > 1 ? ta.ema(te_str_raw, smoothing) : te_str_raw
        te_dir_out := te_osc_out
    [te_osc_out, te_str_out, te_dir_out]

export f_calculate_te_multilag(array<float> primary_arr, array<float> ticker_arr, int window, int bins, int max_lag) =>
    float best_te = 0.0
    float best_dir = 0.0
    int best_lag = 1
    if max_lag >= 1 and array.size(primary_arr) >= window + max_lag and array.size(ticker_arr) >= window
        for test_lag = 1 to max_lag
            [te_val, dir_val] = f_calculate_te_score_v2(primary_arr, ticker_arr, window, bins, test_lag)
            if math.abs(te_val) > math.abs(best_te)
                best_te := te_val
                best_dir := dir_val
                best_lag := test_lag
    [best_te, best_dir, best_lag]

export f_calculate_te_gated(array<float> primary_arr, array<float> ticker_arr, int window, int bins, int max_lag, float coupling_damping, float coupling_floor) =>
    float gated_te = 0.0
    float gated_dir = 0.0
    int best_lag = 1
    if not na(coupling_damping) and coupling_damping >= coupling_floor
        [raw_te, raw_dir, raw_lag] = f_calculate_te_multilag(primary_arr, ticker_arr, window, bins, max_lag)
        float scale = math.max(0.0, math.min(1.0, (coupling_damping - coupling_floor) / math.max(1.0 - coupling_floor, 1e-10)))
        gated_te := raw_te * scale
        gated_dir := raw_dir
        best_lag := raw_lag
    [gated_te, gated_dir, best_lag]

export f_calculate_net_te(array<float> primary_arr, array<float> ticker_arr, int window, int bins, int lag) =>
    [te_fwd, _] = f_calculate_te_score_v2(ticker_arr, primary_arr, window, bins, lag)
    [te_rev, _2] = f_calculate_te_score_v2(primary_arr, ticker_arr, window, bins, lag)
    [te_fwd - te_rev, te_fwd, te_rev]

export f_kalman_hedge_ratio(float measurement, float observation, float prev_beta, float prev_P, float Q, float R) =>
    float beta_pred = nz(prev_beta, 0.0)
    float P_pred = nz(prev_P, 1.0) + Q
    float innov = measurement - beta_pred * observation
    float S = observation * observation * P_pred + R
    float K = S > 0 ? (P_pred * observation) / S : 0.0
    float beta_new = beta_pred + K * innov
    float P_new = math.max((1.0 - K * observation) * P_pred, 1e-10)
    [beta_new, P_new, innov, K]

