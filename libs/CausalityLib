// @function Wrapper for Transfer Entropy calculation with ensemble and fallback logic
// @param te_primary Primary asset return array
// @param te_b1 Basket asset 1 return array
// @param te_b2 Basket asset 2 return array
// @param te_b3 Basket asset 3 return array
// @param te_b4 Basket asset 4 return array
// @param te_win TE window size
// @param te_b TE bins count
// @param te_smooth TE smoothing length
// @param self1 Whether basket 1 is self-reference
// @param self2 Whether basket 2 is self-reference
// @param self3 Whether basket 3 is self-reference
// @param self4 Whether basket 4 is self-reference
// @param is_hard Whether in hard zone (recent bars)
// @param bar_idx Current bar index
// @returns [te_osc, te_strength, te_direction] - TE oscillator, strength, and direction
export f_compute_te_wrapper(array<float> te_primary, array<float> te_b1, array<float> te_b2, array<float> te_b3, array<float> te_b4, 
             int te_win, int te_b, int te_smooth, bool self1, bool self2, bool self3, bool self4, bool is_hard, int bar_idx) =>
    float result_osc = na
    float result_str = na
    float result_dir = na
    
    if is_hard and bar_idx > te_win + 5
        // Call ensemble TE calculation
        [t_osc, t_str, t_dir] = f_compute_te_ensemble(te_primary, te_b1, te_b2, te_b3, te_b4, array.new_float(0), te_win, te_b, te_smooth, self1, self2, self3, self4, false, false)
        
        // Fallback calculation for basket 1 if ensemble fails
        float fb_score = na
        float fb_dir = na
        if not self1 and array.size(te_primary) > te_win + 1 and array.size(te_b1) > te_win + 1
            [fb1_score, fb1_dir, _, _, _, _, _, _, _, _, _, _, _, _, _, _] = f_calculate_te_score_debug(te_primary, te_b1, te_win, te_b, 1)
            fb_score := fb1_score
            fb_dir := fb1_dir
        
        // Check if ensemble is invalid (NA or exactly 0.0)
        bool ensemble_invalid = na(t_osc) or na(t_str) or na(t_dir) or (t_osc == 0.0 and t_str == 0.0)
        
        if ensemble_invalid
            result_osc := nz(fb_score, 0.0) * nz(fb_dir, 0.0)
            result_str := math.abs(nz(fb_score, 0.0))
            result_dir := nz(fb_dir, 0.0)
        else
            result_osc := t_osc
            result_str := t_str
            result_dir := t_dir
    
    [result_osc, result_str, result_dir]

