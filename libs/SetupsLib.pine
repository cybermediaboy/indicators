export type Family
    int id = 4
    string label = "UNC"
    string name = "Uncertain"
    int direction = 0
    bool directional = false
    color col = color.gray

// ═══════════════════════════════════════════════════════════════════════════
// SETUP TYPES AND CONSTANTS
// ═══════════════════════════════════════════════════════════════════════════

export type SetupSpec
    string id
    string name
    string dir
    Family family = na
    float wr
    float sharpe
    float tp_pct
    float sl_pct
    int avg_bars
    string tooltip
    int timestop = na
    float edge_ratio = 1.0
    string thesis = "MOMENTUM"
    int thesis_flags = 0
    int showstopper_mask = 0
    float impulse_penalty_scale = 1.0
    int code = 0
    int mask = 0

export f_build_family_table() =>
    array<Family> fam = array.new<Family>(5)
    array.set(fam, 0, Family.new(0, "CONT", "Continuation", 0, false, color.green))
    array.set(fam, 1, Family.new(1, "MR", "Mean Reversion", 0, false, color.purple))
    array.set(fam, 2, Family.new(2, "TRAN", "Transition", 0, false, color.orange))
    array.set(fam, 3, Family.new(3, "VEL", "Velocity", 0, false, color.aqua))
    array.set(fam, 4, Family.new(4, "UNC", "Uncertain", 0, false, color.gray))
    fam

export f_family_get(array<Family> fam, int id) =>
    int safe = math.max(0, math.min(id, array.size(fam) - 1))
    array.get(fam, safe)

export f_family_match(int fam_a, int fam_b, bool soft) =>
    if fam_a == fam_b
        true
    else if soft and (fam_a == 4 or fam_b == 4)
        fam_a != 4 or fam_b != 4
    else
        false

// @function Market state classifier using 6 normalized features (wrapper for backward compatibility)
// @param f1_vec Basket vector z-score
// @param f2_corr Basket correlation z-score  
// @param f3_innov Innovation width z-score
// @param f4_te Transfer entropy z-score
// @param f5_orth Orthogonal component z-score
// @param f6_phi Phi divergence z-score
// @returns Family ID: 0=Continuation, 1=Mean-Revert, 2=Transition, 3=Velocity, 4=Uncertain
export f_get_mc_family(float f1_vec, float f2_corr, float f3_innov, float f4_te, float f5_orth, float f6_phi) =>
    int family = 4  // Default: Uncertain
    
    // Family 0: Continuation - Strong basket pull + high coupling + stable regime
    if f1_vec > 1.0 and f2_corr > 1.0 and math.abs(f6_phi) < 0.5
        family := 0
    // Family 1: Mean-Revert - Asset stretched beyond basket + basket pulling back
    else if math.abs(f5_orth) > 1.5 and ((f5_orth > 0 and f1_vec < 0) or (f5_orth < 0 and f1_vec > 0))
        family := 1
    // Family 2: Transition - Regime shift + model lost price
    else if math.abs(f6_phi) > 1.5 and f4_te > 1.0
        family := 2
    // Family 3: Velocity - Unexpected momentum + decoupled from basket
    else if math.abs(f3_innov) > 1.5 and f2_corr < 0.0
        family := 3
    
    family

export f_classify_market_state(array<Family> fam,
     float position, float velocity, float pressure,
     float coupling, float mrstate) =>
    bool mr_bias = mrstate > 0.5
    bool mr_override = mrstate > 0.85
    bool continuation = math.abs(velocity) > 0.12 and math.sign(velocity) == math.sign(pressure) and coupling > 0.5 and not mr_bias
    bool meanrevert = math.abs(position) > 1.0 and (mr_bias or math.sign(position) != math.sign(velocity) or math.abs(velocity) < 0.08 or mr_override)
    bool transition = (math.abs(velocity) < 0.06 and math.abs(pressure) > 0.75) or (math.abs(position) < 0.4 and math.abs(pressure) > 1.0 and coupling > 0.35 and not mr_bias)
    bool velocityctx = coupling < 0.35 or (coupling < 0.5 and math.abs(pressure) > 0.8)

    if mr_override
        array.get(fam, 1)
    else if mr_bias and not meanrevert and not transition and not velocityctx
        array.get(fam, 1)
    else if meanrevert
        array.get(fam, 1)
    else if transition
        array.get(fam, 2)
    else if velocityctx
        array.get(fam, 3)
    else if continuation
        array.get(fam, 0)
    else
        array.get(fam, 4)

