export const int SS_NONE = 0
export const int SS_VEC_GT_P75 = 1
export const int SS_VEC_LT_P25 = 2
export const int SS_MR_GT_P75 = 4
export const int SS_MR_LT_P25 = 8
export const int SS_TE_GT_P75 = 16
export const int SS_TE_LT_P25 = 32
export const int SS_CORR_GT_P75 = 64
export const int SS_CORR_LT_P25 = 128
export const int SS_LTF_GT_P80 = 256
export const int SS_LTF_LT_P20 = 512
export const int SS_PRED_GT_P75 = 1024
export const int SS_PRED_LT_P25 = 2048

export const int SLOT_VEC = 0
export const int SLOT_MR = 1
export const int SLOT_TE = 2
export const int SLOT_CORR = 3
export const int SLOT_LTF = 4
export const int SLOT_PRED = 5

// ═══════════════════════════════════════════════════════════════════════════
// HELPER FUNCTIONS
// ═══════════════════════════════════════════════════════════════════════════

f_bitwise_and(int a, int b) =>
    int result = 0
    int bit_val = 1
    int temp_a = a
    int temp_b = b
    for i = 0 to 12
        if (temp_a % 2 == 1) and (temp_b % 2 == 1)
            result += bit_val
        temp_a := int(temp_a / 2)
        temp_b := int(temp_b / 2)
        bit_val *= 2
    result

// ═══════════════════════════════════════════════════════════════════════════
// CORE FUNCTIONS
// ═══════════════════════════════════════════════════════════════════════════

export f_eval_showstoppers(int mask, OscContext ctx) =>
    bool triggered = false
    if f_bitwise_and(mask, SS_VEC_GT_P75) != 0
        if array.get(ctx.values, SLOT_VEC) > array.get(ctx.p75, SLOT_VEC)
            triggered := true
    if f_bitwise_and(mask, SS_VEC_LT_P25) != 0
        if array.get(ctx.values, SLOT_VEC) < array.get(ctx.p25, SLOT_VEC)
            triggered := true
    if f_bitwise_and(mask, SS_MR_GT_P75) != 0
        if array.get(ctx.values, SLOT_MR) > array.get(ctx.p75, SLOT_MR)
            triggered := true
    if f_bitwise_and(mask, SS_MR_LT_P25) != 0
        if array.get(ctx.values, SLOT_MR) < array.get(ctx.p25, SLOT_MR)
            triggered := true
    if f_bitwise_and(mask, SS_TE_GT_P75) != 0
        if array.get(ctx.values, SLOT_TE) > array.get(ctx.p75, SLOT_TE)
            triggered := true
    if f_bitwise_and(mask, SS_TE_LT_P25) != 0
        if array.get(ctx.values, SLOT_TE) < array.get(ctx.p25, SLOT_TE)
            triggered := true
    if f_bitwise_and(mask, SS_CORR_GT_P75) != 0
        if array.get(ctx.values, SLOT_CORR) > array.get(ctx.p_hi, SLOT_CORR)
            triggered := true
    if f_bitwise_and(mask, SS_CORR_LT_P25) != 0
        if array.get(ctx.values, SLOT_CORR) < array.get(ctx.p_lo, SLOT_CORR)
            triggered := true
    if f_bitwise_and(mask, SS_LTF_GT_P80) != 0
        if array.get(ctx.values, SLOT_LTF) > array.get(ctx.p_hi, SLOT_LTF)
            triggered := true
    if f_bitwise_and(mask, SS_LTF_LT_P20) != 0
        if array.get(ctx.values, SLOT_LTF) < array.get(ctx.p_lo, SLOT_LTF)
            triggered := true
    if f_bitwise_and(mask, SS_PRED_GT_P75) != 0
        if array.get(ctx.values, SLOT_PRED) > array.get(ctx.p75, SLOT_PRED)
            triggered := true
    if f_bitwise_and(mask, SS_PRED_LT_P25) != 0
        if array.get(ctx.values, SLOT_PRED) < array.get(ctx.p25, SLOT_PRED)
            triggered := true
    triggered

export f_check_showstoppers(SetupSpec spec, SetupContext ctx) =>
    int mask = spec.showstopper_mask
    int hits = 0
    string reason = ""
    bool blocked = false
    if mask != SS_NONE
        if math.floor(mask / SS_VEC_GT_P75) % 2 != 0 and not na(ctx.vec_osc) and not na(ctx.vec_p75) and ctx.vec_osc > ctx.vec_p75
            hits += 1
            reason += "vec>P75 "
        if math.floor(mask / SS_VEC_LT_P25) % 2 != 0 and not na(ctx.vec_osc) and not na(ctx.vec_p25) and ctx.vec_osc < ctx.vec_p25
            hits += 1
            reason += "vec<P25 "
        if math.floor(mask / SS_MR_GT_P75) % 2 != 0 and not na(ctx.mr_osc) and not na(ctx.mr_p75) and ctx.mr_osc > ctx.mr_p75
            hits += 1
            reason += "mr>P75 "
        if math.floor(mask / SS_MR_LT_P25) % 2 != 0 and not na(ctx.mr_osc) and not na(ctx.mr_p25) and ctx.mr_osc < ctx.mr_p25
            hits += 1
            reason += "mr<P25 "
        if math.floor(mask / SS_TE_GT_P75) % 2 != 0 and not na(ctx.te_osc) and not na(ctx.te_p75) and ctx.te_osc > ctx.te_p75
            hits += 1
            reason += "te>P75 "
        if math.floor(mask / SS_TE_LT_P25) % 2 != 0 and not na(ctx.te_osc) and not na(ctx.te_p25) and ctx.te_osc < ctx.te_p25
            hits += 1
            reason += "te<P25 "
        if math.floor(mask / SS_CORR_GT_P75) % 2 != 0 and not na(ctx.corr_osc) and not na(ctx.corr_p80) and ctx.corr_osc > ctx.corr_p80
            hits += 1
            reason += "corr>P80 "
        if math.floor(mask / SS_CORR_LT_P25) % 2 != 0 and not na(ctx.corr_osc) and not na(ctx.corr_p20) and ctx.corr_osc < ctx.corr_p20
            hits += 1
            reason += "corr<P20 "
        if math.floor(mask / SS_LTF_GT_P80) % 2 != 0 and not na(ctx.ltf_corr) and not na(ctx.ltf_p80) and ctx.ltf_corr > ctx.ltf_p80
            hits += 1
            reason += "ltf>P80 "
        if math.floor(mask / SS_LTF_LT_P20) % 2 != 0 and not na(ctx.ltf_corr) and not na(ctx.ltf_p20) and ctx.ltf_corr < ctx.ltf_p20
            hits += 1
            reason += "ltf<P20 "
        if math.floor(mask / SS_PRED_GT_P75) % 2 != 0 and not na(ctx.pred_slope) and not na(ctx.pred_p75) and ctx.pred_slope > ctx.pred_p75
            hits += 1
            reason += "pred>P75 "
        if math.floor(mask / SS_PRED_LT_P25) % 2 != 0 and not na(ctx.pred_slope) and not na(ctx.pred_p25) and ctx.pred_slope < ctx.pred_p25
            hits += 1
            reason += "pred<P25 "
        blocked := hits > 0
    [blocked, hits, reason]

export f_score_confidence(SetupSpec spec, SetupContext ctx, float impulse_strength) =>
    float base = math.max(0.0, math.min(spec.wr / 100.0, 1.0))
    float edge_ratio = spec.edge_ratio
    string thesis = spec.thesis
    float edge_bonus = edge_ratio > 1.2 ? 0.10 : (edge_ratio < 0.9 ? -0.15 : 0.0)
    float impulse_pen = 0.0
    if thesis == "MR" or thesis == "DECOUPLE"
        impulse_pen := -impulse_strength * 0.20
    float coupling_pen = 0.0
    if thesis == "MOMENTUM" or thesis == "RECOUPLE"
        if not na(ctx.ltf_corr) and not na(ctx.ltf_p20) and ctx.ltf_corr < ctx.ltf_p20
            coupling_pen := -0.15
    math.max(0.05, math.min(base + edge_bonus + impulse_pen + coupling_pen, 1.0))

export f_register_event_v2(array<SetupEvent> events, bool condition, SetupSpec spec, OscContext ctx, float impulse_strength, string size_info) =>
    SetupEvent evt = na
    if condition
        bool showstopper_triggered = false
        if spec.showstopper_mask != 0
            showstopper_triggered := f_eval_showstoppers(spec.showstopper_mask, ctx)
        float base_confidence = spec.wr / 100.0
        float confidence = base_confidence
        if f_bitwise_and(spec.thesis_flags, 1) != 0 and impulse_strength > 0.5
            float impulse_penalty = (impulse_strength - 0.5) * spec.impulse_penalty_scale
            confidence *= (1.0 - impulse_penalty)
        if f_bitwise_and(spec.thesis_flags, 2) != 0
            float coupling_val = array.get(ctx.values, SLOT_CORR)
            if coupling_val < 0.4
                float coupling_penalty = (0.4 - coupling_val) * 0.5
                confidence *= (1.0 - coupling_penalty)
        if not showstopper_triggered
            int ss_hits = showstopper_triggered ? 1 : 0
            evt := SetupEvent.new(spec.id, spec.tooltip, size_info, confidence, ss_hits)
            array.push(events, evt)
    evt

// REMOVED: f_get_mc_family_from_setup, f_setup_id_to_code, f_setup_id_to_mask
// All setup metadata now stored in SetupConfig (setupsDBGem.pine)

// ═══════════════════════════════════════════════════════════════════════════
// LEVEL TRACKER — sweep-aware TP/SL/Entry line management (v19 refactored)
// Lines freeze on sweep/expire but remain visible on chart history
// ═══════════════════════════════════════════════════════════════════════════

export type LevelTracker
    line ln
    float price
    int start_bar
    int sweep_dir       // +1=swept when high>=price, -1=swept when low<=price, 0=fixed
    int default_len     // 10 for entry, 20 for TP/SL
    int max_scan        // 0 for entry (no scan), 300 for TP/SL
    bool done

export f_create_level(float price, int bar_idx, int sweep_dir, int default_len, int max_scan, color col, int width, bool dashed) =>
    LevelTracker t = LevelTracker.new(na, nz(price), bar_idx, sweep_dir, default_len, max_scan, true)
    if not na(price)
        t.ln := line.new(bar_idx, price, bar_idx + (sweep_dir == 0 ? default_len : 0), price, color=col, style=dashed ? line.style_dashed : line.style_solid, width=width, force_overlay=true)
        t.done := sweep_dir == 0
    t

export f_create_tpsl_levels(array<LevelTracker> levels, string dir, float tp1, float tp2, float sl, int bar_idx, int default_len, int max_scan, color tp_col, color sl_col) =>
    int start_idx = array.size(levels)
    int tp_sw = dir == "LONG" ? 1 : -1
    int sl_sw = dir == "LONG" ? -1 : 1
    // Entry line removed - label already shows entry price
    array.push(levels, f_create_level(tp1, bar_idx, tp_sw, default_len, max_scan, tp_col, 2, false))
    array.push(levels, f_create_level(tp2, bar_idx, tp_sw, default_len, max_scan, tp_col, 1, true))
    array.push(levels, f_create_level(sl, bar_idx, sl_sw, default_len, max_scan, sl_col, 2, false))
    [start_idx, 3]

export f_update_levels(array<LevelTracker> levels, float hi, float lo, int current_bar) =>
    bool updated = false
    int n = array.size(levels)
    if n > 0
        for i = 0 to n - 1
            LevelTracker t = array.get(levels, i)
            if not t.done and not na(t.ln)
                int age = current_bar - t.start_bar
                bool swept = (t.sweep_dir > 0 and hi >= t.price) or (t.sweep_dir < 0 and lo <= t.price)
                bool late_expired = age > t.max_scan
                bool within_active_window = age <= t.default_len and age <= t.max_scan
                int new_x2 = late_expired ? (t.start_bar + t.default_len) : (swept ? current_bar : (within_active_window ? current_bar : na))
                if not na(new_x2)
                    line.set_x2(t.ln, new_x2)
                    t.done := late_expired or swept
                    updated := true
    updated

export f_freeze_levels(array<LevelTracker> levels, int start_idx, int count) =>
    int end_idx = math.min(start_idx + count, array.size(levels))
    if start_idx >= 0 and start_idx < array.size(levels)
        for i = start_idx to end_idx - 1
            LevelTracker t = array.get(levels, i)
            t.done := true

export f_calc_tpsl(string dir, float ep, float tp_pct, float sl_pct, float z2_up, float z2_dn, float z3_up, float z3_dn, bool use_zones) =>
    float raw_tp = dir == "LONG" ? ep * (1 + tp_pct / 100) : ep * (1 - tp_pct / 100)
    float raw_sl = dir == "LONG" ? ep * (1 + sl_pct / 100) : ep * (1 - sl_pct / 100)
    float tp1 = raw_tp
    float zone_tp2 = dir == "LONG" ? z2_up : z2_dn
    float zone_tp3 = dir == "LONG" ? z3_up : z3_dn
    float zone_sl = dir == "LONG" ? z2_dn : z2_up
    bool zone_tp2_valid = not na(zone_tp2) and (dir == "LONG" ? zone_tp2 > ep : zone_tp2 < ep)
    bool zone_tp3_valid = not na(zone_tp3) and (dir == "LONG" ? zone_tp3 > ep : zone_tp3 < ep)
    bool zone_sl_valid = not na(zone_sl) and (dir == "LONG" ? zone_sl < ep : zone_sl > ep)
    // NOTE Bug #13: When zone invalid, tp2/tp3 fallback to raw_tp (same as tp1), creating overlapping lines
    // Cosmetic issue only - doesn't affect exit logic (only TP1 is checked in f_evaluate_exit)
    float tp2 = use_zones and zone_tp2_valid ? zone_tp2 : raw_tp
    float tp3 = use_zones and zone_tp3_valid ? zone_tp3 : raw_tp
    float sl = use_zones ? (zone_sl_valid ? (dir == "LONG" ? math.min(raw_sl, zone_sl) : math.max(raw_sl, zone_sl)) : raw_sl) : raw_sl
    [tp1, tp2, tp3, sl]

// Universal exit evaluation (used by both Live and BT)
// Returns: [exit_code, new_trail_sl]
// exit_code: 0=HardSL, 1=TrailSL, 2=PredFlip, 3=Breakeven, 4=TP1, -1=NoExit
export f_evaluate_exit(string dir, float pnl, float max_pnl, int bars_held, float hi, float lo, float tp1, float trail_sl_in, float pred_ma_now, bool pred_rising_now, bool pred_rising_1ago) =>
    int exit_code = -1
    float trail_sl_out = trail_sl_in
    
    // Update trailing SL if profitable
    if bars_held >= 1 and max_pnl > 0.5
        trail_sl_out := na(trail_sl_in) ? pred_ma_now : (dir == "LONG" ? math.max(trail_sl_in, pred_ma_now) : math.min(trail_sl_in, pred_ma_now))
    
    // Exit conditions (priority order)
    bool exit_hard_sl = pnl <= -1.8
    bool exit_trail_sl = not na(trail_sl_out) and (dir == "LONG" ? lo <= trail_sl_out : hi >= trail_sl_out)
    bool pred_flip_bear = not pred_rising_now and pred_rising_1ago
    bool pred_flip_bull = pred_rising_now and not pred_rising_1ago
    bool exit_pred_flip = dir == "LONG" ? pred_flip_bear : pred_flip_bull
    bool exit_be = bars_held >= 5 and pnl <= 0
    bool hit_tp1 = dir == "LONG" ? hi >= tp1 : lo <= tp1
    
    if exit_hard_sl
        exit_code := 0
    else if exit_trail_sl
        exit_code := 1
    else if exit_pred_flip
        exit_code := 2
    else if exit_be
        exit_code := 3
    else if hit_tp1
        exit_code := 4
    
    [exit_code, trail_sl_out]

// Update setup label with exit marker and color
// exit_code: 0=HardSL, 1=TrailSL, 2=PredFlip, 3=Breakeven, 4=TP1
export f_update_exit_label(label lbl, string setup_id, string dir, int exit_code, float pnl) =>
    if not na(lbl)
        // Marker selection based on exit_code
        // ✓ = TP reached, ✗ = SL hit, ~ = other exits
        string exit_marker = exit_code == 4 ? " ✓" : (exit_code == 0 or exit_code == 1) ? " ✗" : " ~"
        
        // Text color logic
        // TP (exit_code 4): always white
        // SL (exit_code 0,1): always white (visible on red/green label)
        // Other exits (2,3): color depends on PnL
        color text_col = color.white
        if exit_code == 2 or exit_code == 3  // PredFlip or Breakeven
            bool is_profit = pnl > 0.1
            text_col := is_profit ? color.white : (dir == "LONG" ? color.red : color.black)
        
        // NOTE Bug #12: This discards the width padding added by f_add_setup_label (cosmetic issue)
        // To fix: store original label text in ActivePosition.tooltip or separate field
        label.set_text(lbl, setup_id + exit_marker)
        label.set_textcolor(lbl, text_col)

// Append exit type to label tooltip
// exit_code: 0=HardSL, 1=TrailSL, 2=PredFlip, 3=Breakeven, 4=TP1
// Returns: updated tooltip string
export f_get_exit_info(int exit_code) =>
    string exit_name = exit_code == 0 ? "Hard SL" : exit_code == 1 ? "Trail SL" : exit_code == 2 ? "PredFlip" : exit_code == 3 ? "Breakeven" : exit_code == 4 ? "TP1" : "Unknown"
    "\n\nExit: [" + str.tostring(exit_code) + "] " + exit_name

// Backtest simulation using unified exit logic
// Returns: [exit_pnl, mae, mfe, exit_reason_string]
export f_simulate_bt_position(string dir, float ep, float tp_pct, int hold_limit, array<float> arr_close, array<float> arr_high, array<float> arr_low, array<float> arr_predma, int offset, int arr_size) =>
    float exit_pnl = na
    float best = 0.0
    float worst = 0.0
    string exit_rsn = "MAXHOLD"
    float trail_sl = na
    bool is_long = dir == "LONG"
    
    for h = 1 to hold_limit
        int idx = offset + h
        if idx >= arr_size
            break
        
        float px = array.get(arr_close, idx)
        float hi = array.get(arr_high, idx)  // FIX Bug #3: use actual high for TP detection
        float lo = array.get(arr_low, idx)   // FIX Bug #3: use actual low for SL detection
        float pnl = is_long ? (px - ep) / ep * 100.0 : (ep - px) / ep * 100.0
        best := math.max(best, pnl)
        worst := math.min(worst, pnl)
        
        // Get pred_ma values for exit evaluation
        // NOTE Bug #10 RESOLVED: Using 3-bar delta (pma_1ago > pma_4ago) to match Live exit logic
        float pma_now = array.get(arr_predma, idx)
        float pma_3ago = idx >= 3 ? array.get(arr_predma, idx - 3) : pma_now
        float pma_1ago = idx >= 1 ? array.get(arr_predma, idx - 1) : pma_now
        float pma_4ago = idx >= 4 ? array.get(arr_predma, idx - 4) : pma_now
        bool pred_rising_now = pma_now > pma_3ago
        bool pred_rising_1ago = pma_1ago > pma_4ago  // 3-bar lookback, consistent with Live
        
        // Use unified exit evaluation with actual high/low
        float tp1 = ep * (1.0 + tp_pct / 100.0 * (is_long ? 1.0 : -1.0))
        [temp_exit_code, temp_trail_sl] = f_evaluate_exit(dir, pnl, best, h, hi, lo, tp1, trail_sl, pma_now, pred_rising_now, pred_rising_1ago)
        trail_sl := temp_trail_sl
        
        if temp_exit_code >= 0
            exit_pnl := pnl
            exit_rsn := temp_exit_code == 0 ? "SL" : temp_exit_code == 1 ? "TRAIL" : temp_exit_code == 2 ? "PREDFLIP" : temp_exit_code == 3 ? "BE" : "TP"
            break
    
    // Max hold fallback
    if na(exit_pnl)
        int last_h = math.min(hold_limit, arr_size - offset - 1)
        if last_h > 0
            float last_px = array.get(arr_close, offset + last_h)
            exit_pnl := is_long ? (last_px - ep) / ep * 100.0 : (ep - last_px) / ep * 100.0
        else
            exit_pnl := 0.0
    
    [exit_pnl, worst, best, exit_rsn]

export f_find_setup_spec(array<SetupSpec> setup_db, string setup_id) =>
    string found_name = ""
    string found_dir = ""
    float found_wr = na
    float found_sharpe = na
    float found_tp = na
    float found_sl = na
    int found_avg_bars = na
    string found_tooltip = ""
    int db_size = array.size(setup_db)
    for i = 0 to db_size - 1
        SetupSpec spec = array.get(setup_db, i)
        if spec.id == setup_id
            found_name := spec.name
            found_dir := spec.dir
            found_wr := spec.wr
            found_sharpe := spec.sharpe
            found_tp := spec.tp_pct
            found_sl := spec.sl_pct
            found_avg_bars := spec.avg_bars
            found_tooltip := spec.tooltip
            break
    [found_name, found_dir, found_wr, found_sharpe, found_tp, found_sl, found_avg_bars, found_tooltip]

export f_get_setup_horizon(array<SetupSpec> setup_db, string setup_id, int fallback_horizon) =>
    int horizon = fallback_horizon
    int setup_db_size = array.size(setup_db)
    if setup_db_size > 0
        for i = 0 to setup_db_size - 1
            SetupSpec spec = array.get(setup_db, i)
            if spec.id == setup_id
                horizon := spec.avg_bars
                break
    horizon

export f_register_event(array<SetupEvent> engine_events, bool fire_condition, string setup_id, string setup_tooltip, string setup_size_info) =>
    if fire_condition
        array.push(engine_events, SetupEvent.new(setup_id, setup_tooltip, setup_size_info, 0.5, 0))

export f_register_event_auto(array<SetupEvent> engine_events, array<SetupSpec> setup_db, bool fire_condition, string setup_id, string setup_size_info) =>
    if fire_condition
        string tooltip = ""
        int db_size = array.size(setup_db)
        for i = 0 to db_size - 1
            SetupSpec spec = array.get(setup_db, i)
            if spec.id == setup_id
                tooltip := spec.tooltip
                break
        array.push(engine_events, SetupEvent.new(setup_id, tooltip, setup_size_info, 0.5, 0))

export f_get_spec(array<SetupSpec> setup_db, string setup_id) =>
    SetupSpec result = na
    int db_size = array.size(setup_db)
    if db_size > 0
        for i = 0 to db_size - 1
            SetupSpec spec = array.get(setup_db, i)
            if spec.id == setup_id
                result := spec
                break
    result

export f_build_setup_db() =>
    array.new<SetupSpec>()

export f_seed_validation(string next_setup_id, string next_setup_direction, label next_label, string next_tooltip) =>
    [next_setup_id, bar_index, close, next_setup_direction, next_label, next_tooltip, 1]

export f_start_or_queue_validation(ValidationState vs, string next_setup_id, int next_trigger_bar, float next_entry_price, string next_direction, label next_label, string next_tooltip, int next_phase) =>
    bool validator_idle = vs.validation_phase == 0
    if validator_idle
        vs.validating_setup_id := next_setup_id
        vs.setup_trigger_bar := next_trigger_bar
        vs.setup_entry_price := next_entry_price
        vs.setup_direction := next_direction
        vs.validating_label := next_label
        vs.validating_tooltip := next_tooltip
        vs.validation_phase := next_phase
    else
        vs.pending_setup_id := next_setup_id
        vs.pending_trigger_bar := next_trigger_bar
        vs.pending_entry_price := next_entry_price
        vs.pending_direction := next_direction
        vs.pending_label := next_label
        vs.pending_tooltip := next_tooltip
        vs.pending_phase := next_phase
    vs

export f_exit_logic(string dir, float tp1, float pos_pnl, int bars_held, float pred_ma_now, float pred_ma_3ago, float pred_ma_1ago, float trail_sl_in, float max_pnl, float low_price, float high_price, float close_price) =>
    bool pred_rising_now = pred_ma_now > pred_ma_3ago
    bool pred_falling_now = pred_ma_now < pred_ma_3ago
    bool pred_rising_1ago = pred_ma_1ago > pred_ma_3ago
    bool pred_falling_1ago = pred_ma_1ago < pred_ma_3ago
    bool pred_flip_bear = pred_falling_now and pred_rising_1ago
    bool pred_flip_bull = pred_rising_now and pred_falling_1ago
    float trail_sl = trail_sl_in
    if bars_held >= 1 and max_pnl > 0.5
        float trail_level = pred_ma_now
        if dir == "LONG"
            trail_sl := na(trail_sl) ? trail_level : math.max(trail_sl, trail_level)
        else
            trail_sl := na(trail_sl) ? trail_level : math.min(trail_sl, trail_level)
    else if bars_held == 0
        trail_sl := na
    bool exit_triggered = false
    int exit_reason = -1
    bool show_label = false
    string label_text = ""
    color label_color = color.white
    float label_y = close_price
    bool exit_trail_sl = not na(trail_sl) and (dir == "LONG" ? low_price <= trail_sl : high_price >= trail_sl)
    bool exit_pred_flip = dir == "LONG" ? pred_flip_bear : pred_flip_bull
    bool exit_be = bars_held >= 5 and pos_pnl <= 0
    bool exit_hard_sl = pos_pnl <= -1.8
    bool hit_tp1 = dir == "LONG" ? high_price >= tp1 : low_price <= tp1
    if exit_hard_sl
        exit_triggered := true
        exit_reason := 0
        show_label := true
        label_text := "✗ SL"
        label_color := color.red
        label_y := close_price
    else if exit_trail_sl
        exit_triggered := true
        exit_reason := 1
        show_label := true
        label_text := "⤴ Trail " + str.tostring(pos_pnl, "#.#") + "%"
        label_color := color.green
        label_y := trail_sl
    else if exit_pred_flip
        exit_triggered := true
        exit_reason := 2
        show_label := true
        label_text := "⟲ Flip " + str.tostring(pos_pnl, "#.#") + "%"
        label_color := pos_pnl > 0 ? color.green : color.orange
        label_y := close_price
    else if exit_be
        exit_triggered := true
        exit_reason := 3
        show_label := true
        label_text := "BE 0%"
        label_color := color.gray
        label_y := close_price
    else if hit_tp1
        exit_triggered := true
        exit_reason := 4
        show_label := true
        label_text := "✓ TP1"
        label_color := color.green
        label_y := tp1
    [exit_triggered, exit_reason, trail_sl, show_label, label_text, label_color, label_y]
