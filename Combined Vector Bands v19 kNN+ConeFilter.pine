// --- TYPES ---
type ConfluenceCluster
    float level
    int count

type ActivePosition
    string setup_id
    string dir      // "LONG" or "SHORT"
    int entry_bar
    float entry_price
    float tp1
    float tp2
    float sl
    float mc_p10    // MC-calculated MAE (Stop)
    float mc_p50    // MC-calculated MFE (Target)
    float rrr
    bool is_active
    int levels_idx = -1   // start index in global level_trackers array
    int levels_cnt = 0    // number of LevelTrackers (typically 4)

type HistoricalSetup
    int bar_idx
    string setup_id
    string direction
    float entry_price
    float tp_pct
    float sl_pct
    int max_hold
    float f1_snap
    float f2_snap
    float f3_snap
    float f4_snap
    float f5_snap
    float f6_snap
    float f7_snap
