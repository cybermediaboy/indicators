//@version=6
import cybermediaboy/CausalityLib/15 as CausalityLib
import cybermediaboy/MCLib/10 as MCLib
import cybermediaboy/SetupsLib/15 as SetupsLib
import cybermediaboy/TAUtilityLib/53 as TAUtilityLib
import cybermediaboy/kNNLib/15 as kNNLib
import cybermediaboy/BandsLib/5 as BandsLib
import cybermediaboy/BasketLib/3 as BasketLib
indicator("Combined Vector Bands v19 Family UDT", shorttitle="CVB v19", overlay=true, max_boxes_count=500, max_labels_count=500, max_lines_count=500, dynamic_requests=true, max_bars_back=5000)

// --- GLOBAL DISPLAY CONTROLS ---
grp_global_display = "Global Display Controls"
show_setup_labels = input.bool(true, "Show Setup Labels", group=grp_global_display, tooltip="Enable/disable all setup labels (L1-L8, S1-S10, V1-V4). Turn off to reduce chart clutter.")

// Loading time measurement (latched once; avoid updating on realtime ticks)
var int load_start_ms = na
load_start_ms := na(load_start_ms) ? timenow : load_start_ms
var float load_secs_latched = na
var bool load_secs_captured = false
if barstate.islastconfirmedhistory and not load_secs_captured
    load_secs_latched := (timenow - load_start_ms) / 1000.0
    load_secs_captured := true

// --- INPUTS ---
grp_display = "Display Mode"
simple_mode = input.bool(true, "Simple Mode", group=grp_display, tooltip="ON: Show only Innovation Bands, Predictive FV, Info Table, Coupling Circles, MR Diamonds. OFF: Show all signals and markers.")
show_survival_bands_simple = input.bool(false, "Show Survival Bands in Simple Mode", group=grp_display, tooltip="Enable to display survival zones (Z1, Z2, Z3) even when Simple Mode is ON.")
pred_fv_color_candles = input.bool(false, "Color Candles With Predictive FV", group=grp_display, tooltip="Use the Predictive FV color/transparency on candles instead of drawing the Predictive FV line.")
pred_ma_transparency_src = input.string("Corr Damping", "Pred MA Transparency Source", options=["Corr Damping", "LTF Correlation"], group=grp_display, tooltip="Corr Damping: HTF Kalman rho → Fisher sigmoid (same coefficient that drives pred_ma signal). LTF Correlation: lower-timeframe correlation EMA magnitude. Both self-normalized to running percentile range.")
show_tables = input.bool(false, "Show Info Table", group=grp_display, tooltip="Show or hide the info table to reduce visual clutter and improve performance.")

grp_tpsl = "TP/SL Visualization"
tpsl_min_rrr = input.float(0.5, "Min R:R (below = bad trade)", step=0.1, group=grp_tpsl)
tpsl_max_hold = input.int(20, "Max Hold Bars", minval=5, maxval=50, group=grp_tpsl)
tpsl_enable_maxhold_tp = input.bool(true, "Enable MaxHold TP Exit", group=grp_tpsl, tooltip="When enabled, positions will exit at max hold duration even if TP/SL not hit. When disabled, positions can hold indefinitely until TP/SL is hit.")
tpsl_level_scan = input.int(300, "Level Sweep Scan (bars)", minval=20, maxval=500, group=grp_tpsl, tooltip="Max bars to track late sweep of TP/SL levels. Lines extend to sweep point if hit hit within this window.")
tpsl_use_zones = input.bool(true, "Snap TP to Survival Zones", group=grp_tpsl)
tpsl_show_result = input.bool(true, "Show ✓/✗ Exit Markers", group=grp_tpsl)

grp_basket = "Basket Settings"
basket_preset = input.string("Auto Scan", "Basket Preset", options=["Auto Scan", "Custom", "Basket B (Memes)", "Basket C (DeFi + New L1)", "Basket D (Universal 5)", "Basket E (TON Niches)"], group=grp_basket)
enable_basket_rescan = input.bool(false, "Enable Basket Relatch/Rescan", group=grp_basket, tooltip="When enabled, Auto Scan will re-rank the basket every N bars instead of locking after the first selection.")
basket_rescan_interval = input.int(250, "Basket Relatch Interval Bars", minval=10, maxval=5000, group=grp_basket, tooltip="Only used when relatch/rescan is enabled. The basket composition is re-evaluated every N bars.")
basis_mode = input.string("VWMA+VWStDev", "Basis Mode", options=["Simple MA", "Median+MAD", "VWMA+VWStDev"], group=grp_basket, tooltip="Simple MA: standard SMA. Median+MAD: outlier-proof (50% breakdown point). VWMA+VWStDev: volume-weighted (integrates order flow).")
sym1_in = input.symbol("BINANCE:BTCUSDT", "Asset 1", group=grp_basket)
sym2_in = input.symbol("BINANCE:ETHUSDT", "Asset 2", group=grp_basket)
sym3_in = input.symbol("BINANCE:SOLUSDT", "Asset 3", group=grp_basket)
sym4_in = input.symbol("BINANCE:BNBUSDT", "Asset 4", group=grp_basket)
// REMOVED: sym5 pipeline (only used by Basket D, not needed for TE ensemble)

basket_weight_mode = input.string("Correlation Power", "Weighting Mode", options=["Correlation Power", "Equal", "Manual"], group=grp_basket)
w1 = input.float(1.0, "Weight 1", minval=0.0, step=0.1, group=grp_basket)
w2 = input.float(1.0, "Weight 2", minval=0.0, step=0.1, group=grp_basket)
w3 = input.float(1.0, "Weight 3", minval=0.0, step=0.1, group=grp_basket)
w4 = input.float(1.0, "Weight 4", minval=0.0, step=0.1, group=grp_basket)
w5 = input.float(1.0, "Weight 5", minval=0.0, step=0.1, group=grp_basket)

grp_perf = "Performance & Heavy Calculations"
max_heavy_bars = input.int(5000, "Max Heavy Bars Limit", minval=500, maxval=10000, group=grp_perf, tooltip="Unified limit for expensive calculations (LTF correlation tracking, Transfer Entropy) applied to most recent N bars. Saves computation while keeping visible chart area smooth. Recommended: 1500-2000 for fast load, 2500-3000 for deep history.")
percentile_scan_interval = input.int(100, "Percentile Scan Interval", minval=10, maxval=500, group=grp_perf, tooltip="Recalculate oscillator percentiles every N bars instead of per-bar. Higher = faster performance, lower = more responsive adaptive thresholds. Recommended: 100 bars.")
max_validation_bars = input.int(500, "Max Validation Bars", minval=100, maxval=2000, group=grp_perf, tooltip="Only validate setups on the most recent N bars of history. Lower = faster load, higher = more historical validation. 500 recommended for performance.")
mc_validator_direction_mode = input.string("Setup Direction", "Validator Direction Mode", options=["Setup Direction", "Best MC Direction"], group=grp_perf, tooltip="Setup Direction: validate only the setup's intended side. Best MC Direction: score both long and short interpretations on the same MC paths and use the stronger MC direction.")
mc_use_oracle_direction = input.bool(true, "Use Oracle Direction for MAE/MFE", group=grp_perf, tooltip="When enabled: MC calculates MAE/MFE based on the oracle's selected best direction (may flip from setup). When disabled: MC always uses the setup's original direction for MAE/MFE calculations, regardless of oracle selection.")

grp_model = "Model Settings"
basis_len = input.int(40, "Basis MA Length", minval=10, group=grp_model, tooltip="Length for baseline MA and band deviation calculation")
len_z = input.int(50, "Z-Score & Correlation Lookback", group=grp_model)
len_smooth = input.int(14, "Predictive MA Smoothing (HMA)", group=grp_model)
vector_sens = input.float(1.5, "Vector Sensitivity (K)", group=grp_model)
weight_power = input.float(3.0, "Correlation Weight Power", step=0.5, tooltip="3.0 = Cubic (Strong Filter)", group=grp_model)
hyp_mode = input.string("Catch-up", "Cyclic Hypothesis", options=["Catch-up", "Gravity Reversion"], group=grp_model)

grp_kb = "Kirschenbaum & ML (Self-Tuning)"
show_kirschenbaum = input.bool(true, "Enable Kirschenbaum Learning", group=grp_kb)
kb_pivot_len = input.int(5, "Pivot Lookback", minval=2, group=grp_kb)
enable_adaptive = input.bool(true, "Enable Adaptive Sensitivity", group=grp_kb, tooltip="Uses SGD to optimize Vector Sensitivity based on pivot prediction error.")
learning_rate = input.float(0.01, "Learning Rate", step=0.001, group=grp_kb)
sgd_proximity_pct = input.float(30.0, "Proximity Filter (%)", minval=5.0, group=grp_kb, tooltip="Only learn from pivots within X% distance of the Zone 3 band.") / 100.0
vector_sens_min = input.float(0.5, "Min Sensitivity", group=grp_kb)
vector_sens_max = input.float(5.0, "Max Sensitivity", group=grp_kb)
enable_vwap_sgd = input.bool(true, "Enable VWAP Rejection SGD", group=grp_kb)
vwap_learning_rate = input.float(0.005, "VWAP Learning Rate", step=0.001, group=grp_kb)
show_vwap_rejection_signal = input.bool(true, "Show VWAP Rejection Signal", group=grp_kb)

grp_surv = "Survival Zones"
survival_p1 = input.float(2.0, "Zone 1 Probability (%)", group=grp_surv, tooltip="Innermost (Hardest to breach)")
survival_p2 = input.float(8.0, "Zone 2 Probability (%)", group=grp_surv, tooltip="Middle")
survival_p3 = input.float(15.0, "Zone 3 Probability (%)", group=grp_surv, tooltip="Outermost (Easiest to breach)")
use_mr_factor = input.bool(false, "Include MR Factor in Bands", group=grp_surv, tooltip="Adds Mean Reversion oscillator as additional shift factor alongside Vector Pressure")
mr_weight = input.float(0.5, "MR Factor Weight", minval=0.0, maxval=2.0, step=0.1, group=grp_surv, tooltip="Weight of MR oscillator influence on band shift (0.5 = half of vector influence)")
use_orthogonal_mr = input.bool(false, "Orthogonalize MR", group=grp_surv, tooltip="Decompose MR into parallel (basket-driven) and perpendicular (pure mean reversion) components. Uses only perpendicular component.")

grp_filter = "Correlation Filter (Decoupling)"
use_corr_filter = input.bool(true, "Enable Correlation Filter", group=grp_filter, tooltip="Dampens Vector Pressure to 0 if Asset decouples from Basket.")
corr_source_type = input.string("Returns", "Correlation Source", options=["Z-Score", "Returns", "Price"], group=grp_filter, tooltip="Data series to correlate. V8: 'Returns' recommended for lag-free velocity coupling.")
corr_len = input.int(30, "Correlation Lookback", minval=10, group=grp_filter)
corr_thresh = input.float(0.3, "Decoupling Threshold (Correlation < X)", minval=0.0, maxval=0.9, step=0.1, group=grp_filter)

grp_fit = "Basket Fit"
fit_eval_len = input.int(100, "Basket Fit Lookback", minval=20, group=grp_fit)
force_low_fit_visual_regime = input.bool(false, "Force Low Basket-Fit Visual Regime", group=grp_fit, tooltip="Mimics the weak basket-fit visual regime even on highly correlated tickers by forcing the fit-normalized trust input to its lowest state for opacity-based visuals.")

grp_visual = "Innovation Bands"
innov_band_ma_source = input.string("Kalman Cyclic FV", "Innovation Band MA Source", options=["Price", "Kalman Cyclic FV"], group=grp_visual, tooltip="Price = use current price, Kalman Cyclic FV = use Kalman-smoothed cyclic fair value as center")
innov_band_ma_type = input.string("KAMA", "Innovation Band MA Type", options=["SMA", "EMA", "HMA", "ALMA", "Kalman", "KAMA"], group=grp_visual, tooltip="MA type for innovation bands. KAMA = adaptive zero-lag (recommended), Kalman = true innovations, ALMA = smoothest, HMA = zero-lag, EMA = exponential decay")
innov_band_len = input.int(20, "Innovation Band Length", minval=5, maxval=100, group=grp_visual, tooltip="Period for innovation band MA calculation")
innov_band_dev_type = input.string("MAD", "Innovation Band Deviation", options=["StDev", "MAD", "ATR"], group=grp_visual, tooltip="ATR = Average True Range (best for fast scalping), MAD = Mean Absolute Deviation (robust to spikes), StDev = standard deviation (traditional)")
innov_band_mult = input.float(1.5, "Innovation Band Multiplier", minval=0.5, maxval=3.0, step=0.1, group=grp_visual, tooltip="Deviation multiplier for innovation bands width")
// REMOVED: Innovation KB Learning inputs (saves ~30 vars)
innov_kalman_q = input.float(0.01, "Kalman FV Process Noise (Q)", minval=0.001, maxval=0.1, step=0.001, group=grp_visual, tooltip="Process noise for Kalman-smoothed cyclic FV. Lower = smoother, Higher = more responsive")
innov_kalman_r = input.float(0.1, "Kalman FV Measurement Noise (R)", minval=0.01, maxval=1.0, step=0.01, group=grp_visual, tooltip="Measurement noise for Kalman-smoothed cyclic FV. Lower = trust measurement more, Higher = trust model more")

grp_regime = "Regime Event Detector"
show_regime_markers = input.bool(true, "Show Regime Markers", group=grp_regime, tooltip="▲ Lime = Trend Bounce  ● Aqua = MR Setup  ◆ Orange = Trend Change")
regime_bounce_z = input.float(0.8, "Bounce: Max |z0|", step=0.1, group=grp_regime, tooltip="Max distance from MA to qualify as 'near median'")
regime_bounce_hist = input.int(5, "Bounce: Lookback (was away)", minval=2, group=grp_regime, tooltip="How many bars ago price must have been stretched")
// V8: MR z-threshold lowered from 1.5 to 1.0 (Strategy HF optimization)
regime_mr_z = input.float(1.0, "MR: Min |z0|", step=0.1, group=grp_regime, tooltip="Min z-score to count as 'at extreme' (lowered to 1.0 for better recall)")
regime_innov_len = input.int(10, "Innovation Smooth Len", minval=3, group=grp_regime)

grp_entropy = "Shannon Entropy (Background Coloring)"
show_entropy_bg = input.bool(true, "Show Entropy Background", group=grp_entropy, tooltip="Price background stripe coloring for trend change detection")
entropy_window = input.int(120, "Entropy Window", minval=30, maxval=500, group=grp_entropy)
entropy_bins = input.int(10, "Entropy Bins", minval=4, maxval=20, group=grp_entropy)

grp_cld = "Correlation Lifecycle Detector"
cld_enable = input.bool(true, "Enable CLD", group=grp_cld, tooltip="Empirically validated pattern detector: FALL-RISE (97% continuation), RISE-FALL (76% reversal)")
cld_min_bars = input.int(10, "Min Half-Window", minval=5, group=grp_cld, tooltip="Minimum bars for each half of the pattern. Full pattern = 2x this. 10 covers 85% of detected swings (20-50 bar moves).")
cld_max_bars = input.int(25, "Max Half-Window", minval=10, group=grp_cld, tooltip="Maximum bars for each half. Larger = catches longer trends but more lag.")
cld_slope_thresh_manual = input.float(0.04, "Min Slope Magnitude (Manual)", minval=0.01, step=0.01, group=grp_cld, tooltip="Minimum absolute linreg slope if adaptive is disabled.")
cld_auto_slope = input.bool(true, "Auto-Adaptive Slope Threshold", group=grp_cld, tooltip="Scales slope threshold dynamically based on recent rho volatility.")
cld_price_consist = input.float(0.55, "Price Consistency", minval=0.4, maxval=0.8, step=0.05, group=grp_cld, tooltip="Fraction of bars that must agree with overall price direction to qualify as sustained move.")
cld_z_min = input.float(0.5, "Min |z0| for Signal", minval=0.0, step=0.1, group=grp_cld, tooltip="Price must be at least this far from MA (in z-score) for signal to fire. Filters noise near equilibrium.")

grp_debug = "Debug Oscillators"
show_debug_osc = input.bool(false, "Show Debug Oscillators", group=grp_debug, tooltip="Show Combined Z, Surprisal, and extra hlines")
show_innov_pivots = input.bool(true, "Show Innovation Pivots", group=grp_debug, tooltip="Color high/low pivots on Innovation Z oscillator")
innov_pivot_pct = input.float(15.0, "Pivot Percentile Threshold (%)", minval=1.0, maxval=49.0, step=1.0, group=grp_debug, tooltip="Only show pivots above/below this percentile (measured over 1000 bars)")
burst_osc_mode = input.string("pathA", "BurstScore Mode", options=["pathA", "full"], group=grp_debug, tooltip="pathA = innov_squeeze² × phiDivAccel (clean signal). full = 3-path composite with additional factors.")
osc_compression = input.string("tanh", "Oscillator Compression", options=["tanh", "sigmoid", "clamp", "none"], group=grp_debug, tooltip="Visual compression for all subpane oscillators. tanh (smooth saturation), sigmoid (asymmetric saturation), clamp (hard linear clip), none (raw linear, may clip at ±1)")

// REMOVED: Legend Table inputs (saves ~25 vars)

grp_signals = "V8 Signal Visibility"
show_velocity_signals = input.bool(true, "Show Velocity Coupling Signals", group=grp_signals, tooltip="Red/green circles for velocity decouple/recouple")
show_vector_context = input.bool(true, "Show High Vector Context Markers", group=grp_signals, tooltip="Macro exhaustion and continuation triangles")
show_cld_patterns = input.bool(true, "Show CLD Patterns", group=grp_signals, tooltip="Diamond (continuation) and cross (exhaustion) markers")
show_breakout_markers = input.bool(true, "Show Breakout Markers", group=grp_signals, tooltip="Triangle breakout and squeeze signals")

grp_ltf = "LTF Correlation Tracking"
ltf_enabled = input.bool(true, "Enable LTF Tracking", group=grp_ltf, tooltip="Track lower timeframe correlation for decoupling/recoupling detection")
ltf_mode = input.string("Auto (1/3 to 1/8 of Chart TF)", "LTF Mode", options=["Auto (1/3 to 1/8 of Chart TF)", "Manual Override"], group=grp_ltf, tooltip="Auto: automatically calculates LTF as 1/3 to 1/8 of current chart timeframe. Manual: use fixed timeframe.")
ltf_manual_tf = input.string("1", "Manual LTF Timeframe", options=["1", "3", "5", "15", "30", "60"], group=grp_ltf, tooltip="Manual override timeframe (only used when Manual Override mode selected)")
ltf_corr_len = input.int(20, "LTF Correlation Length", minval=5, maxval=100, group=grp_ltf, tooltip="Number of LTF bars for correlation calculation")
ltf_decouple_thresh = input.float(0.3, "Decoupling Threshold", minval=0.0, maxval=0.5, step=0.05, group=grp_ltf, tooltip="LTF correlation below this = decoupling event")
ltf_recouple_thresh = input.float(0.6, "Recoupling Threshold", minval=0.5, maxval=0.9, step=0.05, group=grp_ltf, tooltip="LTF correlation above this = recoupling event")
ltf_ema_smooth = input.int(3, "LTF Correlation Smoothing", minval=1, maxval=10, group=grp_ltf, tooltip="EMA smoothing for LTF correlation to reduce noise")
ltf_show_labels = input.bool(true, "Show LTF Event Labels", group=grp_ltf, tooltip="Display decoupling/recoupling event labels on chart")

grp_mc = "═══ Monte Carlo Forward Projection ═══"
enable_mc = input.bool(true, "Enable MC Cone", group=grp_mc, tooltip="Enable synchronous kNN path-resampling Monte Carlo forward projection cone.")
mc_horizon = input.int(20, "Projection Horizon (bars)", minval=5, maxval=50, group=grp_mc, tooltip="Number of bars to project forward. Higher = longer cone but slower calculation.")
mcearlydirected = input.bool(true, "Adaptive Cone Horizon", group=grp_mc, tooltip="Truncate cone to the horizon with strongest directional edge (best MFE/MAE × directional consensus).")
mcminhorizon = input.int(5, "Min Cone Horizon", minval=3, maxval=15, group=grp_mc, tooltip="Minimum bars for adaptive cone. Cone won't shrink below this.")
mcedgeminscore = input.float(0.3, "Min Edge Score to Truncate", minval=0.05, maxval=2.0, step=0.05, group=grp_mc, tooltip="Minimum edge score to trigger truncation.")
mcedgedirpct = input.float(0.70, "Min Directional %", minval=0.55, maxval=0.95, step=0.05, group=grp_mc, tooltip="Min fraction of paths agreeing on direction.")
mc_target_runs = input.int(5000, "Target MC Runs", minval=100, maxval=10000, group=grp_mc, tooltip="Number of Monte Carlo simulations (Antithetic Variates: actual paths = 2x this). 5000 = 10,000 paths for institutional-grade precision.")
mc_noise_scale = input.float(0.10, "Bootstrap Noise Scale (×ATR)", minval=0.0, maxval=0.5, step=0.01, group=grp_mc, tooltip="0.0=exact historical paths. 0.10=10% ATR noise per step for path diversity")
show_mc_cone = input.bool(true, "Show MC Cone", group=grp_mc, tooltip="Display P10/P50/P90 cone on chart")
mc_cone_opacity = input.int(80, "Cone Opacity", minval=50, maxval=95, group=grp_mc, tooltip="Transparency of cone fill (higher = more transparent)")
enable_chunked_mc = input.bool(true, "Enable Chunked MC (Tick-Based)", group=grp_mc, tooltip="Split MC execution across realtime ticks instead of blocking. Allows 1000+ runs without timeout. Cone builds progressively.")
mc_chunk_size = input.int(50, "MC Chunk Size (runs/tick)", minval=20, maxval=100, group=grp_mc, tooltip="Number of MC runs per realtime tick. 50 = ~40ms per tick. Lower if experiencing lag.")

// ═══════════════════════════════════════════════════════════════════════════
// TICK-BASED CHUNKED MC STATE MACHINE
// ═══════════════════════════════════════════════════════════════════════════
var int mc_phase = 0              // 0=idle, 1=kNN, 2=MC chunking, 3=percentiles, 4=done
varip int bt_phase = 0              // 0=idle, 1=backtest chunk, 2=backtest summary, 3=done
var int mc_chunk_done = 0         // MC runs completed so far
var bool mc_has_results = false   // Results ready for display
var int mc_result_bar = 0         // Bar index when last MC completed (for freshness check)
varip int bt_chunk_idx = 0          // Current setup index being validated in bt_phase 1

// Persistent debug vars for stable table display (survive across ticks)
var int dbg_total_iter = 0
var int dbg_hamming_skip = 0
var int dbg_na_skip = 0
var int dbg_cands = 0
var float dbg_avg_dist = na
var array<int> final_knn_ids_display = array.new_int(0)

// Persistent backtest metrics (survive across Phase 5-6 ticks)
varip int bt_raw_wins = 0
varip int bt_raw_total = 0
varip float bt_raw_pnl_sum = 0.0
varip int bt_filt_wins = 0
varip int bt_filt_total = 0
varip float bt_filt_pnl_sum = 0.0
varip float bt_agree_sum = 0.0
// MAE/MFE for RR calculation
varip float bt_raw_mae_sum = 0.0
varip float bt_raw_mfe_sum = 0.0
varip float bt_filt_mae_sum = 0.0
varip float bt_filt_mfe_sum = 0.0
// Welford accumulators for Sharpe (variance tracking)
varip float bt_raw_mean = 0.0
varip float bt_raw_m2 = 0.0
varip float bt_filt_mean = 0.0
varip float bt_filt_m2 = 0.0
var array<float> bt_cw = array.new_float()

// Persistent kNN results (survive across ticks)
var array<int> var_knn_ids = na
var array<float> var_knn_weights = na
var array<float> var_cumw = na

// Persistent Welford accumulators (survive across MC chunks)
var array<float> var_wMean = na
var array<float> var_wM2 = na
var array<int> var_wCount = na
var array<int> var_pathsUp = na
var int var_total_paths = 0

// Progressive percentiles (updated after each chunk or at end)
var array<float> mc_progressive_p10 = na
var array<float> mc_progressive_p50 = na
var array<float> mc_progressive_p90 = na

// ═══════════════════════════════════════════════════════════════════════════
// INSTANT SETUP VALIDATOR - Global Variables
// ═══════════════════════════════════════════════════════════════════════════
var float mae_viz_price = na              // MAE price for visualization
var float mfe_viz_price = na              // MFE price for visualization
var int mc_opt_horizon = 20
var float mc_opt_score = 0.0
var string mc_opt_dir = ""
var float mc_opt_dir_pct = na

grp_norm = "Regime-Switched Normalization"
enable_normalization = input.bool(true, "Enable Adaptive Normalization", group=grp_norm, tooltip="Enable regime-switched normalization system for oscillators. Improves signal quality on low-coupling assets.")
norm_percentile_window = input.int(300, "Percentile Window", minval=100, maxval=1000, group=grp_norm, tooltip="Rolling window for percentile calculations (IQR normalization). 300 bars ≈ 3 days on 15m chart.")
coupling_strong_thresh = input.float(0.6, "Strong Coupling Threshold", minval=0.5, maxval=0.9, step=0.05, group=grp_norm, tooltip="TE 75th percentile above this = Coupled regime (use original thresholds)")
coupling_weak_thresh = input.float(0.22, "Weak Coupling Threshold", minval=0.1, maxval=0.5, step=0.02, group=grp_norm, tooltip="TE 75th percentile below this = Decoupled regime (switch to self-momentum)")
mr_vol_lookback = input.int(50, "MR Vol Expansion Lookback", minval=20, maxval=200, group=grp_norm, tooltip="Lookback for ATR expansion factor in volatility-homoscedastic MR adjustment")

grp_setups = "Setup Filters"
enable_pred_round_delay = input.bool(false, "Delayed Entry: Wait for Pred Round", group=grp_setups, tooltip="When enabled, setups that require pred_rounded will arm immediately when conditions are met, then activate when pred MA rounds within the wait window")
pred_round_max_wait = input.int(5, "Max Wait Bars for Pred Round", minval=1, maxval=15, group=grp_setups)
